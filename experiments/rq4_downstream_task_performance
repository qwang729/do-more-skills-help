def write_csv(path: Path, rows: list[dict]) -> None:
    import csv

    if not rows:
        path.write_text("")
        return
    with path.open("w", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=list(rows[0]))
        writer.writeheader()
        writer.writerows(rows)


def write_bar_svg(summary_rows: list[dict], path: Path) -> None:
    width, height = 900, 420
    left, right, top, bottom = 70, 30, 40, 110
    plot_w = width - left - right
    plot_h = height - top - bottom
    n = len(summary_rows)
    gap = plot_w / max(n, 1)
    bar_w = gap * 0.45

    def sy(v: float) -> float:
        return top + (1.0 - v) * plot_h

    lines = [
        f'<svg xmlns="http://www.w3.org/2000/svg" width="{width}" height="{height}" viewBox="0 0 {width} {height}">',
        '<rect width="100%" height="100%" fill="white"/>',
        f'<text x="{left}" y="22" font-family="Arial" font-size="18" font-weight="700">RQ4 (LLM-judged): downstream task pass rate by condition</text>',
        f'<line x1="{left}" y1="{top}" x2="{left}" y2="{top + plot_h}" stroke="#333"/>',
        f'<line x1="{left}" y1="{top + plot_h}" x2="{left + plot_w}" y2="{top + plot_h}" stroke="#333"/>',
    ]
    for tick in [0, 0.25, 0.5, 0.75, 1.0]:
        y = sy(tick)
        lines.append(f'<line x1="{left}" y1="{y:.2f}" x2="{left + plot_w}" y2="{y:.2f}" stroke="#e5e5e5"/>')
        lines.append(f'<text x="{left - 10}" y="{y + 4:.2f}" text-anchor="end" font-family="Arial" font-size="12">{tick:.2f}</text>')

    for i, row in enumerate(summary_rows):
        cx = left + gap * i + gap / 2
        h = plot_h * min(row.get("pass_rate", 0.0), 1.0)
        x = cx - bar_w / 2
        lines.append(f'<rect x="{x:.2f}" y="{top + plot_h - h:.2f}" width="{bar_w:.2f}" height="{h:.2f}" fill="#1f77b4"/>')
        lines.append(
            f'<text x="{cx:.2f}" y="{top + plot_h + 18}" text-anchor="middle" font-family="Arial" '
            f'font-size="11" transform="rotate(28 {cx:.2f},{top + plot_h + 18})">{row["condition"]} (n={row["n"]})</text>'
        )
    lines.append(f'<text x="18" y="{top + plot_h / 2:.2f}" transform="rotate(-90 18,{top + plot_h / 2:.2f})" text-anchor="middle" font-family="Arial" font-size="13">Judged pass rate</text>')
    lines.append("</svg>")
    path.write_text("\n".join(lines) + "\n")


# --------------------------------------------------------------------------
# Main
# --------------------------------------------------------------------------

def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--skill-usage-root", default="data/raw/Skill-Usage")
    parser.add_argument("--tasks-root", default="", help="Defaults to <skill-usage-root>/tasks")
    parser.add_argument("--output-dir", default="data/experiments/rq4_downstream_task_performance")
    parser.add_argument("--conditions", nargs="+", default=DEFAULT_CONDITIONS)
    parser.add_argument("--repeats", type=int, default=1, help="1 is consistent with RQ1's 'full pool' convention; raise later if budget allows.")
    parser.add_argument("--seed", type=int, default=6002)
    parser.add_argument("--limit-tasks", type=int, default=5, help="Safety default. Pass 0 for all tasks once you trust the setup.")

    parser.add_argument("--model", default="qwen-plus", help="Exact Aliyun DashScope model id, e.g. qwen-plus / qwen-max / your deployed model name.")
    parser.add_argument("--api-key-env", default="DASHSCOPE_API_KEY")
    parser.add_argument("--base-url", default=DASHSCOPE_COMPATIBLE_URL)
    parser.add_argument("--temperature", type=float, default=0.0)
    parser.add_argument("--max-tokens-solver", type=int, default=500)
    parser.add_argument("--max-tokens-judge", type=int, default=300)
    parser.add_argument("--instructions-cap", type=int, default=3000, help="Chars of task instructions sent to the solver.")
    parser.add_argument("--oracle-cap", type=int, default=1500, help="Chars of oracle text sent to the judge.")
    parser.add_argument("--verifier-cap", type=int, default=1500, help="Chars of verifier text sent to the judge.")
    parser.add_argument("--token-budget", type=int, default=900000, help="Stops (with partial results saved) once cumulative tokens would exceed this.")
    parser.add_argument("--sleep-between-calls", type=float, default=0.3)
    parser.add_argument("--dry-run", action="store_true", help="Build all prompts and estimate tokens; make NO API calls.")
    parser.add_argument("--resume", action="store_true", help="Skip (task, condition, repeat) rows already present in per_task_results.jsonl.")
    args = parser.parse_args()

    import os

    root = Path(args.skill_usage_root)
    tasks_root = Path(args.tasks_root) if args.tasks_root else root / "tasks"
    output_dir = Path(args.output_dir)
    output_dir.mkdir(parents=True, exist_ok=True)

    api_key = os.environ.get(args.api_key_env, "")
    if not args.dry_run and not api_key:
        raise SystemExit(
            f"No API key found in environment variable {args.api_key_env}. "
            f"Set it first, e.g. in PowerShell: $env:{args.api_key_env} = 'sk-xxxx' "
            f"or run with --dry-run to test without calling the API."
        )

    queries = load_json(root / "data" / "task_queries.json")
    gt = normalize_gt(load_json(root / "data" / "task_skill_mapping.json"))
    docs = load_skill_docs(root / "skills-34k" / "skills_meta.jsonl")
    all_skill_ids = sorted(docs)

    tasks = sorted(set(queries) & set(gt))
    if args.limit_tasks:
        tasks = tasks[: args.limit_tasks]

    print(f"Loaded {len(docs)} skills, {len(tasks)} tasks (limit-tasks={args.limit_tasks or 'all'}).")

    results_path = output_dir / "per_task_results.jsonl"
    already_done: set[tuple[str, str, int]] = set()
    if args.resume and results_path.exists():
        for line in results_path.read_text().splitlines():
            if not line.strip():
                continue
            row = json.loads(line)
            already_done.add((row["task"], row["condition"], row["repeat"]))
        print(f"Resuming: {len(already_done)} rows already recorded, will be skipped.")

    budget = TokenBudget(output_dir / "token_usage_state.json", args.token_budget)
    print(f"Token budget: {budget.remaining()} remaining of {args.token_budget} (persisted across runs).")

    missing_task_dirs = []
    missing_bundle = []
    est_total_tokens = 0
    stopped_early = False

    results_file = results_path.open("a")

    try:
        for task in tasks:
            task_dir = find_task_dir(tasks_root, task)
            if task_dir is None:
                missing_task_dirs.append(task)
                continue
            bundle = load_task_bundle(task_dir)
            instructions = bundle["instructions_text"] or " ".join(queries[task])
            oracle_text = bundle["oracle_text"][: args.oracle_cap]
            verifier_text = bundle["verifier_text"][: args.verifier_cap]
            instructions = instructions[: args.instructions_cap]
            if not oracle_text and not verifier_text:
                missing_bundle.append(task)
                # We can still attempt it, but the judge will have nothing
                # to grade against, so skip rather than waste tokens.
                continue

            gold = gt[task]
            query = " ".join(queries[task])

            for repeat in range(args.repeats):
                rng = random.Random(args.seed + repeat + hash(task) % 100000)
                conditions = build_conditions_for_task(query, gold, all_skill_ids, docs, rng)

                for cond_name in args.conditions:
                    if cond_name not in conditions:
                        continue
                    key = (task, cond_name, repeat)
                    if key in already_done:
                        continue

                    skill_id = conditions[cond_name]["skill_id"]
                    skill_name = docs[skill_id]["name"] if skill_id else None
                    skill_desc = docs[skill_id]["description"] if skill_id else None

                    solver_messages = build_solver_messages(instructions, skill_name, skill_desc)

                    if args.dry_run:
                        est_total_tokens += estimate_tokens(json.dumps(solver_messages))
                        # Rough placeholder judge estimate reusing capped oracle/verifier text.
                        placeholder_solution = "x" * 400
                        judge_messages = build_judge_messages(instructions, oracle_text, verifier_text, placeholder_solution)
                        est_total_tokens += estimate_tokens(json.dumps(judge_messages))
                        continue

                    if budget.remaining() <= 0:
                        print("Token budget exhausted; stopping early. Partial results are saved.")
                        stopped_early = True
                        break

                    solution_text, solver_usage = call_qwen(
                        solver_messages, args.model, api_key, args.base_url,
                        args.temperature, args.max_tokens_solver,
                    )
                    time.sleep(args.sleep_between_calls)

                    judge_messages = build_judge_messages(instructions, oracle_text, verifier_text, solution_text)
                    judge_raw, judge_usage = call_qwen(
                        judge_messages, args.model, api_key, args.base_url,
                        0.0, args.max_tokens_judge,
                    )
                    time.sleep(args.sleep_between_calls)
                    verdict = parse_judge_json(judge_raw)

                    solver_tokens = solver_usage.get("total_tokens", estimate_tokens(solution_text))
                    judge_tokens = judge_usage.get("total_tokens", estimate_tokens(judge_raw))
                    budget.add(solver_tokens + judge_tokens)

                    row = {
                        "task": task,
                        "condition": cond_name,
                        "repeat": repeat,
                        "skill_id": skill_id,
                        "retrieval_correct": conditions[cond_name]["retrieval_correct"],
                        "judged_pass": verdict["pass"],
                        "judged_score": verdict["score"],
                        "judge_reason": verdict["reason"],
                        "solver_tokens": solver_tokens,
                        "judge_tokens": judge_tokens,
                        "solution_text": solution_text[:2000],
                    }
                    results_file.write(json.dumps(row) + "\n")
                    results_file.flush()

                if stopped_early:
                    break
            if stopped_early:
                break
    finally:
        results_file.close()

    if missing_task_dirs:
        print(f"\nWARNING: no task directory found for {len(missing_task_dirs)} tasks: {missing_task_dirs[:10]}")
    if missing_bundle:
        print(f"WARNING: {len(missing_bundle)} tasks had no oracle/verifier text, skipped: {missing_bundle[:10]}")

    if args.dry_run:
        n_calls = sum(
            1 for _t in tasks for _c in args.conditions for _r in range(args.repeats)
        ) * 2
        print(f"\n[DRY RUN] Estimated ~{est_total_tokens} tokens across ~{n_calls} API calls (rough estimate, not exact).")
        print("No API calls were made. Remove --dry-run to actually run.")
        return

    # ---- Summarize from the JSONL (source of truth, survives resumes) ----
    all_rows = [json.loads(line) for line in results_path.read_text().splitlines() if line.strip()]
    conditions_seen = []
    for row in all_rows:
        if row["condition"] not in conditions_seen:
            conditions_seen.append(row["condition"])

    summary_rows = []
    for cond in conditions_seen:
        rows = [r for r in all_rows if r["condition"] == cond]
        n = len(rows)
        summary_rows.append({
            "condition": cond,
            "n": n,
            "pass_rate": mean(1.0 if r["judged_pass"] else 0.0 for r in rows) if n else 0.0,
            "mean_score": mean(r["judged_score"] for r in rows) if n else 0.0,
            "mean_solver_tokens": mean(r["solver_tokens"] for r in rows) if n else 0.0,
            "mean_judge_tokens": mean(r["judge_tokens"] for r in rows) if n else 0.0,
        })

    write_csv(output_dir / "summary.csv", summary_rows)
    (output_dir / "summary.json").write_text(json.dumps({
        "metadata": {
            "tasks_requested": len(tasks),
            "tasks_missing_dir": len(missing_task_dirs),
            "tasks_missing_bundle": len(missing_bundle),
            "model": args.model,
            "repeats": args.repeats,
            "conditions": args.conditions,
            "important_boundary": (
                "judged_pass is an LLM-judge proxy grading a text solution against "
                "the task's oracle solution and verifier text, NOT execution in a "
                "real sandbox. Treat as a necessary-condition-style signal, not a "
                "ground-truth pass rate."
            ),
        },
        "summary": summary_rows,
    }, indent=2) + "\n")
    write_bar_svg(summary_rows, output_dir / "condition_pass_rate_bar.svg")

    print(f"\nWrote {results_path}")
    print(f"Wrote {output_dir / 'summary.csv'}")
    print(f"Wrote {output_dir / 'summary.json'}")
    print(f"Wrote {output_dir / 'condition_pass_rate_bar.svg'}")
    print(f"\nTokens spent so far (persisted): {budget.spent} / {args.token_budget}")
    print()
    print(f"{'condition':>24} {'n':>5} {'pass_rate':>10} {'mean_score':>11}")
    for row in summary_rows:
        print(f"{row['condition']:>24} {row['n']:>5} {row['pass_rate']:>10.3f} {row['mean_score']:>11.2f}")


if __name__ == "__main__":
    main()
