DEFAULT_CONDITIONS = ["no_skill", "gold_skill", "retrieved_top1_full", "hard_distractor", "random_wrong"]

INSTRUCTION_FILENAMES = ["task.md", "task.txt", "instructions.md", "prompt.md", "README.md"]
ORACLE_DIR_NAMES = ["oracle", "solution", "gold"]
ORACLE_FLAT_NAMES = ["oracle.md", "solution.md", "solve.sh", "solve.py"]
VERIFIER_DIR_NAMES = ["verifier", "verify", "tests", "test"]
VERIFIER_FLAT_NAMES = ["verifier.md", "test_outputs.py", "test.sh", "test.py"]
TEXT_SUFFIXES = {".md", ".txt", ".sh", ".py", ".yaml", ".yml", ".json", ".cfg", ".ini"}

DASHSCOPE_COMPATIBLE_URL = "https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions"


# --------------------------------------------------------------------------
# Task-folder discovery. If your real tasks/ layout differs from
# task.md + oracle/ + verifier/, run inspect_tasks.py first and adjust the
# constants/heuristics above and find_task_dir()/load_task_bundle() below.
# --------------------------------------------------------------------------

@functools.lru_cache(maxsize=8)
def _list_task_dirs(tasks_root_str: str) -> tuple[str, ...]:
    root = Path(tasks_root_str)
    if not root.exists():
        return tuple()
    return tuple(sorted(p.name for p in root.iterdir() if p.is_dir()))


def find_task_dir(tasks_root: Path, task_id: str) -> Path | None:
    root = Path(tasks_root)
    direct = root / task_id
    if direct.is_dir():
        return direct

    names = _list_task_dirs(str(root))
    if not names:
        return None

    candidates = {task_id, task_id.replace("/", "__"), task_id.replace("/", "--")}
    if "/" in task_id:
        candidates.add(task_id.split("/")[-1])
    if "--" in task_id:
        candidates.add(task_id.split("--")[-1])

    lower_names = {n.lower(): n for n in names}
    for cand in candidates:
        if cand in names:
            return root / cand
        if cand.lower() in lower_names:
            return root / lower_names[cand.lower()]

    for n in names:
        if task_id in n or n in task_id:
            return root / n
    return None


def _read_text(path: Path, cap: int) -> str:
    try:
        return path.read_text(errors="replace")[:cap]
    except Exception:
        return ""


def _concat_dir_text(dir_path: Path, cap: int) -> str:
    if not dir_path.exists():
        return ""
    chunks: list[str] = []
    total = 0
    for p in sorted(dir_path.rglob("*")):
        if not p.is_file() or p.suffix.lower() not in TEXT_SUFFIXES:
            continue
        text = _read_text(p, cap)
        if not text.strip():
            continue
        chunks.append(f"# {p.name}\n{text}")
        total += len(text)
        if total >= cap:
            break
    return "\n\n".join(chunks)[:cap]


def load_task_bundle(task_dir: Path, cap: int = 6000) -> dict:
    task_dir = Path(task_dir)

    instructions_text = ""
    for name in INSTRUCTION_FILENAMES:
        p = task_dir / name
        if p.exists():
            instructions_text = _read_text(p, cap)
            break

    oracle_text = ""
    for name in ORACLE_DIR_NAMES:
        d = task_dir / name
        if d.exists():
            oracle_text = _concat_dir_text(d, cap)
            if oracle_text:
                break
    if not oracle_text:
        for name in ORACLE_FLAT_NAMES:
            p = task_dir / name
            if p.exists():
                oracle_text = _read_text(p, cap)
                break

    verifier_text = ""
    for name in VERIFIER_DIR_NAMES:
        d = task_dir / name
        if d.exists():
            verifier_text = _concat_dir_text(d, cap)
            if verifier_text:
                break
    if not verifier_text:
        for name in VERIFIER_FLAT_NAMES:
            p = task_dir / name
            if p.exists():
                verifier_text = _read_text(p, cap)
                break

    return {
        "task_dir": str(task_dir),
        "instructions_text": instructions_text,
        "oracle_text": oracle_text,
        "verifier_text": verifier_text,
    }


def find_task_dir_for(tasks_root: Path, task_id: str) -> Path | None:
    return find_task_dir(tasks_root, task_id)


# --------------------------------------------------------------------------
# Condition construction -- same logic/semantics as rq4_free_lexical_proxy's
# build_conditions_for_task, kept in sync deliberately so both scripts
# expose identical conditions over the identical full 34k-skill library.
# --------------------------------------------------------------------------

def build_conditions_for_task(query: str, gold: set, all_skill_ids: list[str], docs: dict, rng: random.Random) -> dict:
    gold_sorted = sorted(gold & set(all_skill_ids))
    gold_id = gold_sorted[0] if gold_sorted else None

    ranked_full = bm25_rank(query, all_skill_ids, docs, 1)
    retrieved_id = ranked_full[0]["skill_id"] if ranked_full else None
    retrieval_correct = bool(retrieved_id and retrieved_id in gold)

    non_gold_ids = [sid for sid in all_skill_ids if sid not in gold]
    hard_ranked = rank_by_query_overlap(query, non_gold_ids, docs)
    hard_id = hard_ranked[0] if hard_ranked else rng.choice(non_gold_ids)

    random_id = rng.choice(non_gold_ids)

    return {
        "no_skill": {"skill_id": None, "retrieval_correct": None},
        "gold_skill": {"skill_id": gold_id, "retrieval_correct": True},
        "retrieved_top1_full": {"skill_id": retrieved_id, "retrieval_correct": retrieval_correct},
        "hard_distractor": {"skill_id": hard_id, "retrieval_correct": False},
        "random_wrong": {"skill_id": random_id, "retrieval_correct": False},
    }


# --------------------------------------------------------------------------
# Qwen / DashScope calls
# --------------------------------------------------------------------------

def estimate_tokens(text: str) -> int:
    """Rough, conservative estimate for mixed CJK/English text. Not exact --
    use only for pre-flight budget planning in --dry-run."""
    if not text:
        return 0
    non_ascii = sum(1 for ch in text if ord(ch) > 127)
    ascii_chars = len(text) - non_ascii
    return int(non_ascii * 0.6 + ascii_chars / 3.2)


class TokenBudget:
    def __init__(self, state_path: Path, budget: int):
        self.state_path = state_path
        self.budget = budget
        if state_path.exists():
            try:
                self.spent = json.loads(state_path.read_text()).get("total_tokens", 0)
            except Exception:
                self.spent = 0
        else:
            self.spent = 0

    def remaining(self) -> int:
        return self.budget - self.spent

    def add(self, n_tokens: int) -> None:
        self.spent += n_tokens
        self.state_path.write_text(json.dumps({"total_tokens": self.spent}, indent=2) + "\n")


def call_qwen(
    messages: list[dict],
    model: str,
    api_key: str,
    base_url: str,
    temperature: float,
    max_tokens: int,
    max_retries: int = 5,
    timeout: int = 120,
) -> tuple[str, dict]:
    headers = {"Authorization": f"Bearer {api_key}", "Content-Type": "application/json"}
    payload = {
        "model": model,
        "messages": messages,
        "temperature": temperature,
        "max_tokens": max_tokens,
    }
    last_err = None
    for attempt in range(max_retries):
        try:
            resp = requests.post(base_url, headers=headers, json=payload, timeout=timeout)
        except requests.RequestException as exc:
            last_err = exc
            time.sleep(min(2 ** attempt, 20))
            continue
        if resp.status_code == 200:
            data = resp.json()
            text = data["choices"][0]["message"]["content"]
            usage = data.get("usage", {})
            return text, usage
        if resp.status_code in (429, 500, 502, 503):
            last_err = RuntimeError(f"HTTP {resp.status_code}: {resp.text[:300]}")
            time.sleep(min(2 ** attempt, 20))
            continue
        raise RuntimeError(f"Qwen API error {resp.status_code}: {resp.text[:500]}")
    raise RuntimeError(f"Qwen API call failed after {max_retries} retries: {last_err}")


SOLVER_SYSTEM = (
    "You are an AI agent attempting a software/technical task. "
    "If a skill guide is provided, use it. Respond with a concrete, actionable "
    "solution (steps, commands, or code) that would accomplish the task. "
    "Do not ask clarifying questions; make reasonable assumptions and commit to an answer."
)

JUDGE_SYSTEM = (
    "You are a strict grader. You will be shown a task, its reference oracle "
    "solution, its verifier/pass criteria, and an agent's proposed solution. "
    "Decide whether the agent's proposed solution would satisfy the verifier "
    "criteria and matches the essential approach of the oracle solution. "
    "Respond with STRICT JSON ONLY, no markdown fences, no extra text: "
    '{"pass": true or false, "score": integer 0-5, "reason": "one short sentence"}'
)


def build_solver_messages(instructions: str, skill_name: str | None, skill_desc: str | None) -> list[dict]:
    if skill_name:
        skill_block = f"\n\nYou have access to this skill guide:\nName: {skill_name}\nDescription: {skill_desc or ''}\n"
    else:
        skill_block = "\n\n(No skill guide is provided for this attempt.)\n"
    user = f"Task:\n{instructions}\n{skill_block}\nProvide your solution now."
    return [
        {"role": "system", "content": SOLVER_SYSTEM},
        {"role": "user", "content": user},
    ]


def build_judge_messages(instructions: str, oracle_text: str, verifier_text: str, solution_text: str) -> list[dict]:
    user = (
        f"Task instructions:\n{instructions}\n\n"
        f"Reference oracle solution:\n{oracle_text or '(not available)'}\n\n"
        f"Verifier / pass criteria:\n{verifier_text or '(not available)'}\n\n"
        f"Agent's proposed solution:\n{solution_text}\n\n"
        "Grade now. JSON only."
    )
    return [
        {"role": "system", "content": JUDGE_SYSTEM},
        {"role": "user", "content": user},
    ]


def parse_judge_json(text: str) -> dict:
    match = re.search(r"\{.*\}", text, re.DOTALL)
    if not match:
        return {"pass": False, "score": 0, "reason": "unparsable judge output"}
    try:
        obj = json.loads(match.group(0))
    except Exception:
        return {"pass": False, "score": 0, "reason": "unparsable judge JSON"}
    return {
        "pass": bool(obj.get("pass", False)),
        "score": int(obj.get("score", 0)) if str(obj.get("score", 0)).lstrip("-").isdigit() else 0,
        "reason": str(obj.get("reason", ""))[:300],
    }


