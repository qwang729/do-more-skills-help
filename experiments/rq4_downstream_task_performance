def estimate_tokens(text: str) -> int:
    """Rough, conservative estimate for mixed CJK/English text. Not exact --
    use only for pre-flight budget planning in --dry-run."""
    if not text:
        return 0
    non_ascii = sum(1 for ch in text if ord(ch) > 127)
    ascii_chars = len(text) - non_ascii
    return int(non_ascii * 0.6 + ascii_chars / 3.2)


class TokenBudget:
    def __init__(self, state_path: Path, budget: int):
        self.state_path = state_path
        self.budget = budget
        if state_path.exists():
            try:
                self.spent = json.loads(state_path.read_text()).get("total_tokens", 0)
            except Exception:
                self.spent = 0
        else:
            self.spent = 0

    def remaining(self) -> int:
        return self.budget - self.spent

    def add(self, n_tokens: int) -> None:
        self.spent += n_tokens
        self.state_path.write_text(json.dumps({"total_tokens": self.spent}, indent=2) + "\n")


def call_qwen(
    messages: list[dict],
    model: str,
    api_key: str,
    base_url: str,
    temperature: float,
    max_tokens: int,
    max_retries: int = 5,
    timeout: int = 300,
) -> tuple[str, dict]:
    headers = {"Authorization": f"Bearer {api_key}", "Content-Type": "application/json"}
    payload = {
        "model": model,
        "messages": messages,
        "temperature": temperature,
        "max_tokens": max_tokens,
    }
    last_err = None
    for attempt in range(max_retries):
        try:
            resp = requests.post(base_url, headers=headers, json=payload, timeout=timeout)
        except requests.RequestException as exc:
            last_err = exc
            time.sleep(min(2 ** attempt, 20))
            continue
        if resp.status_code == 200:
            data = resp.json()
            choice = data["choices"][0]
            message = choice.get("message", {})
            text = message.get("content") or ""
            # Thinking models (e.g. qwen3-*-thinking) may put their chain-of-thought
            # in a separate "reasoning_content" field. If max_tokens ran out while the
            # model was still "thinking", `content` can come back empty even though
            # usage.total_tokens is non-trivial -- surface that instead of silently
            # returning an empty string that will read as "solution incomplete".
            if not text.strip():
                reasoning = message.get("reasoning_content") or ""
                if reasoning:
                    text = "(SOLVER RAN OUT OF TOKENS WHILE THINKING; no final answer text.)"
            usage = dict(data.get("usage", {}))
            usage["finish_reason"] = choice.get("finish_reason")
            return text, usage
        if resp.status_code in (429, 500, 502, 503):
            last_err = RuntimeError(f"HTTP {resp.status_code}: {resp.text[:300]}")
            time.sleep(min(2 ** attempt, 20))
            continue
        raise RuntimeError(f"Qwen API error {resp.status_code}: {resp.text[:500]}")
    raise RuntimeError(f"Qwen API call failed after {max_retries} retries: {last_err}")


SOLVER_SYSTEM = (
    "You are an AI agent attempting a software/technical task. "
    "If a skill guide is provided, use it. Respond with a concrete, actionable, "
    "COMPLETE solution (steps, commands, or code) that would accomplish the task -- "
    "implement every required computation/output explicitly, do not leave any part "
    "as a TODO or description of what you would do. "
    "Do not ask clarifying questions; make reasonable assumptions and commit to an answer. "
    "Keep any internal reasoning brief and go straight to the final solution: your "
    "answer budget is limited, so do not spend it on long deliberation."
)

JUDGE_SYSTEM = (
    "You are a strict grader. You will be shown a task, its reference oracle "
    "solution, its verifier/pass criteria, and an agent's proposed solution. "
    "Decide whether the agent's proposed solution would satisfy the verifier "
    "criteria and matches the essential approach of the oracle solution. "
    "Respond with STRICT JSON ONLY, no markdown fences, no extra text: "
    '{"pass": true or false, "score": integer 0-5, "reason": "one short sentence"}'
)


def build_solver_messages(instructions: str, skills_list: list[dict]) -> list[dict]:
    if skills_list:
        skill_block = "\n\nYou have access to these skill guides:\n"
        for idx, sk in enumerate(skills_list, 1):
            skill_block += f"\n--- Skill Guide #{idx} ---\nName: {sk['name']}\nDescription: {sk['description'] or ''}\n"
    else:
        skill_block = "\n\n(No skill guide is provided for this attempt.)\n"
        
    user = f"Task:\n{instructions}\n{skill_block}\nProvide your solution now."
    return [
        {"role": "system", "content": SOLVER_SYSTEM},
        {"role": "user", "content": user},
    ]


def build_judge_messages(instructions: str, oracle_text: str, verifier_text: str, solution_text: str) -> list[dict]:
    user = (
        f"Task instructions:\n{instructions}\n\n"
        f"Reference oracle solution:\n{oracle_text or '(not available)'}\n\n"
        f"Verifier / pass criteria:\n{verifier_text or '(not available)'}\n\n"
        f"Agent's proposed solution:\n{solution_text}\n\n"
        "Grade now. JSON only."
    )
    return [
        {"role": "system", "content": JUDGE_SYSTEM},
        {"role": "user", "content": user},
    ]


def parse_judge_json(text: str) -> dict:
    # 1. 清理通用的 Markdown 代码块标记
    clean_text = re.sub(r"^```json\s*", "", text, flags=re.IGNORECASE)
    clean_text = re.sub(r"^```\s*", "", clean_text)
    clean_text = re.sub(r"\s*```$", "", clean_text).strip()
    
    # 2. 精准截取最外层的 {}
    match = re.search(r"\{.*\}", clean_text, re.DOTALL)
    if not match:
        return {"pass": False, "score": 0, "reason": "unparsable judge output: no braces"}
        
    try:
        obj = json.loads(match.group(0))
    except Exception:
        return {"pass": False, "score": 0, "reason": "unparsable judge JSON format"}
    
    # 3. 增强版布尔值解析：兼容 True, False, "true", "True", 1, "yes"
    raw_pass = obj.get("pass", False)
    if isinstance(raw_pass, str):
        is_passed = raw_pass.lower() in ("true", "yes", "1")
    else:
        is_passed = bool(raw_pass)
        
    # 4. 增强版数字解析：兼容整数、浮点数字符串（如 "4.0"）及前后空格
    raw_score = obj.get("score", 0)
    try:
        # 先转为浮点数，再取整，完美兼容 "4.0" 或 "3" 或 4
        final_score = int(float(str(raw_score).strip()))
    except (ValueError, TypeError):
        final_score = 0

    return {
        "pass": is_passed,
        "score": final_score,
        "reason": str(obj.get("reason", ""))[:300],
    }
