_code == 404:\n            return False, \"DOI not found in CrossRef database.\"\n        if response.status_code != 200:\n            return False, f\"CrossRef API returned status {response.status_code}.\"\n        \n        data = response.json()['message']\n        \n        # 1. Verify Title\n        crossref_title = clean_latex(data.get('title', [''])[0])\n        entry_title = clean_latex(entry.get('title', ''))\n        if crossref_title != entry_title:\n            return False, f\"Title mismatch.\\n       BibTeX:   '{entry_title}'\\n       CrossRef: '{crossref_title}'\"\n            \n        # 2. Verify Year\n        # CrossRef stores dates in nested 'date-parts' arrays depending on print/online status\n        year_found = None\n        for date_type in ['published-print', 'published-online', 'issued', 'created']:\n            if date_type in data and 'date-parts' in data[date_type]:\n                parts = data[date_type]['date-parts'][0]\n                if parts and parts[0]:\n                    year_found = str(parts[0])\n                    break\n                    \n        entry_year = str(entry.get('year', '')).strip()\n        if year_found and entry_year and year_found != entry_year:\n            return False, f\"Year mismatch.\\n       BibTeX: '{entry_year}'\\n       CrossRef: '{year_found}'\"\n            \n        return True, \"Metadata verified successfully against CrossRef.\"\n        \n    except requests.exceptions.RequestException as e:\n        return False, f\"Network error while querying CrossRef: {str(e)}\"\n    except Exception as e:\n        return False, f\"Unexpected error: {str(e)}\"\n\ndef parse_and_verify(bibtex_input):\n    \"\"\"Parses BibTeX and runs verification checks.\"\"\"\n    # Handle file path or raw string\n    if os.path.isfile(bibtex_input):\n        with open(bibtex_input, 'r', encoding='utf-8') as bibtex_file:\n            bibtex_str = bibtex_file.read()\n    else:\n        bibtex_str = bibtex_input\n\n    bib_database = bibtexparser.loads(bibtex_str)\n    results = []\n    \n    print(f\"Found {len(bib_database.entries)} entries to verify.\\n\")\n    print(\"-\" * 60)\n    \n    for entry in bib_database.entries:\n        entry_id = entry.get('ID', 'Unknown_ID')\n        entry_type = entry.get('ENTRYTYPE', 'unknown')\n        doi = entry.get('doi', '').strip()\n        \n        print(f\"Checking [{entry_type}] {entry_id}...\")\n        \n        if not doi:\n            results.append((entry_id, \"WARNING\", \"No DOI provided. Manual verification required.\"))\n            continue\n            \n        is_valid, message = verify_via_crossref(doi, entry)\n        status = \"VALID\" if is_valid else \"INVALID\"\n        results.append((entry_id, status, message))\n        \n    return results\n\ndef print_report(results):\n    \"\"\"Prints a formatted summary of the verification results.\"\"\"\n    print(\"\\n\" + \"=\" * 60)\n    print(\"CITATION VERIFICATION REPORT\")\n    print(\"=\" * 60)\n    \n    valid_count = sum(1 for _, status, _ in results if status == \"VALID\")\n    invalid_count = sum(1 for _, status, _ in results if status == \"INVALID\")\n    warning_count = sum(1 for _, status, _ in results if status == \"WARNING\")\n    \n    for entry_id, status, message in results:\n        icon = \"\u2705\" if status == \"VALID\" else (\"\u274c\" if status == \"INVALID\" else \"\u26a0\ufe0f\")\n        print(f\"{icon} [{status}] {entry_id}\")\n        print(f\"   -> {message}\\n\")\n        \n    print(\"-\" * 60)\n    print(f\"SUMMARY: {valid_count} Valid | {invalid_count} Invalid | {warning_count} Warnings\")\n    print(\"=\" * 60)\n\nif __name__ == \"__main__\":\n    # Example BibTeX string (Replace with your .bib file path, e.g., \"references.bib\")\n    SAMPLE_BIBTEX = \"\"\"\n    @article{einstein1905,\n      title={On the Electrodynamics of Moving Bodies},\n      author={Einstein, Albert},\n      journal={Annalen der Physik},\n      volume={17},\n      pages={891--921},\n      year={1905},\n      doi={10.1002/andp.19053221004}\n    }\n    @article{typo_in_year,\n      title={Deep learning},\n      author={LeCun, Yann and Bengio, Yoshua and Hinton, Geoffrey},\n      journal={Nature},\n      volume={521},\n      number={7553},\n      pages={436--444},\n      year={2016},\n      doi={10.1038/nature14539}\n    }\n    @inproceedings{missing_doi,\n      title={A Conference Paper Without a DOI},\n      author={Smith, Jane},\n      booktitle={Proceedings of Fake Conference},\n      year={2022}\n    }\n    \"\"\"\n    \n    # To use a file instead, uncomment the line below and comment out SAMPLE_BIBTEX:\n    # INPUT_SOURCE = \"my_references.bib\" \n    INPUT_SOURCE = SAMPLE_BIBTEX\n    \n    results = parse_and_verify(INPUT_SOURCE)\n    print_report(results)\n```\n\n### 3. How to Run\nExecute the script in your terminal:\n```bash\npython verify_citations.py\n```\n\n### 4. How the Verification Works\n1. **Parsing:** Uses `bibtexparser` to safely extract fields (Title, Year, DOI, etc.) while ignoring BibTeX syntax quirks.\n2. **Sanitization:** Strips LaTeX artifacts (like `\\textbf{}` or `{}`) from titles so they can be accurately compared against API responses.\n3. **CrossRef API Lookup:** Queries the free, public CrossRef REST API using the entry's DOI.\n4. **Metadata Cross-Checking:** \n   - Confirms the DOI actually exists.\n   - Compares the **Title** (case-insensitive, stripped of formatting).\n   - Compares the **Year** (checking print, online, and issued date metadata from CrossRef).\n5. **Fallback Handling:** If an entry lacks a DOI, it flags it as a `WARNING` requiring manual verification, ensuring the script doesn't crash on incomplete bibliographies.", "solver_finish_reason": "stop"}
