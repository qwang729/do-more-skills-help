one and child.text:\n                return child.text.strip()\n            if tag in elem.attrib:\n                return elem.attrib[tag].strip()\n        return default\n\n    @staticmethod\n    def _terrain_code_to_name(code: str) -> str:\n        \"\"\"Map numeric terrain codes to names (if applicable).\"\"\"\n        mapping = {\n            '0': 'TERRAIN_GRASS',\n            '1': 'TERRAIN_PLAINS',\n            '2': 'TERRAIN_DESERT',\n            '3': 'TERRAIN_TUNDRA',\n            '4': 'TERRAIN_TERRAIN_SNOW',\n            '5': 'TERRAIN_COAST',\n            '6': 'TERRAIN_OCEAN',\n            '7': 'TERRAIN_MOUNTAIN',\n        }\n        return mapping.get(code.strip(), f'TERRAIN_{code.strip().upper()}')\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 3. HEX GRID & ADJACENCY\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nclass HexGrid:\n    \"\"\"\n    Hex grid manager for Civ6 maps.\n\n    Civ6 uses an offset coordinate system (odd-r):\n      - Pointy-top hexagons\n      - Odd rows are shifted right by half a hex width\n      - The map wraps horizontally (world wrap)\n\n    Neighbor offsets for odd-r (pointy-top):\n      Even row 