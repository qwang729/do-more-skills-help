tructured_data_from_text(text_pages):\n    \"\"\"\n    Parse structured key-value data from extracted text.\n    Handles patterns like 'Key: Value' or 'Key    Value'.\n    \"\"\"\n    records = []\n    for page_data in text_pages:\n        lines = page_data['text'].split('\\n')\n        for line in lines:\n            # Match \"Key: Value\" or \"Key   Value\" patterns\n            match = re.match(r'^([A-Za-z][A-Za-z\\s_]+?)\\s*[:\\t]\\s*(.+)$', line.strip())\n            if match:\n                records.append({\n                    'page': page_data['page'],\n                    'field': match.group(1).strip(),\n                    'value': match.group(2).strip()\n                })\n    return pd.DataFrame(records)\n\n\ndef extract_invoice_data(pdf_path):\n    \"\"\"\n    Example: Extract invoice-like data (date, amount, vendor, etc.)\n    from a PDF using regex patterns.\n    \"\"\"\n    results = []\n    with pdfplumber.open(pdf_path) as pdf:\n        full_text = \"\"\n        for page in pdf.pages:\n            text = page.extract_text()\n            if text:\n                full_text += text + \"\\n\"\n\n    # Common invoice patterns\n    patterns = {\n        'invoice_number': r'(?:Invoice|Inv)[\\s#.:-]*([A-Z0-9-]+)',\n        'date': r'(?:Date|Dated?)[\\s:.:-]*(\\d{1,2}[/-]\\d{1,2}[/-]\\d{2,4})',\n        'total_amount': r'(?:Total|Amount|Due)[\\s:.:-]*\\$?([\\d,]+\\.?\\d*)',\n        'vendor': r'(?:Vendor|From|Supplier|Company)[\\s:.:-]*(.+?)(?:\\n|$)',\n    }\n\n    record = {'source_file': os.path.basename(pdf_path)}\n    for field, pattern in patterns.items():\n        match = re.search(pattern, full_text, re.IGNORECASE)\n        record[field] = match.group(1).strip() if match else None\n\n    results.append(record)\n    return pd.DataFrame(results)\n\n\n# ============================================================\n# STEP 2: PANDAS ANALYSIS\n# ============================================================\n\ndef analyze_extracted_data(df):\n    \"\"\"Perform analysis on extracted tabular data.\"\"\"\n    analysis = {}\n\n    # Basic stats\n    analysis['summary'] = {\n        'total_rows': len(df),\n        'total_columns': len(df.columns),\n        'null_counts': df.isnull().sum().to_dict(),\n        'dtypes': {col: str(dtype) for col, dtype in df.dtypes.items()}\n    }\n\n    # Try to find and analyze numeric columns\n    numeric_cols = df.select_dtypes(include=['number']).columns.tolist()\n    if numeric_cols:\n        analysis['numeric_summary'] = df[numeric_cols].describe().to_dict()\n\n    # Value counts for categorical columns\n    cat_cols = df.select_dtypes(include=['object']).columns.tolist()\n    analysis['categorical_summary'] = {}\n    for col in cat_cols[:5]:  # Limit to first 5 categorical columns\n        if df[col].nunique() < 50:\n            analysis['categorical_summary'][col] = df[col].value_counts().to_dict()\n\n    return analysis\n\n\ndef clean_and_transform(df):\n    \"\"\"Clean and transform extracted data.\"\"\"\n    # Remove completely empty rows/columns\n    df = df.dropna(how='all').dropna(axis=1, how='all')\n\n    # Strip whitespace from string columns\n    for col in df.select_dtypes(include=['object']).columns:\n        df[col] = df[col].astype(str).str.strip()\n        df[col] = df[col].replace({'nan': None, 'None': None})\n\n    # Try to convert numeric-looking columns\n    for col in df.columns:\n        try:\n            converted = pd.to_numeric(df[col].astype(str).str.replace(',', ''),\n                                       errors='coerce')\n            if converted.notna().sum() > len(df) * 0.5:\n                df[col] = converted\n        except (ValueError, AttributeError):\n            pass\n\n    return df\n\n\n# ============================================================\n# STEP 3: EXCEL EXPORT\n# ============================================================\n\ndef export_to_excel(data_dict, output_path):\n    \"\"\"\n    Export multiple DataFrames and analysis results to a single Excel file\n    with multiple sheets.\n    \"\"\"\n    with pd.ExcelWriter(output_path, engine='xlsxwriter') as writer:\n        workbook = writer.book\n\n        # Formats\n        header_fmt = workbook.add_format({\n            'bold': True,\n            'bg_color': '#4472C4',\n            'font_color': 'white',\n            'border': 1\n        })\n        money_fmt = workbook.add_format({'num_format': '$#,##0.00'})\n        date_fmt = workbook.add_format({'num_format': 'yyyy-mm-dd'})\n\n        sheet_num = 0\n        for sheet_name, df in data_dict.items():\n            # Excel sheet names max 31 chars\n            safe_name = sheet_name[:31]\n            df.to_excel(writer, sheet_name=safe_name, index=False,\n                        startrow=1, header=False)\n\n            worksheet = writer.sheets[safe_name]\n\n            # Write headers with formatting\n            for col_num, col_name in enumerate(df.columns):\n                worksheet.write(0, col_num, col_name, header_fmt)\n\n            # Auto-fit column widths\n            for col_num, col_name in enumerate(df.columns):\n                max_len = max(\n                    df[col_name].astype(str).map(len).max(),\n                    len(str(col_name))\n                ) + 2\n                worksheet.set_column(col_num, col_num, min(max_len, 50))\n\n            sheet_num += 1\n\n    print(f\"\u2705 Exported to: {output_path}\")\n    return output_path\n\n\n# ============================================================\n# MAIN PIPELINE\n# ============================================================\n\ndef process_pdf_pipeline(pdf_path, output_excel=None):\n    \"\"\"\n    Complete pipeline: PDF \u2192 Extract \u2192 Analyze \u2192 Excel\n    \"\"\"\n    if output_excel is None:\n        base = os.path.splitext(os.path.basename(pdf_path))[0]\n        output_excel = f\"{base}_analysis_{datetime.now().strftime('%Y%m%d')}.xlsx\"\n\n    print(f\"\ud83d\udcc4 Processing: {pdf_path}\")\n\n    # --- Extract ---\n    print(\"  \u2192 Extracting tables...\")\n    tables = extract_tables_from_pdf(pdf_path)\n\n    print(\"  \u2192 Extracting text...\")\n    text_pages = extract_text_from_pdf(pdf_path)\n\n    print(\"  \u2192 Parsing structured data...\")\n    structured_df = parse_structured_data_from_text(text_pages)\n\n    # Try invoice extraction as well\n    invoice_df = extract_invoice_data(pdf_path)\n\n    # --- Combine & Clean ---\n    data_dict = {}\n\n    if tables:\n        combined_tables = pd.concat(tables, ignore_index=True)\n        combined_tables = clean_and_transform(combined_tables)\n        data_dict['Extracted_Tables'] = combined_tables\n        print(f\"  \u2192 Found {len(tables)} table(s), {len(combined_tables)} total rows\")\n\n    if not structured_df.empty:\n        data_dict['Key_Value_Data'] = structured_df\n        print(f\"  \u2192 Found {len(structured_df)} key-value pairs\")\n\n    if not invoice_df.empty:\n        data_dict['Invoice_Data'] = invoice_df\n\n    if not data_dict:\n        # Fallback: raw text per page\n        raw_df = pd.DataFrame(text_pages)\n        data_dict['Raw_Text'] = raw_df\n        print(\"  \u2192 No tables found; saved raw text\")\n\n    # --- Analyze ---\n    print(\"  \u2192 Running analysis...\")\n    for sheet_name, df in data_dict.items():\n        analysis = analyze_extracted_data(df)\n        # Add analysis as a separate sheet\n        summary_rows = []\n        summary_rows.append({'Metric': 'Total Rows', 'Value': analysis['summary']['total_rows']})\n        summary_rows.append({'Metric': 'Total Columns', 'Value': analysis['summary']['total_columns']})\n        for col, count in analysis['summary']['null_counts'].items():\n            summary_rows.append({'Metric': f'Nulls: {col}', 'Value': count})\n        data_dict[f'{sheet_name}_Summary'] = pd.DataFrame(summary_rows)\n\n    # --- Export ---\n    print(\"  \u2192 Exporting to Excel...\")\n    export_to_excel(data_dict, output_excel)\n\n    print(f\"\\n\u2705 Done! Output: {output_excel}\")\n    return data_dict, output_excel\n\n\n# ============================================================\n# BATCH PROCESSING (multiple PDFs)\n# ============================================================\n\ndef batch_process_pdfs(pdf_directory, output_excel=None):\n    \"\"\"Process all PDFs in a directory and combine into one Excel file.\"\"\"\n    if output_excel is None:\n        output_excel = f\"batch_analysis_{datetime.now().strftime('%Y%m%d')}.xlsx\"\n\n    all_data = {}\n    pdf_files = [f for f in os.listdir(pdf_directory) if f.lower().endswith('.pdf')]\n\n    print(f\"\ud83d\udcc1 Found {len(pdf_files)} PDFs in {pdf_directory}\")\n\n    for pdf_file in pdf_files:\n        pdf_path = os.path.join(pdf_directory, pdf_file)\n        try:\n            tables = extract_tables_from_pdf(pdf_path)\n            if tables:\n                combined = pd.concat(tables, ignore_index=True)\n                combined = clean_and_transform(combined)\n                combined['source_file'] = pdf_file\n                sheet_name = os.path.splitext(pdf_file)[0][:25]\n                all_data[sheet_name] = combined\n                print(f\"  \u2705 {pdf_file}: {len(combined)} rows extracted\")\n            else:\n                print(f\"  \u26a0\ufe0f  {pdf_file}: No tables found\")\n        except Exception as e:\n            print(f\"  \u274c {pdf_file}: Error - {e}\")\n\n    if all_data:\n        export_to_excel(all_data, output_excel)\n    else:\n        print(\"No data extracted from any PDF.\")\n\n    return all_data\n\n\n# ============================================================\n# USAGE EXAMPLES\n# ============================================================\n\nif __name__ == \"__main__\":\n    # --- Example 1: Single PDF ---\n    # process_pdf_pipeline(\"invoice_2024.pdf\")\n\n    # --- Example 2: Batch processing ---\n    # batch_process_pdfs(\"./pdf_documents/\")\n\n    # --- Example 3: Just extract tables and analyze ---\n    # tables = extract_tables_from_pdf(\"report.pdf\")\n    # df = pd.concat(tables, ignore_index=True)\n    # df = clean_and_transform(df)\n    # print(df.describe())\n    # df.to_excel(\"output.xlsx\", index=False)\n\n    # --- Example 4: Extract specific data with custom logic ---\n    # text_pages = extract_text_from_pdf(\"contract.pdf\")\n    # structured = parse_structured_data_from_text(text_pages)\n    # pivot = structured.pivot(index='field', columns='page', values='value')\n    # pivot.to_excel(\"contract_data.xlsx\")\n\n    print(\"PDF Analysis Pipeline Ready.\")\n    print(\"Usage: process_pdf_pipeline('your_file.pdf')\")\n    print(\"       batch_process_pdfs('./pdf_folder/')\")\n```\n\n### 3. Quick-Start Minimal Example\n\n```python\nimport pdfplumber\nimport pandas as pd\n\n# One-liner: extract first table from PDF \u2192 clean \u2192 export\nwith pdfplumber.open(\"report.pdf\") as pdf:\n    tables = [pd.DataFrame(t[1:], columns=t[0])\n              for page in pdf.pages\n              for t in page.extract_tables() if t and len(t) > 1]\n\ndf = pd.concat(tables, ignore_index=True)\ndf = df.dropna(how='all').apply(lambda c: c.str.strip() if c.dtype == \"object\" else c)\n\n# Analysis\nprint(df.describe())\nprint(df.isnull().sum())\n\n# Export\ndf.to_excel(\"output.xlsx\", index=False, sheet_name=\"Extracted\")\n```\n\n### Key Libraries & What They Do\n\n| Library | Purpose |\n|---------|---------|\n| `pdfplumber` | Extract tables & text from PDFs (best for text-based PDFs) |\n| `tabula-py` | Alternative table extraction (wraps Java tabula) |\n| `camelot-py` | Another table extraction option (good for complex layouts) |\n| `pandas` | Data cleaning, transformation, analysis |\n| `openpyxl` / `xlsxwriter` | Excel file writing with formatting |\n\n### Handling Scanned PDFs (OCR)\n\n```python\n# For scanned/image-based PDFs, use pdf2image + pytesseract\nfrom pdf2image import convert_from_path\nimport pytesseract\n\nimages = convert_from_path(