n(2 * np.pi * t / 16)\nnoise = np.random.normal(0, 0.005, len(quarters))\nlog_gdp = true_trend + cycle + noise\n\ndf = pd.DataFrame({\n    \"date\": quarters,\n    \"log_gdp\": log_gdp,\n    \"gdp_level\": np.exp(log_gdp) * 100  # index, base ~22000\n}, index=quarters)\n\ndf.index.name = \"date\"\n\n# ============================================================\n# 2. APPLY THE HODRICK-PREScott FILTER\n# ============================================================\n\n# The smoothing parameter lambda (\u03bb):\n#   - Quarterly data: \u03bb = 1600 (standard, per Hodrick & Prescott 1997)\n#   - Annual data:    \u03bb = 100  (or 6.25 per Ravn-Uhlig convention)\n#   - Monthly data:   \u03bb = 14400\n\nLAMBDA_QUARTERLY = 1600\n\n# hpfilter returns (cycle, trend)\ncycle, trend = hpfilter(df[\"log_gdp\"], lamb=LAMBDA_QUARTERLY)\n\n# Build results DataFrame\nresults = pd.DataFrame({\n    \"date\": df.index,\n    \"log_gdp_observed\": df[\"log_gdp\"].values,\n    \"hp_trend\": trend.values,\n    \"hp_cycle\": cycle.values,\n    \"gdp_level\": df[\"gdp_level\"].values,\n})\nresults[\"date\"] = pd.to_datetime(results[\"date\"])\nresults.set_index(\"date\", inplace=True)\n\n# Summary statistics for the cycle\ncycle_stats = pd.DataFrame({\n    \"Statistic\": [\"Mean\", \"Std Dev\", \"Min\", \"Max\", \"Amplitude (peak-to-trough)\"],\n    \"HP_Cycle\": [\n        cycle.mean(),\n        cycle.std(),\n        cycle.min(),\n        cycle.max(),\n        cycle.max() - cycle.min()\n    ]\n})\n\nprint(\"=\" * 60)\nprint(\"HODRICK-PRESCOTT FILTER RESULTS\")\nprint(f\"Smoothing parameter (\u03bb): {LAMBDA_QUARTERLY}\")\nprint(f\"Observations: {len(df)}\")\nprint(\"=\" * 60)\nprint(results.head(10).to_string())\nprint(\"\\nCycle Statistics:\")\nprint(cycle_stats.to_string(index=False))\n\n# ============================================================\n# 3. EXPORT TO EXCEL WITH FORMATTING & CHARTS\n# ============================================================\n\noutput_file = \"hp_filter_results.xlsx\"\n\nwith pd.ExcelWriter(output_file, engine=\"xlsxwriter\") as writer:\n    # --- Sheet 1: Full Results ---\n    results.to_excel(writer, sheet_name=\"HP_Filter_Results\", float_format=\"%.6f\")\n\n    # --- Sheet 2: Cycle Statistics ---\n    cycle_stats.to_excel(writer, sheet_name=\"Cycle_Statistics\", index=False)\n\n    # --- Sheet 3: Source Data ---\n    df.to_excel(writer, sheet_name=\"Source_Data\", float_format=\"%.6f\")\n\n    # Access the xlsxwriter workbook and worksheet objects\n    workbook = writer.book\n    ws_results = writer.sheets[\"HP_Filter_Results\"]\n    ws_stats = writer.sheets[\"Cycle_Statistics\"]\n\n    # --- Formatting ---\n    header_format = workbook.add_format({\n        \"bold\": True,\n        \"font_color\": \"white\",\n        \"bg_color\": \"#2F5496\",\n        \"border\": 1,\n        \"align\": \"center\",\n        \"valign\": \"vcenter\",\n    })\n    number_format = workbook.add_format({\"num_format\": \"0.000000\", \"align\": \"center\"})\n    date_format = workbook.add_format({\"num_format\": \"yyyy-mm-dd\", \"align\": \"center\"})\n\n    # Format headers\n    for col_num, col_name in enumerate(results.reset_index().columns):\n        ws_results.write(0, col_num, col_name, header_format)\n        ws_results.set_column(col_num, col_num, 18)\n\n    # Format data cells\n    for row in range(1, len(results) + 1):\n        ws_results.write_datetime(row, 0, results.index[row - 1].to_pydatetime(), date_format)\n        for col in range(1, len(results.columns) + 1):\n            ws_results.write_number(row, col, results.iloc[row - 1, col - 1], number_format)\n\n    # --- Chart 1: Observed vs Trend ---\n    chart1 = workbook.add_chart({\"type\": \"line\"})\n    chart1.set_title({\"name\": \"Log GDP: Observed vs HP Trend\"})\n    chart1.set_y_axis({\"name\": \"Log GDP\"})\n    chart1.set_x_axis({\"name\": \"Date\"})\n    chart1.set_size({\"width\": 900, \"height\": 450})\n\n    n_rows = len(results)\n    chart1.add_series({\n        \"name\": \"Observed\",\n        \"categories\": [\"HP_Filter_Results\", 1, 0, n_rows, 0],\n        \"values\": [\"HP_Filter_Results\", 1, 1, n_rows, 1],\n        \"line\": {\"color\": \"#4472C4\", \"width\": 1.5},\n    })\n    chart1.add_series({\n        \"name\": \"HP Trend\",\n        \"categories\": [\"HP_Filter_Results\", 1, 0, n_rows, 0],\n        \"values\": [\"HP_Filter_Results\", 1, 2, n_rows, 2],\n        \"line\": {\"color\": \"#ED7D31\", \"width\": 2.5, \"dash_type\": \"dash\"},\n    })\n    ws_results.insert_chart(\"G2\", chart1)\n\n    # --- Chart 2: HP Cycle ---\n    chart2 = workbook.add_chart({\"type\": \"line\"})\n    chart2.set_title({\"name\": \"HP Filtered Cycle (Deviation from Trend)\"})\n    chart2.set_y_axis({\"name\": \"Cycle Component\", \"crosses\": \"min\"})\n    chart2.set_x_axis({\"name\": \"Date\"})\n    chart2.set_size({\"width\": 900, \"height\": 350})\n\n    chart2.add_series({\n        \"name\": \"HP Cycle\",\n        \"categories\": [\"HP_Filter_Results\", 1, 0, n_rows, 0],\n        \"values\": [\"HP_Filter_Results\", 1, 3, n_rows, 3],\n        \"line\": {\"color\": \"#70AD47\", \"width\": 1.5},\n    })\n    ws_results.insert_chart(\"G20\", chart2)\n\n    # Format statistics sheet\n    for col_num, col_name in enumerate(cycle_stats.columns):\n        ws_stats.write(0, col_num, col_name, header_format)\n        ws_stats.set_column(col_num, col_num, 25)\n\nprint(f\"\\n\u2705 Results saved to: {os.path.abspath(output_file)}\")\nprint(f\"   Sheets: 'HP_Filter_Results', 'Cycle_Statistics', 'Source_Data'\")\nprint(f\"   Charts: Observed vs Trend, HP Cycle\")\n```\n\n## How It Works\n\n| Component | Description |\n|-----------|-------------|\n| **`hpfilter(series, lamb=1600)`** | Decomposes `series` into `(cycle, trend)` by minimizing: $\\sum (y_t - \\tau_t)^2 + \\lambda \\sum [(\\tau_{t+1} - \\tau_t) - (\\tau_t - \\tau_{t-1})]^2$ |\n| **\u03bb = 1600** | Standard for **quarterly** data (Hodrick-Prescott 1997). Use 100 for annual