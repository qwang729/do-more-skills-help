xlsx', '.xlsm', '.xls')):\n                    print(f\"Found embedded Excel: {filename}\")\n                    \n                    # Load, edit, and save the workbook\n                    wb = openpyxl.load_workbook(filepath)\n                    edit_function(wb, filename)\n                    wb.save(filepath)\n                    edited_files.append(filename)\n                    print(f\"  -> Edited and saved: {filename}\")\n        \n        if not edited_files:\n            print(\"No embedded Excel files found in the presentation.\")\n        \n        # Repack the pptx\n        with zipfile.ZipFile(output_pptx, 'w', zipfile.ZIP_DEFLATED) as zout:\n            for root, dirs, files in os.walk(temp_dir):\n                for file in files:\n                    file_path = os.path.join(root, file)\n                    arcname = os.path.relpath(file_path, temp_dir)\n                    zout.write(file_path, arcname)\n        \n        print(f\"\\nOutput saved to: {output_pptx}\")\n        return edited_files\n    \n    finally:\n        # Clean up temp directory\n        if os.path.exists(temp_dir):\n            shutil.rmtree(temp_dir)\n\n\ndef edit_embedded_excel_by_index(input_pptx, output_pptx, target_index, edit_function):\n    \"\"\"\n    Edit a specific embedded Excel object by its index (0-based).\n    \"\"\"\n    temp_dir = '_temp_pptx_work'\n    \n    if os.path.exists(temp_dir):\n        shutil.rmtree(temp_dir)\n    \n    try:\n        with zipfile.ZipFile(input_pptx, 'r') as z:\n            z.extractall(temp_dir)\n        \n        embeddings_dir = os.path.join(temp_dir, 'ppt', 'embeddings')\n        excel_files = []\n        \n        if os.path.exists(embeddings_dir):\n            for filename in sorted(os.listdir(embeddings_dir)):\n                if filename.lower().endswith(('.xlsx', '.xlsm', '.xls')):\n                    excel_files.append(filename)\n        \n        if target_index >= len(excel_files):\n            raise IndexError(f\"Embedded Excel index {target_index} out of range. \"\n                           f\"Found {len(excel_files)} embedded Excel files.\")\n        \n        target_file = excel_files[target_index]\n        filepath = os.path.join(embeddings_dir, target_file)\n        \n        wb = openpyxl.load_workbook(filepath)\n        edit_function(wb, target_file)\n        wb.save(filepath)\n        \n        # Repack\n        with zipfile.ZipFile(output_pptx, 'w', zipfile.ZIP_DEFLATED) as zout:\n            for root, dirs, files in os.walk(temp_dir):\n                for file in files:\n                    file_path = os.path.join(root, file)\n                    arcname = os.path.relpath(file_path, temp_dir)\n                    zout.write(file_path, arcname)\n        \n        print(f\"Edited embedded Excel #{target_index}: {target_file}\")\n        print(f\"Output saved to: {output_pptx}\")\n    \n    finally:\n        if os.path.exists(temp_dir):\n            shutil.rmtree(temp_dir)\n\n\ndef list_embedded_objects(pptx_path):\n    \"\"\"\n    List all embedded objects in a .pptx file with their details.\n    \"\"\"\n    print(f\"\\n=== Embedded Objects in: {pptx_path} ===\\n\")\n    \n    with zipfile.ZipFile(pptx_path, 'r') as z:\n        # List all files in the package\n        embeddings = [f for f in z.namelist() if 'embeddings' in f.lower()]\n        \n        if not embeddings:\n            print(\"No embedded objects found.\")\n            return\n        \n        for i, emb_path in enumerate(embeddings):\n            print(f\"[{i}] {emb_path}\")\n            info = z.getinfo(emb_path)\n            print(f\"    Size: {info.file_size} bytes\")\n            \n            # Try to identify the type\n            if emb_path.endswith('.xlsx'):\n                print(f\"    Type: Excel Workbook (.xlsx)\")\n            elif emb_path.endswith('.xls'):\n                print(f\"    Type: Excel Workbook (legacy .xls)\")\n            elif emb_path.endswith('.bin'):\n                print(f\"    Type: OLE Binary Object\")\n            else:\n                print(f\"    Type: Unknown\")\n            print()\n    \n    # Also check slide-level relationships\n    print(\"=== Slide Relationships ===\\n\")\n    prs = Presentation(pptx_path)\n    for slide_idx, slide in enumerate(prs.slides):\n        for rel in slide.part.rels.values():\n            if 'oleObject' in str(rel.reltype) or 'package' in str(rel.reltype):\n                print(f\"Slide {slide_idx + 1}: {rel.reltype}\")\n                print(f\"  Target: {rel.target_ref}\")\n                print()\n\n\ndef read_embedded_excel(pptx_path, index=0):\n    \"\"\"\n    Read and return the contents of an embedded Excel file without modifying the pptx.\n    \"\"\"\n    with zipfile.ZipFile(pptx_path, 'r') as z:\n        embeddings_dir = 'ppt/embeddings/'\n        excel_files = [f for f in z.namelist() \n                      if f.startswith(embeddings_dir) and f.lower().endswith(('.xlsx', '.xlsm'))]\n        \n        if not excel_files:\n            print(\"No embedded Excel files found.\")\n            return None\n        \n        if index >= len(excel_files):\n            raise IndexError(f\"Index {index} out of range. Found {len(excel_files)} files.\")\n        \n        target = excel_files[index]\n        print(f\"Reading: {target}\")\n        \n        with z.open(target) as f:\n            wb = openpyxl.load_workbook(io.BytesIO(f.read()))\n            return wb\n\n\n# ============================================================\n# EXAMPLE USAGE\n# ============================================================\n\ndef example_edit_all(wb, filename):\n    \"\"\"Example: Edit all cells - add a header and some data.\"\"\"\n    ws = wb.active\n    print(f\"  Sheet '{ws.title}' has {ws.max_row} rows, {ws.max_column} columns\")\n    \n    # Example modification: Add/update a cell\n    ws['A1'] = 'Modified by Python'\n    ws['A1'].font = openpyxl.styles.Font(bold=True, color='FF0000')\n    \n    # Add data to next available row\n    next_row = ws.max_row + 1\n    ws.cell(row=next_row, column=1, value='New data added')\n    ws.cell(row=next_row, column=2, value=42)\n\n\ndef example_edit_specific(wb, filename):\n    \"\"\"Example: More targeted editing.\"\"\"\n    ws = wb.active\n    \n    # Update specific cells\n    ws['B2'] = 'Updated Value'\n    ws['C2'] = 100\n    \n    # Add formatting\n    from openpyxl.styles import PatternFill, Font, Alignment\n    \n    fill = PatternFill(start_color='FFFF00', end_color='FFFF00', fill_type='solid')\n    ws['B2'].fill = fill\n    ws['B2'].font = Font(bold=True)\n    ws['B2'].alignment = Alignment(horizontal='center')\n    \n    # Add a formula\n    ws['D1'] = '=SUM(B2:B10)'\n\n\ndef example_create_new_data(wb, filename):\n    \"\"\"Example: Replace all content with new data.\"\"\"\n    # Clear existing sheets\n    for sheet_name in wb.sheetnames:\n        if sheet_name != wb.active.title:\n            del wb[sheet_name]\n    \n    ws = wb.active\n    ws.title = 'Report Data'\n    \n    # Write headers\n    headers = ['Category', 'Q1', 'Q2', 'Q3', 'Q4', 'Total']\n    for col, header in enumerate(headers, 1):\n        cell = ws.cell(row=1, column=col, value=header)\n        cell.font = openpyxl.styles.Font(bold=True)\n        cell.fill = openpyxl.styles.PatternFill(\n            start_color='4472C4', end_color='4472C4', fill_type='solid'\n        )\n        cell.font = openpyxl.styles.Font(bold=True, color='FFFFFF')\n    \n    # Write data\n    data = [\n        ['Product A', 100, 150, 200, 180],\n        ['Product B', 80, 90, 110, 130],\n        ['Product C', 200, 220, 190, 250],\n    ]\n    \n    for row_idx, row_data in enumerate(data, 2):\n        for col_idx, value in enumerate(row_data, 1):\n            ws.cell(row=row_idx, column=col_idx, value=value)\n        # Add SUM formula\n        ws.cell(row=row_idx, column=6, \n                value=f'=SUM(B{row_idx}:E{row_idx})')\n\n\nif __name__ == '__main__':\n    # --- List all embedded objects ---\n    # list_embedded_objects('input.pptx')\n    \n    # --- Read embedded Excel (read-only) ---\n    # wb = read_embedded_excel('input.pptx', index=0)\n    # if wb:\n    #     ws = wb.active\n    #     for row in ws.iter_rows(values_only=True):\n    #         print(row)\n    \n    # --- Edit ALL embedded Excel files ---\n    # edit_embedded_excel_in_pptx(\n    #     input_pptx='input.pptx',\n    #     output_pptx='output.pptx',\n    #     edit_function=example_edit_all\n    # )\n    \n    # --- Edit a SPECIFIC embedded Excel by index ---\n    # edit_embedded_excel_by_index(\n    #     input_pptx='input.pptx',\n    #     output_pptx='output.pptx',\n    #     target_index=0,\n    #     edit_function=example_edit_specific\n    # )\n    \n    # --- Replace embedded Excel data entirely ---\n    # edit_embedded_excel_in_pptx(\n    #     input_pptx='input.pptx',\n    #     output_pptx='output.pptx',\n    #     edit_function=example_create_new_data\n    # )\n    \n    print(\"Script loaded. Uncomment the example usage above to run.\")\n    print(\"\\nQuick start:\")\n    print(\"  edit_embedded_excel_in_pptx('input.pptx', 'output.pptx', example_edit_all)\")\n```\n\n## Key Points\n\n| Concept | Detail |\n|---------|--------|\n| **Storage** | Embedded Excel files live in `ppt/embeddings/` inside the .pptx zip |\n| **Format** | Usually `.xlsx` or `.bin` (OLE binary) |\n| **Editing** | Extract \u2192 modify with `openpyxl` \u2192 repack as zip |\n| **python-pptx** | Handles slide/table structure; package-level access needed for OLE |\n\n## How It Works\n\n1. **Extract** the `.pptx` (it's a ZIP) to a temp directory\n2. **Locate** embedded Excel files in `ppt/embeddings/`\n3. **Open** each with `openpyxl`, apply your modifications\n4. **Repack** everything back into a valid `.pptx` ZIP\n\nThe `edit_function` callback receives an `openpyxl.Workbook` object \u2014 use the full openpyxl API (cells, formulas, formatting, charts, etc.) to make any changes needed.", "solver_finish_reason": "stop"}
{"task": "exceltable-in-ppt", "condition": "retrieved_top1_full", "repeat": 0, "skill_ids": ["benchflow-ai--pptx"], "retrieval_correct": true, "judged_pass": false, "judged_score": 1, "judge_reason": "Agent's solution does not read exchange rate from text box or update specific Excel cell as required.", "solver_tokens": 6812, "judge_tokens": 4758, "solution_text": "# Editing Embedded Excel in PPTX with python-pptx\n\nHere's a complete solution covering both **regular PPTX tables** and **embedded Excel OLE objects**.\n\n## Complete Script\n\n```python\n\"\"\"\nEdit embedded Excel spreadsheets and tables within a PPTX file.\nHandles:\n  1. Regular PPTX tables (created via Insert > Table)\n  2. Embedded Excel OLE objects (Insert > Object > Excel Spreadsheet)\n     - Direct .xlsx embeddings (Office 2007+)\n     - OLE-wrapped .xls embeddings (legacy format)\n\"\"\"\n\nimport io\nimport os\nimport copy\nfrom lxml import etree\nfrom pptx import Presentation\nfrom pptx.util import Inches, Pt, Emu\nimport openpyxl\n\n# Try to import olefile for legacy OLE-wrapped Excel files\ntry:\n    import olefile\n    HAS_OLEFILE = True\nexcept ImportError:\n    HAS_OLEFILE = False\n    print(\"Warning: olefile not installed. Legacy .xls OLE objects won't be editable.\")\n    print(\"Install with: pip install olefile\")\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# PART 1: Edit regular PPTX tables\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef edit_pptx_tables(prs):\n    \"\"\"Find and edit all regular tables in the presentation.\"\"\"\n    for slide_idx, slide in enumerate(prs.slides):\n        for shape in slide.shapes:\n            if shape.has_table:\n                table = shape.table\n                print(f\"  Slide {slide_idx+1}: Found table \"\n                      f\"({table.rows.__len__()} rows x {len(table.columns)} cols)\")\n\n                # Example: Edit every cell\n                for row_idx, row in enumerate(table.rows):\n                    for col_idx, cell in enumerate(row.cells):\n                        old_text = cell.text\n                        # Modify cell text\n                        cell.text = f\"Edited: {old_text}\" if old_text.strip() else \"\"\n\n                        # Format the cell\n                        for paragraph in cell.text_frame.paragraphs:\n                            for run in paragraph.runs:\n                                run.font.size = Pt(11)\n                                run.font.bold = False\n\n                # Example: Set specific cell\n                if table.rows.__len__() > 0 and len(table.columns) > 0:\n                    table.cell(0, 0).text = \"Header Modified\"\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# PART 2: Edit embedded Excel OLE objects\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef _get_ole_objects_from_slide(slide):\n    \"\"\"\n    Extract OLE object metadata from a slide's XML.\n    Returns list of dicts with rId, progId, and the XML element.\n    \"\"\"\n    nsmap = {\n        'p': 'http://schemas.openxmlformats.org/presentationml/2006/main',\n        'r': 'http://schemas.openxmlformats.org/officeDocument/2006/relationships',\n        'a': 'http://schemas.openxmlformats.org/drawingml/2006/main',\n        'mc': 'http://schemas.openxmlformats.org/markup-compatibility/2006',\n    }\n\n    results = []\n    slide_element = slide._element\n\n    # Search for oleObj elements in various locations\n    for ole_obj in slide_element.iter():\n        tag = etree.QName(ole_obj.tag).localname if '}' in ole_obj.tag else ole_obj.tag\n        if tag == 'oleObj':\n            r_ns = 'http://schemas.openxmlformats.org/officeDocument/2006/relationships'\n            r_id = ole_obj.get(f'{{{r_ns}}}id')\n            prog_id = ole_obj.get('progId', '')\n            results.append({\n                'rId': r_id,\n                'progId': prog_id,\n                'element': ole_obj,\n            })\n\n    return results\n\n\ndef _is_excel_ole(prog_id):\n    \"\"\"Check if the OLE progId indicates an Excel object.\"\"\"\n    if not prog_id:\n        return False\n    prog_lower = prog_id.lower()\n    return ('excel' in prog_lower or\n            'sheet' in prog_lower or\n            'xlsx' in prog_lower or\n            'xls' in prog_lower or\n            'xlmac' in prog_lower)\n\n\ndef _extract_xlsx_from_ole_package(blob):\n    \"\"\"\n    If the embedded object is wrapped in an OLE compound document (legacy .xls),\n    extract the actual Excel data from it.\n    Returns (excel_bytes, is_wrapped).\n    \"\"\"\n    if not HAS_OLEFILE:\n        return blob, False\n\n    try:\n        ole = olefile.OleFileIO(io.BytesIO(blob))\n        # Look for common Excel streams inside the OLE package\n        if ole.exists('Package'):\n            # The actual file is stored in the 'Package' stream\n            package_data = ole.openstream('Package').read()\n            ole.close()\n            return package_data, True\n        elif ole.exists('Workbook'):\n            # It's a raw .xls workbook\n            workbook_data = ole.openstream('Workbook').read()\n            ole.close()\n            return blob, False  # Return original, it's already usable\n        else:\n            ole.close()\n            return blob, False\n    except Exception:\n        return blob, False\n\n\ndef _repackage_xlsx_into_ole(original_blob, new_xlsx_bytes):\n    \"\"\"\n    If the original was OLE-wrapped, re-wrap the new xlsx bytes.\n    \"\"\"\n    if not HAS_OLEFILE:\n        return new_xlsx_bytes\n\n    try:\n        ole = olefile.OleFileIO(io.BytesIO(original_blob))\n        if ole.exists('Package'):\n            ole.close()\n            # Re-create the OLE package with the new data\n            out = io.BytesIO()\n            ole_out = olefile.OleFileIO(out, write_mode=True)\n            ole_out.write_stream('Package', new_xlsx_bytes)\n            # Copy other streams if needed\n            ole_out.close()\n            return out.getvalue()\n        else:\n            ole.close()\n            return new_xlsx_bytes\n    except Exception:\n        return new_xlsx_bytes\n\n\ndef _modify_excel_bytes(excel_bytes, modification_func):\n    \"\"\"\n    Open Excel bytes with openpyxl, apply modification_func, return new bytes.\n    modification_func receives (workbook) and should modify it in place.\n    \"\"\"\n    wb = openpyxl.load_workbook(io.BytesIO(excel_bytes), data_only=False)\n    modification_func(wb)\n    output = io.BytesIO()\n    wb.save(output)\n    return output.getvalue()\n\n\ndef edit_embedded_excel(prs, modification_func=None):\n    \"\"\"\n    Find and edit all embedded Excel OLE objects in the presentation.\n\n    modification_func: callable(workbook) that modifies the openpyxl Workbook.\n                       If None, a default modification is applied.\n    \"\"\"\n    if modification_func is None:\n        def modification_func(wb):\n            \"\"\"Default: write 'Edited by python-pptx' into cell A1 of every sheet.\"\"\"\n            for ws in wb.worksheets:\n                ws['A1'] = 'Edited by python-pptx'\n                ws['A2'] = f'Sheet: {ws.title}'\n\n    for slide_idx, slide in enumerate(prs.slides):\n        ole_objects = _get_ole_objects_from_slide(slide)\n\n        for ole_info in ole_objects:\n            prog_id = ole_info['progId']\n            r_id = ole_info['rId']\n\n            if not _is_excel_ole(prog_id):\n                print(f\"  Slide {slide_idx+1}: Skipping non-Excel OLE (progId={prog_id})\")\n                continue\n\n            print(f\"  Slide {slide_idx+1}: Found Excel OLE object \"\n                  f\"(progId={prog_id}, rId={r_id})\")\n\n            # Get the relationship and target part\n            try:\n                rel = slide.part.rels[r_id]\n            except KeyError:\n                print(f\"    WARNING: Could not find relationship {r_id}\")\n                continue\n\n            target_part = rel.target_part\n            original_blob = target_part.blob\n\n            print(f\"    Original size: {len(original_blob)} bytes\")\n\n            # Check if it's OLE-wrapped\n            excel_bytes, is_wrapped = _extract_xlsx_from_ole_package(original_blob)\n            if is_wrapped:\n                print(f\"    OLE-wrapped package detected, extracted \"\n                      f\"{len(excel_bytes)} bytes of Excel data\")\n\n            # Modify the Excel data\n            try:\n                new_excel_bytes = _modify_excel_bytes(excel_bytes, modification_func)\n                print(f\"    Modified Excel data: {len(new_excel_bytes)} bytes\")\n            except Exception as e:\n                print(f\"    ERROR modifying Excel: {e}\")\n                continue\n\n            # Re-wrap if necessary\n            if is_wrapped:\n                new_blob = _repackage_xlsx_into_ole(original_blob, new_excel_bytes)\n            else:\n                new_blob = new_excel_bytes\n\n            # Write back to the part\n            target_part._blob = new_blob\n            print(f\"    Updated part blob: {len(new_blob)} bytes\")\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# PART 3: Create a demo PPTX with embedded Excel for testing\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef create_demo_pptx(output_path):\n    \"\"\"Create a PPTX with both a table and an embedded Excel object for testing.\"\"\"\n    prs = Presentation()\n    slide_layout = prs.slide_layouts[5]  # Blank layout\n    slide = prs.slides.add_slide(slide_layout)\n\n    # Add a regular table\n    from pptx.util import Inches, Pt\n    rows, cols = 3, 4\n    left = Inches(0.5)\n    top = Inches(0.5)\n    width = Inches(9)\n    height = Inches(2)\n\n    table_shape = slide.shapes.add_table(rows, cols, left, top, width, height)\n    table = table_shape.table\n\n    # Populate table\n    headers = ['Name', 'Q1 Sales', 'Q2 Sales', 'Q3 Sales']\n    data = [\n        ['Product A', '1000', '1200', '1400'],\n        ['Product B', '800', '950', '1100'],\n    ]\n\n    for col_idx, header in en