    })\n        except Exception as e:\n            # If appearance update fails, the value is still set\n            pass\n\n    def _escape_pdf_string(self, s: str) -> str:\n        \"\"\"Escape special characters for PDF string literals.\"\"\"\n        return s.replace(\"\\\\\", \"\\\\\\\\\").replace(\"(\", \"\\\\(\").replace(\")\", \"\\\\)\")\n\n    def _to_bool(self, value: Any) -> bool:\n        \"\"\"Convert various representations to boolean.\"\"\"\n        if isinstance(value, bool):\n            return value\n        if isinstance(value, (int, float)):\n            return bool(value)\n        if isinstance(value, str):\n            return value.lower() in (\"true\", \"yes\", \"1\", \"on\", \"x\", \"checked\")\n        return bool(value)\n\n    def flatten(self) -> \"CourtFormFiller\":\n        \"\"\"Flatten the form so fields become non-editable.\"\"\"\n        # Set NeedAppearances to false\n        if \"/AcroForm\" in self.writer._root_object:\n            acroform = self.writer._root_object[\"/AcroForm\"]\n            acroform.update({\n                NameObject(\"/NeedAppearances\"): BooleanObject(False),\n            })\n\n        # Remove form fields from each page\n        for page in self.writer.pages:\n            if \"/Annots\" in page:\n                annots = page[\"/Annots\"]\n                new_annots = ArrayObject()\n                for annot_ref in annots:\n                    annot = annot_ref.get_object()\n                    subtype = annot.get(\"/Subtype\")\n                    if subtype and str(subtype) != \"/Widget\":\n                        new_annots.append(annot_ref)\n                    elif \"/FT\" not in annot and \"/Parent\" not in annot:\n                        new_annots.append(annot_ref)\n                page.update({\n                    NameObject(\"/Annots\"): new_annots,\n                })\n\n        # Remove AcroForm\n        if \"/AcroForm\" in self.writer._root_object:\n            del self.writer._root_object[