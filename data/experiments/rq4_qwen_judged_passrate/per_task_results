_entropies if e <= low_entropy_threshold)\n            low_pct = (low_entropy_count / len(self.payload_entropies)) * 100\n            print(f\"\\n  Low entropy payloads (<={low_entropy_threshold} bits):\")\n            print(f\"    Count: {low_entropy_count} / {len(self.payload_entropies)} ({low_pct:.1f}%)\")\n            if low_pct > 30:\n                print(f\"    \u2139 NOTE: Many low-entropy payloads detected.\")\n                print(f\"      This may indicate repetitive/structured data or protocol overhead.\")\n\n        print(f\"\\n{'=' * 70}\")\n        print(\"  END OF REPORT\")\n        print(f\"{'=' * 70}\\n\")\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Standalone Entropy Utility Functions\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef entropy_of_file(filepath: str) -> float:\n    \"\"\"Calculate Shannon entropy of an entire file.\"\"\"\n    with open(filepath, 'rb') as f:\n        data = f.read()\n    return shannon_entropy(data)\n\n\ndef entropy_of_string(s: str) -> float:\n    \"\"\"Calculate Shannon entropy of a string.\"\"\"\n    return shannon_entropy_string(s)\n\n\ndef sliding_window_entropy(data: bytes, window_size: int = 256, step: int = 64):\n    \"\"\"\n    Compute Shannon entropy over a sliding window across data.\n    Returns list of (offset, entropy) tuples.\n    \"\"\"\n    results = []\n    for offset in range(0, len(data) - window_size + 1, step):\n        chunk = data[offset:offset + window_size]\n        ent = shannon_entropy(chunk)\n        results.append((offset, ent))