und name, CID, or SMILES\n        search_type: 'name', 'cid', or 'smiles'\n    \n    Returns:\n        SMILES string or None\n    \"\"\"\n    base_url = \"https://pubchem.ncbi.nlm.nih.gov/rest/pug/compound\"\n    \n    if search_type == \"name\":\n        url = f\"{base_url}/name/{query}/property/IsomericSMILES/JSON\"\n    elif search_type == \"cid\":\n        url = f\"{base_url}/cid/{query}/property/IsomericSMILES/JSON\"\n    elif search_type == \"smiles\":\n        # Validate SMILES by round-tripping through PubChem\n        url = f\"{base_url}/smiles/{query}/property/IsomericSMILES/JSON\"\n    else:\n        raise ValueError(f\"Unknown search_type: {search_type}\")\n    \n    try:\n        req = urllib.request.Request(url)\n        req.add_header(\"Accept\", \"application/json\")\n        with urllib.request.urlopen(req, timeout=10) as response:\n            data = json.loads(response.read().decode())\n            return data[\"PropertyTable\"][\"Properties\"][0][\"IsomericSMILES\"]\n    except Exception as e:\n        print(f\"PubChem lookup failed for '{query}': {e}\")\n        return None\n\n\ndef get_multiple_smiles_from_pubchem(names: List[str]) -> dict:\n    \"\"\"Fetch SMILES for a list of compound names.\"\"\"\n    results = {}\n    for name in names:\n        smiles = get_smiles_from_pubchem(name, search_type=\"name\")\n        if smiles:\n            results[name] = smiles\n    return results\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 2. Fingerprint Generation\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef smiles_to_mol(smiles: str) -> Optional[rdkit.Chem.rdchem.Mol]:\n    \"\"\"Convert SMILES to RDKit Mol object.\"\"\"\n    mol = Chem.MolFromSmiles(smiles)\n    if mol is None:\n        print(f\"WARNING: Could not parse SMILES: {smiles}\")\n    return mol\n\n\ndef generate_morgan_fingerprint(mol: rdkit.Chem.rdchem.Mol,\n                                 radius: int = 2,\n                                 n_bits: int = 2048) -> DataStructs.cDataStructs.ExplicitBitVect:\n    \"\"\"\n    Generate Morgan (circular) fingerprint.\n    \n    Args:\n        mol: RDKit Mol object\n        radius: fingerprint radius (2 = ECFP4, 3 = ECFP6)\n        n_bits: number of bits in fingerprint\n    \n    Returns:\n        ExplicitBitVect fingerprint\n    \"\"\"\n    return AllChem.GetMorganFingerprintAsBitVect(mol, radius, nBits=n_bits)\n\n\ndef generate_rdkit_fingerprint(mol: rdkit.Chem.rdchem.Mol,\n                                n_bits: int = 2048) -> DataStructs.cDataStructs.ExplicitBitVect:\n    \"\"\"Generate RDKit (topological) fingerprint.\"\"\"\n    return Chem.RDKFingerprint(mol, fpSize=n_bits)\n\n\ndef generate_maccs_fingerprint(mol: rdkit.Chem.rdchem.Mol) -> DataStructs.cDataStructs.ExplicitBitVect:\n    \"\"\"Generate MACCS keys (166 bits).\"\"\"\n    return rdMolDescriptors.GetMACCSKeysFingerprint(mol)\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 3. Tanimoto Similarity Computation\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef tanimoto_similarity(fp1: DataStructs.cDataStructs.ExplicitBitVect,\n                        fp2: DataStructs.cDataStructs.ExplicitBitVect) -> float:\n    \"\"\"\n    Compute Tanimoto (Jaccard) similarity between two fingerprints.\n    \n    Tanimoto = c / (a + b - c)\n    where a = bits set in fp1, b = bits set in fp2, c = common bits\n    \"\"\"\n    return DataStructs.TanimotoSimilarity(fp1, fp2)\n\n\ndef tanimoto_distance(fp1, fp2) -> float:\n    \"\"\"Tanimoto distance = 1 - Tanimoto similarity.\"\"\"\n    return 1.0 - DataStructs.TanimotoSimilarity(fp1, fp2)\n\n\ndef bulk_tanimoto_similarity(query_fp: DataStructs.cDataStructs.ExplicitBitVect,\n                              target_fps: List[DataStructs.cDataStructs.ExplicitBitVect]) -> List[float]:\n    \"\"\"Compute Tanimoto similarity of query against a list of target fingerprints.\"\"\"\n    similarities = []\n    for fp in target_fps:\n        similarities.append(DataStructs.TanimotoSimilarity(query_fp, fp))\n    return similarities\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 4. Similarity Search Engine\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nclass TanimotoSearchEngine:\n    \"\"\"\n    A simple in-memory Tanimoto similarity search engine.\n    \"\"\"\n    \n    def __init__(self, fp_type: str = \"morgan\", radius: int = 2, n_bits: int = 2048):\n        \"\"\"\n        Args:\n            fp_type: 'morgan', 'rdkit', or 'maccs'\n            radius: Morgan fingerprint radius\n            n_bits: fingerprint bit length\n        \"\"\"\n        self.fp_type = fp_type\n        self.radius = radius\n        self.n_bits = n_bits\n        self.compounds = []   # list of (name, smiles, mol, fingerprint)\n    \n    def _generate_fp(self, mol):\n        if self.fp_type == \"morgan\":\n            return generate_morgan_fingerprint(mol, self.radius, self.n_bits)\n        elif self.fp_type == \"rdkit\":\n            return generate_rdkit_fingerprint(mol, self.n_bits)\n        elif self.fp_type == \"maccs\":\n            return generate_maccs_fingerprint(mol)\n        else:\n            raise ValueError(f\"Unknown fingerprint type: {self.fp_type}\")\n    \n    def add_compound(self, name: str, smiles: str) -> bool:\n        \"\"\"Add a compound to the search database.\"\"\"\n        mol = smiles_to_mol(smiles)\n        if mol is None:\n            return False\n        fp = self._generate_fp(mol)\n        self.compounds.append((name, smiles, mol, fp))\n        return True\n    \n    def add_from_pubchem(self, name: str) -> bool:\n        \"\"\"Fetch SMILES from PubChem and add compound.\"\"\"\n        smiles = get_smiles_from_pubchem(name, search_type=\"name\")\n        if smiles is None:\n            return False\n        return self.add_compound(name, smiles)\n    \n    def load_smiles_list(self, smiles_list: List[Tuple[str, str]]):\n        \"\"\"\n        Load a list of (name, smiles) tuples.\n        \"\"\"\n        for name, smiles in smiles_list:\n            self.add_compound(name, smiles)\n    \n    def search(self, query_smiles: str, threshold: float = 0.0,\n               top_n: int = 10) -> List[Tuple[str, str, float]]:\n        \"\"\"\n        Search for compounds similar to query.\n        \n        Args:\n            query_smiles: SMILES of query molecule\n            threshold: minimum Tanimoto similarity (0.0 to 1.0)\n            top_n: return top N results\n        \n        Returns:\n            List of (name, smiles, similarity) tuples, sorted by descending similarity\n        \"\"\"\n        query_mol = smiles_to_mol(query_smiles)\n        if query_mol is None:\n            raise ValueError(f\"Invalid query SMILES: {query_smiles}\")\n        \n        query_fp = self._generate_fp(query_mol)\n        \n        results = []\n        for name, smiles, mol, fp in self.compounds:\n            sim = DataStructs.TanimotoSimilarity(query_fp, fp)\n            if sim >= threshold:\n                results.append((name, smiles, sim))\n        \n        # Sort by descending similarity\n        results.sort(key=lambda x: x[2], reverse=True)\n        return results[:top_n]\n    \n    def search_by_name(self, query_name: str, threshold: float = 0.0,\n                       top_n: int = 10) -> List[Tuple[str, str, float]]:\n        \"\"\"Search using a PubChem compound name as query.\"\"\"\n        smiles = get_smiles_from_pubchem(query_name, search_type=\"name\")\n        if smiles is None:\n            raise ValueError(f\"Could not find compound: {query_name}\")\n        return self.search(smiles, threshold, top_n)\n    \n    def similarity_matrix(self) -> np.ndarray:\n        \"\"\"Compute full pairwise Tanimoto similarity matrix.\"\"\"\n        n = len(self.compounds)\n        matrix = np.zeros((n, n))\n        for i in range(n):\n            for j in range(i, n):\n                sim = DataStructs.TanimotoSimilarity(\n                    self.compounds[i][3], self.compounds[j][3]\n                )\n                matrix[i][j] = sim\n                matrix[j][i] = sim\n        return matrix\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 5. Demo / Main\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef main():\n    print(\"=\" * 60)\n    print(\"RDKit Tanimoto Similarity Search Demo\")\n    print(\"=\" * 60)\n    \n    # --- Example compound database (SMILES from PubChem) ---\n    compound_db = [\n        (\"Aspirin\",        \"CC(=O)Oc1ccccc1C(O)=O\"),\n        (\"Ibuprofen\",      \"CC(C)Cc1ccc(cc1)C(C)C(O)=O\"),\n        (\"Acetaminophen\",  \"CC(=O)Nc1ccc(O)cc1\"),\n        (\"Naproxen\",       \"COc1cccc2c1CC(C)C2C(O)=O\"),\n        (\"Caffeine\",       \"Cn1c(=O)c2c(ncn2C)n(C)c1=O\"),\n        (\"Benzene\",        \"c1ccccc1\"),\n        (\"Phenol\",         \"Oc1ccccc1\"),\n        (\"Toluene\",        \"Cc1ccccc1\"),\n        (\"Aniline\",        \"Nc1ccccc1\"),\n        (\"Salicylic acid\", \"OC(=O)c1ccccc1O\"),\n        (\"Morphine\",       \"CN1CCC23C4C1CC5=C2C(=C3)OC(O)=C3C4\"),  # simplified\n        (\"Nicotine\",       \"CN1CCCC1c1cccnc1\"),\n        (\"Ethanol\",        \"CCO\"),\n        (\"Methanol\",       \"CO\"),\n        (\"Glucose\",        \"OC[C@H]1OC(O)[C@H](O)[C@@H](O)[C@@H]1O\"),\n    ]\n    \n    # --- Initialize search engine ---\n    engine = TanimotoSearchEngine(fp_type=\"morgan\", radius=2, n_bits=2048)\n    \n    print(f\"\\nLoading {len(compound_db)} compounds into search engine...\")\n    loaded = 0\n    for name, smiles in compound_db:\n        if engine.add_compound(name, smiles):\n            loaded += 1\n            print(f\"  \u2713 {name}: {smiles}\")\n        else:\n            print(f\"  \u2717 {name}: FAILED to parse\")\n    print(f\"\\nLoaded {loaded}/{len(compound_db)} compounds.\\n\")\n    \n    # --- Similarity Search ---\n    query_name = \"Aspirin\"\n    query_smiles = \"CC(=O)Oc1ccccc1C(O)=O\"\n    threshold = 0.1\n    \n    print(\"-\" * 60)\n    print(f\"Query: {query_name}\")\n    print(f\"SMILES: {query_smiles}\")\n    print(f\"Threshold: Tanimoto >= {threshold}\")\n    print(\"-\" * 60)\n    \n    results = engine.search(query_smiles, threshold=threshold, top_n=15)\n    \n    print(f\"\\n{'Rank':<5} {'Compound':<20} {'Tanimoto':<10} {'SMILES'}\")\n    print(\"-\" * 80)\n    for i, (name, smiles, sim) in enumerate(results, 1):\n        marker = \" <-- query\" if name == query_name else \"\"\n        print(f\"{i:<5} {name:<20} {sim:<10.4f} {smiles}{marker}\")\n    \n    # --- Pairwise similarity matrix (subset) ---\n    print(\"\\n\" + \"=\" * 60)\n    print(\"Pairwise Tanimoto Similarity Matrix (first 8 compounds)\")\n    print(\"=\" * 60)\n    \n    subset_engine = TanimotoSearchEngine(fp_type=\"morgan\", radius=2, n_bits=2048)\n    for name, smiles in compound_db[:8]:\n        subset_engine.add_compound(name, smiles)\n    \n    matrix = subset_engine.similarity_matrix()\n    names = [c[0] for c in subset_engine.compounds]\n    \n    # Print header\n    header = f\"{'':>15}\" + \"\".join(f\"{n[:8]:>10}\" for n in names)\n    print(header)\n    for i, name in enumerate(names):\n        row = f\"{name:>15}\" + \"\".join(f\"{matrix[i][j]:>10.3f}\" for j in range(len(names)))\n        print(row)\n    \n    # --- Demonstrate different fingerprint types ---\n    print(\"\\n\" + \"=\" * 60)\n    print(\"Fingerprint Type Comparison: Aspirin vs Salicylic acid\")\n    print(\"=\" * 60)\n    \n    aspirin_mol = Chem.MolFromSmiles(\"CC(=O)Oc1ccccc1C(O)=O\")\n    salicylic_mol = Chem.MolFromSmiles(\"OC(=O)c1ccccc1O\")\n    \n    for fp_name, fp_func in [\n        (\"Morgan (ECFP4, r=2, 2048 bits)\",\n         lambda m: generate_morgan_fingerprint(m, radius=2, n_bits=2048)),\n        (\"Morgan (ECFP6, r=3, 2048 bits)\",\n         lambda m: generate_morgan_fingerprint(m, radius=3, n_bits=2048)),\n        (\"RDKit topological (2048 bits)\",\n         lambda m: generate_rdkit_fingerprint(m, n_bits=2048)),\n        (\"MACCS keys (166 bits)\",\n         lambda m: generate_maccs_fingerprint(m)),\n    ]:\n        fp1 = fp_func(aspirin_mol)\n        fp2 = fp_func(salicylic_mol)\n        sim = DataStructs.TanimotoSimilarity(fp1, fp2)\n        print(f\"  {fp_name:<40} Tanim