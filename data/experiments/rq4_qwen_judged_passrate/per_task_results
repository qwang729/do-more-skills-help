{"task": "dapt-intrusion-detection", "condition": "no_skill", "repeat": 0, "skill_ids": [], "retrieval_correct": null, "judged_pass": false, "judged_score": 2, "judge_reason": "Agent's solution provides comprehensive entropy and traffic analysis but fails to generate the required network_stats.csv file as expected by the verifier.", "solver_tokens": 5400, "judge_tokens": 4869, "solution_text": "# PCAP Packet Parsing, Network Traffic Analysis & Shannon Entropy Calculation\n\n## Prerequisites\n\n```bash\npip install scapy\n```\n\n## Complete Solution\n\n```python\n#!/usr/bin/env python3\n\"\"\"\nPCAP Packet Parser, Network Traffic Analyzer, and Shannon Entropy Calculator.\nParses a pcap file, extracts network traffic statistics, and computes\nShannon entropy on packet payloads to detect encrypted/compressed traffic.\n\"\"\"\n\nimport sys\nimport math\nimport os\nfrom collections import Counter, defaultdict\nfrom datetime import datetime\n\ntry:\n    from scapy.all import rdpcap, IP, TCP, UDP, ICMP, DNS, Raw, Ether\nexcept ImportError:\n    print(\"Error: scapy is required. Install with: pip install scapy\")\n    sys.exit(1)\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Shannon Entropy Calculation\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef shannon_entropy(data: bytes) -> float:\n    \"\"\"\n    Calculate Shannon entropy of a byte sequence.\n    H = -\u03a3 p(x) * log2(p(x)) for each unique byte x.\n    Returns entropy in bits (0.0 to 8.0 for byte data).\n    \"\"\"\n    if not data:\n        return 0.0\n\n    length = len(data)\n    counts = Counter(data)\n    entropy = 0.0\n\n    for count in counts.values():\n        probability = count / length\n        if probability > 0:\n            entropy -= probability * math.log2(probability)\n\n    return entropy\n\n\ndef shannon_entropy_string(s: str) -> float:\n    \"\"\"Calculate Shannon entropy of a string.\"\"\"\n    return shannon_entropy(s.encode('utf-8', errors='replace'))\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# PCAP Parser & Traffic Analyzer\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nclass TrafficAnalyzer:\n    def __init__(self, pcap_file: str):\n        self.pcap_file = pcap_file\n        self.packets = []\n        self.total_packets = 0\n        self.total_bytes = 0\n\n        # Protocol counters\n        self.protocol_counts = Counter()\n        self.src_ip_counts = Counter()\n        self.dst_ip_counts = Counter()\n        self.src_port_counts = Counter()\n        self.dst_port_counts = Counter()\n        self.conversations = Counter()  # (src_ip, dst_ip) -> count\n\n        # Per-packet entropy\n        self.packet_entropies = []\n        self.payload_entropies = []\n\n        # Time analysis\n        self.timestamps = []\n\n        # Size distribution\n        self.packet_sizes = []\n\n        # Per-protocol entropy\n        self.protocol_entropies = defaultdict(list)\n\n    def parse(self):\n        \"\"\"Read and parse the pcap file.\"\"\"\n        print(f\"[*] Reading pcap file: {self.pcap_file}\")\n        if not os.path.exists(self.pcap_file):\n            print(f\"[!] File not found: {self.pcap_file}\")\n            sys.exit(1)\n\n        self.packets = rdpcap(self.pcap_file)\n        self.total_packets = len(self.packets)\n        print(f\"[*] Loaded {self.total_packets} packets\")\n\n    def analyze(self):\n        \"\"\"Perform full traffic analysis.\"\"\"\n        print(\"[*] Analyzing traffic...\")\n\n        for i, pkt in enumerate(self.packets):\n            pkt_len = len(pkt)\n            self.total_bytes += pkt_len\n            self.packet_sizes.append(pkt_len)\n\n            # Timestamp\n            if pkt.time:\n                self.timestamps.append(float(pkt.time))\n\n            # Full packet entropy (raw bytes)\n            raw_bytes = bytes(pkt)\n            full_entropy = shannon_entropy(raw_bytes)\n            self.packet_entropies.append(full_entropy)\n\n            # Protocol detection and payload entropy\n            if pkt.haslayer(IP):\n                ip_layer = pkt[IP]\n                src_ip = ip_layer.src\n                dst_ip = ip_layer.dst\n                self.src_ip_counts[src_ip] += 1\n                self.dst_ip_counts[dst_ip] += 1\n                self.conversations[(src_ip, dst_ip)] += 1\n\n                if pkt.haslayer(TCP):\n                    tcp_layer = pkt[TCP]\n                    self.protocol_counts['TCP'] += 1\n                    self.src_port_counts[tcp_layer.sport] += 1\n                    self.dst_port_counts[tcp_layer.dport] += 1\n\n                    # Payload entropy\n                    if pkt.haslayer(Raw):\n                        payload = bytes(pkt[Raw].load)\n                        payload_entropy = shannon_entropy(payload)\n                        self.payload_entropies.append(payload_entropy)\n                        self.protocol_entropies['TCP'].append(payload_entropy)\n\n                elif pkt.haslayer(UDP):\n                    udp_layer = pkt[UDP]\n                    self.protocol_counts['UDP'] += 1\n                    self.src_port_counts[udp_layer.sport] += 1\n                    self.dst_port_counts[udp_layer.dport] += 1\n\n                    if pkt.haslayer(DNS):\n                        self.protocol_counts['DNS'] += 1\n\n                    if pkt.haslayer(Raw):\n                        payload = bytes(pkt[Raw].load)\n                        payload_entropy = shannon_entropy(payload)\n                        self.payload_entropies.append(payload_entropy)\n                        self.protocol_entropies['UDP'].append(payload_entropy)\n\n                elif pkt.haslayer(ICMP):\n                    self.protocol_counts['ICMP'] += 1\n                    if pkt.haslayer(Raw):\n                        payload = bytes(pkt[Raw].load)\n                        payload_entropy = shannon_entropy(payload)\n                        self.payload_entropies.append(payload_entropy)\n                        self.protocol_entropies['ICMP'].append(payload_entropy)\n\n                else:\n                    self.protocol_counts['Other IP'] += 1\n            else:\n                self.protocol_counts['Non-IP'] += 1\n\n        print(\"[*] Analysis complete.\")\n\n    def report(self):\n        \"\"\"Print comprehensive traffic analysis report.\"\"\"\n        print(\"\\n\" + \"=\" * 70)\n        print(\"  NETWORK TRAFFIC ANALYSIS REPORT\")\n        print(\"=\" * 70)\n\n        # \u2500\u2500 General Statistics \u2500\u2500\n        print(f\"\\n{'\u2500' * 40}\")\n        print(\"  GENERAL STATISTICS\")\n        print(f\"{'\u2500' * 40}\")\n        print(f\"  File:              {self.pcap_file}\")\n        print(f\"  Total Packets:     {self.total_packets}\")\n        print(f\"  Total Bytes:       {self.total_bytes:,}\")\n        print(f\"  Avg Packet Size:   {self.total_bytes / max(self.total_packets, 1):.1f} bytes\")\n\n        if self.packet_sizes:\n            print(f\"  Min Packet Size:   {min(self.packet_sizes)} bytes\")\n            print(f\"  Max Packet Size:   {max(self.packet_sizes)} bytes\")\n\n        if self.timestamps and len(self.timestamps) > 1:\n            duration = self.timestamps[-1] - self.timestamps[0]\n            print(f\"  Capture Duration:  {duration:.3f} seconds\")\n            if duration > 0:\n                print(f\"  Avg Pkt Rate:      {self.total_packets / duration:.1f} pkt/s\")\n                print(f\"  Avg Throughput:    {(self.total_bytes / duration) / 1024:.2f} KB/s\")\n\n        # \u2500\u2500 Protocol Distribution \u2500\u2500\n        print(f\"\\n{'\u2500' * 40}\")\n        print(\"  PROTOCOL DISTRIBUTION\")\n        print(f\"{'\u2500' * 40}\")\n        for proto, count in self.protocol_counts.most_common():\n            pct = (count / self.total_packets) * 100\n            bar = \"\u2588\" * int(pct / 2)\n            print(f\"  {proto:<12} {count:>8}  ({pct:5.1f}%)  {bar}\")\n\n        # \u2500\u2500 Top Talkers (Source IPs) \u2500\u2500\n        print(f\"\\n{'\u2500' * 40}\")\n        print(\"  TOP 10 SOURCE IPs\")\n        print(f\"{'\u2500' * 40}\")\n        for ip, count in self.src_ip_counts.most_common(10):\n            pct = (count / self.total_packets) * 100\n            print(f\"  {ip:<20} {count:>8} packets  ({pct:.1f}%)\")\n\n        # \u2500\u2500 Top Destinations \u2500\u2500\n        print(f\"\\n{'\u2500' * 40}\")\n        print(\"  TOP 10 DESTINATION IPs\")\n        print(f\"{'\u2500' * 40}\")\n        for ip, count in self.dst_ip_counts.most_common(10):\n            pct = (count / self.total_packets) * 100\n            print(f\"  {ip:<20} {count:>8} packets  ({pct:.1f}%)\")\n\n        # \u2500\u2500 Top Ports \u2500\u2500\n        print(f\"\\n{'\u2500' * 40}\")\n        print(\"  TOP 10 DESTINATION PORTS\")\n        print(f\"{'\u2500' * 40}\")\n        well_known = {80: 'HTTP', 443: 'HTTPS', 53: 'DNS', 22: 'SSH',\n                      21: 'FTP', 25: 'SMTP', 110: 'POP3', 143: 'IMAP',\n                      3306: 'MySQL', 5432: 'PostgreSQL', 8080: 'HTTP-Alt',\n                      8443: 'HTTPS-Alt', 3389: 'RDP', 445: 'SMB'}\n        for port, count in self.dst_port_counts.most_common(10):\n            service = well_known.get(port, '')\n            label = f\"{port} ({service})\" if service else str(port)\n            print(f\"  {label:<25} {count:>8} packets\")\n\n        # \u2500\u2500 Top Conversations \u2500\u2500\n        print(f\"\\n{'\u2500' * 40}\")\n        print(\"  TOP 10 CONVERSATIONS (src -> dst)\")\n        print(f\"{'\u2500' * 40}\")\n        for (src, dst), count in self.conversations.most_common(10):\n            print(f\"  {src} -> {dst}  :  {count} packets\")\n\n        # \u2500\u2500 Shannon Entropy Analysis \u2500\u2500\n        print(f\"\\n{'\u2500' * 40}\")\n        print(\"  SHANNON ENTROPY ANALYSIS\")\n        print(f\"{'\u2500' * 40}\")\n\n        if self.packet_entropies:\n            avg_full = sum(self.packet_entropies) / len(self.packet_entropies)\n            min_full = min(self.packet_entropies)\n            max_full = max(self.packet_entropies)\n            print(f\"\\n  Full Packet Entropy (all packets):\")\n            print(f\"    Average:  {avg_full:.4f} bits\")\n            print(f\"    Min:      {min_full:.4f} bits\")\n            print(f\"    Max:      {max_full:.4f} bits\")\n\n        if self.payload_entropies:\n            avg_payload = sum(self.payload_entropies) / len(self.payload_entropies)\n            min_payload = min(self.payload_entropies)\n            max_payload = max(self.payload_entropies)\n            print(f\"\\n  Payload Entropy (packets with data):\")\n            print(f\"    Average:  {avg_payload:.4f} bits\")\n            print(f\"    Min:      {min_payload:.4f} bits\")\n            print(f\"    Max:      {max_payload:.4f} bits\")\n            print(f\"    Samples:  {len(self.payload_entropies)}\")\n\n            # Entropy distribution buckets\n            print(f\"\\n  Payload Entropy Distribution:\")\n            buckets = [(0, 2), (2, 4), (4, 5), (5, 6), (6, 7), (7, 8.01)]\n            for low, h