beta_r = np.radians(self.beta)\n        gamma_r = np.radians(self.gamma)\n        cos_alpha = np.cos(alpha_r)\n        cos_beta = np.cos(beta_r)\n        cos_gamma = np.cos(gamma_r)\n        vol = self.a * self.b * self.c * np.sqrt(\n            1 - cos_alpha**2 - cos_beta**2 - cos_gamma**2\n            + 2 * cos_alpha * cos_beta * cos_gamma\n        )\n        return round(vol, 4)\n\n    def get_metric_tensor(self) -> np.ndarray:\n        \"\"\"Return the metric tensor G for the unit cell.\"\"\"\n        alpha_r = np.radians(self.alpha)\n        beta_r = np.radians(self.beta)\n        gamma_r = np.radians(self.gamma)\n        G = np.array([\n            [self.a**2,\n             self.a * self.b * np.cos(gamma_r),\n             self.a * self.c * np.cos(beta_r)],\n            [self.a * self.b * np.cos(gamma_r),\n             self.b**2,\n             self.b * self.c * np.cos(alpha_r)],\n            [self.a * self.c * np.cos(beta_r),\n             self.b * self.c * np.cos(alpha_r),\n             self.c**2]\n        ])\n        return G\n\n\n@dataclass\nclass WyckoffPosition:\n    \"\"\"Represents a Wyckoff position.\"\"\"\n    letter: str\n    multiplicity: int\n    site_symmetry: str\n    coordinates: List[str]\n    atoms: List[Atom] = field(default_factory=list)\n\n\n@dataclass\nclass SpaceGroupInfo:\n    \"\"\"Space group information.\"\"\"\n    number: int\n    symbol: str\n    hall_symbol: str = \"\"\n    crystal_system: str = \"\"\n    point_group: str = \"\"\n    symmetry_operations: List[str] = field(default_factory=list)\n\n\n@dataclass\nclass CIFData:\n    \"\"\"Complete parsed CIF data.\"\"\"\n    filename: str = \"\"\n    compound_name: str = \"\"\n    chemical_formula: str = \"\"\n    unit_cell: Optional[UnitCell] = None\n    space_group: Optional[SpaceGroupInfo] = None\n    atoms: List[Atom] = field(default_factory=list)\n    wyckoff_positions: Dict[str, WyckoffPosition] = field(default_factory=dict)\n    raw_data: Dict[str, str] = field(default_factory=dict)\n\n\n# =============================================================================\n# SPACE GROUP DATABASE (subset of 230 space groups)\n# =============================================================================\n\nSPACE_GROUP_DATA = {\n    1:   {\"symbol\": \"P1\",       \"hall\": \"P 1\",        \"system\": \"triclinic\",  \"point_group\": \"1\"},\n    2:   {\"symbol\": \"P-1\",      \"hall\": \"-P 1\",       \"system\": \"triclinic\",  \"point_group\": \"-1\"},\n    3:   {\"symbol\": \"P2\",       \"hall\": \"P 2y\",       \"system\": \"monoclinic\", \"point_group\": \"2\"},\n    4:   {\"symbol\": \"P21\",      \"hall\": \"P 2yb\",      \"system\": \"monoclinic\", \"point_group\": \"2\"},\n    5:   {\"symbol\": \"C2\",       \"hall\": \"C 2y\",       \"system\": \"monoclinic\", \"point_group\": \"2\"},\n    6:   {\"symbol\": \"Pm\",       \"hall\": \"P -2y\",      \"system\": \"monoclinic\", \"point_group\": \"m\"},\n    7:   {\"symbol\": \"Pc\",       \"hall\": \"P -2yc\",     \"system\": \"monoclinic\", \"point_group\": \"m\"},\n    8:   {\"symbol\": \"Cm\",       \"hall\": \"C -2y\",      \"system\": \"monoclinic\", \"point_group\": \"m\"},\n    9:   {\"symbol\": \"Cc\",       \"hall\": \"C -2yc\",     \"system\": \"monoclinic\", \"point_group\": \"m\"},\n    10:  {\"symbol\": \"P2/m\",     \"hall\": \"-P 2y\",      \"system\": \"monoclinic\", \"point_group\": \"2/m\"},\n    11:  {\"symbol\": \"P21/m\",    \"hall\": \"-P 2yb\",     \"system\": \"monoclinic\", \"point_group\": \"2/m\"},\n    12:  {\"symbol\": \"C2/m\",     \"hall\": \"-C 2y\",      \"system\": \"monoclinic\", \"point_group\": \"2/m\"},\n    13:  {\"symbol\": \"P2/c\",     \"hall\": \"-P 2yc\",     \"system\": \"monoclinic\", \"point_group\": \"2/m\"},\n    14:  {\"symbol\": \"P21/c\",    \"hall\": \"-P 2ybc\",    \"system\": \"monoclinic\", \"point_group\": \"2/m\"},\n    15:  {\"symbol\": \"C2/c\",     \"hall\": \"-C 2yc\",     \"system\": \"monoclinic\", \"point_group\": \"2/m\"},