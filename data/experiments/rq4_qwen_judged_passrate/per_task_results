elf.options})\")\n\n    def to_dict(self) -> dict:\n        return {\n            \"name\": self.name,\n            \"type\": self.field_type,\n            \"value\": self.value,\n            \"options\": self.options,\n            \"readonly\": self.is_readonly,\n            \"required\": self.is_required,\n            \"max_length\": self.max_length,\n        }\n\n\nclass CourtFormFiller:\n    \"\"\"\n    Main class for filling PDF court forms.\n    Supports AcroForm text fields, checkboxes, radio buttons, and dropdowns.\n    \"\"\"\n\n    # Field type mapping from PDF internal names\n    FIELD_TYPE_MAP = {\n        \"/Tx\": \"text\",\n        \"/Btn\": \"button\",  # checkbox or radio button\n        \"/Ch\": \"choice\",   # dropdown/listbox\n        \"/Sig\": \"signature\",\n    }\n\n    def __init__(self, template_path: str):\n        self.template_path = template_path\n        self.reader = PdfReader(template_path)\n        self.writer = PdfWriter()\n        self.writer.append_pages_from_reader(self.reader)\n        self.fields = self._discover_fields()\n\n    def _discover_fields(self) -> Dict[str, PDFFormField]:\n        \"\"\"Discover all fillable fields in the PDF.\"\"\"\n        fields = {}\n        if not self.reader.get_fields():\n            return fields\n\n        for field_name, field_obj in self.reader.get_fields().items():\n            field_type_raw = field_obj.get(\"/FT\", \"\")\n            field_type = self.FIELD_TYPE_MAP.get(str(field_type_raw), \"unknown\")\n\n            # Get current value\n            value = field_obj.get(\"/V\")\n            if value is not None:\n                value = str(value)\n\n            # Get options for choice fields\n            options = []\n            opt = field_obj.get(\"/Opt\")\n            if opt:\n                for item in opt:\n                    if isinstance(item, list):\n                        options.append(str(item[1]) if len(item) > 1 else str(item[0]))\n                    else:\n                        options.append(str(item))\n\n            # Check flags\n            ff = field_obj.get(\"/Ff\", 0)\n            ff_int = int(ff) if ff else 0\n            is_readonly = bool(ff_int & 1)\n            is_required = bool(ff_int & 2)\n\n            # For buttons, determine if checkbox or radio\n            if field_type == \"button\":\n                if ff_int & (1 << 15):  # Radio flag\n                    field_type = \"radio\"\n                else:\n                    field_type = \"checkbox\"\n\n            # Max length for text fields\n            max_length = field_obj.get(\"/MaxLen\")\n            if max_length is not None:\n                max_length = int(max_length)\n\n            fields[field_name] = PDFFormField(\n                name=field_name,\n                field_type=field_type,\n                value=value,\n                options=options,\n                is_readonly=is_readonly,\n                is_required=is_required,\n                max_length=max_length,\n            )\n\n        return fields\n\n    def get_fields(self) -> Dict[str, PDFFormField]:\n        \"\"\"Return all discovered fields.\"\"\"\n        return self.fields\n\n    def get_field_names(self) -> List[str]:\n        \"\"\"Return list of all field names.\"\"\"\n        return list(self.fields.keys())\n\n    def export_fields(self, output_path: str):\n        \"\"\"Export field definitions to JSON for mapping.\"\"\"\n        data = {name: field.to_dict() for name, field in self.fields.items()}\n        with open(output_path, \"w\", encoding=\"utf-8\") as f:\n            json.dump(data, f, indent=2, ensure_ascii=False)\n        print(f\"Fields exported to {output_path}\")\n\n    def fill(self, data: Dict[str, Any], truncate: bool = True) -> \"CourtFormFiller\":\n        \"\"\"\n        Fill form fields with provided data.\n\n        Args:\n            data: Dictionary mapping field names to values.\n            truncate: If True, truncate text to max_length.\n        \"\"\"\n        for field_name, value in data.items():\n            if field_name not in self.fields:\n                print(f\"  WARNING: Field '{field_name}' not found in form, skipping.\")\n                continue\n\n            field = self.fields[field_name]\n\n            if field.is_readonly:\n                print(f\"  WARNING: Field '{field_name}' is read-only, skipping.\")\n                continue\n\n            self._set_field_value(field_name, value, field, truncate)\n\n        return self\n\n    def _set_field_value(self, field_name: str, value: Any,\n                         field: PDFFormField, truncate: bool):\n        \"\"\"Set a single field's value in the PDF writer.\"\"\"\n        # Update the writer's field\n        for page_num in range(len(self.writer.pages)):\n            page = self.writer.pages[page_num]\n            if \"/Annots\" not in page:\n                continue\n            annots = page[\"/Annots\"]\n            for annot_ref in annots:\n                annot = annot_ref.get_object()\n                if annot.get(\"/T\") == field_name or self._get_full_field_name(annot) == field_name:\n                    self._write_field_value(annot, value, field, truncate)\n\n        # Also update via the AcroForm\n        if \"/AcroForm\" in self.writer._root_object:\n            acroform = self.writer._root_object[\"/AcroForm\"]\n            if \"/Fields\" in acroform:\n                for field_ref in acroform[\"/Fields\"]:\n                    field_obj = field_ref.get_object()\n                    fname = self._get_full_field_name(field_obj)\n                    if fname == field_name or field_obj.get(\"/T\") == field_name:\n                        self._write_field_value(field_obj, value, field, truncate)\n\n    def _get_full_field_name(self, field_obj) -> str:\n        \"\"\"Get the fully qualified field name by walking up the parent chain.\"\"\"\n        parts = []\n        current = field_obj\n        while current is not None: