retrained='{PRETRAINED}')...\")\nif MODEL_NAME == \"PhaseNet\":\n    model = sbm.PhaseNet.from_pretrained(PRETRAINED)\nelif MODEL_NAME == \"EQTransformer\":\n    model = sbm.EQTransformer.from_pretrained(PRETRAINED)\nelse:\n    raise ValueError(f\"Unknown model: {MODEL_NAME}\")\n\nmodel.eval()\nprint(f\"Model loaded. Sampling rate required: {model.sampling_rate} Hz\")\n\n# \u2500\u2500\u2500 3. Read mseed waveform with ObsPy \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nprint(f\"Reading {MSEED_FILE}...\")\nstream = obspy.read(MSEED_FILE)\nprint(f\"Stream: {stream}\")\nprint(f\"  Traces: {len(stream)}\")\nfor tr in stream:\n    print(f\"    {tr.stats.network}.{tr.stats.station}.{tr.stats.location}.{tr.stats.channel} \"\n          f\"| {tr.stats.npts} samples @ {tr.stats.sampling_rate} Hz \"\n          f\"| {tr.stats.starttime} \u2013 {tr.stats.endtime}\")\n\n# \u2500\u2500\u2500 4. Preprocess: resample & ensure correct channels \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# SeisBench models expect 3-component (ENZ or ZNE) data at a specific sampling rate.\n# Resample if needed.\ntarget_sr = model.sampling_rate\nfor tr in stream:\n    if tr.stats.sampling_rate != target_sr:\n        print(f\"  Resampling {tr.id} from {tr.stats.sampling_rate} \u2192 {target_sr} Hz\")\n        tr.resample(target_sr)\n\n# Sort channels to ensure consistent ordering (Z, N, E)\nstream.sort(keys=[\"channel\"])\n\n# \u2500\u2500\u2500 5. Annotate the waveform (run the model) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nprint(\"Running model annotation...\")\n# model.annotate returns an ObsPy Stream with probability traces for P and S\nannotations = model.annotate(stream, stride=64)  # stride depends on model\nprint(f\"Annotation stream: {annotations}\")\n\n# \u2500\u2500\u2500 6. Extract picks from annotations \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nprint(\"Extracting picks...\")\npicks = model.pick(\n    annotations,\n    P_threshold=P_PICK_THRESHOLD,\n    S_threshold=S_PICK_THRESHOLD,\n)\nprint(f\"Found {len(picks)} picks.\")\n\n# \u2500\u2500\u2500 7. Display and save picks \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nprint(\"\\n\" + \"=\" * 70)\nprint(f\"{'Phase':<8} {'Trace':<20} {'Pick Time (UTC)':<30} {'Confidence':<12}\")\nprint(\"=\" * 70)\n\npicks_list = []\nfor pick in picks:\n    phase = pick.get(\"phase\", \"?\")\n    trace_id = pick.get(\"trace_id\", \"?\")\n    peak_time = pick.get(\"peak_time\", None)\n    peak_value = pick.get(\"peak_value\", 0.0)\n\n    if peak_time is not None:\n        if isinstance(peak_time, (int, float, np.floating, np.integer)):\n            # Convert sample index to UTCDateTime\n            peak_time_utc = stream[0].stats.starttime + peak_time / target_sr\n        else:\n            peak_time_utc = peak_time\n    else:\n        peak_time_utc = \"N/A\"\n\n    print(f\"{phase:<8} {trace_id:<20} {str(peak_time_utc):<30} {peak_value:.4f}\")\n\n    picks_list.append({\n        \"phase\": phase,\n        \"trace_id\": trace_id,\n        \"peak_time_utc\": str(peak_time_utc),\n        \"peak_value\": float(peak_value),\n        \"onset_time_utc\": str(pick.get(\"onset_time\", \"N/A\")),\n    })\n\n# Save to JSON\nwith open(OUTPUT_JSON, \"w\") as f:\n    json.dump(picks_list, f, indent=2, default=str)\nprint(f\"\\nPicks saved to {OUTPUT_JSON}\")\n\n# \u2500\u2500\u2500 8. (Optional) Plot results \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ntry:\n    import matplotlib\n    matplotlib.use(\"Agg\")\n    import matplotlib.pyplot as plt\n\n    fig, axes = plt.subplots(len(stream) + len(annotations), 1,\n                             figsize=(14, 3 * (len(stream) + len(annotations))),\n                             sharex=True)\n\n    # Plot raw waveforms\n    for i, tr in enumerate(stream):\n        times = tr.times(\"matplotlib\")\n        axes[i].plot(times, tr.data, \"k\", linewidth=0.5)\n        axes[i].set_ylabel(f\"{tr.id}\\n{tr.stats.channel}\")\n        axes[i].grid(True, alpha=0.3)\n\n        # Overlay picks on corresponding waveform\n        for p in picks_list:\n            if p[\"trace_id\"] in tr.id or tr.id in p[\"trace_id\"]:\n                pt = obspy.UTCDateTime(p[\"peak_time_utc\"])\n                axes[i].axvline(pt.matplotlib_date, color=\"red\" if p[\"phase\"] == \"P\" else \"blue\",\n                                linestyle=\"--\", alpha=0.7, label=p[\"phase\"])\n\n    # Plot annotation probabilities\n    for j, tr in enumerate(annotations):\n        idx = len(stream) + j\n        times = tr.times(\"matplotlib\")\n        color = \"red\" if \"P\" in tr.stats.channel else \"blue\"\n        axes[idx].plot(times, tr.data, color=color, linewidth=0.8)\n        axes[idx].set_ylabel(f\"{tr.id}\")\n        axes[idx].set_ylim(-0.05, 1.05)\n        axes[idx].axhline(P_PICK_THRESHOLD if \"P\" in tr.stats.channel else S_PICK_THRESHOLD,\n                          color=\"gray\", linestyle=\":\", alpha=0.5)\n        axes[idx].grid(True, alpha=0.3)\n\n    axes[-1].set_xlabel(\"Time\")\n    fig.suptitle(f\"SeisBench {MODEL_NAME} Phase Picks\", fontsize=14)\n    plt.tight_layout()\n    plt.savefig(\"picks_plot.png\", dpi=150)\n    print(\"Plot saved to picks_plot.png\")\nexcept Exception as e:\n    print(f\"Plotting skipped: {e}\")\n\nprint(\"\\nDone.\")\n```\n\n## Quick-Start Minimal Example\n\nIf you just want the bare minimum to get picks from an mseed file:\n\n```python\nimport obspy\nimport seisbench.models as sbm\n\n# Load model\nmodel = sbm.PhaseNet.from_pretrained(\"original\")\n\n# Read data\nstream = obspy.read(\"waveform.mseed\")\n\n# Resample to model's expected rate\nfor tr in stream:\n    tr.resample(model.sampling_rate)\n\n# Annotate and pick\nannotations = model.annotate(stream)\npicks = model.pick(annotations, P_threshold=0.3, S_threshold=0.3)\n\nfor p in picks:\n    print(p)\n```\n\n## Key Notes\n\n| Aspect | Detail |\n|--------|--------|\n| **Models** | `PhaseNet` (faster, good general picker) or `EQTransformer` (attention-based, often higher accuracy) |\n| **Input** | 3-component mseed (BHZ, BHN, BHE or similar); SeisBench handles ENZ conversion internally |\n| **Sampling rate** | Models expect 100 Hz by default; the script resamples automatically |\n| **Output** | P and S arrival times with confidence scores, saved as JSON |\n| **Pretrained weights** | `\"original\"` uses the weights from the original published model; other options like `\"ethz\"`, `\"geofon\"`, `\"iquique\"` are region-specific |", "solver_finish_reason": "stop"}
