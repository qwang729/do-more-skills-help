\n    Iy[1:-1, :] = (image[2:, :] - image[:-2, :]) / 2.0\n    return Ix, Iy\n\ndef harris_corners(image, k=0.04, threshold=0.01, max_corners=500):\n    \"\"\"Detect Harris corner features.\"\"\"\n    image = image.astype(np.float64)\n    Ix, Iy = compute_gradients(image)\n\n    # Structure tensor components (smoothed)\n    Ixx = Ix * Ix\n    Iyy = Iy * Iy\n    Ixy = Ix * Iy\n\n    # Gaussian smoothing\n    kernel = gaussian_kernel(5, 1.0)\n    from numpy import convolve\n    # Use separable convolution for speed\n    def smooth(img, kern):\n        # Pad and convolve\n        pad = len(kern) // 2\n        result = np.zeros_like(img)\n        for i in range(img.shape[0]):\n            for j in range(img.shape[1]):\n                val = 0.0\n                for ki in range(-pad, pad + 1):\n                    for kj in range(-pad, pad + 1):\n                        ii = min(max(i + ki, 0), img.shape[0] - 1)\n                        jj = min(max(j + kj, 0), img.shape[1] - 1)\n                        val += img[ii, jj] * kern[ki + pad, kj + pad]\n                result[i, j] = val\n        return result\n\n    # Faster: use np.convolve via 2D convolution\n    from scipy.signal import convolve2d\n    try:\n        Sxx = convolve2d(Ixx, kernel, mode='same', boundary='symm')\n        Syy = convolve2d(Iyy, kernel, mode='same', boundary='symm')\n        Sxy = convolve2d(Ixy, kernel, mode='same', boundary='symm')\n    except ImportError:\n        # Fallback: manual separable convolution\n        def sep_conv(img, kern_1d):\n            pad = len(kern_1d) // 2\n            # Horizontal\n            padded = np.pad(img, ((0, 0), (pad, pad)), mode='edge')\n            h = np.zeros_like(img)\n            for i in range(len(kern_1d)):\n                h += padded[:, i:i + img.shape[1]] * kern_1d[i]\n            # Vertical\n            padded = np.pad(h, ((pad, pad), (0, 0)), mode='edge')\n            v = np.zeros_like(img)\n            for i in range(len(kern_1d)):\n                v += padded[i:i + img.shape[0], :] * kern_1d[i]\n            return v\n\n        kern_1d = np.exp(-0.5 * (np.arange(5) - 2) ** 2)\n        kern_1d /= kern_1d.sum()\n        Sxx = sep_conv(Ixx, kern_1d)\n        Syy = sep_conv(Iyy, kern_1d)\n        Sxy = sep_conv(Ixy, kern_1d)\n\n    # Harris response\n    det_M = Sxx * Syy - Sxy * Sxy\n    trace_M = Sxx + Syy\n    R = det_M - k * trace_M ** 2\n\n    # Non-maximum suppression\n    corners = []\n    R_thresh = threshold * R.max()\n    for i in range(1, R.shape[0] - 1):\n        for j in range(1, R.shape[1] - 1):\n            if R[i, j] > R_thresh:\n                neighborhood = R[i - 1:i + 2, j - 1:j + 2]\n                if R[i, j] == neighborhood.max():\n                    corners.append((j, i, R[i, j]))  # (x, y, response)\n\n    # Sort by response and keep top N\n    corners.sort(key=lambda c: -c[2])\n    corners = corners[:max_corners]\n    return np.array([(c[0], c[1]) for c in corners], dtype=np.float64)\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 2. Sparse Mask Application\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef apply_sparse_mask(points, mask, image_shape):\n    \"\"\"\n    Filter feature points using a binary sparse mask.\n    Only points falling on mask==1 regions are kept.\n    \n    Args:\n        points: (N, 2) array of (x, y) coordinates\n        mask: (H, W) binary array\n        image_shape: (H, W)\n    \n    Returns:\n        Filtered points array\n    \"\"\"\n    h, w = image_shape[:2]\n    valid = []\n    for pt in points:\n  