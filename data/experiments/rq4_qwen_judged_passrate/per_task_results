   # Fallback: assume it's a direct adjacency list {\"AS1\": [\"AS2\", \"AS3\"]}\n            for src, dsts in data.items():\n                if isinstance(dsts, list):\n                    for dst in dsts:\n                        if src != dst:\n                            graph[src].add(dst)\n            return graph\n\n    for edge in edges:\n        src = edge.get('source') or edge.get('from') or edge.get('src')\n        dst = edge.get('target') or edge.get('to') or edge.get('dst')\n        if src and dst and src != dst:\n            graph[src].add(dst)\n            \n    # Explicitly free the raw JSON data from memory\n    del data \n    return graph\n\ndef find_cycles_iterative(graph):\n    \"\"\"\n    Detects all unique cycles in a directed graph using iterative DFS.\n    Memory optimized: yields cycles via generator, uses O(V) auxiliary space.\n    \"\"\"\n    WHITE, GRAY, BLACK = 0, 1, 2\n    # Using a dict for color tracking is memory efficient for sparse node IDs\n    color = {node: WHITE for node in graph}\n    \n    path = []\n    path_set = set()\n    node_to_index = {}  # O(1) lookup for cycle start index\n    \n    # Stack stores tuples of (current_node, iterator_over_neighbors)\n    stack = []\n    \n    for start_node in graph:\n        if color[start_node] != WHITE:\n            continue\n            \n        stack.append((start_node, iter(graph[start_node])))\n        color[start_node] = GRAY\n        path.append(start_node)\n        path_set.add(start_node)\n        node_to_index[start_node] = 0\n        \n        while stack:\n            node, neighbors = stack[-1]\n            try:\n                neighbor = next(neighbors)\n                \n                # If neighbor is in the current active path, we found a loop\n                if color[neighbor] == GRAY and neighbor in path_set:\n                    cycle_start_idx = node_to_index[neighbor]\n                    # Yield the cycle immediately to save memory\n                    yield