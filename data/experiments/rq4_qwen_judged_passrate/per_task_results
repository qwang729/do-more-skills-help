ogy.\"\"\"\n\n    def __init__(self):\n        self.adjacency: Dict[str, List[Dict]] = defaultdict(list)\n        self.nodes: Dict[str, Dict] = {}\n        self.edges: List[Dict] = []\n\n    def add_node(self, node_id: str, attributes: Dict):\n        self.nodes[node_id] = attributes\n\n    def add_edge(self, src: str, dst: str, attributes: Dict):\n        self.adjacency[src].append({\"target\": dst, **attributes})\n        self.edges.append({\"from\": src, \"to\": dst, **attributes})\n\n    @classmethod\n    def from_json(cls, filepath: str) -> \"BGPGraph\":\n        \"\"\"Load topology from a JSON file.\"\"\"\n        with open(filepath, \"r\") as f:\n            data = json.load(f)\n\n        graph = cls()\n\n        for node in data.get(\"nodes\", []):\n            graph.add_node(node[\"id\"], {k: v for k, v in node.items() if k != \"id\"})\n\n        for edge in data.get(\"edges\", []):\n            graph.add_edge(\n                edge[\"from\"],\n                edge[\"to\"],\n                {k: v for k, v in edge.items() if k not in (\"from\", \"to\")},\n            )\n\n        return graph\n\n    @classmethod\n    def from_json_string(cls, json_str: str) -> \"BGPGraph\":\n        \"\"\"Load topology from a JSON string.\"\"\"\n        data = json.loads(json_str)\n        graph = cls()\n\n        for node in data.get(\"nodes\", []):\n            graph.add_node(node[\"id\"], {k: v for k, v in node.items() if k != \"id\"})\n\n        for edge in data.get(\"edges\", []):\n            graph.add_edge(\n                edge[\"from\"],\n                edge[\"to\"],\n                {k: v for k, v in edge.items() if k not in (\"from\", \"to\")},\n            )\n\n        return graph\n\n\nclass CycleDetector:\n    \"\"\"Detects cycles in a directed graph using DFS with coloring.\"\"\"\n\n    # Node colors for DFS\n    WHITE = 0  # Unvisited\n    GRAY = 1   # In current DFS path (on recursion stack)\n    BLACK = 2  # Fully processed\n\n    def __init__(self, graph: BGPGraph):\n        self.graph = graph\n        self.color: Dict[str, int] = {node: self.WHITE for node in graph.nodes}\n        self.parent: Dict[str, Optional[str]] = {node: None for node in graph.nodes}\n        self.cycles: List[List[str]] = []\n        self.cycle_details: List[Dict] = []\n\n    def detect_all_cycles(self) -> List[List[str]]:\n        \"\"\"Find all elementary cycles in the directed graph.\"\"\"\n        self.cycles = []\n        self.cycle_details = []\n\n        # Method 1: DFS-based back-edge detection\n        self._dfs_find_cycles()\n\n        # Method 2: Johnson's algorithm for all elementary cycles\n        johnson_cycles = self._johnsons_algorithm()\n\n        # Merge and deduplicate\n        all_cycles = self._normalize_and_deduplicate(\n            self.cycles + johnson_cycles\n        )\n\n        return all_cycles\n\n    def _dfs_find_cycles(self) -> None:\n        \"\"\"DFS-based cycle detection via back edges.\"\"\"\n        for node in self.graph.nodes:\n            if self.color[node] == self.WHITE:\n                path = []\n                self._dfs_visit(node, path, set())\n\n    def _dfs_visit(self, u: str, path: List[str], path_set: Set[str]) -> None:\n        self.color[u] = self.GRAY\n        path.append(u)\n        path_set.add(u)\n\n        for neighbor_info in self.graph.adjacency.get(u, []):\n            v = neighbor_info[\"target\"]\n\n            if v in path_set:\n                # Found a cycle - extract it\n                cycle_start_idx = path.index(v)\n                cycle = path[cycle_start_idx:] + [v]\n                self.cycles.append(cycle)\n\n                # Build cycle details\n                edge_details = []\n                for i in range(len(cycle) - 1):\n                    for edge in self.graph.edges:\n                        if edge[\"from\"] == cycle[i] and edge[\"to\"] == cycle[i + 1]:\n                            edge_details.append(edge)\n                            break\n\n                self.cycle_details.append({\n                    \"cycle\": cycle,\n                    \"length\": len(cycle) - 1,\n                    \"edges\": edge_details,\n                    \"severity\": self._classify_severity(cycle),\n                })\n\n            elif self.color[v] == self.WHITE:\n                self._dfs_visit(v, path, path_set)\n\n        path.pop()\n        path_set.remove(u)\n        self.color[u] = self.BLACK\n\n    def _johnsons_algorithm(self) -> List[List[str]]:\n        \"\"\"Johnson's algorithm to find all elementary cycles.\"\"\"\n        cycles = []\n        nodes = sorted(self.graph.nodes.keys())\n\n        for start_idx, start_node in enumerate(nodes):\n            # Build subgraph with only nodes >= start_node (by index)\n            subgraph_nodes = set(nodes[start_idx:])\n            blocked: Set[str] = set()\n            blocked_map: Dict[str, Set[str]] = defaultdict(set)\n            path = [start_node]\n\n            self._johnson_circuit(\n                start_node, start_node, subgraph_nodes,\n                blocked, blocked_map, path, cycles\n            )\n\n        return cycles\n\n    def _johnson_circuit(\n        self,\n        v: str,\n        start: str,\n        subgraph_nodes: Set[str],\n        blocked: Set[str],\n        blocked_map: Dict[str, Set[str]],\n        path: List[str],\n        cycles: List[List[str]],\n    ) -> bool:\n        found_cycle = False\n        blocked.add(v)\n\n        for neighbor_info in self.graph.adjacency.get(v, []):\n            w = neighbor_info[\"target\"]\n            if w not in subgraph_nodes:\n                continue\n\n            if w == start:\n                cycle = path + [start]\n                cycles.append(cycle)\n                found_cycle = True\n            elif w not in blocked:\n                path.append(w)\n                if self._johnson_circuit(\n                    w, start, subgraph_nodes,\n                    blocked, blocked_map, path, cycles\n                ):\n                    found_cycle = True\n                path.pop()\n\n        if found_cycle:\n            blocked.discard(v)\n        else:\n            for neighbor_info in self.graph.adjacency.get(v, []):\n                w = neighbor_info[\"target\"]\n                if w not in subgraph_nodes:\n                    continue\n                blocked_map[w].add(v)\n\n        for w in blocked_map.get(v, set()):\n            blocked.discard(w)\n\n        blocked_map[v] = set()\n        return found_cycle\n\n    def _classify_severity(self, cycle: List[str]) -> str:\n        \"\"\"Classify cycle severity based on length and prefix.\"\"\"\n        length = len(cycle) - 1\n        if length <= 2:\n            return \"CRITICAL\"\n        elif length <= 4:\n            return \"HIGH\"\n        elif length <= 6:\n            return \"MEDIUM\"\n        else:\n            return \"LOW\"\n\n    def _normalize_and_deduplicate(\n        self, cycles: List[List[str]]\n    ) -> List[List[str]]:\n        \"\"\"Remove duplicate cycles (same cycle starting at different nodes).\"\"\"\n        unique = []\n        seen = set()\n\n        for cycle in cycles:\n            if len(cycle) < 2:\n                continue\n            # Normalize: rotate so smallest element is first\n            core = cycle[:-1]  # Remove the repeated last element\n            min_idx = core.index(min(core))\n            normalized = tuple(core[min_idx:] + core[:min_idx])\n\n            if normalized not in seen:\n                seen.add(normalized)\n                unique.append(list(normalized) + [normalized[0]])\n\n        return unique\n\n    def get_analysis_report(self) -> Dict:\n        \"\"\"Generate a comprehensive analysis report.\"\"\"\n        all_cycles = self.detect_all_cycles()\n\n        # Rebuild cycle details for the final deduplicated set\n        final_details = []\n        for cycle in all_cycles:\n            edge_details = []\n            for i in range(len(cycle) - 1):\n                for edge in self.graph.edges:\n                    if edge[\"from\"] == cycle[i] and edge[\"to\"] == cycle[i + 1]:\n                        edge_details.append(edge)\n                        break\n\n            final_details.append({\n                \"cycle\": cycle,\n                \"cycle_path\": \" -> \".join(cycle),\n                \"length\": len(cycle) - 1,\n                \"edges\": edge_details,\n                \"severity\": self._classify_severity(cycle),\n            })\n\n        # Identify nodes involved in cycles\n        nodes_in_cycles = set()\n        for cycle in all_cycles:\n            nodes_in_cycles.update(cycle[:-1])\n\n        # Identify affected prefixes\n        affected_prefixes = set()\n        for detail in final_details:\n            for edge in detail[\"edges\"]:\n                if \"prefix\" in edge:\n                    affected_prefixes.add(edge[\"prefix\"])\n\n        report = {\n            \"analysis_summary\": {\n                \"total_nodes\": len(self.graph.nodes),\n                \"total_edges\": len(self.graph.edges),\n                \"cycles_detected\": len(all_cycles),\n                \"nodes_in_cycles\": sorted(list(nodes_in_cycles)),\n                \"affected_prefixes\": sorted(list(affected_prefixes)),\n                \"has_routing_loops\": len(all_cycles) > 0,\n            },\n            \"cycles\": final_details,\n            \"severity_breakdown\": {\n                \"CRITICAL\": sum(1 for d in final_details if d[\"severity\"] == \"CRITICAL\"),\n                \"HIGH\": sum(1 for d in final_details if d[\"severity\"] == \"HIGH\"),\n                \"MEDIUM\": sum(1 for d in final_details if d[\"severity\"] == \"MEDIUM\"),\n                \"LOW\": sum(1 for d in final_details if d[\"severity\"] == \"LOW\"),\n            },\n            \"recommendations\": self._generate_recommendations(final_details),\n        }\n\n        return report\n\n    def _generate_recommendations(self