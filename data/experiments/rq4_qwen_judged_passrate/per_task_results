trieval.\"\"\"\n        self.all_employees = []\n        self.employee_by_name = {}\n        self.employee_by_id = {}\n        self.department_by_name = {}\n        self.product_by_name = {}\n\n        for dept in self.data.get(\"departments\", []):\n            dept_name_lower = dept[\"name\"].lower()\n            self.department_by_name[dept_name_lower] = dept\n            for emp in dept.get(\"employees\", []):\n                self.all_employees.append({**emp, \"department\": dept[\"name\"]})\n                self.employee_by_name[emp[\"name\"].lower()] = {**emp, \"department\": dept[\"name\"]}\n                self.employee_by_id[emp[\"id\"].lower()] = {**emp, \"department\": dept[\"name\"]}\n\n        for prod in self.data.get(\"products\", []):\n            self.product_by_name[prod[\"name\"].lower()] = prod\n\n    def answer(self, question: str) -> str:\n        \"\"\"Parse a natural language question and return an answer.\"\"\"\n        q = question.strip().lower().rstrip(\"?\")\n\n        # --- Company-level questions ---\n        if self._match(q, [\"company name\", \"name of the company\", \"what is the company\"]):\n            return f\"The company name is {self.data['company']}.\"\n\n        if self._match(q, [\"when was.*founded\", \"founded\", \"year founded\", \"established\"]):\n            return f\"{self.data['company']} was founded in {self.data['founded']}.\"\n\n        if self._match(q, [\"headquarters\", \"head office\", \"head office location\", \"where is.*located\"]):\n            return f\"The headquarters is in {self.data['headquarters']}.\"\n\n        if self._match(q, [\"how many departments\", \"number of departments\", \"count of departments\"]):\n            count = len(self.data[\"departments\"])\n            return f\"There are {count} departments.\"\n\n        if self._match(q, [\"list departments\", \"what departments\", \"name.*departments\", \"all departments\"]):\n            names = [d[\"name\"] for d in self.data[\"departments\"]]\n            return f\"The departments are: {', '.join(names)}.\"\n\n        # --- Total employee count ---\n        if self._match(q, [\"how many employees\", \"total employees\", \"number of employees\", \"employee count\"]):\n            return f\"There are {len(self.all_employees)} total employees.\"\n\n        # --- Department-specific questions ---\n        dept_match = re.search(r\"(?:in|of|for)\\s+(engineering|sales|marketing)\", q)\n        if not dept_match:\n            dept_match = re.search(r\"(engineering|sales|marketing)\\s+department\", q)\n\n        if dept_match:\n            dept_name = dept_match.group(1)\n            dept = self.department_by_name.get(dept_name)\n            if not dept:\n                return f\"Department '{dept_name}' not found.\"\n            return self._answer_department_question(q, dept)\n\n        # --- Employee-specific questions ---\n        emp = self._find_employee(q)\n        if emp:\n            return self._answer_employee_question(q, emp)\n\n        # --- Product-specific questions ---\n        prod = self._find_product(q)\n        if prod:\n            return self._answer_product_question(q, prod)\n\n        # --- Aggregate / comparison questions ---\n        if self._match(q, [\"highest salary\", \"highest paid\", \"most paid\", \"top salary\", \"who earns the most\"]):\n            top = max(self.all_employees, key=lambda e: e[\"salary\"])\n            return f\"The highest paid employee is {top['name']} ({top['role']}, {top['department']}) with a salary of ${top['salary']:,}.\"\n\n        if self._match(q, [\"lowest salary\", \"lowest paid\", \"least paid\", \"who earns the least\"]):\n            low = min(self.all_employees, key=lambda e: e[\"salary\"])\n            return f\"The lowest paid employee is {low['name']} ({low['role']}, {low['department']}) with a salary of ${low['salary']:,}.\"\n\n        if self._match(q, [\"average salary\", \"mean salary\", \"avg salary\"]):\n            avg = sum(e[\"salary\"] for e in self.all_employees) / len(self.all_employees)\n            return f\"The average salary across all employees is ${avg:,.2f}.\"\n\n        if self._match(q, [\"total budget\", \"total.*budget\", \"sum of.*budget\", \"combined budget\"]):\n            total = sum(d[\"budget\"] for d in self.data[\"departments\"])\n            return f\"The total budget across all departments is ${total:,}.\"\n\n        if self._match(q, [\"total revenue\", \"total.*revenue\", \"combined revenue\", \"sum.*revenue\"]):\n            total = sum(p[\"revenue_2023\"] for p in self.data[\"products\"])\n            return f\"The total revenue for 2023 is ${total:,}.\"\n\n        if self._match(q, [\"highest revenue\", \"top revenue\", \"most revenue\", \"best selling\"]):\n            top = max(self.data[\"products\"], key=lambda p: p[\"revenue_2023\"])\n            return f\"The highest revenue product is {top['name']} with ${top['revenue_2023']:,} in 2023.\"\n\n        if self._match(q, [\"remote employees\", \"who.*remote\", \"work.*remote\", \"working remotely\"]):\n            remote = [e for e in self.all_employees if e[\"location\"].lower() == \"remote\"]\n            if not remote:\n                return \"No employees work remotely.\"\n            names = [f\"{e['name']} ({e['department']})\" for e in remote]\n            return f\"Remote employees: {', '.join(names)}.\"\n\n        if self._match(q, [\"hired in\", \"hired during\", \"joined in\", \"employees hired in\"]):\n            year_match = re.search(r\"(\\d{4})\", q)\n            if year_match:\n                year = int(year_match.group(1))\n                hired = [e for e in self.all_employees if e[\"hire_date\"].startswith(str(year))]\n                if not hired:\n                    return f\"No employees were hired in {year}.\"\n                names = [f\"{e['name']} ({e['department']})\" for e in hired]\n                return f\"Employees hired in {year}: {', '.join(names)}.\"\n\n        if self._match(q, [\"list all employees\", \"all employees\", \"show employees\", \"who works\"]):\n            lines = [f\"  {e['name']} - {e['role']} ({e['department']})\" for e in self.all_employees]\n            return \"All employees:\\n\" + \"\\n\".join(lines)\n\n        if self._match(q, [\"list products\", \"all products\", \"what products\", \"show products\"]):\n            lines = [f\"  {p['name']} - ${p['price']} ({p['category']})\" for p in self.data[\"products\"]]\n            return \"Products:\\n\" + \"\\n\".join(lines)\n\n        return \"I couldn't understand the question. Try asking about employees, departments, products, salaries, budgets, or revenue.\"\n\n    def _answer_department_question(self, q: str, dept: dict) -> str:\n        dept_name = dept[\"name\"]\n        employees = dept.get(\"employees\", [])\n\n        if self._match(q, [\"head\", \"leader\", \"manager\", \"who leads\", \"who runs\", \"vp\"]):\n            return f\"The head of {dept_name} is {dept['head']}.\"\n\n        if self._match(q, [\"budget\"]):\n            return f\"The budget for {dept_name} is ${dept['budget']:,}.\"\n\n        if self._match(q, [\"how many\", \"number of\", \"count\"]):\n            return f\"{dept_name} has {len(employees)} employees.\"\n\n        if self._match(q, [\"average salary\", \"avg salary\", \"mean salary\"]):\n            if not employees:\n                return f\"No employees in {dept_name}.\"\n            avg = sum(e[\"salary\"] for e in employees) / len(employees)\n            return f\"The average salary in {dept_name} is ${avg:,.2f}.\"\n\n        if self._match(q, [\"list\", \"who\", \"names\", \"show\", \"all\"]):\n            lines = [f\"  {e['name']} - {e['role']} (${e['salary']:,})\" for e in employees]\n            return f\"Employees in {dept_name}:\\n\" + \"\\n\".join(lines)\n\n        if self._match(q, [\"highest salary\", \"highest paid\", \"top earner\"]):\n            top = max(employees, key=lambda e: e[\"salary\"])\n            return f\"The highest paid in {dept_name} is {top['name']} with ${top['salary']:,}.\"\n\n        return f\"Department: {dept_name} | Head: {dept['head']} | Budget: ${dept['budget']:,} | Employees: {len(employees)}\"\n\n    def _answer_employee_question(self, q: str, emp: dict) -> str:\n        name = emp[\"name\"]\n\n        if self._match(q, [\"salary\", \"pay\", \"earn\", \"income\", \"compensation\"]):\n            return f\"{name}'s salary is ${emp['salary']:,}.\"\n\n        if self._match(q, [\"role\", \"title\", \"position\", \"job\"]):\n            return f\"{name}'s role is {emp['role']}.\"\n\n        if self._match(q, [\"department\", \"team\", \"which dept\"]):\n            return f\"{name} works in the {emp['department']} department.\"\n\n        if self._match(q, [\"location\", \"where\", \"office\", \"based\"]):\n            return f\"{name} is based in {emp['location']}.\"\n\n        if self._match(q, [\"hire date\", \"hired\", \"joined\", \"start date\", \"when did\"]):\n            return f\"{name} was hired on {emp['hire_date']}.\"\n\n        if self._match(q, [\"id\", \"employee id\", \"badge\"]):\n            return f\"{name}'s employee ID is {emp['id']}.\"\n\n        # Default: return full profile\n        return (\n            f\"{name} | ID: {emp['id']} | Role: {emp['role']} | \"\n            f\"Department: {emp['department']} | Salary: ${emp['salary']:,} | \"\n            f\"Location: {emp['location']} | Hired: {emp['hire_date']}\"\n        )\n\n    def _answer_product_question(self, q: str, prod: dict) -> str:\n        name = prod[\"name\"]\n\n        if self._match(q, [\"price\", \"cost\", \"how much\"]):\n            return f\"{name} costs ${prod['price']}.\"\n\n        if self._match(q, [\"category\", \"type\", \"kind\"]):\n            return f\"{name} is in the {prod['category']} category.\"\n\n        if self._match(q, [\"revenue\", \"sales\", \"earned\"]):\n            return f\"{name} generated ${prod['revenue_2023']:,} in 2023 revenue.\"\n\n        return f\"{name} | Price: ${prod['price']} | Category: {prod['category']} | 2023 Revenue: ${prod['revenue_2023']:,}\"\n\n    def _find_employee(self, q: str) -> Optional[dict]:\n        \"\"\"Try to find an employee mentioned in the question.\"\"\"\n        # Check all known employee names\n        for name_lower, emp in self.employee_by_name.items():\n            # Match full name or last name\n            parts = name_lower.split()\n            for part in parts:\n                if len(part) > 2 and part in q:\n                    return emp\n        # Check employee IDs\n        for eid_lower, emp in self.employee_by_id.items():\n            if eid_lower in q:\n                return emp\n        return None\n\n    def _find_product(self, q: str) -> Optional[dict]:\n        \"\"\"Try to find a product mentioned in the question.\"\"\"\n        for name_lower, prod in self.product_by_name.items():\n            words = name_lower.split()\n            for word in words:\n                if len(word) > 2 and word in q:\n                    return prod\n        return None\n\n    @staticmethod\n    def _match(question: str, patterns: list[str]) -> bool:\n        \"\"\"Check if the question matches any of the given regex patterns.\"\"\"\n        for pattern in patterns:\n            if re.search(pattern, question):\n                return True\n        return False\n\n\n# --- CLI Interface ---\ndef main():\n    import sys\n\n    data_path = \"enterprise_data.json\"\n    if len(sys.argv) > 1:\n        data_path = sys.argv[1]\n\n    qa = EnterpriseQA(data_path)\n\n    print(\"=\" * 60)\n    print(\"  Enterprise Data QA System\")\n    print(\"  Type your question or 'quit' to exit.\")\n    print(\"=\" * 60)\n    print()\n    print(\"Example questions:\")\n    print(\"  - What is the company name?\")\n    print(\"  - How many employees are there?\")\n    print(\"  - What is Bob Smith's salary?\")\n    print(\"  - Who is the head of Engineering?\")\n    print(\"  - What is the budget for Sales?\")\n    print(\"  - Who is the highest paid employee?\")\n    print(\"  - What is the average salary?\")\n    print(\"  - List all remote employees\")\n    print(\"  - Who was hired in 2021?\")\n    print(\"  - What is the price of Gadget Plus?\")\n    print(\"  - Which product has the highest revenue?\")\n    print()\n\n    while True:\n        try:\n            question = input(\"Q: \").strip()\n        except (EOFError, KeyboardInterrupt):\n            print(\"\\nGoodbye!\")\n            break\n\n        if not question:\n            continue\n        if question.lower() in (\"quit\", \"exit\", \"q\"):\n            print(\"Goodbye!\")\n            break\n\n        answer = qa.answer(question)\n        print(f\"A: {answer}\\n\")\n\n\nif __name__ == \"__main__\":\n    main()\n```\n\n## 3. Usage\n\n```bash\n# Run the QA system\npython qa_engine.py enterprise_data.json\n```\n\n### Example Session\n\n```\nQ: What is the company name?\nA: The company name is Acme Corp.\n\nQ: How many employees are there?\nA: There are 12 total employees.\n\nQ: What is Bob Smith's salary?\nA: Bob Smith's salary is $165,000.\n\nQ: Who is the head of Engineering?\nA: The head of Engineering is Alice Johnson.\n\nQ: What is the budget for Sales?\nA: The budget for Sales is $3,000,000.\n\nQ: Who is the highest paid employee?\nA: The highest paid employee is Alice Johnson (VP of Engineering, Engineering) with a salary of $220,000.\n\nQ: What is the average salary?\nA: The average salary across all employees is $144,750.00.\n\nQ: List all remote employees\nA: Remote employees: Eve ", "solver_finish_reason": "stop"}
{"task": "exceltable-in-ppt", "condition": "no_skill", "repeat": 0, "skill_ids": [], "retrieval_correct": null, "judged_pass": false, "judged_score": 2, "judge_reason": "The agent's solution provides a comprehensive framework for editing embedded Excel objects but does not specifically address the task of reading an exchange rate from a text box and updating only the direct rate cell in the Excel table as required.", "solver_tokens": 5477, "judge_tokens": 4823, "solution_text": "# Editing Embedded Excel Objects in PPTX Tables with python-pptx\n\nThis is a multi-step process because `python-pptx` doesn't natively support editing OLE-embedded Excel objects. We must extract the embedded Excel binary, modify it, and re-embed it.\n\n## Complete Solution\n\n```python\n\"\"\"\nEdit embedded Excel objects inside a PowerPoint file.\n\nDependencies:\n    pip install python-pptx openpyxl olefile lxml\n\"\"\"\n\nimport os\nimport io\nimport zipfile\nimport shutil\nimport tempfile\nimport copy\nfrom lxml import etree\n\nimport olefile\nimport openpyxl\nfrom pptx import Presentation\nfrom pptx.util import Inches, Pt, Emu\nfrom pptx.enum.shapes import MSO_SHAPE_TYPE\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 1. LOCATE EMBEDDED EXCEL OLE OBJECTS IN THE PPTX\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef find_embedded_excel_objects(pptx_path):\n    \"\"\"\n    Walk every slide, find OLE objects whose ProgID indicates Excel,\n    and return a list of dicts with slide index, shape, and the\n    relationship ID that points to the embedded part.\n    \"\"\"\n    prs = Presentation(pptx_path)\n    results = []\n\n    for slide_idx, slide in enumerate(prs.slides):\n        for shape in slide.shapes:\n            # OLE objects show up as shape_type == MSO_SHAPE_TYPE.EMBEDDED_OBJECT (not always reliable)\n            # More reliable: check the XML for <o:OLEObject> with a ProgID containing \"Excel\"\n            if shape.shape_type is not None and shape.shape_type == 10000:\n                # 10000 = EMBEDDED_OBJECT in some versions; fall through to XML check\n                pass\n\n            # Check the underlying XML for OLE references\n            sp_xml = shape._element.xml\n            if \"Excel\" in sp_xml or \"xlsx\" in sp_xml.lower() or \"xls\" in sp_xml.lower():\n                # Extract the r:id that links to the embedded part\n                nsmap = {\n                    'a':  'http://schemas.openxmlformats.org/drawingml/2006/main',\n                    'r':  'http://schemas.openxmlformats.org/officeDocument/2006/relationships',\n                    'p':  'http://schemas.openxmlformats.org/presentationml/2006/main',\n                }\n                # Look for <a:oleObj r:id=\"rIdX\">\n                ole_objs = shape._element.xpath('.//a:oleObj', namespaces=nsmap)\n                for ole_obj in ole_objs:\n                    r_id = ole_obj.get('{http://schemas.openxmlformats.org/officeDocument/2006/relationships}id')\n                    prog_id = ole_obj.get('progId', '')\n                    if r_id and 'Excel' in prog_id:\n                        results.append({\n                            'slide_index': slide_idx,\n                            'slide': slide,\n                            'shape': shape,\n                            'rId': r_id,\n                            'progId': prog_id,\n                        })\n    return results\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 2. EXTRACT THE RAW EXCEL BLOB FROM THE OLE PACKAGE\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef extract_excel_from_ole(ole_bytes):\n    \"\"\"\n    Given the raw bytes of an OLE 'Package' compound document,\n    extract the embedded Excel workbook bytes.\n    \"\"\"\n    ole = olefile.OleFileIO(io.BytesIO(ole_bytes))\n\n    # The actual file is usually stored in the '\\x01Ole' stream\n    # or directly as the root.  For \"Package\" OLE objects the\n    # payload is in the '\\x01Ole10Native' or 'CONTENTS' stream.\n    # Try common stream names:\n    for stream_name in ['CONTENTS', '\\x01Ole10Native', '\\x01Ole']:\n        if ole.exists(stream_name):\n            data = ole.openstream(stream_name).read()\n            # For \\x01Ole10Native the first 4 bytes are a length prefix\n            if stream_name == '\\x01Ole10Native' and len(data) > 4:\n                import struct\n                size = struct.unpack('<I', data[:4])[0]\n                data = data[4:4 + size]\n            ole.close()\n            return data\n\n    # Fallback: read the whole OLE as-is (might be a raw xlsx)\n    ole.close()\n    return ole_bytes\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 3. MODIFY THE EXCEL WORKBOOK\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef modify_excel_workbook(excel_bytes, edit_func):\n    \"\"\"\n    Open the Excel bytes with openpyxl, call edit_func(wb),\n    and return the modified bytes.\n\n    edit_func receives an openpyxl Workbook and should modify it in-place.\n    \"\"\"\n    wb = openpyxl.load_workbook(io.BytesIO(excel_bytes))\n    edit_func(wb)\n    out = io.BytesIO()\n    wb.save(out)\n    return out.getvalue()\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 4. RE-PACKAGE THE MODIFIED EXCEL INTO AN OLE CONTAINER\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef rebuild_ole_package(original_ole_bytes, new_excel_bytes):\n    \"\"\"\n    Replace the Excel payload inside the OLE compound document\n    while preserving the OLE structure.\n    \"\"\"\n    # Strategy: work on the raw ZIP (PPTX) level.\n    # We rebuild the OLE file by replacing the CONTENTS stream.\n    # Since olefile can write, we do:\n    buf = io.BytesIO()\n    # Copy original OLE\n    buf.write(original_ole_bytes)\n    buf.seek(0)\n\n    ole = olefile.OleFileIO(buf, write_mode=True)\n\n    # Determine which stream holds the payload\n    target_stream = None\n    for stream_name in ['CONTENTS', '\\x01Ole10Native', '\\x01Ole']:\n        if ole.exists(stream_name):\n            target_stream = stream_name\n            break\n\n    if target_stream is None:\n        # If no known stream, just replace the whole thing\n        ole.close()\n        return new_excel_bytes\n\n    # olefile write support is limited; use a lower-level approach:\n    # We'll rebuild the OLE from scratch using the original as template\n    ole.close()\n\n    # Alternative: use the OLE compound file builder\n    return _rebuild_ole_with_new_payload(original_ole_bytes, target_stream, new_excel_bytes)\n\n\ndef _rebuild_ole_with_new_payload(original_ole_bytes, stream_name, new_payload):\n    \"\"\"\n    Rebuild an OLE compound file, replacing one stream's content.\n    Uses a temp-file approach with olefile's write mode.\n    \"\"\"\n    import struct\n\n    # olefile doesn't fully support stream replacement, so we use\n    # a manual approach: parse the original OLE, copy all streams,\n    # and replace the target.\n    #\n    # For simplicity and reliability, we use the compound-file\n    # binary format directly via a helper.\n\n    # Actually, the simplest reliable method: write a new OLE file\n    # using the Python `compoundfiles` or manual construction.\n    # Since we want zero extra deps beyond olefile, we'll use a\n    # known-working technique: patch the bytes in-place if the\n    # new payload fits, or rebuild.\n\n    # Most robust approach: use a temp directory with the OLE\n    # extracted, modify, and re-pack.\n\n    tmpdir = tempfile.mkdtemp()\n    try:\n        # Extract all streams\n        ole = olefile.OleFileIO(io.BytesIO(original_ole_bytes))\n        streams = {}\n        for entry in ole.listdir():\n            path = '/'.join(entry)\n            streams[path] = ole.openstream(entry).read()\n        ole.close()\n\n        # Replace the target stream\n        if stream_name in streams:\n            if stream_name == '\\x01Ole10Native':\n                # Re-add the 4-byte length prefix\n                streams[stream_name] = struct.pack('<I', len(new_payload)) + new_payload\n            else:\n                streams[stream_name] = new_payload\n\n        # Rebuild OLE using olefile write mode\n        out_path = os.path.join(tmpdir, 'output.ole')\n        ole_out = olefile.OleFileIO(out_path, write_mode=True)\n        for path, data in streams.items():\n            parts = path.split('/')\n            ole_out.write_stream(parts, data)\n        ole_out.close()\n\n        with open(out_path, 'rb') as f:\n            return f.read()\n    finally:\n        shutil.rmtree(tmpdir, ignore_errors=True)\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 5. PUT THE MODIFIED OLE BACK INTO THE PPTX\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef replace_embedded_excel_in_pptx(pptx_path, output_path, slide_index, rId, new_ole_bytes):\n    \"\"\"\n    Open the PPTX as a ZIP, find the part referenced by rId on the\n    given slide, and replace its content with new_ole_bytes.\n    \"\"\"\n    tmpdir = tempfile.mkdtemp()\n    try:\n        # Extract PPTX\n        with zipfile.ZipFile(pptx_path, 'r') as zin:\n            zin.extractall(tmpdir)\n\n        # Find the slide XML\n        slide_xml_path = os.path.join(tmpdir, 'ppt', 'slides', f'slide{slide_index + 1}.xml')\n\n        # Parse relationships to find the target part\n        rels_path = os.path.join(tmpdir, 'ppt', 'slides', '_rels', f'slide{slide_index + 1}.xml.rels')\n        rels_tree = etree.parse(rels_path)\n        rels_root = rels_tree.getroot()\n        ns = 'http://schemas.openxmlformats.org/package/2006/relationships'\n\n        target_part = None\n        for rel in rels_root.findall(f'{{{ns}}}Relationship'):\n            if rel.get('Id') == rId:\n                target_part = rel.get('Target')\n                break\n\n        if target_part is None:\n            raise ValueError(f\"Relationship {rId} not found in slide{slide_index + 1}\")\n\n        # Resolve the part path (it's relative to ppt/slides/)\n        part_path = os.path.join(tmpdir, 'ppt', 'slides', target_part)\n        if not os.path.exists(part_path):\n            # Try absolute from tmpdir\n            part_path = os.path.join(tmpdir, target_part.lstrip('/'))\n\n        # Write the new OLE bytes\n        with open(part_path, 'wb') as f:\n            f.write(new_ole_bytes)\n\n        # Re-pack the PPTX\n        if os.path.exists(output_path):\n            os.remove(output_path)\n        with zipfile.ZipFile(output_path, 'w', zipfile.ZIP_DEFLATED) as zout:\n            for root, dirs, files in os.walk(tmpdir):\n                for file in files:\n                    file_path = os.path.join(root, file)\n                    arcname = os.path.relpath(file_path, tmpdir)\n                    zout.write(file_path, arcname)\n    finally:\n        shutil.rmtree(tmpdir, ignore_errors=True)\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 6. HIGH-LEVEL API: EDIT EMBEDDED EXCEL IN PPTX\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef edit_embedded_excel(pptx_path, output_path, edit_func, target_index=0):\n    \"\"\"\n    High-level function to edit an embedded Excel object in a PPTX.\n\n    Parameters\n    ----------\n    pptx_path : str\n        Path to the input .pptx file.\n    output_path : str\n        Path to write the modified .pptx file.\n    edit_func : callable\n        A function that takes an openpyxl.Workbook and modifies it.\n        Example: lambda wb: wb.active.cell(1, 1).set_value(\"Hello\")\n    target_index : int\n        If multiple Excel objects exist, which one to edit (0-based).\n    \"\"\"\n    # Step 1: Find embedded Excel objects\n    objects = find_embedded_excel_objects(pptx_path)\n    if not objects:\n        raise RuntimeError(\"No embedded Excel objects found in the PPTX.\")\n\n    obj = objects[target_index]\n    print(f\"Found Excel OLE object on slide {obj['slide_index']}, rId={obj['rId']}, progId={obj['progId']}\")\n\n    # Step 2: Extract the OLE blob from the PPTX ZIP\n    slide_num = obj['slide_index'] + 1\n    with zipfile.ZipFile(pptx_path, 'r') as z:\n        # Find the relationship target\n        rels_xml = z.read(f'ppt/slides/_rels/slide{slide_num}.xml.rels')\n        rels_tree = etree.fromstring(rels_xml)\n        ns = 'http://schemas.openxmlformats.org/package/2006/relationships'\n        target = None\n        for rel in rels_tree.findall(f'{{{ns}}}Relationship'):\n            if rel.get('Id') == obj['rId']:\n                target = rel.get('Target')\n                break\n        if target is None:\n            raise ValueError(f\"rId {obj['rId']} not found in relationships\")\n\n        # The target is like \"../embeddings/Microsoft_Excel_Worksheet3.xlsx\"\n        # Resolve relative to ppt/slides/\n        ole_part_path = f'ppt/slides/{target}'\n        # Normalize path\n        ole_part_path = os.path.normpath(ole_part_path).replace('\\\\', '/')\n\n        original_ole_bytes = z.read(ole_part_path)\n\n    # Step 3: Extract Excel from OLE\n    excel_bytes = extract_excel_from_ole(original_ole_bytes)\n\n    # Step 4: Modify the Excel workbook\n    new_excel_bytes = modify_excel_workbook(excel_bytes, edit_func)\n\n    # Step 5: Re-package into OLE\n    new_ole_bytes = rebuild_ole_package(original_ole_bytes, new_excel_bytes)\n\n    # Step 6: Replace in PPTX\n    replace_embedded_excel_in_pptx(pptx_path, output_path, obj['slide_index'], obj['rId'], new_ole_bytes)\n\n    print(f\"Modified PPTX saved to: {output_path}\")\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 7. ALSO: EDITING THE PPTX TABLE ITSELF (non-OLE cells)\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u250