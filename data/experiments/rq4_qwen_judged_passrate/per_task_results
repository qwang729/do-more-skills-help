t,\n    flatten: bool = True,\n) -> str:\n    \"\"\"\n    Fill a PDF form with the provided data dictionary.\n    \n    Args:\n        input_pdf:  Path to the blank court form PDF\n        output_pdf: Path for the filled output PDF\n        data:       Dict mapping field names to values\n        flatten:    If True, flatten the form (make non-editable)\n    \n    Returns:\n        Path to the output PDF\n    \"\"\"\n    reader = PdfReader(input_pdf)\n    writer = PdfWriter()\n\n    # Clone all pages\n    writer.append(reader)\n\n    # Get existing fields\n    existing_fields = reader.get_fields()\n    if not existing_fields:\n        raise ValueError(f\"No form fields found in {input_pdf}\")\n\n    # Build update dict for writer\n    update_dict = {}\n    matched = 0\n    unmatched_keys = []\n\n    for field_name, value in data.items():\n        if field_name in existing_fields:\n            # Convert value to string for PDF text fields\n            str_value = str(value) if value is not None else \"\"\n            update_dict[NameObject(f\"/{field_name}\")] = TextStringObject(str_value)\n            matched += 1\n        else:\n            unmatched_keys.append(field_name)\n\n    if unmatched_keys:\n        print(f\"[WARNING] These keys were not found in the form and were skipped:\")\n        for k in unmatched_keys:\n            print(f\"  - {k}\")\n\n    print(f\"[INFO] Matched {matched}/{len(data)} data fields to form fields.\")\n\n    # Apply field updates\n    writer.update_page_form_field_values(writer.pages[0], update_dict)\n\n    # Flatten if requested (makes fields read-only / bakes values into content)\n    if flatten:\n        _flatten_form(writer)\n\n    # Write output\n    output_path = Path(output_pdf)\n    output_path.parent.mkdir(parents=True, exist_ok=True)\n    with open(output_path, \"wb\") as f:\n        writer.write(f)\n\n    print(f\"[OK] Filled form saved to: {output_path}\")\n    return str(output_path)\n\n\ndef _flatten_form(writer: PdfWrit