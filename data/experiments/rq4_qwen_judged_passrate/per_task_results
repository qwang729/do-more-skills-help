l loop against a simulated first-order plant, and exports the results to a new CSV.\n\n```python\nimport yaml\nimport pandas as pd\nimport numpy as np\n\ndef load_config(config_path):\n    \"\"\"Parse the YAML configuration file.\"\"\"\n    with open(config_path, 'r') as file:\n        return yaml.safe_load(file)\n\ndef interpolate_setpoints(df, time_col, sp_col, sim_time_step, sim_duration):\n    \"\"\"Interpolate the CSV time series to match the simulation time step.\"\"\"\n    sim_times = np.arange(0, sim_duration + sim_time_step, sim_time_step)\n    interpolated_sp = np.interp(sim_times, df[time_col].values, df[sp_col].values)\n    return sim_times, interpolated_sp\n\ndef run_simulation(config):\n    \"\"\"Execute the PID simulation.\"\"\"\n    # Load input data\n    df_in = pd.read_csv(config['input']['csv_path'])\n    time_col = config['input']['time_column']\n    sp_col = config['input']['setpoint_column']\n    \n    # Extract parameters\n    dt = config['simulation']['time_step']\n    duration = config['simulation']['duration']\n    \n    kp = config['pid']['kp']\n    ki = config['pid']['ki']\n    kd = config['pid']['kd']\n    u_min = config['pid']['output_min']\n    u_max = config['pid']['output_max']\n    \n    plant_gain = config['plant']['gain']\n    plant_tau = config['plant']['tau']\n    \n    # Generate continuous time series from CSV steps\n    sim_times, setpoints = interpolate_setpoints(df_in, time_col, sp_col, dt, duration)\n    \n    # Initialize state variables\n    pv = 0.0             # Process Variable\n    integral = 0.0       # Integral term\n    prev_error = 0.0     # Previous error for derivative\n    \n    results = []\n    \n    # Simulation Loop\n    for t, sp in zip(sim_times, setpoints):\n        error = sp - pv\n        \n        # PID Calculations\n        integral += error * dt\n        derivative = (error - prev_error) / dt if dt > 0 else 0.0\n        \n        # Calculate control output and apply limits (Anti-windup)\n        u = (kp * error) + (ki * integral) + (kd * derivative)\n        u = np.clip(u, u_min, u_max)\n        \n        # Plant Model Simulation (First-Order Lag: tau * dy/dt = -y + K*u)\n        # Euler forward integration\n        pv = pv + (dt / plant_tau) * (-pv + plant_gain * u)\n        \n        prev_error = error\n        \n        # Record results\n        results.append({\n            'time': round(t, 4),\n            'setpoint': sp,\n            'process_variable': round(pv, 4),\n            'control_output': round(u, 4),\n            'error': round(error, 4)\n        })\n        \n    # Save output\n    df_out = pd.DataFrame(results)\n    df_out.to_csv(config['output']['csv_path'], index=False)\n    print(f\"Simulation complete. Results saved to {config['output']['csv_path']}\")\n\nif __name__ == \"__main__\":\n    # Ensure PyYAML and Pandas are installed: pip install pyyaml pandas numpy\n    config = load_config(\"pid_config.yaml\")\n    run_simulation(config)\n```\n\n### How to Run:\n1. Save the YAML, CSV, and Python files in the same directory.\n2. Install dependencies: `pip install pyyaml pandas numpy`\n3. Execute the script: `python simulate_pid.py`\n4. Check `output_timeseries.csv` for the simulated Process Variable (PV), Control Output (u), and Error over time.", "solver_finish_reason": "stop"}
