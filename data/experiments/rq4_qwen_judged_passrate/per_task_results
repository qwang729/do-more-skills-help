rn entropy\n\ndef parse_packets(pcap_file: str) -> List[Packet]:\n    \"\"\"Utility function to read and parse packets from a PCAP file.\"\"\"\n    print(f\"[*] Reading PCAP file: {pcap_file} ...\")\n    return rdpcap(pcap_file)\n\ndef analyze_traffic(packets: List[Packet]) -> dict:\n    \"\"\"\n    Utility function to iterate through packets and extract \n    network statistics and raw payload data.\n    \"\"\"\n    stats = {\n        \"total\": len(packets),\n        \"tcp\": 0,\n        \"udp\": 0,\n        \"icmp\": 0,\n        \"other\": 0,\n        \"src_ips\": [],\n        \"dst_ips\": [],\n        \"payload_bytes\": bytearray()\n    }\n    \n    for pkt in packets:\n        if IP in pkt:\n            stats[\"src_ips\"].append(pkt[IP].src)\n            stats[\"dst_ips\"].append(pkt[IP].dst)\n            \n            # Tally protocol counts\n            if TCP in pkt:\n                stats[\"tcp\"] += 1\n            elif UDP in pkt:\n                stats[\"udp\"] += 1\n            elif ICMP in pkt:\n                stats[\"icmp\"] += 1\n            else:\n                stats[\"other\"] += 1\n                \n            # Extract raw payload for entropy analysis\n            if Raw in pkt:\n                stats[\"payload_bytes\"].extend(pkt[Raw].load)\n        else:\n            stats[\"other\"] += 1\n            \n    return stats\n\ndef print_report(stats: dict):\n    \"\"\"Calculate final entropy metrics and print the analysis report.\"\"\"\n    unique_src = len(set(stats[\"src_ips\"]))\n    unique_dst = len(set(stats[\"dst_ips\"]))\n    \n    # Calculate Shannon Entropy for different dimensions\n    src_entropy = calculate_shannon_entropy(stats[\"src_ips\"])\n    dst_entropy = calculate_shannon_entropy(stats[\"dst_ips\"])\n    payload_entropy = calculate_shannon_entropy(stats[\"payload_bytes\"])\n    \n    print(\"\\n\" + \"=\"*45)\n    print(\"         NETWORK TRAFFIC ANALYSIS\")\n    print(\"=\"*45)\n    print(f\"Total Packets:   {stats['total']}\