2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef flatten_json(obj: Any, parent_key: str = \"\", sep: str = \".\") -> List[Dict[str, Any]]:\n    \"\"\"Recursively flatten JSON into a list of {path, value, context} dicts.\"\"\"\n    items: List[Dict[str, Any]] = []\n\n    def _recurse(o: Any, path: str, context: Dict[str, Any]):\n        if isinstance(o, dict):\n            new_context = {**context, **{k: v for k, v in o.items() if not isinstance(v, (dict, list))}}\n            for k, v in o.items():\n                new_path = f\"{path}{sep}{k}\" if path else k\n                _recurse(v, new_path, new_context)\n        elif isinstance(o, list):\n            for i, item in enumerate(o):\n                _recurse(item, f\"{path}[{i}]\", context)\n        else:\n            items.append({\"path\": path, \"value\": o, \"context\": context})\n\n    _recurse(obj, \"\", {})\n    return items\n\n\nFLAT_DATA = flatten_json(ENTERPRISE_DATA)\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 3. QUESTION PARSER\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nclass QuestionIntent:\n    \"\"\"Parsed representation of a user question.\"\"\"\n    def __init__(self):\n        self.raw: str = \"\"\n        self.intent: str = \"unknown\"          # count, sum, list, lookup, compare, financial, project, who, where\n        self.target_field: str = \"\"\n        self.filters: Dict[str, str] = {}\n        self.aggregation: str = \"\"            # max, min, avg, sum, count\n        self.department: str = \"\"\n        self.location: str = \"\"\n        self.status: str = \"\"\n        self.entity_name: str = \"\"\n        self.quarter: str = \"\"\n\n\ndef parse_question(question: str) -> QuestionIntent:\n    \"\"\"Parse a natural-language question into a structured intent.\"\"\"\n    q = question.lower().strip().rstrip(\"?!.\")\n    intent = QuestionIntent()\n    intent.raw = question\n\n    # --- Detect aggregation ---\n    if any(w in q for w in [\"how many\", \"count\", \"number of\", \"total number\"]):\n        intent.aggregation = \"count\"\n        intent.intent = \"count\"\n    elif any(w in q for w in [\"total\", \"sum\", \"aggregate\"]):\n        intent.aggregation = \"sum\"\n        intent.intent = \"sum\"\n    elif any(w in q for w in [\"highest\", \"maximum\", \"most\", \"top\", \"largest\"]):\n        intent.aggregation = \"max\"\n        intent.intent = \"lookup\"\n    elif any(w in q for w in [\"lowest\", \"minimum\", \"least\", \"smallest\", \"cheapest\"]):\n        intent.aggregation = \"min\"\n        intent.intent = \"lookup\"\n    elif any(w in q for w in [\"average\", \"mean\", \"avg\"]):\n        intent.aggregation = \"avg\"\n        intent.intent = \"sum\"\n\n    # --- Detect department ---\n    dept_map = {\"engineering\": \"Engineering\", \"sales\": \"Sales\", \"marketing\": \"Marketing\"}\n    for key, val in dept_map.items():\n        if key in q:\n            intent.department = val\n            break\n\n    # --- Detect location ---\n    locs = [\"san francisco\", \"austin\", \"new york\", \"chicago\", \"los angeles\", \"remote\"]\n    for loc in locs:\n        if loc in q:\n            intent.location = loc.title().replace(\" \", \" \")\n            if loc == \"remote\":\n                intent.location = \"Remote\"\n            break\n\n    # --- Detect project status ---\n    if \"active\" in q:\n        intent.status = \"active\"\n    elif \"completed\" in q:\n        intent.status = \"completed\"\n\n    # --- Detect quarter ---\n    for qtr in [\"q1\", \"q2\", \"q3\", \"q4\"]:\n        if qtr in q:\n            intent.quarter = qtr.upper()\n            break\n\n    # --- Detect specific intent patterns ---\n    if any(w in q for w in [\"revenue\", \"expense\", \"profit\", \"financial\"]):\n        intent.intent = \"financial\"\n    elif any(w in q for w in [\"project\", \"projects\"]):\n        intent.intent = \"project\"\n    elif any(w in q for w in [\"who is\", \"who heads\", \"who leads\", \"head of\", \"manager of\", \"lead of\"]):\n        intent.intent = \"who\"\n    elif any(w in q for w in [\"where\", \"location\"]):\n        intent.intent = \"where\"\n    elif any(w in q for w in [\"salary\", \"pay\", \"compensation\", \"earn\"]):\n        intent.target_field = \"salary\"\n        if intent.intent == \"unknown\":\n            intent.intent = \"lookup\"\n    elif any(w in q for w in [\"budget\"]):\n        intent.target_field = \"budget\"\n        if intent.intent == \"unknown\":\n            intent.intent = \"lookup\"\n    elif any(w in q for w in [\"employee\", \"employees\", \"people\", \"staff\", \"team\"]):\n        if intent.intent == \"unknown\":\n            intent.intent = \"list\"\n    elif any(w in q for w in [\"list\", \"show\", \"what are\", \"which\"]):\n        if intent.intent == \"unknown\":\n            intent.intent = \"list\"\n\n    # --- Detect entity name (person) ---\n    name_match = re.search(r'(?:for|by|named|is)\\s+([A-Z][a-z]+(?:\\s+[A-Z][a-z]+)?)', question)\n    if name_match:\n        intent.entity_name = name_match.group(1)\n\n    return intent\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 4. DATA RETRIEVAL ENGINE\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef get_all_employees() -> List[Dict[str, Any]]:\n    \"\"\"Return flat list of all employees with department info.\"\"\"\n    employees = []\n    for dept in ENTERPRISE_DATA[\"departments\"]:\n        for emp in dept[\"employees\"]:\n            employees.append({**emp, \"department\": dept[\"name\"]})\n    return employees\n\n\ndef get_all_projects() -> List[Dict[str, Any]]:\n    return ENTERPRISE_DATA[\"projects\"]\n\n\ndef filter_employees(intent: QuestionIntent) -> List[Dict[str, Any]]:\n    emps = get_all_employees()\n    if intent.department:\n        emps = [e for e in emps if e[\"department\"] == intent.department]\n    if intent.location:\n        emps = [e for e in emps if e[\"location\"].lower() == intent.location.lower()]\n    if intent.entity_name:\n        emps = [e for e in emps if intent.entity_name.lower() in e[\"name\"].lower()]\n    return emps\n\n\ndef filter_projects(intent: QuestionIntent) -> List[Dict[str, Any]]:\n    projs = get_all_projects()\n    if intent.department:\n        projs = [p for p in projs if p[\"department\"] == intent.department]\n    if intent.status:\n        projs = [p for p in projs if p[\"status\"] == intent.status]\n    return projs\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 5. ANSWER GENERATOR\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef fmt_money(val: float) -> str:\n    return f\"${val: