0\n10.5,25.0,0.0\n11.0,28.0,0.0\n11.5,30.0,0.0\n12.0,30.0,0.0\n12.5,30.0,0.0\n13.0,25.0,0.0\n13.5,25.0,0.0\n14.0,25.0,0.0\n14.5,25.0,0.0\n15.0,25.0,0.0\n15.5,25.0,0.0\n16.0,25.0,0.0\n16.5,25.0,0.0\n17.0,25.0,0.0\n17.5,25.0,0.0\n18.0,25.0,0.0\n18.5,25.0,0.0\n19.0,25.0,0.0\n19.5,25.0,0.0\n20.0,25.0,0.0\n```\n\n## 3. Python Simulation Script\n\n**`pid_simulation.py`**\n```python\n#!/usr/bin/env python3\n\"\"\"\nPID Controller Simulation\n- Reads YAML config for PID gains and vehicle parameters\n- Reads CSV time series for lead vehicle speed and road grade\n- Simulates vehicle dynamics with PID cruise control\n- Outputs results CSV and prints performance metrics\n\"\"\"\n\nimport yaml\nimport csv\nimport math\nimport sys\nfrom dataclasses import dataclass\nfrom typing import List, Tuple, Optional\n\n\n# \u2500\u2500\u2500 YAML Config Loading \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef load_config(path: str) -> dict:\n    \"\"\"Load and validate YAML configuration file.\"\"\"\n    try:\n        with open(path, 'r') as f:\n            config = yaml.safe_load(f)\n    except FileNotFoundError:\n        print(f\"ERROR: Config file '{path}' not found.\")\n        sys.exit(1)\n    except yaml.YAMLError as e:\n        print(f\"ERROR: Failed to parse YAML config: {e}\")\n        sys.exit(1)\n\n    # Validate required sections\n    required_sections = ['pid', 'vehicle', 'simulation']\n    for section in required_sections:\n        if section not in config:\n            print(f\"ERROR: Missing required config section: '{section}'\")\n            sys.exit(1)\n\n    # Validate PID params\n    pid = config['pid']\n    for key in ['kp', 'ki', 'kd']:\n        if key not in pid:\n            print(f\"ERROR: Missing PID parameter: '{key}'\")\n            sys.exit(1)\n\n    return config\n\n\n# \u2500\u2500\u2500 CSV Time Series Loading \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef load_sensor_csv(path: str) -> List[dict]:\n    \"\"\"\n    Load CSV time series data.\n    Expected columns: time, lead_vehicle_speed, road_grade\n    Handles missing values by forward-filling.\n    \"\"\"\n    data = []\n    try:\n        with open(path, 'r') as f:\n            reader = csv.DictReader(f)\n            for row in reader:\n                entry = {\n                    'time': float(row['time']),\n                    'lead_vehicle_speed': row.get('lead_vehicle_speed', ''),\n                    'road_grade': row.get('road_grade', ''),\n                }\n                data.append(entry)\n    except FileNotFoundError:\n        print(f\"ERROR: Sensor CSV file '{path}' not found.\")\n        sys.exit(1)\n    except (KeyError, ValueError) as e:\n        print(f\"ERROR: Failed to parse sensor CSV: {e}\")\n        sys.exit(1)\n\n    # Forward-fill missing values\n    last_lead_speed = 0.0\n    last_grade = 0.0\n    for entry in data:\n        if entry['lead_vehicle_speed'] == '' or entry['lead_vehicle_speed'] is None:\n            entry['lead_vehicle_speed'] = last_lead_speed\n        else:\n            entry['lead_vehicle_speed'] = float(entry['lead_vehicle_speed'])\n            last_lead_speed = entry['lead_vehicle_speed']\n\n        if entry['road_grade'] == '' or entry['road_grade'] is None:\n            entry['road_grade'] = last_grade\n        else:\n            entry['road_grade'] = float(entry['road_grade'])\n            last_grade = entry['road_grade']\n\n    return data\n\n\ndef interpolate_sensor(sensor_data: List[dict], t: float) -> Tuple[float, float]:\n    \"\"\"Interpolate sensor values at time t from the discrete CSV data.\"\"\"\n    if not sensor_data:\n        return 0.0, 0.0\n\n    # Before first sample\n    if t <= sensor_data[0]['time']:\n        return sensor_data[0]['lead_vehicle_speed'], sensor_data[0]['road_grade']\n\n    # After last sample\n    if t >= sensor_data[-1]['time']:\n        return sensor_data[-1]['lead_vehicle_speed'], sensor_data[-1]['road_grade']\n\n    # Find bracketing samples\n    for i in range(len(sensor_data) - 1):\n        t0 = sensor_data[i]['time']\n        t1 = sensor_data[i + 1]['time']\n        if t0 <= t <= t1:\n            alpha = (t - t0) / (t1 - t0) if (t1 - t0) > 0 else 0.0\n            lead_speed = (1 - alpha) * sensor_data[i]['lead_vehicle_speed'] + \\\n                         alpha * sensor_data[i + 1]['lead_vehicle_speed']\n            grade = (1 - alpha) * sensor_data[i]['road_grade'] + \\\n                    alpha * sensor_data[i + 1]['road_grade']\n            return lead_speed, grade\n\n    return sensor_data[-1]['lead_vehicle_speed'], sensor_data[-1]['road_grade']\n\n\n# \u2500\u2500\u2500 PID Controller \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n@dataclass\nclass PIDState:\n    integral: float = 0.0\n    prev_error: float = 0.0\n    prev_output: float = 0.0\n\n\nclass PIDController:\n    def __init__(self, kp: float, ki: float, kd: float,\n                 integral_limit: float, output_min: float, output_max: float):\n        self.kp = kp\n        self.ki = ki\n        self.kd = kd\n        self.integral_limit = integral_limit\n        self.output_min = output_min\n        self.output_max = output_max\n        self.state = PIDState()\n\n    def compute(self, error: float, dt: float) -> float:\n        \"\"\"\n        Compute PID control output.\n        error = setpoint - measured_value\n        \"\"\"\n        if dt <= 0:\n            return self.state.prev_output\n\n        # Proportional\n        p_term = self.kp * error\n\n        # Integral with anti-windup\n        self.state.integral += error * dt\n        self.state.integral = max(-self.integral_limit,\n                                  min(self.integral_limit, self.state.integral))\n        i_term = self.ki * self.state.integral\n\n        # Derivative (on error)\n        derivative = (error - self.state.prev_error) / dt\n        d_term = self.kd * derivative\n\n        # Total output\n        output = p_term + i_term + d_term\n\n        # Clamp output\n        output = max(self.output_min, min(self.output_max, output))\n\n        # Update state\n        self.state.prev_error = error\n        self.state.prev_output = output\n\n        return output\n\n    def reset(self):\n        self.state = PIDState()\n\n\n# \u2500\u2500\u2500 Vehicle Dynamics \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n@dataclass\nclass VehicleState:\n    speed: float = 0.0        # m/s\n    position: float = 0.0     # m\n    acceleration: float = 0.0 # m/s^2\n\n\nclass VehicleModel:\n    \"\"\"Simple longitudinal vehicle dynamics model.\"\"\"\n\n    GRAVITY = 9.81  # m/s^2\n    AIR_DENSITY = 1.225  # kg/m^3\n    FRONTAL_AREA = 2.2  # m^2\n\n    def __init__(self, mass: float, drag_coefficient: float,\n                 rolling_resistance: float, max_throttle_force: float,\n                 max_brake_force: float):\n        self.mass = mass\n        self.cd = drag_coefficient\n        self.cr = rolling_resistance\n        self.max_throttle = max_throttle_force\n        self.max_brake = max_brake_force\n\n    def update(self, state: VehicleState, control_output: float,\n               road_grade: float, dt: float) -> VehicleState:\n        \"\"\"\n        Update vehicle state given control output (normalized -1 to 1 range\n        mapped to force), road grade, and time step.\n        \"\"\"\n        # Map control output to force\n        # control_output > 0 => throttle, < 0 => brake\n        if control_output >= 0:\n            force = control_output * self.max_throttle\n        else:\n            force = control_output * self.max_brake\n\n        # Resistive forces\n        # Aerodynamic drag: F_drag = 0.5 * rho * Cd * A * v^2\n        drag = 0.5 * self.AIR_DENSITY * self.cd * self.FRONTAL_AREA * \\\n               state.speed * abs(state.speed)\n\n        # Rolling resistance: F_roll = Cr * m * g * cos(theta)\n        cos_grade = math.cos(math.atan(road_grade))\n        rolling = self.cr * self.mass * self.GRAVITY * cos_grade\n        if state.speed > 0:\n            rolling *= -1.0  # opposes motion\n        elif state.speed < 0:\n            rolling *= 1.0\n        else:\n            rolling = 0.0\n\n        # Grade force: F_grade = -m * g * sin(theta)\n        sin_grade = math.sin(math.atan(road_grade))\n        grade_force = -self.mass * self.GRAVITY * sin_grade\n\n        # Net force\n        net_force = force + drag + rolling + grade_force\n\n        # Acceleration\n        accel = net_force / self.mass\n\n        # Update speed (Euler integration), prevent negative speed\n        new_speed = state.speed + accel * dt\n        if new_speed < 0:\n            new_speed = 0.0\n            accel = -state.speed / dt if dt > 0 else 0.0\n\n        # Update position\n        new_position = state.position + state.speed * dt + \\\n                       0.5 * accel * dt * dt\n\n        return VehicleState(\n            speed=new_speed,\n            position=new_position,\n            acceleration=accel\n        )\n\n\n# \u2500\u2500\u2500 Simulation Metrics \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef compute_metrics(time_list: List[float], speed_list: List[float],\n                    target_speed: float) -> dict:\n    \"\"\"Compute performance metrics for the simulation.\"\"\"\n    if not time_list or not speed_list:\n        return {}\n\n    # Rise time: time to first reach 90% of target\n    rise_time = None\n    threshold = 0.9 * target_speed\n    for i, s in enumerate(speed_list):\n        if s >= threshold:\n            rise_time = time_list[i]\n            break\n\n    # Overshoot: max speed above target\n    max_speed = max(speed_list)\n    overshoot_pct = ((max_speed - target_speed) / target_speed * 100.0) \\\n        if max_speed > target_speed else 0.0\n\n    # Steady-state error: average error in last 20% of simulation\n    n = len(speed_list)\n    start_idx = int(0.8 * n)\n    if start_idx < n:\n        steady_errors = [abs(target_speed - s) for s in speed_list[start_idx:]]\n        steady_state_error = sum(steady_errors) / len(steady_errors)\n    else:\n        steady_state_error = abs(target_speed - speed_list[-1])\n\n    # Settling time: time after which speed stays within 2% of target\n    settling_time = None\n    band = 0.02 * target_speed\n    for i in range(len(speed_list) - 1, -1, -1):\n        if abs(speed_list[i] - target_speed) > band:\n            if i + 1 < len(speed_list):\n                settling_time = time_list[i + 1]\n            break\n\n    # RMSE\n    errors = [(target_speed - s) for s in speed_list]\n    rmse = math.sqrt(sum(e * e for e in errors) / len(errors))\n\n    return {\n        'rise_time_s': rise_time,\n        'overshoot_pct': overshoot_pct,\n        'steady_state_error_mps': steady_state_error,\n        'settling_time_s': settling_time,\n        'rmse_mps': rmse,\n        'max_speed_mps': max_speed,\n        'final_speed_mps': speed_list[-1],\n    }\n\n\n# \u2500\u2500\u2500 Main Simulation \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef run_simulation(config_path: str, sensor_csv_path: str):\n    \"\"\"Run the full PID simulation.\"\"\"\n\n    # Load configuration\n    print(f\"Loading config from: {config_path}\")\n    config = load_config(config_path)\n\n    pid_cfg = config['pid']\n    veh_cfg = config['vehicle']\n    sim_cfg = config['simulation']\n\n    dt = sim_cfg['dt']\n    target_speed = sim_cfg['target_speed']\n    output_file = sim_cfg.get('output_file', 'results.csv')\n\n    # Load sensor data\n    print(f\"Loading sensor data from: {sensor_csv_path}\")\n    sensor_data = load_sensor_csv(sensor_csv_path)\n    print(f\"  Loaded {len(sensor_data)} sensor samples\")\n\n    # Determine simulation duration from sensor data\n    t_end = sensor_data[-1]['time']\n    n_steps = int(t_end / dt) + 1\n\n    # Initialize components\n    pid = PIDController(\n        kp=pid_cfg['kp'],\n        ki=pid_cfg['ki'],\n        kd=pid_cfg['kd'],\n        integral_limit=pid_cfg.get('integral_limit', 50.0),\n        output_min=pid_cfg.get('output_min', -5.0),\n        output_max=pid_cfg.get('output_max', 3.0),\n    )\n\n    vehicle = VehicleModel(\n        mass=veh_cfg['mass'],\n        drag_coefficient=veh_cfg['drag_coefficient'],\n        rolling_resistance=veh_cfg['rolling_resistance'],\n        max_throttle_force=veh_cfg['max_throttle_force'],\n        max_brake_forc