space(0, 27, 2000) * u.day \n    flux = np.ones_like(time.value)\n    \n    # Inject a transit signal\n    period_true = 6.0 * u.day\n    t0 = 2.0 * u.day\n    duration = 0.12 * u.day\n    depth = 0.01\n    \n    phase = ((time.value - t0.value) % period_true.value) / period_true.value\n    in_transit = (phase < duration.value / period_true.value) | (phase > 1 - duration.value / period_true.value)\n    flux[in_transit] -= depth\n    flux += np.random.normal(0, 0.002, len(time)) # Add white noise\n\n# ==========================================\n# 2. Setup and Run Box Least Squares (BLS)\n# ==========================================\n# Define the search grid for periods and durations\n# For a 27-day TESS sector, searching 1 to 13 days covers up to 2 transits\nperiod_grid = np.linspace(1, 13, 10000) * u.day\nduration_grid = np.linspace(0.05, 0.25, 30) * u.day\n\n# Initialize the BLS model\nprint(\"Computing BLS periodogram...\")\nbls = BoxLeastSquares(time, flux)\n\n# Compute the periodogram\nperiodogram = bls.power(period_grid, duration_grid)\n\n# Extract the best-fit parameters\nbest_idx = np.argmax(periodogram.power)\nbest_period = periodogram.period[best_idx]\nbest_duration = periodogram.duration[best_idx]\nbest_t0 = periodogram.transit_time[best_idx]\nbest_depth = periodogram.depth[best_idx]\n\nprint(\"\\n--- BLS Best Fit Results ---\")\nprint(f\"Period:   {best_period.value:.4f} days\")\nprint(f\"Duration: {best_duration.value:.4f} days\")\nprint(f\"Epoch (t0): {best_t0.value:.4f} days\")\nprint(f\"Depth:    {best_depth.value:.4f}\")\n\n# ==========================================\n# 3. Visualize the Results\n# ==========================================\nfig, axes = plt.subplots(2, 1, figsize=(10, 8))\n\n# Plot 1: BLS Periodogram\naxes[0].plot(periodogram.period.value, periodogram.power, 'k-', lw=0.8)\naxes[0].axvline(best_period.value, color='red', linestyle='--', lw=1.5, \n                label=f'Best Period: {best_period.value:.3f} days')\naxes[0].set_xlabel('Period [days]')\naxes[0].set_ylabel('BLS Power')\naxes[0].set_title('Box Least Squares (BLS) Periodogram')\naxes[0].legend()\n\n# Plot 2: Phase-Folded Light Curve\n# Calculate phase relative to the best transit time\nphase_fold = ((time.value - best_t0.value) % best_period.value) / best_period.value\nphase_fold[phase_fold > 0.5] -= 1.0\nphase_fold *= best_period.value # Convert back to days for x-axis\n\n# Sort by phase for clean plotting\nsort_idx = np.argsort(phase_fold)\n\naxes[1].plot(phase_fold[sort_idx], flux[sort_idx], 'k.', markersize=2, alpha=0.6, label='Data')\naxes[1].set_xlabel('Phase [days]')\naxes[1].set_ylabel('Relative Flux')\naxes[1].set_title(f'Phase-Folded Light Curve (P = {best_period.value:.3f} days)')\naxes[1].legend()\n\nplt.tight_layout()\nplt.show()\n```\n\n### How it Works:\n1. **Data Ingestion**: Uses `lightkurve` to grab a TESS FITS lightcurve, cleans it, and converts the time/flux arrays into `astropy.units.Quantity` objects to maintain strict unit tracking.\n2. **Grid Definition**: BLS requires a grid of trial periods and trial durations. The period grid is set from 1 to 13 days (capturing planets with up to 2 transits in a 27-day TESS sector), and the duration grid spans typical hot Jupiter/Neptune transit lengths.\n3. **BLS Execution**: `astropy.timeseries.BoxLeastSquares` evaluates the signal-to-noise ratio of a box-shaped dip at every combination of period, duration, and phase. \n4. **Extraction & Plotting**: The periodogram's maximum power index reveals the most statistically significant period, duration, epoch ($t_0$), and depth. The script then folds the raw data on the detected period to visually confirm the V-shaped transit dip.", "solver_finish_reason": "stop"}
