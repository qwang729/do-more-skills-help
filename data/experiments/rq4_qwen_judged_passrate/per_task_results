iles_list:\n        print(\"No valid SMILES fetched. Exiting.\")\n        exit(1)\n\n    # 2. Perform Tanimoto Similarity Search\n    query_smi = smiles_list[0]  # e.g., Aspirin\n    print(f\"\\n--- Similarity Search (Query: {query_smi}) ---\")\n    hits = perform_similarity_search(query_smi, smiles_list, threshold=0.2)\n    for smi, sim in hits:\n        print(f\"Tanimoto: {sim:.3f} | {smi}\")\n\n    # 3. Cluster using Custom Tanimoto Distance Metric in DBSCAN\n    print(\"\\n--- DBSCAN Clustering (Custom Tanimoto Distance) ---\")\n    # eps=0.4 means molecules must have a Tanimoto similarity >= 0.6 to be clustered together\n    clustered_smiles, labels = cluster_molecules(smiles_list, eps=0.4, min_samples=1)\n    \n    for smi, label in zip(clustered_smiles, labels):\n        cluster_name = f\"Cluster {label}\" if label != -1 else \"Noise\"\n        print(f\"{cluster_name:10} | {smi}\")\n```", "solver_finish_reason": "stop"}
