eturn json.loads(response.choices[0].message.content).get(\"product\")\n\ndef decompose_query(question: str) -> List[str]:\n    \"\"\"Breaks complex questions into sequential multi-hop sub-queries.\"\"\"\n    prompt = f\"\"\"\n    Break down the following enterprise question into 1-3 sequential sub-queries \n    required to answer it. If it's a simple question, return just the original question.\n    \n    Question: {question}\n    Return JSON: {{\"sub_queries\": [\"query1\", \"query2\"]}}\n    \"\"\"\n    response = client.chat.completions.create(\n        model=\"gpt-4o\",\n        messages=[{\"role\": \"user\", \"content\": prompt}],\n        response_format={\"type\": \"json_object\"}\n    )\n    return json.loads(response.choices[0].message.content).get(\"sub_queries\", [question])\n\n# ==========================================\n# 4. Main Execution Pipeline\n# ==========================================\n\ndef answer_enterprise_question(question: str, store: EnterpriseArtifactStore, known_products: List[str]) -> EnterpriseSearchResponse:\n    # Step 1: Disambiguate Product (Prevent Cross-Product Leakage)\n    target_product = disambiguate_product(question, known_products)\n    \n    # Step 2: Multi-Hop Query Decomposition\n    sub_queries = decompose_query(question)\n    \n    # Step 3: Retrieve Evidence with Metadata Filtering\n    all_evidence = []\n    for sq in sub_queries:\n        results = store.search(sq, product_filter=target_product, top_k=3)\n        all_evidence.extend(results)\n        \n    # Deduplicate artifacts\n    seen_ids = set()\n    unique_evidence = []\n    for ev in all_evidence:\n        if ev[\"id\"] not in seen_ids:\n            seen_ids.add(ev[\"id\"])\n            unique_evidence.append(ev)\n            \n    # Format context for the LLM\n    context_str = \"\\n\\n---\\n\\n\".join([\n        f\"[{e['id']}] (Type: {e['type']} | Product: {e['product']} | URL: {e.get('url', 'N/A')})\\n{e['content']}\" \n        for e in unique_evidence