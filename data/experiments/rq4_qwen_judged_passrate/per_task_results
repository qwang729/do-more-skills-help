(\"EXAMPLE 3: Fingerprint Type Comparison\")\n    print(\"=\" * 70)\n    \n    fp_types = [\"morgan\", \"rdkit\", \"maccs\", \"topological\"]\n    query_mol = smiles_to_mol(pubchem_compounds[\"Aspirin\"])\n    \n    print(f\"\\nQuery: Aspirin\")\n    print(f\"\\n{'Compound':<20}\", end=\"\")\n    for fpt in fp_types:\n        print(f\"{fpt:<12}\", end=\"\")\n    print()\n    print(\"-\" * 68)\n    \n    for name in pubchem_compounds:\n        if name == \"Aspirin\":\n            continue\n        target_mol = smiles_to_mol(pubchem_compounds[name])\n        print(f\"{name:<20}\", end=\"\")\n        for fpt in fp_types:\n            if fpt == \"maccs\":\n                fp_q = generate_fingerprint(query_mol, fp_type=fpt)\n                fp_t = generate_fingerprint(target_mol, fp_type=fpt)\n            else:\n                fp_q = generate_fingerprint(query_mol, fp_type=fpt, n_bits=2048)\n                fp_t = generate_fingerprint(target_mol, fp_type=fpt, n_bits=2048)\n            sim = tanimoto_similarity(fp_q, fp_t)\n            print(f\"{sim:<12.4f}\", end=\"\")\n        print()\n\n    # ---- Example 4: Performance benchmark ----\n    print(\"\\n\" + \"=\" * 70)\n    print(\"EXAMPLE 4: Performance Benchmark\")\n    print(\"=\" * 70)\n    \n    # Create a larger database by repeating compounds with slight variations\n    large_db = list(pubchem_compounds.values()) * 50  # ~1000 compounds\n    \n    query_mol = smiles_to_mol(pubchem_compounds[\"Aspirin\"])\n    query_fp = generate_fingerprint(query_mol, fp_type=\"morgan\", radius=2, n_bits=2048)\n    \n    db_fps = []\n    for smi in large_db:\n        mol = smiles_to_mol(smi)\n        if mol:\n            db_fps.append(generate_fingerprint(mol, fp_type=\"morgan\", radius=2, n_bits=2048))\n    \n    start = time.time()\n    sims = bulk_tanimoto_similarity(query_fp, db_fps)\n    elapsed = time.time() - start\n    \n    max_sim = max(sims)\n    mean_sim = np.mean(sims)\n    \n    print(f\"\\nDatabase size: {len(db_fp