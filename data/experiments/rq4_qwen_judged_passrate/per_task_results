00\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nclass CIFParser:\n    \"\"\"Minimal but robust CIF parser supporting data blocks, key-value pairs,\n    and loop_ constructs.  Handles single-quoted, double-quoted, and\n    semicolon-delimited text fields.\"\"\"\n\n    def __init__(self, text: str):\n        self.text = text\n        self.data_blocks: Dict[str, Dict[str, Any]] = OrderedDict()\n        self._parse()\n\n    # \u2500\u2500 public \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    def get_block(self, name: str = None) -> Dict[str, Any]:\n        if name:\n            return self.data_blocks[name]\n        return next(iter(self.data_blocks.values()))\n\n    # \u2500\u2500 internals \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    def _tokenize(self) -> List[str]:\n        tokens: List[str] = []\n        i = 0\n        n = len(self.text)\n        while i < n:\n            c = self.text[i]\n            # skip whitespace\n            if c in (' ', '\\t', '\\n', '\\r'):\n                i += 1\n                continue\n            # comment\n            if c == '#':\n                while i < n and self.text[i] != '\\n':\n                    i += 1\n                continue\n            # semicolon-delimited text field (must be at start of line)\n            if c == ';' and (i == 0 or self.text[i-1] == '\\n'):\n                j = i + 1\n                while j < n:\n                    if self.text[j] == '\\n' and j + 1 < n and self.text[j+1] == ';':\n                        tokens.append(self.text[i+1:j+1])\n                        i = j + 2\n                        break\n                    j += 1\n                else:\n                    tokens.append(self.text[i+1:])\n                    i = n\n                continue\n            # quoted string\n            if c in (\"'\", '\"'):\n                quote = c\n                j = i + 1\n                while j < n and self.text[j] != quote:\n                    j += 1\n                tokens.append(self.text[i+1:j])\n                i = j + 1\n                continue\n            # ordinary token\n            j = i\n            while j < n and self.text[j] not in (' ', '\\t', '\\n', '\\r'):\n                j += 1\n            tokens.append(self.text[i:j])\n            i = j\n        return tokens\n\n    def _parse(self):\n        tokens = self._tokenize()\n        idx = 0\n        current_block = None\n        while idx < len(tokens):\n            tok = tokens[idx]\n            if tok.startswith('data_'):\n                current_block = tok[5:]\n                self.data_blocks[current_block] = {}\n                idx += 1\n                continue\n            if tok.lower() == 'loop_':\n                idx += 1\n                # collect tag names\n                tags = []\n                while idx < len(tokens) and tokens[idx].startswith('_'):\n                    tags.append(tokens[idx])\n                    idx += 1\n                # collect values\n                values = []\n                while idx < len(tokens) and not tokens[idx].startswith('_') \\\n                        and not tokens[idx].startswith('data_') \\\n                        and tokens[idx].lower() != 'loop_':\n                    values.append(tokens[idx])\n                    idx += 1\n                # store as list-of-dicts\n                ntags = len(tags)\n                rows = []\n                for vi in range(0, len(values), ntags):\n                    row = {}\n                    for ti, t in enumerate(tags):\n                        row[t] = values[vi + ti] if vi + ti < len(values) else '?'\n                    rows.append(row)\n                if current_block is not None:\n                    self.data_blocks[current_block].setdefault('_loops', []).append(\n                        (tags, rows))\n                    # also store first row under tag names for convenience\n                    if rows:\n                        for t in tags:\n                            self.data_blocks[current_block][t] = [r[t] for r in rows]\n                continue\n            if tok.startswith('_'):\n                key = tok\n                idx += 1\n                val = tokens[idx] if idx < len(tokens) else '?'\n                idx += 1\n                if current_block is not None:\n                    self.data_blocks[current_block][key] = val\n                continue\n            idx += 1\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 2.  SYMMETRY OPERATIONS  (Hall / Hermann-Mauguin \u2192 4\u00d74 matrices)\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n# A compact table of common space-group symmetry operations expressed as\n# xyz triplets.  For a full production system one would embed the complete\n# International Tables; here we cover the most common groups so the demo and\n# typical CIF files work out of the box.\n\n_SYMM_OPS: Dict[str, List[str]] = {\n    \"P 1\":           [\"x,y,z\"],\n    \"P -1\":          [\"x,y,z\", \"-x,-y,-z\"],\n    \"P 2\":           [\"x,y,z\", \"-x,y,-z\"],\n    \"P 21\":          [\"x,y,z\", \"-x,y+1/2,-z\"],\n    \"P m\":           [\"x,y,z\", \"x,-y,z\"],\n    \"P 2/m\":         [\"x,y,z\", \"-x,y,-z\", \"-x,-y,-z\", \"x,-y,z\"],\n    \"P 21/m\":        [\"x,y,z\", \"-x,y+1/2,-z\", \"-x,-y,-z\", \"x,-y+1/2,z\"],\n    \"P m m 2\":       [\"x,y,z\", \"-x,-y,z\", \"x,-y,z\", \"-x,y,z\"],\n    \"P m c 21\":      [\"x,y,z\", \"-x,-y,z+1/2\", \"x,-y,z+1/2\", \"-x,y,z\"],\n    \"P c c a\":       [\"x,y,z\", \"-x,-y,z\", \"-x,y,-z\", \"x,-y,-z\",\n                       \"x+1/2,y+1/2,z\", \"-x+1/2,-y+1/2,z\",\n                       \"-x+1/2,y,-z\", \"x+1/2,-y,-z\"],\n    \"P n m a\":       [\"x,y,z\", \"-x+1/2,-y,z+1/2\", \"-x,y+1/2,-z+1/2\",\n                       \"x+1/2,-y+1/2,-z\", \"-x,-y,-z\", \"x+1/2,y,-z+1/2\",\n                       \"x,-y+1/2,z+1/2\", \"-x+1/2,y+1/2,z\"],\n    \"P 4/m m m\":     [\"x,y,z\", \"-x,-y,z\", \"-y,x,z\", \"y,-x,z\",\n                       \"-x,y,-z\", \"x,-y,-z\", \"y,x,-z\", \"-y,-x,-z\",\n                       \"-x,-y,-z\", \"x,y,-z\", \"y,-x,-z\", \"-y,x,-z\",\n                       \"x,-y,z\", \"-x,y,z\", \"-y,-x,z\", \"y,x,z\"],\n    \"P 6/m m m\":     [\"x,y,z\", \"-y,x-y,z\", \"-x+y,-x,z\", \"-x,-y,z\",\n                       \"y,-x+y,z\", \"x-y,x,z\",\n                       \"y,x,-z\", \"x-y,-y,-z\", \"-x,-x+y,-z\",\n                       \"-y,-x,-z\", \"x,y,-z\", \"-x+y,y,-z\",\n                       \"-x,-y,-z\", \"y,-x+y,-z\", \"x-y,x,-z\",\n                       \"x,y,-z\", \"-y,x-y,-z\", \"-x+y,-x,-z\",\n                       \"-y,-x,z\", \"-x+y,y,z\", \"x,y,z\"],  # simplified\n    \"F m -3 m\":      None,  # placeholder \u2013 generated below\n    \"I m -3 m\":      None,\n    \"F d -3 m\":      None,\n}\n\n# For cubic Fm-3m (#225) we generate the 192 ops from the 48 point-group\n# operations of m-3m plus the FCC centering translations.\n\ndef _generate_cubic_fm3m() -> List[str]:\n    \"\"\"Generate all 192 symmetry operations for Fm-3m (#225).\"\"\"\n    # 48 point-group ops of m-3m as (sign_x, sign_y, sign_z, perm)\n    import itertools\n    ops = []\n    for perm in itertools.permutations([0, 1, 2]):\n        for signs in itertools.product([1, -1], repeat=3):\n            ops.append((perm, signs))\n    # FCC centering translations\n    centering = [(0,0,0), (0,1/2,1/2), (1/2,0,1/2), (1/2,1/2,0)]\n    result = []\n    for perm, signs in ops:\n        for cx, cy, cz in centering:\n            labels = ['x', 'y', 'z']\n            parts = []\n            for i in range(3):\n                s = signs[i]\n                p = perm[i]\n                lbl = labels[p]\n                if s == -1:\n                    parts.append(f\"-{lbl}\")\n                else:\n                    parts.append(lbl)\n            # add centering\n            triplet = \",\".join(parts)\n            # We'll encode centering as fractional offsets\n            result.append((triplet, (cx, cy, cz)))\n    # Convert to string form \"x,y,z\" with fractions baked in\n    str_ops = []\n    for triplet, (cx, cy, cz) in result:\n        parts = triplet.split(\",\")\n        new_parts = []\n        for k, p in enumerate(parts):\n            c = [cx, cy, cz][k]\n            if c == 0:\n                new_parts.append(p)\n            else:\n                frac = _frac_str(c)\n                new_parts.append(f\"{p}+{frac}\")\n        str_ops.append(\",\".join(new_parts))\n    return str_ops\n\ndef _frac_str(v: float) -> str:\n    for d in range(1, 13):\n        n = round(v * d)\n        if abs(n / d - v) < 1e-9:\n            if d == 1:\n                return str(n)\n            return f\"{n}/{d}\"\n    return str(v)\n\n_SYMM_OPS[\"F m -3 m\"] = _generate_cubic_fm3m()\n\n\ndef _parse_symop_string(s: str) -> Tuple[List[List[float]], List[float]]:\n    \"\"\"Parse a symmetry-operation string like 'x,-y,z+1/2' into a 3\u00d73 rotation\n    matrix R and a translation vector t such that x' = R\u00b7x + t.\"\"\"\n    parts = s.replace(' ', '').split(',')\n    R = [[0.0]*3 for _ in range(3)]\n    t = [0.0]*3\n    var_map = {'x': 0, 'y': 1, 'z': 2}\n    for i, part in enumerate(parts):\n        # tokenize into signed terms\n        terms = re.findall(r'[+-]?[^+-]+', part)\n        for term in terms:\n            term = term.strip()\n            if not term:\n                continue\n            # check for variable\n            found_var = False\n            for vname, vidx in var_map.items():\n                if vname in term:\n                    coeff_str = term.replace(vname, '').replace(' ', '')\n                    if coeff_str in ('', '+'):\n                        coeff = 1.0\n                    elif coeff_str == '-':\n                        coeff = -1.0\n                    else:\n                        coeff = float(coeff_str)\n                    R[i][vidx] = coeff\n                    found_var = True\n                    break\n            if not found_var:\n                # pure translation\n                if '/' in term:\n                    num, den = term.split('/')\n                    t[i] = float(num) / float(den)\n                else:\n                    t[i] = float(term)\n    return R, t\n\n\ndef get_symmetry_operations(space_group: str) -> List[Tuple[List[List[float]], List[float]]]:\n    \"\"\"Return list of (R, t) for the given space group.\"\"\"\n    sg = space_group.strip()\n    # Try direct lookup\n    ops_str = _SYMM_OPS.get(sg)\n    if ops_str is None:\n        # Try common alternatives\n        alt = {\n            \"Fm-3m\": \"F m -3 m\",\n            \"Fm3m\":  \"F m -3 m\",\n            \"Fm3\u0304m\":  \"F m -3 m\",\n            \"Pnma\":  \"P n m a\",\n            \"Pmma\":  \"P m m a\",\n            \"P21/m\": \"P 21/m\",\n            \"P2_1/m\": \"P 21/m\",\n            \"Pmm2\":  \"P m m 2\",\n            \"Pmc2_1\": \"P m c 21\",\n            \"P2_1/c\": \"P 21/c\",\n            \"P21/c\":  \"P 21/c\",\n            \"P4/mmm\": \"P 4/m m m\",\n            \"P6/mmm\": \"P 6/m m m\",\n            \"Im-3m\":  \"I m -3 m\",\n            \"Fd-3m\":  \"F d -3 m\",\n        }\n        sg2 = alt.get(sg, sg)\n        ops_str = _SYMM_OPS.get(sg2)\n    if ops_str is None:\n        # Fallback: identity only\n        return [[[1,0,0],[0,1,0],[0,0,1]], [0,0,0]],\n    result = []\n    for s in ops_str:\n        R, t = _parse_symop_string(s)\n        result.append((R, t))\n    return result\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 3.  WYCKOFF POSITION DATABASE  (selected common space groups)\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u250