],\n            'techreport': ['author', 'title', 'institution', 'year'],\n            'misc': [],\n            'unpublished': ['author', 'title', 'note'],\n        }\n\n        required = required_fields.get(self.entry_type.lower(), ['author', 'title', 'year'])\n\n        for rf in required:\n            if rf not in self.fields or not self.fields[rf].strip():\n                errors.append(f\"Missing required field '{rf}' in @{self.entry_type}{{{self.cite_key}}}\")\n\n        # Check year format\n        if 'year' in self.fields:\n            year = self.fields['year'].strip()\n            if not re.match(r'^\\d{4}$', year):\n                warnings.append(f\"Year '{year}' in {self.cite_key} is not a 4-digit number\")\n\n        # Check author format (should have commas or 'and')\n        if 'author' in self.fields:\n            author = self.fields['author'].strip()\n            if author and not re.search(r'[,]', author) and ' and ' not in author.lower():\n                if len(author.split()) > 2:\n                    warnings.append(f\"Author '{author}' in {self.cite_key} may not be in 'Last, First' format\")\n\n        # Check for empty fields\n        for k, v in self.fields.items():\n            if not v.strip():\n                warnings.append(f\"Empty field '{k}' in {self.cite_key}\")\n\n        # Check DOI format if present\n        if 'doi' in self.fields:\n            doi = self.fields['doi'].strip()\n            if doi and not re.match(r'^10\\.\\d{4,}/', doi):\n                warnings.append(f\"DOI '{doi}' in {self.cite_key} may be malformed\")\n\n        # Check URL format if present\n        if 'url' in self.fields:\n            url = self.fields['url'].strip()\n            if url and not re.match(r'^https?://', url):\n                warnings.append(f\"URL '{url}' in {self.cite_key} may be malformed\")\n\n        return errors, warnings\n\n\nclass BibTeXParser:\n    def __init__(self):\n        self.entries: List[BibTeXEntry] = []\n        self.errors: List[str] = []\n\n    def parse(self, text: str) -> List[BibTeXEntry]:\n        \"\"\"Parse BibTeX text into entries.\"\"\"\n        self.entries = []\n        self.errors = []\n\n        # Remove comments (lines starting with %)\n        lines = text.split('\\n')\n        cleaned_lines = []\n        for i, line in enumerate(lines):\n            stripped = line.strip()\n            if not stripped.startswith('%'):\n                cleaned_lines.append(line)\n        text = '\\n'.join(cleaned_lines)\n\n        # Find all entries using regex\n        # Match @type{key, ... }\n        pattern = re.compile(\n            r'@(\\w+)\\s*\\{([^,]*),\\s*(.*?)\\n\\s*\\}',\n            re.DOTALL | re.MULTILINE\n        )\n\n        for match in pattern.finditer(text):\n            entry_type = match.group(1).strip()\n            cite_key = match.group(2).strip()\n            fields_text = match.group(3).strip()\n            raw = match.group(0)\n            line_num = text[:match.start()].count('\\n') + 1\n\n            fields = self._parse_fields(fields_text)\n            entry = BibTeXEntry(\n                entry_type=entry_type,\n                cite_key=cite_key,\n                fields=fields,\n                raw=raw,\n                line_number=line_num\n            )\n            self.entries.append(entry)\n\n        if not self.entries:\n            self.errors.append(\"No valid BibTeX entries found in input.\")\n\n        return self.entries\n\n    def _parse_fields(self, fields_text: str) -> Dict[str, str]:\n        \"\"\"Parse key-value fields from BibTeX entry body.\"\"\"\n        fields = {}\n        # Match field = {value} or field = \"value\" or field = number\n        field_pattern = re.compile(\n            r'(\\w+)\\s*=\\s*(?:\\{((?:[^{}]|\\{[^{}]*\\})*)\\}|\"([^\"]*)\"|(\\d+))',\n            re.DOTALL\n        )\n        for m in field_pattern.finditer(fields_text):\n            key = m.group(1).lower()\n            value = m.group(2) or m.group(3) or m.group(4) or ''\n            # Clean up LaTeX special characters\n            value = self._clean_latex(value.strip())\n            fields[key] = value\n        return fields\n\n    def _clean_latex(self, text: str) -> str:\n        \"\"\"Remove common LaTeX formatting.\"\"\"\n        text = re.sub(r'\\\\[a-zA-Z]+\\{([^}]*)\\}', r'\\1', text)  # \\textbf{...} -> ...\n        text = re.sub(r'\\{([^}]*)\\}', r'\\1', text)  # {text} -> text\n        text = text.replace('---', '\u2014').replace('--', '\u2013')\n        text = re.sub(r'\\\\&', '&', text)\n        text = re.sub(r'\\\\%', '%', text)\n        return text.strip()\n\n    def verify_citations(self, text: str) -> Dict:\n        \"\"\"Verify that \\\\cite{...} references in a LaTeX document match BibTeX entries.\"\"\"\n        cite_keys_in_doc = set(re.findall(r'\\\\cite[pt]?\\{([^}]+)\\}', text))\n        # Expand comma-separated cite keys\n        expanded_keys = set()\n        for key_group in cite_keys_in_doc:\n            for k in key_group.split(','):\n                expanded_keys.add(k.strip())\n\n        bib_keys = {e.cite_key for e in self.entries}\n\n        undefined = expanded_keys - bib_keys\n        unused = bib_keys - expanded_keys\n\n        return {\n            'cited_in_doc': sorted(expanded_keys),\n            'defined_in_bib': sorted(bib_keys),\n            'undefined_citations': sorted(undefined),\n            'unused_entries': sorted(unused),\n            'all_valid': len(undefined) == 0\n        }\n\n    def generate_report(self) -> str:\n        \"\"\"Generate a full verification report.\"\"\"\n        report = []\n        report.append(\"=\" * 60)\n        report.append(\"BIBTEX CITATION VERIFICATION REPORT\")\n        report.append(\"=\" * 60)\n        report.append(f\"Total entries found: {len(self.entries)}\")\n        report.append(\"\")\n\n        all_errors = []\n        all_warnings = []\n\n        for entry in self.entries:\n            errors, warnings = entry.validate()