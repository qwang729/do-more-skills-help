0:\n            line = line[:idx]\n        cleaned_lines.append(line)\n    content = '\\n'.join(cleaned_lines)\n\n    data = {}\n\n    # Parse baseMVA\n    m = re.search(r'mpc\\.baseMVA\\s*=\\s*([\\d.]+)', content)\n    if m:\n        data['baseMVA'] = float(m.group(1))\n    else:\n        data['baseMVA'] = 100.0\n\n    # Generic matrix parser for MATPOWER data matrices\n    def parse_matrix(varname):\n        pattern = rf'mpc\\.{varname}\\s*=\\s*\\[(.*?)\\];'\n        m = re.search(pattern, content, re.DOTALL)\n        if not m:\n            return None\n        matrix_str = m.group(1).strip()\n        if not matrix_str:\n            return np.array([]).reshape(0, 0)\n        rows = []\n        for row_str in matrix_str.split(';'):\n            row_str = row_str.strip()\n            if not row_str:\n                continue\n            # Handle both space and comma separated\n            vals = re.split(r'[\\s,]+', row_str)\n            vals = [v for v in vals if v]\n            if vals:\n                rows.append([float(v) for v in vals])\n        return np.array(rows) if rows else np.array([]).reshape(0, 0)\n\n    data['bus'] = parse_matrix('bus')\n    data['gen'] = parse_matrix('gen')\n    data['branch'] = parse_matrix('branch')\n    data['gencost'] = parse_matrix('gencost')\n\n    return data\n\n\n# =============================================================================\n# 2. NETWORK DATA EXTRACTION\n# =============================================================================\n\ndef extract_network_data(mpc):\n    \"\"\"\n    Extract structured network parameters from parsed MATPOWER data.\n    \n    MATPOWER bus columns:  bus_i, type, Pd, Qd, Gs, Bs, area, Vm, Va, baseKV, zone, Vmax, Vmin\n    MATPOWER gen columns:  bus, Pg, Qg, Qmax, Qmin, Vg, mBase, status, Pmax, Pmin, ...\n    MATPOWER branch cols:  fbus, tbus, r, x, b, rateA, rateB, rateC, ratio, angle, status, angmin, angmax\n    MATPOWER gencost cols: model, startup, shutdown, n, c(n-1)...c0 