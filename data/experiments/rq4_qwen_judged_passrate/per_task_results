s_region = plates.cx[minx:maxx, miny:maxy]\n\n# 3. Proper Coordinate Projection for Planar Distance\n# EPSG:4326 uses degrees. We project to a local Azimuthal Equidistant CRS \n# centered on our region of interest to calculate distances in meters.\ncenter_lon, center_lat = 145, 45\naeqd_crs = f\"+proj=aeqd +lat_0={center_lat} +lon_0={center_lon} +datum=WGS84 +units=m +no_defs\"\n\neq_proj = eq_region.to_crs(aeqd_crs)\nplates_proj = plates_region.to_crs(aeqd_crs)\n\n# 4. Calculate Nearest Plate Boundary and Planar Distance\n# sjoin_nearest finds the closest feature and calculates the distance in the CRS units (meters)\neq_nearest = gpd.sjoin_nearest(eq_proj, plates_proj, distance_col=\"dist_m_planar\")\n\n# 5. Calculate Exact Geodesic Distance\n# Planar distance in a projected CRS has slight distortions over large areas. \n# For exact ellipsoidal distance, we use pyproj.Geod on the original WGS84 geometries.\ngeod = Geod(ellps=\"WGS84\")\nexact_distances = []\n\nfor idx, row in eq_nearest.iterrows():\n    # Get the original 4326 geometries\n    eq_geom = eq_region.loc[idx].geometry\n    plate_idx = row['index_right']\n    plate_geom = plates_region.loc[plate_idx].geometry\n    \n    # Find the closest points between the earthquake point and the plate boundary line\n    pt1, pt2 = nearest_points(eq_geom, plate_geom)\n    \n    # Calculate exact geodesic distance in meters\n    _, _, dist_m = geod.inv(pt1.x, pt1.y, pt2.x, pt2.y)\n    exact_distances.append(dist_m)\n\neq_nearest['exact_dist_m'] = exact_distances\neq_nearest['exact_dist_km'] = eq_nearest['exact_dist_m'] / 1000.0\n\n# 6. Visualization\nfig, ax = plt.subplots(figsize=(10, 8))\n\n# Plot plate boundaries\nplates_region.plot(ax=ax, color='red', linewidth=2, label='Plate Boundaries')\n\n# Plot earthquakes colored by exact distance to boundary\neq_nearest_plot = eq_nearest.to_crs(epsg=4326) # Back to 4326 for standard map plotting\neq_nearest_plot.plot(ax=ax, column='exact_dist_km', cmap='YlOrRd', \n           