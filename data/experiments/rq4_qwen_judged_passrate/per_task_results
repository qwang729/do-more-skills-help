c_clean = lc_flat.sigma_clip(sigma=5)\n    return lc_clean.time.value, lc_clean.flux.value, lc_clean.flux_err.value\n\n\ndef generate_synthetic_transit_data(n_points=5000, period_days=3.5, \n                                     transit_depth=0.01, transit_duration=0.15,\n                                     t0=0.0, noise_level=0.002):\n    \"\"\"\n    Generate a synthetic TESS-like lightcurve with periodic transits.\n    Returns time (days), flux (normalized), and flux errors.\n    \"\"\"\n    np.random.seed(42)\n    time = np.linspace(0, 100, n_points)  # ~100 days of observations\n    \n    # Baseline flux = 1.0 (normalized)\n    flux = np.ones(n_points)\n    \n    # Add transit model (box-shaped transits)\n    phase = ((time - t0) % period_days) / period_days\n    half_duration_phase = (transit_duration / period_days) / 2.0\n    \n    in_transit = np.abs(phase - 0.5) < half_duration_phase\n    flux[in_transit] -= transit_depth\n    \n    # Add realistic noise (Gaussian + some red noise)\n    noise = np.random.normal(0, noise_level, n_points)\n    # Add slight red noise component\n    red_noise = np.zeros(n_points)\n    for i in range(1, n_points):\n        red_noise[i] = 0.95 * red_noise[i-1] + np.random.normal(0, noise_level * 0.3)\n    \n    flux += noise + red_noise\n    \n    # Add some gaps (simulate TESS data gaps)\n    gap_mask = np.random.random(n_points) > 0.02\n    time = time[gap_mask]\n    flux = flux[gap_mask]\n    \n    flux_err = np.full_like(flux, noise_level)\n    \n    return time, flux, flux_err\n\n\n# ============================================================\n# STEP 2: Detrending and Preprocessing\n# ============================================================\n\ndef detrend_lightcurve(time, flux, window_size=51):\n    \"\"\"\n    Remove long-term trends using a moving median filter.\n    This preserves transit signals while removing systematics.\n    \"\"\"\n    from scipy.ndimage import median_filter\n    \n    # Moving median to remove trends\n    trend = median_filter(flux, size=window_size)\n    detrended_flux = flux / trend\n    \n    return detrended_flux\n\n\ndef sigma_clip_lightcurve(time, flux, flux_err, sigma=4.0, max_iter=5):\n    \"\"\"\n    Iterative sigma clipping to remove cosmic rays and bad data points.\n    Uses a generous sigma to avoid clipping transit signals.\n    \"\"\"\n    mask = np.ones(len(flux), dtype=bool)\n    \n    for _ in range(max_iter):\n        median_flux = np.median(flux[mask])\n        mad = np.median(np.abs(flux[mask] - median_flux))\n        std_est = 1.4826 * mad  # Robust std estimate\n        \n        new_mask = np.abs(flux - median_flux) < sigma * std_est\n        if np.sum(new_mask) == np.sum(mask):\n            break\n        mask = new_mask\n    \n    return time[mask], flux[mask], flux_err[mask]\n\n\n# ============================================================\n# STEP 3: Lomb-Scargle Periodogram (for sinusoidal variations)\n# ============================================================\n\ndef compute_lomb_scargle(time, flux, min_period=0.5, max_period=25.0, \n                          oversampling=5, nterms=1):\n    \"\"\"\n    Compute Lomb-Scargle periodogram using astropy.timeseries.\n    Good for detecting sinusoidal variations (e.g., stellar rotation).\n    \"\"\"\n    # Convert time to frequency space\n    min_freq = 1.0 / max_period  # cycles/day\n    max_freq = 1.0 / min_period\n    \n    # Create LombScargle object\n    ls = LombScargle(time * u.day, flux, nterms=nterms)\n    \n    # Compute frequencies with oversampling\n    frequency, power = ls.autopower(minimum_frequency=min_freq / u.day,\n                                     maximum_frequency=max_freq / u.day,\n                                     oversampling_factor=oversampling)\n    \n    # Convert frequency to period\n    period = 1.0 / frequency.value  # days\n    \n    # Find best period\n    best_idx = np.argmax(power)\n    best_period = period[best_idx]\n    best_power = power[best_idx]\n    \n    # Compute false alarm probability\n    fap = ls.false_alarm_probability(best_power, \n                                      method='bootstrap',\n                                      method_kwargs={'n_bootstrap': 1000})\n    \n    return period, power, best_period, fap\n\n\n# ============================================================\n# STEP 4: Box Least Squares (BLS) - Optimal for Transit Detection\n# ============================================================\n\ndef compute_bls_periodogram(time, flux, min_period=0.5, max_period=25.0,\n                             duration=np.linspace(0.05, 0.3, 20)):\n    \"\"\"\n    Compute Box Least Squares periodogram using astropy.timeseries.\n    BLS is specifically designed for detecting box-shaped transit signals.\n    \"\"\"\n    # Create BLS model\n    bls = BoxLeastSquares(time * u.day, flux)\n    \n    # Generate period grid\n    # Use autoperiod for optimal sampling\n    periods = bls.autoperiod(duration * u.day,\n                              minimum_period=min_period * u.day,\n                              maximum_period=max_period * u.day,\n                              minimum_n_transit=2,\n                              frequency_factor=1.0)\n    \n    # Compute BLS periodogram\n    results = bls.power(periods, duration * u.day)\n    \n    # Extract results\n    period = results.period.to(u.day).value\n    power = results.power\n    depth = results.depth\n    transit_duration = results.duration.to(u.day).value\n    transit_time = results.transit_time.jd\n    \n    # Find best period\n    best_idx = np.argmax(power)\n    best_period = period[best_idx]\n    best_power = power[best_idx]\n    best_depth = depth[best_idx]\n    best_duration = transit_duration[best_idx]\n    best_t0 = transit_time[best_idx]\n    \n    # Compute SNR of the best signal\n    snr = best_depth / np.std(flux) * np.sqrt(np.sum(\n        np.abs(((time - best_t0) % best_period) - best_period/2) < best_duration/2\n    ))\n    \n    return {\n        'period': period,\n        'power': power,\n        'depth': depth,\n        'duration': transit_duration,\n        'transit_time': transit_time,\n        'best_period': best_period,\n        'best_power': best_power,\n        'best_depth': best_depth,\n        'best_duration': best_duration,\n        'best_t0': best_t0,\n        'snr': snr\n    }\n\n\n# ============================================================\n# STEP 5: Phase Folding and Transit Visualization\n# ============================================================\n\ndef phase_fold_and_plot(time, flux, period, t0, ax=None):\n    \"\"\"Phase-fold the lightcurve on the detected transit period.\"\"\"\n    phase = ((time - t0) % period) / period\n    # Center phase around 0\n    phase[phase > 0.5] -= 1.0\n    \n    if ax is None:\n        fig, ax = plt.subplots(figsize=(10, 5))\n    \n    ax.scatter(phase, flux, s=1, alpha=0.3, c='steelblue', label='Data')\n    \n    # Bin the phase-folded data\n    n_bins = 50\n    bin_edges = np.linspace(-0.5, 0.5, n_bins + 1)\n    bin_centers = 0.5 * (bin_edges[:-1] + bin_edges[1:])\n    binned_flux = np.zeros(n_bins)\n    for i in range(n_bins):\n        mask = (phase >= bin_edges[i]) & (phase < bin_edges[i+1])\n        if np.sum(mask) > 0:\n            binned_flux[i] = np.median(flux[mask])\n        else:\n            binned_flux[i] = np.nan\n    \n    ax.plot(bin_centers, binned_flux, 'r-', linewidth=2, label='Binned')\n    ax.set_xlabel('Phase', fontsize=12)\n    ax.set_ylabel('Normalized Flux', fontsize=12)\n    ax.set_title(f'Phase-folded Lightcurve (P = {period:.4f} days)', fontsize=14)\n    ax.legend(fontsize=11)\n    ax.grid(True, alpha=0.3)\n    \n    return ax\n\n\n# ============================================================\n# STEP 6: Main Analysis Pipeline\n# ============================================================\n\ndef run_full_analysis(use_real_data=False, tic_id=\"261136679\"):\n    \"\"\"\n    Run the complete TESS transit detection pipeline.\n    \"\"\"\n    print(\"=\" * 70)\n    print(\"TESS LIGHTCURVE TRANSIT PERIOD DETECTION PIPELINE\")\n    print(\"=\" * 70)\n    \n    # --- Step 1: Get Data ---\n    print(\"\\n[1/6] Loading lightcurve data...\")\n    if use_real_data:\n        try:\n            time, flux, flux_err = get_tess_data_with_lightkurve(tic_id)\n            print(f\"  Loaded real TESS data for TIC {tic_id}\")\n            print(f\"  Data points: {len(time)}\")\n            print(f\"  Time span: {time.max() - time.min():.1f} days\")\n        except Exception as e:\n            print(f\"  Could not load real data ({e}). Using synthetic data.\")\n            time, flux, flux_err = generate_synthetic_transit_data()\n    else:\n        time, flux, flux_err = generate_synthetic_transit_data()\n        print(\"  Generated synthetic transit lightcurve\")\n        print(f\"  Data points: {len(time)}\")\n        print(f\"  Time span: {time.max() - time.min():.1f} days\")\n    \n    # --- Step 2: Preprocessing ---\n    print(\"\\n[2/6] Preprocessing (detrending + sigma clipping)...\")\n    flux_detrended = detrend_lightcurve(time, flux, window_size=51)\n    time_clean, flux_clean, flux_err_clean = sigma_clip_lightcurve(\n        time, flux_detrended, flux_err, sigma=4.0\n    )\n    print(f\"  Points after cleaning: {len(time_clean)} / {len(time)}\")\n    \n    # --- Step 3: Lomb-Scargle Periodogram ---\n    print(\"\\n[3/6] Computing Lomb-Scargle periodogram...\")\n    ls_period, ls_power, ls_best_period, ls_fap = compute_lomb_scargle(\n        time_clean, flux_clean, min_period=0.5, max_period=25.0\n    )\n    print(f\"  Best LS period: {ls_best_period:.4f} days\")\n    print(f\"  LS power at peak: {ls_best_period:.4f}\")\n    \n    # --- Step 4: BLS Periodogram ---\n    print(\"\\n[4/6] Computing Box Least Squares (BLS) periodogram...\")\n    bls_results = compute_bls_periodogram(\n        time_clean, flux_clean, min_period=0.5, max_period=25.0\n    )\n    print(f\"  Best BLS period: {bls_results['best_period']:.4f} days\")\n    print(f\"  Transit depth: {bls_results['best_depth']:.5f}\")\n    print(f\"  Transit duration: {bls_results['best_duration']:.4f} days\")\n    print(f\"  Transit epoch (T0): {bls_results['best_t0']:.4f} JD\")\n    print(f\"  Signal SNR: {bls_results['snr']:.1f}\")\n    \n    # --- Step 5: Plot Results ---\n    print(\"\\n[5/6] Generating plots...\")\n    fig, axes = plt.subplots(3, 1, figsize=(14, 14))\n    \n    # Plot 1: Raw lightcurve\n    axes[0].scatter(time, flux, s=0.5, alpha=0.5, c='steelblue')\n    axes[0].set_xlabel('Time (days)', fontsize=12)\n    axes[0].set_ylabel('Normalized Flux', fontsize=12)\n    axes[0].set_title('TESS Lightcurve', fontsize=14)\n    axes[0].grid(True, alpha=0.3)\n    \n    # Plot 2: BLS Periodogram\n    axes[1].plot(bls_results['period'], bls_results['power'], \n                 'k-', linewidth=0.5, alpha=0.7)\n    axes[1].axvline(bls_results['best_period'], color='red', \n                     linestyle='--', linewidth=2, \n                     label=f\"P = {bls_results['best_period']:.4f} d\")\n    axes[1].set_xlabel('Period (days)', fontsize=12)\n    axes[1].set_ylabel('BLS Power', fontsize=12)\n    axes[1].set_title('Box Least Squares Periodogram', fontsize=14)\n    axes[1].legend(fontsize=11)\n    axes[1].grid(True, alpha=0.3)\n    \n    # Plot 3: Phase-folded lightcurve\n    phase_fold_and_plot(time_clean, flux_clean, \n                        bls_results['best_period'], \n                        bls_results['best_t0'], ax=axes[2])\n    \n    plt.tight_layout()\n    plt.savefig('tess_transit_analysis.png', dpi=150, bbox_inches='tight')\n    print(\"  Saved: tess_transit_analysis.png\")\n    \n    # --- Step 6: Summary ---\n    print(\"\\n[6/6] Analysis Summary\")\n    print(\"-\" * 50)\n    print(f\"  Detected Period:     {bls_results['best_period']:.6f} days\")\n    print(f\"  Transit Depth:       {bls_results['best_depth']:.6f} \"\n          f\"({bls_results['best_dept