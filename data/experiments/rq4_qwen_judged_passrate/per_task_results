ies.tabColor = \"2E4057\"\n\n    ws.cell(row=1, column=1, value=\"Sales Analysis Report\").font = Font(\n        name=\"Calibri\", bold=True, size=18, color=\"2E4057\"\n    )\n    ws.cell(row=2, column=1, value=f\"Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\").font = Font(\n        italic=True, color=\"666666\"\n    )\n\n    if \"grand_total\" in results:\n        style_sheet(ws, results[\"grand_total\"], start_row=4, title=\"Key Metrics\")\n\n    if \"profitability_breakdown\" in results:\n        style_sheet(ws, results[\"profitability_breakdown\"], start_row=12, title=\"Profitability Breakdown\")\n\n    # \u2500\u2500 Sheet 2: Raw Data (Regional Sales) \u2500\u2500\n    if len(raw_tables) >= 1:\n        ws2 = wb.create_sheet(\"Raw - Regional Sales\")\n        ws2.sheet_properties.tabColor = \"4CAF50\"\n        style_sheet(ws2, raw_tables[0], title=f\"Source: {table_names[0]}\")\n\n    # \u2500\u2500 Sheet 3: Raw Data (Products) \u2500\u2500\n    if len(raw_tables) >= 2:\n        ws3 = wb.create_sheet(\"Raw - Product Data\")\n        ws3.sheet_properties.tabColor = \"4CAF50\"\n        style_sheet(ws3, raw_tables[1], title=f\"Source: {table_names[1]}\")\n\n    # \u2500\u2500 Sheet 4: Regional Ranking \u2500\u2500\n    if \"regional_ranking\" in results:\n        ws4 = wb.create_sheet(\"Regional Ranking\")\n        ws4.sheet_properties.tabColor = \"FF9800\"\n        style_sheet(ws4, results[\"regional_ranking\"], title=\"Regions Ranked by Total Revenue\")\n\n    # \u2500\u2500 Sheet 5: Quarterly Growth \u2500\u2500\n    if \"quarterly_growth\" in results:\n        ws5 = wb.create_sheet(\"Quarterly Growth\")\n        ws5.sheet_properties.tabColor = \"2196F3\"\n        style_sheet(ws5, results[\"quarterly_growth\"], title=\"Quarter-over-Quarter Growth (%)\")\n\n    # \u2500\u2500 Sheet 6: Product Ranking \u2500\u2500\n    if \"product_ranking\" in results:\n        ws6 = wb.create_sheet(\"Product Ranking\")\n        ws6.sheet_properties.tabColor = \"FF98