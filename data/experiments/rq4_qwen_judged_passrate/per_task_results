 )\n    df = pd.DataFrame(results).sort_values(\"distance_km\").reset_index(drop=True)\n    return df\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 6. MAIN EXECUTION\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nif __name__ == \"__main__\":\n    # --- Load data ---\n    boundaries = download_plate_boundaries()\n    print(f\"\\nPlate boundary GeoDataFrame:\\n{boundaries.head(10)}\\n\")\n    print(f\"CRS: {boundaries.crs}\")\n    print(f\"Total boundary segments: {len(boundaries)}\\n\")\n\n    # --- Example A: Distance from a point (e.g., Tokyo) to all boundaries ---\n    print(\"=\" * 70)\n    print(\"DISTANCE FROM TOKYO (35.6762\u00b0N, 139.6503\u00b0E) TO ALL PLATE BOUNDARIES\")\n    print(\"=\" * 70)\n    tokyo_dists = distance_from_point(boundaries, 139.6503, 35.6762, \"Tokyo\")\n    print(tokyo_dists.head(10).to_string(index=False))\n    print(f\"\\n  Closest boundary: {tokyo_dists.iloc[0]['plate1']}\u2013\"\n          f\"{tokyo_dists.iloc[0]['plate2']} at \"\n          f\"{tokyo_dists.iloc[0]['distance_km']:.1f} km\\n\")\n\n    # --- Example B: Distance from San Andreas Fault to nearest other boundary ---\n    print(\"=\" * 70)\n    print(\"NEAREST BOUNDARY FOR EACH PLATE BOUNDARY SEGMENT (sample)\")\n    print(\"=\" * 70)\n    nearest = find_nearest_boundaries(boundaries, n_samples=20)\n    print(nearest.head(15).to_string(index=False))\n\n    # --- Example C: Pairwise distance matrix (first 10 segments) ---\n    print(\"\\n\" + \"=\" * 70)\n    print(\"PAIRWISE DISTANCE MATRIX (first 10 boundary segments, km)\")\n    print(\"=\" * 70)\n    subset = boundaries.head(10)\n    dist_df = compute_pairwise_distance_matrix(subset, n_samples=20)\n    # Print with shortened labels\n    short_labels = [\n        f\"{r.plate1}-{r.plate2}\" for r in subset.itertuples()\n    ]\n    dist_df.index = short_labels\n    dist_df.columns = short_labels\n    print(dist_df.round(1).to_string())\n\n    # --- Example D: Summary statistics ---\n    print(\"\\n\" + \"=\" * 70)\n    print(\"BOUNDARY LENGTH STATISTICS (geodesic, km)\")\n    print(\"=\" * 70)\n    lengths_km = []\n    for geom in boundaries.geometry:\n        if geom.geom_type == \"MultiLineString\":\n            total = sum(\n                geod.line_length(*zip(*g.coords)) for g in geom.geoms\n            )\n        else:\n            total = geod.line_length(*zip(*geom.coords))\n        lengths_km.append(total / 1000.0)\n    boundaries[\"length_km\"] = lengths_km\n    print(boundaries[[\"plate1\", \"plate2\", \"bound_type\", \"length_km\"]].to_string(index=False))\n    print(f\"\\nTotal boundary length: {boundaries['length_km'].sum():,.0f} km\")\n    print(f\"Mean segment length:   {boundaries['length_km'].mean():,.1f} km\")\n    print(f\"Max segment length:    {boundaries['length_km'].max():,.1f} km\")\n\n    # --- Optional: Plot ---\n    try:\n        import matplotlib.pyplot as plt\n\n        fig, ax = plt.subplots(figsize=(16, 10))\n        boundaries.plot(\n            ax=ax,\n            column=\"bound_type\",\n            categorical=True,\n            legend=True,\n            linewidth=0.8,\n        )\n        ax.set_title(\"Tectonic Plate Boundaries (PB2002)\", fontsize=14)\n        ax.set_xlabel(\"Longitude\")\n     