{"task": "glm-lake-mendota", "condition": "random_wrong", "repeat": 0, "skill_ids": ["benchflow-ai--object_counter"], "retrieval_correct": false, "judged_pass": false, "judged_score": 0, "judge_reason": "Agent's solution is a standalone GLM implementation, but the task requires modifying and running an existing GLM model via NetCDF and parameter optimization, not building a new simulator from scratch.", "solver_tokens": 6077, "judge_tokens": 5162, "solution_text": "# GLM Lake Simulation - NetCDF Hydrodynamic Model\n\nBelow is a complete Python implementation of a 1D General Lake Model (GLM) hydrodynamic simulation that outputs results in NetCDF format.\n\n```python\n#!/usr/bin/env python3\n\"\"\"\nGLM (General Lake Model) - 1D Hydrodynamic Lake Simulation\nOutputs results in NetCDF format.\n\nSimulates:\n- Vertical temperature profiles\n- Lake level dynamics\n- Surface heat fluxes\n- Vertical mixing (eddy diffusivity)\n\"\"\"\n\nimport numpy as np\nfrom netCDF4 import Dataset\nimport datetime\nimport os\n\n# ============================================================\n# MODEL CONFIGURATION\n# ============================================================\nclass GLMConfig:\n    def __init__(self):\n        # Lake geometry (idealized parabolic basin)\n        self.max_depth = 30.0          # meters\n        self.max_radius = 500.0        # meters\n        self.surface_area = np.pi * self.max_radius**2  # m^2\n        self.max_volume = (np.pi * self.max_radius**2 * self.max_depth) / 2  # m^3\n\n        # Vertical discretization\n        self.num_layers = 30\n        self.layer_thickness = self.max_depth / self.num_layers  # meters\n\n        # Time settings\n        self.start_date = datetime.datetime(2023, 1, 1)\n        self.dt = 3600.0               # time step in seconds (1 hour)\n        self.num_days = 365\n        self.num_steps = int(self.num_days * 86400 / self.dt)\n        self.output_interval = 24      # output every 24 steps (daily)\n\n        # Physical constants\n        self.rho_w = 1000.0            # water density (kg/m^3)\n        self.cp_w = 4186.0             # specific heat of water (J/kg/\u00b0C)\n        self.g = 9.81                  # gravity (m/s^2)\n        self.beta_T = 0.000207         # thermal expansion coefficient (1/\u00b0C)\n\n        # Mixing parameters\n        self.Kz_molecular = 1e-6       # molecular diffusivity (m^2/s)\n        self.Kz_max = 1e-2             # max eddy diffusivity (m^2/s)\n        self.wind_factor = 0.001       # wind mixing coefficient\n\n        # Initial conditions\n        self.T_initial = 4.0           # initial uniform temperature (\u00b0C)\n        self.T_bottom = 4.0            # bottom boundary temperature (\u00b0C)\n\n        # Inflow/outflow\n        self.inflow_rate = 0.5         # m^3/s (mean)\n        self.outflow_rate = 0.5        # m^3/s (mean)\n        self.inflow_temp = 4.0         # \u00b0C\n\n        # Output file\n        self.output_file = \"glm_lake_simulation.nc\"\n\n\n# ============================================================\n# METEOROLOGICAL FORCING\n# ============================================================\nclass MetForcing:\n    \"\"\"Generate synthetic meteorological forcing data.\"\"\"\n\n    def __init__(self, config):\n        self.config = config\n\n    def get_air_temperature(self, day_of_year):\n        \"\"\"Sinusoidal annual air temperature cycle (\u00b0C).\"\"\"\n        T_mean = 12.0\n        T_amplitude = 15.0\n        T_peak_day = 200  # peak around mid-July\n        T = T_mean + T_amplitude * np.sin(2 * np.pi * (day_of_year - T_peak_day + 90) / 365.0)\n        # Add small daily variability\n        np.random.seed(day_of_year)\n        T += np.random.normal(0, 2.0)\n        return T\n\n    def get_wind_speed(self, day_of_year):\n        \"\"\"Wind speed (m/s) with seasonal variation.\"\"\"\n        W_mean = 3.5\n        W_amplitude = 1.5\n        W = W_mean + W_amplitude * np.cos(2 * np.pi * (day_of_year - 30) / 365.0)\n        np.random.seed(day_of_year + 1000)\n        W += np.random.uniform(0, 2.0)\n        return max(0.1, W)\n\n    def get_shortwave_radiation(self, day_of_year):\n        \"\"\"Shortwave radiation (W/m^2) with seasonal cycle.\"\"\"\n        SW_max = 300.0\n        SW_min = 50.0\n        SW = (SW_max + SW_min) / 2 + (SW_max - SW_min) / 2 * np.sin(\n            2 * np.pi * (day_of_year - 80) / 365.0\n        )\n        return max(0, SW)\n\n    def get_longwave_radiation(self, T_air):\n        \"\"\"Net longwave radiation (W/m^2) - simplified.\"\"\"\n        sigma = 5.67e-8\n        T_air_K = T_air + 273.15\n        LW_net = sigma * T_air_K**4 * 0.97 - 300.0  # simplified\n        return LW_net\n\n    def get_precipitation(self, day_of_year):\n        \"\"\"Daily precipitation (mm/day).\"\"\"\n        np.random.seed(day_of_year + 2000)\n        if np.random.random() < 0.3:\n            return np.random.exponential(5.0)\n        return 0.0\n\n\n# ============================================================\n# GLM HYDRODYNAMIC MODEL\n# ============================================================\nclass GLMModel:\n    \"\"\"1D General Lake Model hydrodynamic simulation.\"\"\"\n\n    def __init__(self, config):\n        self.config = config\n        self.met = MetForcing(config)\n\n        # State variables\n        self.T = np.full(config.num_layers, config.T_initial)  # temperature profile\n        self.water_level = config.max_depth * 0.8               # initial water level (m)\n        self.ice_thickness = 0.0                                # ice thickness (m)\n\n        # Derived fields\n        self.rho = self._compute_density(self.T)\n        self.N2 = np.zeros(config.num_layers)  # buoyancy frequency squared\n        self.Kz = np.full(config.num_layers, config.Kz_molecular)  # eddy diffusivity\n\n        # Storage for output\n        self.time_data = []\n        self.temp_profiles = []\n        self.water_levels = []\n        self.ice_thicknesses = []\n        self.surface_temps = []\n        self.density_profiles = []\n        self.Kz_profiles = []\n        self.heat_fluxes = []\n\n    def _compute_density(self, T):\n        \"\"\"Compute water density from temperature using UNESCO equation (simplified).\"\"\"\n        # Simplified density-temperature relationship (valid 0-30\u00b0C)\n        rho = 999.842594 + 6.793952e-2 * T - 9.095290e-3 * T**2 + \\\n              1.001685e-4 * T**3 - 1.120083e-6 * T**4 + 6.536332e-9 * T**5\n        return rho\n\n    def _compute_buoyancy_frequency(self):\n        \"\"\"Compute Brunt-V\u00e4is\u00e4l\u00e4 frequency squared (N^2).\"\"\"\n        dz = self.config.layer_thickness\n        for k in range(1, self.config.num_layers - 1):\n            drho_dz = (self.rho[k+1] - self.rho[k-1]) / (2 * dz)\n            self.N2[k] = -self.config.g / self.rho[k] * drho_dz\n        self.N2[0] = self.N2[1]\n        self.N2[-1] = self.N2[-2]\n        # Ensure non-negative\n        self.N2 = np.maximum(self.N2, 0)\n\n    def _compute_eddy_diffusivity(self, wind_speed):\n        \"\"\"Compute vertical eddy diffusivity based on stability and wind.\"\"\"\n        dz = self.config.layer_thickness\n\n        for k in range(self.config.num_layers):\n            # Wind-driven mixing (surface enhanced)\n            surface_enhancement = np.exp(-k * dz / 5.0)  # e-folding depth 5m\n            Kz_wind = self.config.wind_factor * wind_speed**2 * surface_enhancement\n\n            # Stability-dependent reduction\n            if self.N2[k] > 1e-8:\n                Ri = self.N2[k] / max((wind_speed / (dz + 1e-6))**2, 1e-10)\n                stability_factor = 1.0 / (1.0 + 0.2 * Ri)\n            else:\n                stability_factor = 1.0\n\n            self.Kz[k] = max(\n                self.config.Kz_molecular,\n                min(self.config.Kz_max, Kz_wind * stability_factor)\n            )\n\n    def _compute_surface_heat_flux(self, T_air, SW, LW_net, wind_speed):\n        \"\"\"Compute net surface heat flux (W/m^2).\"\"\"\n        T_surface = self.T[0]\n\n        # Sensible heat flux (bulk formula)\n        Ch = 1.3e-3  # heat exchange coefficient\n        Q_sensible = self.config.rho_w * self.config.cp_w * Ch * wind_speed * (T_air - T_surface)\n\n        # Latent heat flux (simplified)\n        Ce = 1.3e-3\n        es = 6.11 * 10**(7.5 * T_surface / (237.3 + T_surface))  # saturation vapor pressure\n        Q_latent = -self.config.rho_w * 2.5e6 * Ce * wind_speed * (es - 6.0) * 0.622 / 1013.0\n\n        # Net heat flux\n        Q_net = SW * 0.9 - LW_net + Q_sensible + Q_latent\n        return Q_net\n\n    def _apply_surface_heat_flux(self, Q_net):\n        \"\"\"Apply surface heat flux to top layer temperature.\"\"\"\n        dz = self.config.layer_thickness\n        dT = Q_net * self.config.dt / (self.config.rho_w * self.config.cp_w * dz)\n        self.T[0] += dT\n\n    def _apply_vertical_diffusion(self):\n        \"\"\"Apply vertical turbulent diffusion to temperature.\"\"\"\n        dz = self.config.layer_thickness\n        dt = self.config.dt\n        T_new = self.T.copy()\n\n        for k in range(1, self.config.num_layers - 1):\n            Kz_upper = 0.5 * (self.Kz[k-1] + self.Kz[k])\n            Kz_lower = 0.5 * (self.Kz[k] + self.Kz[k+1])\n\n            flux_upper = Kz_upper * (self.T[k-1] - self.T[k]) / dz\n            flux_lower = Kz_lower * (self.T[k+1] - self.T[k]) / dz\n\n            T_new[k] += dt / dz * (flux_upper - flux_lower)\n\n        # Boundary conditions\n        T_new[0] += dt / dz * 0.5 * (self.Kz[0] + self.Kz[1]) * (self.T[1] - self.T[0]) / dz\n        T_new[-1] = self.config.T_bottom  # bottom boundary\n\n        self.T = T_new\n\n    def _update_ice(self, T_air):\n        \"\"\"Simple ice formation/melt model.\"\"\"\n        if self.T[0] <= 0.0 and T_air < -2.0:\n            # Ice formation\n            growth_rate = 0.001 * (-T_air) * self.config.dt / 3600.0  # m per timestep\n            self.ice_thickness = min(self.ice_thickness + growth_rate, 1.0)\n            self.T[0] = 0.0  # cap at freezing\n        elif self.ice_thickness > 0 and T_air > 2.0:\n            # Ice melt\n            melt_rate = 0.002 * (T_air - 2.0) * self.config.dt / 3600.0\n            self.ice_thickness = max(0, self.ice_thickness - melt_rate)\n\n    def _update_water_level(self, precip_mm):\n        \"\"\"Update water level from inflow, outflow, and precipitation.\"\"\"\n        dt = self.config.dt\n        # Precipitation contribution (mm -> m)\n        dP = precip_mm / 1000.0\n\n        # Net volume change\n        dV = (self.config.inflow_rate - self.config.outflow_rate) * dt\n        dV += dP * self.config.surface_area\n\n        # Update water level\n        A_surface = self.config.surface_area * (self.water_level / self.config.max_depth)\n        self.water_level += dV / max(A_surface, 1.0)\n        self.water_level = np.clip(self.water_level, 1.0, self.config.max_depth)\n\n    def _compute_layer_areas(self):\n        \"\"\"Compute cross-sectional area at each layer depth (parabolic basin).\"\"\"\n        dz = self.config.layer_thickness\n        areas = np.zeros(self.config.num_layers)\n        for k in range(self.config.num_layers):\n            depth = (k + 0.5) * dz\n            fraction = depth / self.config.max_depth\n            radius = self.config.max_radius * np.sqrt(fraction)\n            areas[k] = np.pi * radius**2\n        return areas\n\n    def run(self):\n        \"\"\"Run the full simulation.\"\"\"\n        print(\"=\" * 60)\n        print(\"GLM Lake Simulation - 1D Hydrodynamic Model\")\n        print(\"=\" * 60)\n        print(f\"Lake max depth: {self.config.max_depth} m\")\n        print(f\"Number of layers: {self.config.num_layers}\")\n        print(f\"Time step: {self.config.dt/3600:.1f} hours\")\n        print(f\"Simulation period: {self.config.num_days} days\")\n        print(f\"Output file: {self.config.output_file}\")\n        print(\"=\" * 60)\n\n        for step in range(self.config.num_steps):\n            day_of_year = (step * self.config.dt / 86400.0) % 365.0\n            current_time = self.config.start_date + datetime.timedelta(seconds=step * self.config.dt)\n\n            # Get meteorological forcing\n            T_air = self.met.get_air_temperature(day_of_year)\n            wind = self.met.get_wind_speed(day_of_year)\n            SW = self.met.get_shortwave_radiation(day_of_year)\n            LW = self.met.get_longwave_radiation(T_air)\n            precip = self.met.get_precipitation(int(day_of_year))\n\n            # Compute derived quantities\n            self.rho = self._compute_density(self.T)\n            self._compute_buoyancy_frequency()\n            self._compute_eddy_diffusivity(wind)\n\n            # Compute surface heat flux\n            Q_net = self._compute_surface_heat_flux(T_air, SW, LW, wind)\n\n            # Update state\n            self._apply_surface_heat_flux(Q_net)\n            self._apply_vertical_diffusion()\n            self._update_ice(T_air)\n            self._update_water_level(precip)\n\n            # Store output\n            if step % self.config.output_interval == 0:\n                self.time_data.append(current_time)\n                self.temp_profiles.append(self.T.copy())\n                self.water_levels.append(self.water_level)\n                self.ice_thicknesses.append(self.ice_thickness)\n                self.surface_temps.append(self.T[0])\n                self.density_profiles.append(self.rho.copy())\n                self.Kz_profiles.append(self.Kz.copy())\n                self.heat_fluxes.append(Q_net)\n\n            # Progress reporting\n            if step % (self.config.num_steps // 10) == 0:\n                pct = 100 * step / self.config.num_steps\n                print(f\"  Progress: {pct:5.1f}% | Day {day_of_year:6.1f} | \"\n                      f\"T_surface: {self.T[0]:6.2f}\u00b0C | \"\n                      f\"Water level: {self.water_level:6.2f}m | \"\n                      f\"Ice: {self.ice_thickness:4.2f}m\")\n\n        print(\"\\nSimulation complete!\")\n        print(f\"  Final surface temp: {self.T[0]:.2f}\u00b0C\")\n        print(f\"  Final water level: {self.water_level:.2f}m\")\n        print(f\"  Output records: {len(self.time_data)}\")\n\n    def write_netcdf(self):\n        \"\"\"Write simulation results to NetCDF file.\"\"\"\n        print(f\"\\nWriting NetCDF output: {self.config.output_file}\")\n\n        nc = Dataset(self.config.output_file, 'w', format='NETCDF4')\n\n        # Global attributes\n        nc.title = \"GLM Lake Simulation - 1D Hydrodynamic Model Output\"\n        nc.institution = \"GLM Lake Model Simulation\"\n        nc.source = \"Python GLM Implementation\"\n        nc.history = f\"Created {datetime.datetime.now().isoformat()}\"\n        nc.conventions = \"CF-1.8\"\n        nc.lake_max_depth = self.config.max_depth\n        nc.lake_max_radius = self.config.max_radius\n        nc.num_layers = self.config.num_layers\n\n        # Dimensions\n        nc.createDimension('time', None)  # unlimited\n        nc.createDimension('depth', self.config.num_layers)\n        nc.createDimension('z', self.config.num_layers)\n\n        # Coordinate variables\n        time_var = nc.createVariable('time', 'f8', ('time',))\n        time_var.standard_name = 'time'\n        time_var.long_name = 'time'\n        time_var.units = f'seconds since {self.config.start_date.isoformat()}'\n        time_var.calendar = 'standard'\n        time_var.axis = 'T'\n\n        depth_var = nc.createVariable('depth', 'f4', ('depth',))\n        depth_var.standard_name = 'depth'\n        depth_var.long_name = 'depth below surface'\n        depth_var.units = 'm'\n        depth_var.positive = 'down'\n        depth_var.axis = 'Z'\n\n        z_var = nc.createVariable('z', 'f4', ('z',))\n        z_var.standard_name = 'altitude'\n        z_var.long_name = 'vertical coordinate'\n        z_var.units = 'm'\n        z_var.positive = 'up'\n\n        # Set depth/z values\n  