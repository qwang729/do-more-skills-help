itigations for Valley-Free Violations\n    for violation in violations:\n        mitigations.append({\n            \"issue_type\": \"valley_free_violation\",\n            \"target_path\": violation[\"path\"],\n            \"allowed_actions\": [\n                \"Configure Azure Virtual WAN Routing Intents to enforce traffic through the Hub.\",\n                \"Implement route-maps on the Hub Route Servers to filter routes learned from Spokes before advertising to other Spokes.\",\n                \"Use BGP communities to tag and drop transitive spoke-to-spoke routes.\"\n            ],\n            \"prohibited_actions\": [\n                \"Do not configure static routes on Spokes that bypass the Hub.\",\n                \"Do not enable transitive routing directly on the Spoke VNets.\"\n            ]\n        })\n\n    return {\n        \"analysis_summary\": {\n            \"total_nodes\": len(nodes),\n            \"total_edges\": len(edges),\n            \"cycles_detected\": len(cycles),\n            \"valley_violations_detected\": len(violations)\n        },\n        \"cycles_detected\": cycles,\n        \"valley_free_violations\": violations,\n        \"mitigations\": mitigations\n    }\n\n# --- Sample JSON Network Topology ---\nsample_topology = \"\"\"\n{\n  \"nodes\": [\n    {\"id\": \"Hub1\", \"type\": \"hub\", \"local_pref\": 100},\n    {\"id\": \"Hub2\", \"type\": \"hub\", \"local_pref\": 100},\n    {\"id\": \"Spoke1\", \"type\": \"spoke\", \"local_pref\": 50},\n    {\"id\": \"Spoke2\", \"type\": \"spoke\", \"local_pref\": 50}\n  ],\n  \"edges\": [\n    {\"source\": \"Hub1\", \"target\": \"Hub2\", \"as_path\": [65001], \"relation\": \"hub-to-hub\"},\n    {\"source\": \"Hub2\", \"target\": \"Hub1\", \"as_path\": [65002], \"relation\": \"hub-to-hub\"},\n    {\"source\": \"Spoke1\", \"target\": \"Hub1\", \"as_path\": [65010], \"relation\": \"spoke-to-hub\"},\n    {\"source\": \"Hub1\", \"target\": \"Spoke2\", \"as_path\": [65010, 65001], \"relation\": \"hub-to-spoke\"},\n    {\"source\": \"Spoke2\", \"target\": \"Hub2\", \"as_path\": [65010, 65001, 65020], \"relation\": \"spoke-to-hub\"},\n    {\"source\": \"Hub2\", \"target\": \"Spoke1\", \"as_path\": [65010, 65001, 65020, 65002], \"relation\": \"hub-to-spoke\"}\n  ]\n}\n\"\"\"\n\nif __name__ == \"__main__\":\n    result = analyze_bgp_topology(sample_topology)\n    print(json.dumps(result, indent=2))\n```\n\n### 2. Expected JSON Output\n\nRunning the script against the provided topology yields the following analysis, correctly identifying the oscillation cycles, the valley-free violations, and the strict Azure Virtual WAN policy mitigations:\n\n```json\n{\n  \"analysis_summary\": {\n    \"total_nodes\": 4,\n    \"total_edges\": 6,\n    \"cycles_detected\": 2,\n    \"valley_violations_detected\": 2\n  },\n  \"cycles_detected\": [\n    [\n      \"Hub1\",\n      \"Hub2\"\n    ],\n    [\n      \"Spoke1\",\n      \"Hub1\",\n      \"Spoke2\",\n      \"Hub2\"\n    ]\n  ],\n  \"valley_free_violations\": [\n    {\n      \"type\": \"valley_free_violation\",\n      \"path\": [\n        \"Hub1\",\n        \"Spoke2\",\n        \"Hub2\"\n      ],\n      \"description\": \"Route traverses a Spoke VNet between two Hubs (Valley)\"\n    },\n    {\n      \"type\": \"valley_free_violation\",\n      \"path\": [\n        \"Hub2\",\n        \"Spoke1\",\n        \"Hub1\"\n      ],\n      \"description\": \"Route traverses a Spoke VNet between two Hubs (Valley)\"\n    }\n  ],\n  \"mitigations\": [\n    {\n      \"issue_type\": \"bgp_oscillation_cycle\",\n      \"target_path\": [\n        \"Hub1\",\n        \"Hub2\"\n      ],\n      \"allowed_actions\": [\n        \"Apply AS_PATH prepending on the edge causing the loop to make it less preferred.\",\n        \"Adjust LOCAL_PREF on the receiving Route Server to break the preference tie.\",\n        \"Implement route-maps to filter specific prefixes from being advertised back to the origin.\"\n      ],\n      \"prohibited_actions\": [\n        \