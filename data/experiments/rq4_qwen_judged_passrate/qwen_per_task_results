, to in self.edges:\n            if frm not in self.nodes:\n                raise ValueError(f\"Edge references missing source node: {frm}\")\n            if to not in self.nodes:\n                raise ValueError(f\"Edge references missing target node: {to}\")\n        return True\n\n    def to_json(self) -> str:\n        \"\"\"Serializes the dialogue graph to a JSON string.\"\"\"\n        self.validate()\n        data = {\n            \"nodes\": [node.to_dict() for node in self.nodes.values()],\n            \"edges\": [{\"from\": frm, \"to\": to} for frm, to in self.edges]\n        }\n        return json.dumps(data, indent=2)\n\n    def to_dot(self) -> str:\n        \"\"\"Generates a Graphviz DOT representation of the dialogue graph.\"\"\"\n        self.validate()\n        lines = [\n            'digraph DialogueGraph {',\n            '    rankdir=TB;',\n            '    node [shape=record, style=filled, fillcolor=\"#E8E8E8\", fontname=\"Helvetica\"];',\n            '    edge [color=\"#555555\"];'\n        ]\n        for node in self.nodes.values():\n            # Format label with speaker and text\n            label = f\"{node.speaker}\\\\n{node.text}\" if node.speaker else node.text\n            label = label.replace('\"', '\\\\\"').replace('\\n', '\\\\n')\n            lines.append(f'    \"{node.id}\" [label=\"{label}\"];')\n        for frm, to in self.edges:\n            lines.append(f'    \"{frm}\" -> \"{to}\";')\n        lines.append('}')\n        return '\\n'.join(lines)\n\ndef parse_dialogue_text(text: str) -> DialogueGraph:\n    \"\"\"\n    Parses a dialogue script into a DialogueGraph.\n    \n    Expected Text Format:\n    [node_id] Speaker: Dialogue text\n    -> target_node_id_1\n    -> target_node_id_2\n    \n    Lines starting with # are treated as comments.\n    \"\"\"\n    graph = DialogueGraph()\n    current_node_id = None\n    \n    # Regex for node definition: [id] Speaker: Text  OR  [id] Text\n    node_re = re.compile(r'^\\[(?P<id>[^\\]]+)\\]\\s*(?:(?P<speaker>[^:]+):\\s*)?(?P<text>.*)$')\n    edge_re = re.compile(r'^->\\s*(?P<target>.+)$')\n    \n    for line in text.splitlines():\n        line = line.strip()\n        if not line or line.startswith('#'):\n            continue\n            \n        m_node = node_re.match(line)\n        if m_node:\n            current_node_id = m_node.group('id').strip()\n            speaker = (m_node.group('speaker') or \"\").strip()\n            text_content = (m_node.group('text') or \"\").strip()\n            graph.add_node(current_node_id, speaker, text_content)\n            continue\n            \n        m_edge = edge_re.match(line)\n        if m_edge:\n            target = m_edge.group('target').strip()\n            if current_node_id is None:\n                raise ValueError(f\"Edge defined before any node: {line}\")\n            graph.add_edge(current_node_id, target)\n            continue\n            \n        # Continuation of text for the current node\n        if current_node_id:\n            graph.nodes[current_node_id].text += \" \" + line\n\n    return graph\n\nif __name__ == \"__main__\":\n    sample_script = \"\"\"\n# Sample Dialogue Tree\n[start] Narrator: Welcome to the game.\n-> choice1\n-> choice2\n\n[choice1] Player: I choose the sword.\n-> combat\n\n[choice2] Player: I choose the magic.\n-> magic\n\n[combat] Narrator: You fight the goblin!\n-> end\n\n[magic] Narrator: You cast a fireball!\n-> end\n\n[end] Narrator: The end.\n\"\"\"\n    \n    # Parse the text into a graph\n    graph = parse_dialogue_text(sample_script)\n    \n    # Output as JSON\n    print(\"=== JSON OUTPUT ===\")\n    print(graph.to_json())\n    \n    # Output as Graphviz DOT\n    print(\"\\n=== GRAPHVIZ DOT OUTPUT ===\")\n    print(graph.to_dot())\n```", "solver_finish_reason": "stop"}
