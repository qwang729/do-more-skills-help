 harbors = countAdjacent(x, y, state, t => t.hasDistrict === 'harbor');\n  if (harbors > 0) bonuses.push({ source: 'harbors', value: harbors * 2 });\n\n  // +2 per adjacent river (tile has river adjacency)\n  const riverTiles = countAdjacent(x, y, state, t => t.isRiver);\n  if (riverTiles > 0) bonuses.push({ source: 'river', value: riverTiles * 2 });\n\n  // +2 per adjacent district\n  const districts = countAdjacent(x, y, state, t => t.hasDistrict !== null && t.hasDistrict !== 'commercial_hub');\n  if (districts > 0) bonuses.push({ source: 'districts', value: districts * 2 });\n\n  return bonuses;\n}\n\nfunction harborAdjacency(x: number, y: number, state: GameState): AdjacencyBonus[] {\n  const bonuses: AdjacencyBonus[] = [];\n\n  // +2 per adjacent commercial hub\n  const commHubs = countAdjacent(x, y, state, t => t.hasDistrict === 'commercial_hub');\n  if (commHubs > 0) bonuses.push({ source: 'commercial_hubs', value: commHubs * 2 });\n\n  // +2 per adjacent sea resource\n  const seaResources = countAdjacent(x, y, state, t =>\n    t.resource === 'fish' || t.resource === 'crabs' || t.resource === 'pearls'\n  );\n  if (seaResources > 0) bonuses.push({ source: 'sea_resources', value: seaResources * 2 });\n\n  // +1 per adjacent city center on coast\n  const coastalCityCenters = countAdjacent(x, y, state, t => t.isCityCenter && t.isCoastal);\n  if (coastalCityCenters > 0) bonuses.push({ source: 'coastal_city_centers', value: coastalCityCenters });\n\n  // +2 per adjacent district\n  const districts = countAdjacent(x, y, state, t => t.hasDistrict !== null && t.hasDistrict !== 'harbor');\n  if (districts > 0) bonuses.push({ source: 'districts', value: districts * 2 });\n\n  return bonuses;\n}\n\nfunction industrialZoneAdjacency(x: number, y: number, state: GameState): AdjacencyBonus[] {\n  const bonuses: AdjacencyBonus[] = [];\n\n  // +1 per adjacent mine or quarry (improvement) - simplified: +1 per adjacent hill with resource\n  const mines = countAdjacent(x, y, stat