piler-plugin</artifactId>\n                <version>3.11.0</version>\n                <configuration>\n                    <source>17</source>\n                    <target>17</target>\n                    <release>17</release>\n                </configuration>\n            </plugin>\n            <plugin>\n                <groupId>org.apache.maven.plugins</groupId>\n                <artifactId>maven-surefire-plugin</artifactId>\n                <version>3.2.2</version>\n            </plugin>\n        </plugins>\n    </pluginManagement>\n</build>\n```\n\n### Issue C: Repository / Download Failures\n\n```xml\n<!-- Add mirrors in settings.xml (~/.m2/settings.xml) -->\n<settings>\n    <mirrors>\n        <mirror>\n            <id>central-mirror</id>\n            <mirrorOf>central</mirrorOf>\n            <url>https://repo.maven.apache.org/maven2</url>\n        </mirror>\n    </mirrors>\n    <profiles>\n        <profile>\n            <id>default-repos</id>\n            <repositories>\n                <repository>\n                    <id>central</id>\n                    <url>https://repo.maven.apache.org/maven2</url>\n                    <releases><enabled>true</enabled></releases>\n                    <snapshots><enabled>true</enabled></snapshots>\n                </repository>\n            </repositories>\n        </profile>\n    </profiles>\n    <activeProfiles>\n        <activeProfile>default-repos</activeProfile>\n    </activeProfiles>\n</settings>\n```\n\n### Issue D: Out of Memory During Build\n\n```bash\n# Set MAVEN_OPTS\nexport MAVEN_OPTS=\"-Xmx2g -XX:MaxMetaspaceSize=512m\"\nmvn clean install\n```\n\nOr in `.mvn/jvm.config`:\n```\n-Xmx2g\n-XX:MaxMetaspaceSize=512m\n```\n\n### Issue E: Stale / Corrupt Local Repository\n\n```bash\n# Purge local repo cache for specific artifact\nmvn dependency:purge-local-repository -DmanualInclude=\"group:artifact\"\n\n# Or nuke the whole local cache\nrm -rf ~/.m2/repository\nmvn clean install -U   # -U forces update of snapshots/releases\n```\n\n## 3. Systematic Debugging Script\n\nSave as `debug-maven.sh`:\n\n```bash\n#!/bin/bash\nset -e\n\necho \"=== Maven Environment ===\"\nmvn --version\necho \"\"\n\necho \"=== Java Environment ===\"\njava -version 2>&1\necho \"JAVA_HOME=$JAVA_HOME\"\necho \"\"\n\necho \"=== Validating POM ===\"\nmvn validate || { echo \"POM validation failed!\"; exit 1; }\necho \"\"\n\necho \"=== Checking Dependency Tree ===\"\nmvn dependency:tree -Dverbose > dependency-tree.txt 2>&1\necho \"Dependency tree saved to dependency-tree.txt\"\necho \"\"\n\necho \"=== Checking for Dependency Conflicts ===\"\nmvn enforcer:enforce -Drules=dependencyConvergence 2>&1 | tee enforcer-output.txt || true\necho \"\"\n\necho \"=== Running Build with Debug ===\"\nmvn clean install -X -e 2>&1 | tee build-debug.log\necho \"\"\n\necho \"=== Build Complete ===\"\necho \"Check build-debug.log for details\"\ngrep -i \"error\\|failure\\|exception\" build-debug.log | head -20 || echo \"No errors found\"\n```\n\n## 4. Quick Fix Checklist\n\n| Symptom | Likely Cause | Fix |\n|---------|-------------|-----|\n| `Could not resolve dependencies` | Missing repo or wrong version | Add repo to POM, verify version exists |\n| `NoSuchMethodError` | Dependency version conflict | Use `<dependencyManagement>` to pin version |\n| `Compilation failure` | Wrong Java version | Set `<source>`/`<target>`/`<release>` in compiler plugin |\n| `OutOfMemoryError` | Large project | Increase `-Xmx` in `MAVEN_OPTS` |\n| `Plugin execution not covered` | Missing plugin lifecycle config | Add `<pluginManagement>` or move to `<plugins>` |\n| `Access denied` / 401 | Auth issue with private repo | Add `<server>` credentials in `settings.xml` |\n| `Non-resolvable parent POM` | Parent not installed | Run `mvn install` on parent first, or check relative path |\n\n## 5. Force Clean Rebuild\n\n```bash\n# Nuclear option - clean everything and rebuild\nmvn dependency:purge-local-repository\nrm -rf target/\nmvn clean install -U -X 2>&1 | tee rebuild.log\n```\n\nRun the diagnostic commands first, identify the specific error from the output, then apply the corresponding fix from the table above.", "solver_finish_reason": "stop"}
