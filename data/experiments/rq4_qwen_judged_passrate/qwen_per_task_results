Table, TableStyle, Paragraph, Spacer\nfrom reportlab.lib import colors\nfrom reportlab.lib.styles import getSampleStyleSheet\n\nSAMPLE_PDF = \"sample_sales_report.pdf\"\nOUTPUT_XLSX = \"sales_analysis_output.xlsx\"\n\ndef create_sample_pdf():\n    \"\"\"Generate a sample PDF containing a sales data table.\"\"\"\n    doc = SimpleDocTemplate(SAMPLE_PDF, pagesize=letter)\n    styles = getSampleStyleSheet()\n    elements = []\n\n    elements.append(Paragraph(\"<b>Quarterly Sales Report</b>\", styles[\"Title\"]))\n    elements.append(Spacer(1, 20))\n\n    # Sample data: Region, Product, Units Sold, Unit Price, Quarter\n    data = [\n        [\"Region\", \"Product\", \"Units Sold\", \"Unit Price ($)\", \"Quarter\"],\n        [\"North\", \"Widget A\", 1200, 25.00, \"Q1\"],\n        [\"North\", \"Widget B\", 800, 40.00, \"Q1\"],\n        [\"South\", \"Widget A\", 1500, 25.00, \"Q1\"],\n        [\"South\", \"Widget C\", 600, 55.00, \"Q1\"],\n        [\"East\", \"Widget B\", 950, 40.00, \"Q2\"],\n        [\"East\", \"Widget A\", 1100, 25.00, \"Q2\"],\n        [\"West\", \"Widget C\", 700, 55.00, \"Q2\"],\n        [\"West\", \"Widget B\", 1300, 40.00, \"Q2\"],\n        [\"North\", \"Widget A\", 1400, 25.00, \"Q3\"],\n        [\"North\", \"Widget C\", 500, 55.00, \"Q3\"],\n        [\"South\", \"Widget B\", 1050, 40.00, \"Q3\"],\n        [\"South\", \"Widget A\", 1600, 25.00, \"Q3\"],\n        [\"East\", \"Widget C\", 850, 55.00, \"Q4\"],\n        [\"East\", \"Widget A\", 1250, 25.00, \"Q4\"],\n        [\"West\", \"Widget B\", 1100, 40.00, \"Q4\"],\n        [\"West\", \"Widget A\", 900, 25.00, \"Q4\"],\n    ]\n\n    table = Table(data)\n    table.setStyle(TableStyle([\n        (\"BACKGROUND\", (0, 0), (-1, 0), colors.HexColor(\"#4472C4\")),\n        (\"TEXTCOLOR\", (0, 0), (-1, 0), colors.whitesmoke),\n        (\"ALIGN\", (0, 0), (-1, -1), \"CENTER\"),\n        (\"FONTNAME\", (0, 0), (-1, 0), \"Helvetica-Bold\"),\n        (\"FONTSIZE\", (0, 0), (-1, -1), 10),\n        (\"BOTTOMPADDING\", (0, 0), (-1, 0), 10),\n        (\"TOPPADDING\", (0, 0), (-1, 0), 10),\n        (\"BACKGROUND\", (0, 1), (-1, -1), colors.HexColor(\"#D9E2F3\")),\n        (\"GRID\", (0, 0), (-1, -1), 0.5, colors.grey),\n        (\"ROWBACKGROUNDS\", (0, 1), (-1, -1), [colors.HexColor(\"#D9E2F3\"), colors.white]),\n    ]))\n    elements.append(table)\n    doc.build(elements)\n    print(f\"[\u2713] Sample PDF created: {SAMPLE_PDF}\")\n\n\n# \u2500\u2500 Step 1: Extract tables from PDF using pdfplumber \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nimport pdfplumber\n\ndef extract_tables_from_pdf(pdf_path):\n    \"\"\"Extract all tables from a PDF and return as a list of DataFrames.\"\"\"\n    all_tables = []\n    with pdfplumber.open(pdf_path) as pdf:\n        print(f\"[i] PDF has {len(pdf.pages)} page(s)\")\n        for i, page in enumerate(pdf.pages):\n            tables = page.extract_tables()\n            print(f\"    Page {i+1}: found {len(tables)} table(s)\")\n            for t_idx, table in enumerate(tables):\n                # First row as header\n                header = table[0]\n                rows = table[1:]\n                df = pd.DataFrame(rows, columns=header)\n                all_tables.append(df)\n    return all_tables\n\n\n# \u2500\u2500 Step 2: Pandas analysis \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nimport pandas as pd\n\ndef analyze_data(df):\n    \"\"\"Perform comprehensive analysis on the sales DataFrame.\"\"\"\n    # Clean data: convert numeric columns\n    df[\"Units Sold\"] = pd.to_numeric(df[\"Units Sold\"], errors=\"coerce\")\n    df[\"Unit Price ($)\"] = pd.to_numeric(df[\"Unit Price ($)\"], errors=\"coerce\")\n\n    # Compute revenue\n    df[\"Revenue ($)\"] = df[\"Units Sold\"] * df[\"Unit Price ($)\"]\n\n    analysis = {}\n\n    # --- Summary statistics ---\n    analysis[\"summary\"] = df.describe()\n\n    # --- Revenue by Region ---\n    analysis[\"by_region\"] = (\n        df.groupby(\"Region\")[\"Revenue ($)\"]\n        .sum()\n        .reset_index()\n        .sort_values(\"Revenue ($)\", ascending=False)\n    )\n\n    # --- Revenue by Product ---\n    analysis[\"by_product\"] = (\n        df.groupby(\"Product\")[\"Revenue ($)\"]\n        .sum()\n        .reset_index()\n        .sort_values(\"Revenue ($)\", ascending=False)\n    )\n\n    # --- Revenue by Quarter ---\n    analysis[\"by_quarter\"] = (\n        df.groupby(\"Quarter\")[\"Revenue ($)\"]\n        .sum()\n        .reset_index()\n        .sort_values(\"Quarter\")\n    )\n\n    # --- Cross-tabulation: Region \u00d7 Product ---\n    analysis[\"region_product\"] = (\n        df.pivot_table(\n            values=\"Revenue ($)\",\n            index=\"Region\",\n            columns=\"Product\",\n            aggfunc=\"sum\",\n            fill_value=0,\n        )\n    )\n\n    # --- Top 5 rows by revenue ---\n    analysis[\"top5\"] = df.nlargest(5, \"Revenue ($)\")\n\n    # --- Units sold by region and quarter ---\n    analysis[\"units_region_quarter\"] = (\n        df.pivot_table(\n            values=\"Units Sold\",\n            index=\"Region\",\n            columns=\"Quarter\",\n            aggfunc=\"sum\",\n            fill_value=0,\n        )\n    )\n\n    return df, analysis\n\n\n# \u2500\u2500 Step 3: Write results to Excel with formatting \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nfrom openpyxl import load_workbook\nfrom openpyxl.styles import Font, PatternFill, Alignment, Border, Side\nfrom openpyxl.utils import get_column_letter\n\ndef write_to_excel(df, analysis, output_path):\n    \"\"\"Write the cleaned data and all analysis sheets to a formatted Excel file.\"\"\"\n    with pd.ExcelWriter(output_path, engine=\"openpyxl\") as writer:\n        # Cleaned source data\n        df.to_excel(writer, sheet_name=\"Raw Data\", index=False)\n\n        # Each analysis result as its own sheet\n        sheet_names = {\n            \"summary\": \"Summary Stats\",\n            \"by_region\": \"Revenue by Region\",\n            \"by_product\": \"Revenue by Product\",\n            \"by_quarter\": \"Revenue by Quarter\",\n            \"region_product\": \"Region \u00d7 Product\",\n            \"top5\": \"Top 5 Transactions\",\n            \"units_region_quarter\": \"Units by Region/Qtr\",\n        }\n        for key, sheet_name in sheet_names.items():\n            analysis[key].to_excel(writer, sheet_name=sheet_name)\n\n    # \u2500\u2500 Apply formatting \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    wb = load_workbook(output_path)\n    header_font = Font(bold=True, color=\"FFFFFF\", size=11)\n    header_fill = PatternFill(start_color=\"4472C4\", end_color=\"4472C4\", fill_type=\"solid\")\n    thin_border = Border(\n        left=Side(style=\"thin\"),\n        right=Side(style=\"thin\"),\n        top=Side(style=\"thin\"),\n        bottom=Side(style=\"thin\"),\n    )\n\n    for ws in wb.worksheets:\n        # Format header row\n        for cell in ws[1]:\n            cell.font = header_font\n            cell.fill = header_fill\n            cell.alignment = Alignment(horizontal=\"center\")\n            cell.border = thin_border\n\n        # Auto-fit column widths\n        for col_idx, col_cells in enumerate(ws.columns, 1):\n            max_len = 0\n            for cell in col_cells:\n                cell.border = thin_border\n                cell.alignment = Alignment(horizontal=\"center\")\n                val = str(cell.value) if cell.value else \"\"\n                max_len = max(max_len, len(val))\n            ws.column_dimensions[get_column_letter(col_idx)].width = min(max_len + 4, 30)\n\n        # Freeze top row\n        ws.freeze_panes = \"A2\"\n\n    wb.save(output_path)\n    print(f\"[\u2713] Excel report written: {output_path}\")\n\n\n# \u2500\u2500 Main pipeline \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef main():\n    print(\"=\" * 60)\n    print(\"  PDF \u2192 Pandas \u2192 Excel Pipeline\")\n    print(\"=\" * 60)\n\n    # 0. Create sample PDF\n    create_sample_pdf()\n\n    # 1. Extract tables from PDF\n    print(\"\\n[Step 1] Extracting tables from PDF...\")\n    tables = extract_tables_from_pdf(SAMPLE_PDF)\n    if not tables:\n        print(\"[!] No tables found in PDF.\")\n        return\n    df = tables[0]\n    print(f\"    Extracted {len(df)} rows, {len(df.columns)} columns\")\n    print(f\"    Columns: {list(df.columns)}\")\n\n    # 2. Analyze with pandas\n    print(\"\\n[Step 2] Analyzing data with pandas...\")\n    df, analysis = analyze_data(df)\n    print(f\"    Total Revenue: ${df['Revenue ($)'].sum():,.2f}\")\n    print(f\"    Total Units Sold: {df['Units Sold'].sum():,}\")\n    print(f\"    Analysis sheets generated: {len(analysis)}\")\n\n    # 3. Write to Excel\n    print(\"\\n[Step 3] Writing results to Excel...\")\n    write_to_excel(df, analysis, OUTPUT_XLSX)\n\n    # 4. Print summary to console\n    print(\"\\n\" + \"=\" * 60)\n    print(\"  RESULTS SUMMARY\")\n    print(\"=\" * 60)\n    print(\"\\nRevenue by Region:\")\n    print(analysis[\"by_region\"].to_string(index=False))\n    print(\"\\nRevenue by Product:\")\n    print(analysis[\"by_product\"].to_string(index=False))\n    print(\"\\nRevenue by Quarter:\")\n    print(analysis[\"by_quarter\"].to_string(index=False))\n    print(f\"\\n\u2713 Output file: {os.path.abspath(OUTPUT_XLSX)}\")\n\n\nif __name__ == \"__main__\":\n    main()\n```\n\n---\n\n## How It Works\n\n| Step | Tool | What It Does |\n|------|------|-------------|\n| **0** | `reportlab` | Generates a sample PDF with a styled sales table |\n| **1** | `pdfplumber` | Opens the PDF, detects and extracts all tables into pandas DataFrames |\n| **2** | `pandas` | Cleans data, computes revenue, groups by region/product/quarter, creates pivot tables, finds top transactions |\n| **3** | `openpyxl` | Writes 8 sheets to Excel with formatted headers, borders, auto-fit columns, and frozen panes |\n\n## Output Excel Sheets\n\n| Sheet | Content |\n|-------|---------|\n| **Raw Data** | Cleaned extracted data with computed Revenue column |\n| **Summary Stats** | `df.describe()` \u2014 count, mean, std, min, max for all numeric columns |\n| **Revenue by Region** | Total revenue grouped by region, sorted descending |\n| **Revenue by Product** | Total revenue grouped by product |\n| **Revenue by Quarter** | Total revenue per quarter |\n| **Region \u00d7 Product** | Pivot table cross-tabulating region and product revenue |\n| **Top 5 Transactions** | The 5 highest-revenue individual transactions |\n| **Units by Region/Qtr** | Pivot table of units sold by region and quarter |\n\n## To Use With Your Own PDF\n\nReplace the `create_sample_pdf()` call and point the extractor at your file:\n\n```python\ntables = extract_tables_from_pdf(\"your_document.pdf\")\ndf = tables[0]  # or iterate through multiple tables\ndf, analysis = analyze_data(df)\nwrite_to_excel(df, analysis, \"output.xlsx\")\n```\n\n> **Note:** `pdfplumber` handles most structured tables well. For scanned/image-based PDFs, add OCR via `pytesseract` + `pdf2image` before table extraction.", "solver_finish_reason": "stop"}
{"task": "financial-modeling-qa", "condition": "retrieved_top1_full", "repeat": 0, "skill_ids": ["benchflow-ai--xlsx-3"], "retrieval_correct": false, "judged_pass": false, "judged_score": 0, "judge_reason": "Agent's solution creates a sample PDF and performs analysis on it, but does not address the actual task of analyzing an existing Excel file and extracting data to produce a specific answer in /root/answer.txt as required by the oracle and verifier.", "solver_tokens": 5858, "judge_tokens": 5446, "solution_text": "# PDF Parsing \u2192 Pandas Analysis \u2192 Excel Output\n\nHere's a complete, self-contained Python solution that extracts tabular data from a PDF, analyzes it with pandas, and exports formatted results to an Excel workbook.\n\n## Prerequisites\n\n```bash\npip install pandas openpyxl pdfplumber xlsxwriter\n```\n\n## Complete Solution\n\n```python\n#!/usr/bin/env python3\n\"\"\"\nPDF \u2192 Pandas Analysis \u2192 Excel Pipeline\nExtracts tables from PDF, performs analysis, outputs formatted Excel workbook.\n\"\"\"\n\nimport pandas as pd\nimport pdfplumber\nimport os\nfrom openpyxl import Workbook\nfrom openpyxl.styles import Font, PatternFill, Alignment, Border, Side\nfrom openpyxl.utils.dataframe import dataframe_to_rows\nfrom openpyxl.chart import BarChart, PieChart, Reference\nfrom datetime import datetime\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# STEP 1: Create a sample PDF with tabular data\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef create_sample_pdf(output_path=\"sample_report.pdf\"):\n    \"\"\"Generate a sample PDF containing tabular sales data for demonstration.\"\"\"\n    from reportlab.lib.pagesizes import letter\n    from reportlab.lib import colors\n    from reportlab.platypus import SimpleDocTemplate, Table, TableStyle, Paragraph, Spacer\n    from reportlab.lib.styles import getSampleStyleSheet\n\n    doc = SimpleDocTemplate(output_path, pagesize=letter)\n    styles = getSampleStyleSheet()\n    elements = []\n\n    elements.append(Paragraph(\"Quarterly Sales Report - 2024\", styles[\"Title\"]))\n    elements.append(Spacer(1, 20))\n\n    # Table 1: Sales by Region\n    sales_data = [\n        [\"Region\", \"Q1\", \"Q2\", \"Q3\", \"Q4\", \"Total\"],\n        [\"North\", 125000, 138000, 142000, 155000, 560000],\n        [\"South\", 98000, 105000, 112000, 120000, 435000],\n        [\"East\", 145000, 152000, 160000, 175000, 632000],\n        [\"West\", 110000, 118000, 125000, 132000, 485000],\n        [\"Central\", 88000, 95000, 102000, 108000, 393000],\n    ]\n    t1 = Table(sales_data, colWidths=[80, 70, 70, 70, 70, 80])\n    t1.setStyle(TableStyle([\n        (\"BACKGROUND\", (0, 0), (-1, 0), colors.HexColor(\"#2E4057\")),\n        (\"TEXTCOLOR\", (0, 0), (-1, 0), colors.white),\n        (\"ALIGN\", (0, 0), (-1, -1), \"CENTER\"),\n        (\"FONTNAME\", (0, 0), (-1, 0), \"Helvetica-Bold\"),\n        (\"FONTSIZE\", (0, 0), (-1, -1), 10),\n        (\"GRID\", (0, 0), (-1, -1), 0.5, colors.grey),\n        (\"ROWBACKGROUNDS\", (0, 1), (-1, -1), [colors.white, colors.HexColor(\"#F0F4F8\")]),\n    ]))\n    elements.append(t1)\n    elements.append(Spacer(1, 30))\n\n    # Table 2: Product Performance\n    product_data = [\n        [\"Product\", \"Units Sold\", \"Revenue\", \"Cost\", \"Profit\", \"Margin %\"],\n        [\"Widget A\", 12500, 375000, 225000, 150000, 40.0],\n        [\"Widget B\", 8900, 267000, 187000, 80000, 29.9],\n        [\"Gadget X\", 15200, 456000, 273600, 182400, 40.0],\n        [\"Gadget Y\", 6800, 204000, 163200, 40800, 20.0],\n        [\"Module Z\", 22000, 440000, 264000, 176000, 40.0],\n        [\"Service P\", 3500, 175000, 87500, 87500, 50.0],\n        [\"Service Q\", 4200, 252000, 151200, 100800, 40.0],\n    ]\n    t2 = Table(product_data, colWidths=[70, 70, 70, 70, 70, 70])\n    t2.setStyle(TableStyle([\n        (\"BACKGROUND\", (0, 0), (-1, 0), colors.HexColor(\"#2E4057\")),\n        (\"TEXTCOLOR\", (0, 0), (-1, 0), colors.white),\n        (\"ALIGN\", (0, 0), (-1, -1), \"CENTER\"),\n        (\"FONTNAME\", (0, 0), (-1, 0), \"Helvetica-Bold\"),\n        (\"FONTSIZE\", (0, 0), (-1, -1), 10),\n        (\"GRID\", (0, 0), (-1, -1), 0.5, colors.grey),\n        (\"ROWBACKGROUNDS\", (0, 1), (-1, -1), [colors.white, colors.HexColor(\"#F0F4F8\")]),\n    ]))\n    elements.append(t2)\n\n    doc.build(elements)\n    print(f\"\u2713 Sample PDF created: {output_path}\")\n    return output_path\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# STEP 2: Extract tables from PDF\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef extract_tables_from_pdf(pdf_path):\n    \"\"\"Parse PDF and extract all tables into a list of DataFrames.\"\"\"\n    tables = []\n    table_names = []\n\n    with pdfplumber.open(pdf_path) as pdf:\n        print(f\"\u2713 Opened PDF: {pdf_path} ({len(pdf.pages)} page(s))\")\n        for i, page in enumerate(pdf.pages):\n            extracted = page.extract_tables()\n            for j, table in enumerate(extracted):\n                if table and len(table) > 1:\n                    # First row as header\n                    df = pd.DataFrame(table[1:], columns=table[0])\n                    # Clean column names\n                    df.columns = [str(c).strip() for c in df.columns]\n                    # Convert numeric columns\n                    for col in df.columns:\n                        df[col] = pd.to_numeric(df[col], errors=\"ignore\")\n                    tables.append(df)\n                    table_names.append(f\"Table_{i+1}_{j+1}\")\n                    print(f\"  \u2713 Extracted {table_names[-1]}: {df.shape[0]} rows \u00d7 {df.shape[1]} cols\")\n\n    return tables, table_names\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# STEP 3: Pandas Analysis\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef analyze_data(tables, table_names):\n    \"\"\"Perform comprehensive analysis on extracted data.\"\"\"\n    results = {}\n\n    # --- Analysis on Table 1 (Regional Sales) ---\n    if len(tables) >= 1:\n        df_sales = tables[0].copy()\n        print(f\"\\n--- Analyzing: {table_names[0]} ---\")\n\n        # Basic stats\n        results[\"regional_summary\"] = df_sales.describe()\n\n        # Rank regions by total\n        df_sales_sorted = df_sales.sort_values(\"Total\", ascending=False).reset_index(drop=True)\n        df_sales_sorted[\"Rank\"] = range(1, len(df_sales_sorted) + 1)\n        df_sales_sorted[\"% of Grand Total\"] = (\n            df_sales_sorted[\"Total\"] / df_sales_sorted[\"Total\"].sum() * 100\n        ).round(1)\n        results[\"regional_ranking\"] = df_sales_sorted\n\n        # Quarter-over-quarter growth\n        quarters = [\"Q1\", \"Q2\", \"Q3\", \"Q4\"]\n        growth_data = []\n        for _, row in df_sales.iterrows():\n            for i in range(1, len(quarters)):\n                prev = row[quarters[i - 1]]\n                curr = row[quarters[i]]\n                growth = ((curr - prev) / prev * 100) if prev != 0 else 0\n                growth_data.append({\n                    \"Region\": row[\"Region\"],\n                    \"Period\": f\"{quarters[i-1]}\u2192{quarters[i]}\",\n                    \"Growth %\": round(growth, 1),\n                })\n        results[\"quarterly_growth\"] = pd.DataFrame(growth_data)\n\n        # Grand totals\n        grand_total = df_sales[\"Total\"].sum()\n        results[\"grand_total\"] = pd.DataFrame({\n            \"Metric\": [\"Grand Total Revenue\", \"Average per Region\", \"Highest Region\", \"Lowest Region\"],\n            \"Value\": [\n                f\"${grand_total:,.0f}\",\n                f\"${grand_total / len(df_sales):,.0f}\",\n                f\"{df_sales.loc[df_sales['Total'].idxmax(), 'Region']} (${df_sales['Total'].max():,.0f})\",\n                f\"{df_sales.loc[df_sales['Total'].idxmin(), 'Region']} (${df_sales['Total'].min():,.0f})\",\n            ],\n        })\n\n    # --- Analysis on Table 2 (Product Performance) ---\n    if len(tables) >= 2:\n        df_products = tables[1].copy()\n        print(f\"\\n--- Analyzing: {table_names[1]} ---\")\n\n        # Sort by profit\n        df_products_sorted = df_products.sort_values(\"Profit\", ascending=False).reset_index(drop=True)\n        df_products_sorted[\"Profit Rank\"] = range(1, len(df_products_sorted) + 1)\n        df_products_sorted[\"Revenue Share %\"] = (\n            df_products_sorted[\"Revenue\"] / df_products_sorted[\"Revenue\"].sum() * 100\n        ).round(1)\n        results[\"product_ranking\"] = df_products_sorted\n\n        # Profitability categories\n        def categorize(margin):\n            if margin >= 40:\n                return \"High\"\n            elif margin >= 25:\n                return \"Medium\"\n            else:\n                return \"Low\"\n\n        df_products[\"Profitability\"] = df_products[\"Margin %\"].apply(categorize)\n        results[\"profitability_breakdown\"] = (\n            df_products.groupby(\"Profitability\")\n            .agg({\"Product\": \"count\", \"Revenue\": \"sum\", \"Profit\": \"sum\"})\n            .rename(columns={\"Product\": \"Count\"})\n            .reset_index()\n        )\n\n        # Top/bottom performers\n        results[\"top_products\"] = df_products.nlargest(3, \"Profit\")[[\"Product\", \"Profit\", \"Margin %\"]]\n        results[\"bottom_products\"] = df_products.nsmallest(2, \"Profit\")[[\"Product\", \"Profit\", \"Margin %\"]]\n\n    return results\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# STEP 4: Export to formatted Excel\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef export_to_excel(results, raw_tables, table_names, output_path=\"analysis_output.xlsx\"):\n    \"\"\"Write all analysis results to a formatted, multi-sheet Excel workbook.\"\"\"\n    wb = Workbook()\n\n    # Style definitions\n    header_font = Font(name=\"Calibri\", bold=True, color=\"FFFFFF\", size=11)\n    header_fill = PatternFill(start_color=\"2E4057\", end_color=\"2E4057\", fill_type=\"solid\")\n    alt_fill = PatternFill(start_color=\"F0F4F8\", end_color=\"F0F4F8\", fill_type=\"solid\")\n    title_font = Font(name=\"Calibri\", bold=True, size=14, color=\"2E4057\")\n    currency_format = '#,##0'\n    pct