\n    \"proceedings\": [\"title\", \"year\"],\n    \"techreport\": [\"author\", \"title\", \"institution\", \"year\"],\n    \"unpublished\": [\"author\", \"title\", \"note\"],\n}\n\nOPTIONAL_FIELDS = {\n    \"article\": [\"volume\", \"number\", \"pages\", \"month\", \"note\", \"doi\", \"url\"],\n    \"book\": [\"editor\", \"volume\", \"number\", \"series\", \"address\", \"edition\", \"month\", \"note\", \"doi\", \"isbn\"],\n    \"inproceedings\": [\"editor\", \"volume\", \"number\", \"series\", \"pages\", \"address\", \"month\", \"organization\", \"publisher\", \"note\", \"doi\"],\n    \"incollection\": [\"editor\", \"volume\", \"number\", \"series\", \"chapter\", \"pages\", \"address\", \"edition\", \"month\", \"note\", \"doi\"],\n    \"phdthesis\": [\"type\", \"address\", \"month\", \"note\"],\n    \"mastersthesis\": [\"type\", \"address\", \"month\", \"note\"],\n    \"techreport\": [\"type\", \"number\", \"address\", \"month\", \"note\"],\n}\n\n# Alternative field names (case-insensitive matching)\nFIELD_ALIASES = {\n    \"author\": [\"author\", \"authors\"],\n    \"title\": [\"title\"],\n    \"year\": [\"year\", \"date\"],\n    \"journal\": [\"journal\", \"journaltitle\"],\n    \"booktitle\": [\"booktitle\"],\n    \"publisher\": [\"publisher\", \"institution\", \"school\", \"organization\"],\n}\n\n\nclass BibTeXParser:\n    \"\"\"Parser for BibTeX format files.\"\"\"\n\n    def __init__(self):\n        self.entries: List[BibEntry] = []\n\n    def parse(self, bibtex_string: str) -> List[BibEntry]:\n        \"\"\"Parse a BibTeX string and return list of entries.\"\"\"\n        self.entries = []\n        # Remove comments (lines starting with %)\n        lines = bibtex_string.split('\\n')\n        cleaned_lines = []\n        for line in lines:\n            # Remove inline comments but preserve strings\n            if line.strip().startswith('%'):\n                cleaned_lines.append('')\n            else:\n                cleaned_lines.append(line)\n        text =