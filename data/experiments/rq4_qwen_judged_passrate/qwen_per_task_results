tifactId>\n            <version>${flink.version}</version>\n            <scope>provided</scope>\n        </dependency>\n        <dependency>\n            <groupId>org.apache.flink</groupId>\n            <artifactId>flink-connector-files</artifactId>\n            <version>${flink.version}</version>\n        </dependency>\n    </dependencies>\n\n    <build>\n        <plugins>\n            <plugin>\n                <groupId>org.apache.maven.plugins</groupId>\n                <artifactId>maven-shade-plugin</artifactId>\n                <version>3.4.1</version>\n                <executions>\n                    <execution>\n                        <phase>package</phase>\n                        <goals><goal>shade</goal></goals>\n                        <configuration>\n                            <transformers>\n                                <transformer implementation=\"org.apache.maven.plugins.shade.resource.ManifestResourceTransformer\">\n                                    <mainClass>com.example.SessionWindowJob</mainClass>\n                                </transformer>\n                            </transformers>\n                        </configuration>\n                    </execution>\n                </executions>\n            </plugin>\n        </plugins>\n    </build>\n</project>\n```\n\n## `src/main/java/com/example/SessionWindowJob.java`\n\n```java\npackage com.example;\n\nimport org.apache.flink.api.common.eventtime.WatermarkStrategy;\nimport org.apache.flink.api.common.functions.AggregateFunction;\nimport org.apache.flink.api.common.functions.MapFunction;\nimport org.apache.flink.api.common.serialization.SimpleStringEncoder;\nimport org.apache.flink.api.java.tuple.Tuple2;\nimport org.apache.flink.api.java.tuple.Tuple3;\nimport org.apache.flink.configuration.MemorySize;\nimport org.apache.flink.connector.file.sink.FileSink;\nimport org.apache.flink.connector.file.src.FileSource;\nimport org.apache.flink.connector.file.src.reader.TextLineInputFormat;\nimport org.apache.flink.core.fs.Path;\nimport org.apache.flink.streaming.api.datastream.DataStream;\nimport org.apache.flink.streaming.api.environment.StreamExecutionEnvironment;\nimport org.apache.flink.streaming.api.functions.windowing.ProcessWindowFunction;\nimport org.apache.flink.streaming.api.window.assigners.EventTimeSessionWindows;\nimport org.apache.flink.streaming.api.window.assigners.ProcessingTimeSessionWindows;\nimport org.apache.flink.streaming.api.window.time.Time;\nimport org.apache.flink.streaming.api.window.windows.TimeWindow;\nimport org.apache.flink.util.Collector;\n\nimport java.time.Duration;\n\n/**\n * Apache Flink Session Window Stream Processing Job\n *\n * Demonstrates:\n * 1. Event-time session windows with gap-based merging\n * 2. Processing-time session windows\n * 3. Window aggregation with ProcessWindowFunction\n * 4. Watermark generation for out-of-order events\n *\n * Input format (CSV): userId,action,timestamp\n * Example: user1,click,1696100000000\n */\npublic class SessionWindowJob {\n\n    // Session gap duration: if no events arrive within this period, the session closes\n    private static final long SESSION_GAP_MS = 5 * 60 * 1000; // 5 minutes\n\n    public static void main(String[] args) throws Exception {\n\n        // ---------------------------------------------------------------\n        // 1. Set up the streaming execution environment\n        // ---------------------------------------------------------------\n        final StreamExecutionEnvironment env = StreamExecutionEnvironment.getExecutionEnvironment();\n        env.setParallelism(2);\n\n        // ---------------------------------------------------------------\n        // 2. Define the source \u2014 reads CSV lines from a directory\n        //    Format: userId,action,timestampEpochMs\n        // ---------------------------------------------------------------\n        FileSource<String> source = FileSource\n                .forRecordStreamFormat(new TextLineInputFormat(), new Path(\"/tmp/flink-input\"))\n                .monitorContinuously(Duration.ofSeconds(5))\n                .build();\n\n        DataStream<Event> eventStream = env\n                .fromSource(source, WatermarkStrategy.noWatermarks(), \"FileSource\")\n                .map(new EventParser())\n                .filter(event -> event != null);\n\n        // ---------------------------------------------------------------\n        // 3. Assign watermarks (bounded out-of-orderness = 10 seconds)\n        // ---------------------------------------------------------------\n        DataStream<Event> withWatermarks = eventStream\n                .assignTimestampsAndWatermarks(\n                        WatermarkStrategy\n                                .<Event>forBoundedOutOfOrderness(Duration.ofSeconds(10))\n                                .withTimestampAssigner((event, timestamp) -> event.timestamp)\n                );\n\n        // ---------------------------------------------------------------\n        // 4. Key by userId and apply EVENT-TIME session window\n        // ---------------------------------------------------------------\n        DataStream<SessionResult> sessionResults = withWatermarks\n                .keyBy(event -> event.userId)\n                .window(EventTimeSessionWindows.withGap(Time.milliseconds(SESSION_GAP_MS)))\n                .process(new SessionWindowProcessor());\n\n        // ---------------------------------------------------------------\n        // 5. Print results to stdout and write to output directory\n        // ---------------------------------------------------------------\n        sessionResults.print(\"SessionResult\");\n\n        FileSink<SessionResult> sink = FileSink\n                .<SessionResult>forRowFormat(new Path(\"/tmp/flink-output\"), new SimpleStringEncoder<>(\"UTF-8\"))\n                .withRollingPolicy(\n                        org.apache.flink.streaming.api.functions.sink.filesystem.rollingpolicies.DefaultRollingPolicy.builder()\n                                .withRolloverInterval(Duration.ofMinutes(5))\n                                .withInactivityInterval(Duration.ofMinutes(1))\n                                .withMaxPartSize(MemorySize.ofMebiBytes(128))\n                                .build())\n                .build();\n\n        sessionResults.map(result -> result.toString()).sinkTo(sink);\n\n        // ---------------------------------------------------------------\n        // 6. Execute the job\n        // ---------------------------------------------------------------\n        env.execute(\"Flink Session Window Job\");\n    }\n\n    // ===================================================================\n    // Data model\n    // ===================================================================\n\n    /** Represents a single user event. */\n    public static class Event implements java.io.Serializable {\n        public String userId;\n        public String action;\n        public long timestamp;\n\n        public Event() {}\n\n        public Event(String userId, String action, long timestamp) {\n            this.userId = userId;\n            this.action = action;\n            this.timestamp = timestamp;\n        }\n\n        @Override\n        public String toString() {\n            return \"Event{\" + userId + \", \" + action + \", \" + timestamp + \"}\";\n        }\n    }\n\n    /** Aggregated result for a completed session window. */\n    public static class SessionResult implements java.io.Serializable {\n        public String userId;\n        public int eventCount;\n        public long sessionStart;\n        public long sessionEnd;\n        public String actions; // comma-separated list of actions in the session\n\n        public SessionResult() {}\n\n        public SessionResult(String userId, int eventCount, long sessionStart, long sessionEnd, String actions) {\n            this.userId = userId;\n            this.eventCount = eventCount;\n            this.sessionStart = sessionStart;\n            this.sessionEnd = sessionEnd;\n            this.actions = actions;\n        }\n\n        @Override\n        public String toString() {\n            return String.format(\n                    \"Session{user=%s, events=%d, start=%d, end=%d, duration=%dms, actions=[%s]}\",\n                    userId, eventCount, sessionStart, sessionEnd,\n                    (sessionEnd - sessionStart), actions\n            );\n        }\n    }\n\n    // ===================================================================\n    // Functions\n    // ===================================================================\n\n    /** Parses CSV lines into Event objects. */\n    public static class EventParser implements MapFunction<String, Event> {\n        @Override\n        public Event map(String line) {\n            if (line == null || line.trim().isEmpty() || line.startsWith(\"#\")) {\n                return null;\n            }\n            try {\n                String[] parts = line.split(\",\");\n                if (parts.length < 3) return null;\n                String userId = parts[0].trim();\n                String action = parts[1].trim();\n                long timestamp = Long.parseLong(parts[2].trim());\n                return new Event(userId, action, timestamp);\n            } catch (Exception e) {\n                System.err.println(\"Failed to parse line: \" + line);\n                return null;\n            }\n        }\n    }\n\n    /**\n     * ProcessWindowFunction that collects all events in a session window\n     * and produces a SessionResult when the window fires.\n     */\n    public static class SessionWindowProcessor\n            extends ProcessWindowFunction<Event, SessionResult, String, TimeWindow> {\n\n        @Override\n        public void process(\n                String userId,\n                Context context,\n                Iterable<Event> events,\n                Collector<SessionResult> out) {\n\n     