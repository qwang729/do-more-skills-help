e.pdfbox.text.PDFTextStripper;\nimport org.springframework.stereotype.Component;\n\nimport java.io.File;\nimport java.io.IOException;\nimport java.nio.file.Path;\n\n@Component\npublic class PdfTextExtractor {\n\n    public String extractText(Path pdfPath) throws IOException {\n        try (PDDocument document = Loader.loadPDF(pdfPath.toFile())) {\n            PDFTextStripper stripper = new PDFTextStripper();\n            stripper.setSortByPosition(true);\n            return stripper.getText(document);\n        }\n    }\n\n    public String extractText(File pdfFile) throws IOException {\n        return extractText(pdfFile.toPath());\n    }\n}\n```\n\n## 4. Document Classifier\n\n```java\npackage com.example.pdfclassifier;\n\nimport org.springframework.stereotype.Component;\nimport java.util.Arrays;\nimport java.util.HashMap;\nimport java.util.Map;\n\n@Component\npublic class DocumentClassifier {\n\n    public DocumentCategory classify(String text) {\n        if (text == null || text.isBlank()) {\n            return DocumentCategory.UNKNOWN;\n        }\n\n        String lowerText = text.toLowerCase();\n        Map<DocumentCategory, Integer> scores = new HashMap<>();\n\n        for (DocumentCategory category : DocumentCategory.values()) {\n            if (category == DocumentCategory.UNKNOWN) continue;\n            \n            int score = 0;\n            for (String keyword : category.getKeywords()) {\n                if (lowerText.contains(keyword.toLowerCase())) {\n                    score++;\n                }\n            }\n            scores.put(category, score);\n        }\n\n        return scores.entrySet().stream()\n                .filter(e -> e.getValue() > 0)\n                .max(Map.Entry.comparingByValue())\n                .map(Map.Entry::getKey)\n                .orElse(DocumentCategory.UNKNOWN);\n    }\n}\n```\n\n## 5. Classified Document Model\n\n```java\npackage com.example.pdfclassifier;\n\nimport java.nio.file.Path;\nimport java.time.LocalDateTime;\n\npublic class ClassifiedDocument {\n    private final Path filePath;\n    private final String extractedText;\n    private final DocumentCategory category;\n    private final LocalDateTime processedAt;\n    private final int pageCount;\n\n    public ClassifiedDocument(Path filePath, String extractedText, \n                              DocumentCategory category, int pageCount) {\n        this.filePath = filePath;\n        this.extractedText = extractedText;\n        this.category = category;\n        this.pageCount = pageCount;\n        this.processedAt = LocalDateTime.now();\n    }\n\n    public Path getFilePath() { return filePath; }\n    public String getExtractedText() { return extractedText; }\n    public DocumentCategory getCategory() { return category; }\n    public LocalDateTime getProcessedAt() { return processedAt; }\n    public int getPageCount() { return pageCount; }\n\n    @Override\n    public String toString() {\n        return String.format(\"ClassifiedDocument{file='%s', category=%s, pages=%d}\",\n                filePath.getFileName(), category, pageCount);\n    }\n}\n```\n\n## 6. Document Processor & Sorter\n\n```java\npackage com.example.pdfclassifier;\n\nimport org.apache.pdfbox.Loader;\nimport org.apache.pdfbox.pdmodel.PDDocument;\nimport org.springframework.stereotype.Service;\n\nimport java.io.IOException;\nimport java.nio.file.*;\nimport java.util.*;\nimport java.util.stream.Collectors;\n\n@Service\npublic class DocumentProcessor {\n\n    private final PdfTextExtractor textExtractor;\n    private final DocumentClassifier classifier;\n\n    public DocumentProcessor(PdfTextExtractor textExtractor, DocumentClassifier classifier) {\n        this.textExtractor = textExtractor;\n        this.classifier = classifier;\n    }\n\n    public List<ClassifiedDocument> processDirectory(Path directory) throws IOException {\n        List<ClassifiedDocument> documents = new ArrayList<>();\n\n        try (DirectoryStream<Path> stream = Files.newDirectoryStream(directory, \"*.pdf\")) {\n            for (Path pdfPath : stream) {\n                try {\n                    ClassifiedDocument doc = processSingleDocument(pdfPath);\n                    documents.add(doc);\n                } catch (IOException e) {\n                    System.err.println(\"Failed to process: \" + pdfPath + \" - \" + e.getMessage());\n                }\n            }\n        }\n\n        return sortDocuments(documents);\n    }\n\n    public ClassifiedDocument processSingleDocument(Path pdfPath) throws IOException {\n        String text = textExtractor.extractText(pdfPath);\n        DocumentCategory category = classifier.classify(text);\n        \n        int pageCount;\n        try (PDDocument doc = Loader.loadPDF(pdfPath.toFile())) {\n            pageCount = doc.getNumberOfPages();\n        }\n\n        return new ClassifiedDocument(pdfPath, text, category, pageCount);\n    }\n\n    public List<ClassifiedDocument> sortDocuments(List<ClassifiedDocument> documents) {\n        return documents.stream()\n                .sorted(Comparator\n                        .comparing((ClassifiedDocument d) -> d.getCategory().name())\n                        .thenComparing(d -> d.getFilePath().getFileName().toString()))\n                .collect(Collectors.toList());\n    }\n\n    public Map<DocumentCategory, List<ClassifiedDocument>> groupByCategory(List<ClassifiedDocument> documents) {\n        return documents.stream()\n                .collect(Collectors.groupingBy(\n                        ClassifiedDocument::getCategory,\n                        TreeMap::new,\n                        Collectors.toList()\n                ));\n    }\n\n    public void moveSortedDocuments(List<ClassifiedDocument> documents, Path outputBase) throws IOException {\n        for (ClassifiedDocument doc : documents) {\n            Path categoryDir = outputBase.resolve(doc.getCategory().name().toLowerCase());\n            Files.createDirectories(categoryDir);\n            \n            Path destFile = categoryDir.resolve(doc.getFilePath().getFileName());\n            if (!Files.exists(destFile)) {\n                Files.copy(doc.getFilePath(), destFile, StandardCopyOption.REPLACE_EXISTING);\n            }\n        }\n    }\n}\n```\n\n## 7. Main Service with RestClient (using skill guide)\n\n```java\npackage com.example.pdfclassifier;\n\nimport org.springframework.stereotype.Service;\nimport org.springframework.web.client.RestClient;\nimport org.springframework.core.ParameterizedTypeReference;\n\nimport java.nio.file.Path;\nimport java.util.List;\nimport java.util.Map;\n\n@Service\npublic class PdfClassificationService {\n\n    private final DocumentProcessor documentProcessor;\n    private final RestClient restClient;\n\n    public PdfClassificationService(DocumentProcessor documentProcessor, RestClient.Builder restClientBuilder) {\n        this.documentProcessor = documentProcessor;\n        this.restClient = restClientBuilder\n                .baseUrl(\"https://api.example.com\")\n                .build();\n    }\n\n    public Map<DocumentCategory, List<ClassifiedDocument>> processAndSort(Path inputDir) throws IOException {\n        List<ClassifiedDocument> documents = documentProcessor.processDirectory(inputDir);\n        return documentProcessor.groupByCategory(documents);\n    }\n\n    public void exportResults(List<ClassifiedDocument> documents, String endpoint) {\n        List<Map<String, Object>> payload = documents.stream()\n                .map(d -> Map.<String, Object>of(\n                        \"filename\", d.getFilePath().getFileName().toString(),\n                        \"category\", d.getCategory().name(),\n                        \"pageCount\", d.getPageCount(),\n                        \"processedAt\", d.getProcessedAt().toString()\n                ))\n                .toList();\n\n        restClient.post()\n                .uri(endpoint)\n                .body(payload)\n                .retrieve()\n                .toBodilessEntity();\n    }\n\n    public List<String> fetchClassificationRules(String endpoint) {\n        return restClient.get()\n                .uri(endpoint)\n                .retrieve()\n                .body(new ParameterizedTypeReference<>() {});\n    }\n}\n```\n\n## 8. RestClient Configuration\n\n```java\npackage com.example.pdfclassifier;\n\nimport org.springframework.context.annotation.Bean;\nimport org.springframework.context.annotation.Configuration;\nimport org.springframework.web.client.RestClient;\n\nimport java.time.Duration;\n\n@Configuration\npublic class RestClientConfig {\n\n    @Bean\n    public RestClient.Builder restClientBuilder() {\n        return RestClient.builder()\n                .defaultHeader(\"Accept\", \"application/json\")\n                .defaultHeader(\"Content-Type\", \"application/json\");\n    }\n}\n```\n\n## 9. Command Line Runner\n\n```java\npackage com.example.pdfclassifier;\n\nimport org.springframework.boot.CommandLineRunner;\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.boot.autoconfigure.SpringBootApplication;\n\nimport java.nio.file.Path;\nimport java.util.List;\nimport java.util.Map;\n\n@SpringBootApplication\npublic class PdfClassifierApplication implements CommandLineRunner {\n\n    private final PdfClassificationService service;\n\n    public PdfClassifierApplication(PdfClassificationService service) {\n        this.service = service;\n    }\n\n    public static void main(String[] args) {\n        SpringApplication.run(PdfClassifierApplication.class, args);\n    }\n\n    @Override\n    public void run(String... args) throws Exception {\n        Path inputDir = args.length > 0 ? Path.of(args[0]) : Path.of(\"./pdfs\");\n        Path outputDir = args.length > 1 ? Path.of(args[1]) : Path.of(\"./sorted\");\n\n        System.out.println(\"Processing PDFs from: \" + inputDir);\n        \n        Map<DocumentCategory, List<ClassifiedDocument>> grouped = service.processAndSort(inputD