{"task": "3d-scan-calc", "condition": "no_skill", "repeat": 0, "skill_ids": [], "retrieval_correct": null, "judged_pass": false, "judged_score": 2, "judge_reason": "Agent's solution performs comprehensive STL analysis but does not compute mass using material ID and density table as required by the oracle", "solver_tokens": 4447, "judge_tokens": 4751, "solution_text": "# STL Mesh: Parsing, Connected Component Analysis & Volume Calculation\n\nBelow is a complete, self-contained Python solution. It handles both **binary** and **ASCII** STL files, performs **connected component analysis** via edge-sharing adjacency + BFS, and computes **signed volume** using the divergence theorem.\n\n```python\n#!/usr/bin/env python3\n\"\"\"\nSTL Mesh Analysis Tool\n- Parses binary and ASCII STL files\n- Connected component analysis (edge-adjacency + BFS)\n- Volume calculation per component (divergence theorem)\n\"\"\"\n\nimport struct\nimport numpy as np\nfrom collections import defaultdict, deque\nimport sys\nimport os\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 1. STL PARSING\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef parse_stl(filepath):\n    \"\"\"\n    Parse an STL file (auto-detects binary vs ASCII).\n    Returns:\n        vertices: np.ndarray of shape (N, 3, 3)  \u2014 N triangles, each with 3 vertices\n        normals:  np.ndarray of shape (N, 3)     \u2014 face normals\n    \"\"\"\n    with open(filepath, 'rb') as f:\n        header = f.read(80)\n        # Check if ASCII\n        f.seek(0)\n        first_line = f.readline()\n        f.seek(0)\n\n        if first_line.strip().startswith(b'solid') and not _is_binary_stl(filepath):\n            return _parse_ascii_stl(filepath)\n        else:\n            return _parse_binary_stl(filepath)\n\n\ndef _is_binary_stl(filepath):\n    \"\"\"Heuristic: if file size matches binary expectation, it's binary.\"\"\"\n    file_size = os.path.getsize(filepath)\n    with open(filepath, 'rb') as f:\n        f.read(80)  # skip header\n        num_triangles = struct.unpack('<I', f.read(4))[0]\n    expected_size = 80 + 4 + num_triangles * 50\n    return file_size == expected_size\n\n\ndef _parse_binary_stl(filepath):\n    \"\"\"Parse a binary STL file.\"\"\"\n    with open(filepath, 'rb') as f:\n        header = f.read(80)\n        num_triangles = struct.unpack('<I', f.read(4))[0]\n\n        vertices = np.zeros((num_triangles, 3, 3), dtype=np.float64)\n        normals = np.zeros((num_triangles, 3), dtype=np.float64)\n\n        for i in range(num_triangles):\n            data = f.read(50)\n            if len(data) < 50:\n                break\n            vals = struct.unpack('<12fH', data)\n            normals[i] = vals[0:3]\n            vertices[i, 0] = vals[3:6]\n            vertices[i, 1] = vals[6:9]\n            vertices[i, 2] = vals[9:12]\n            # attribute_byte_count = vals[12]  # usually 0\n\n    return vertices, normals\n\n\ndef _parse_ascii_stl(filepath):\n    \"\"\"Parse an ASCII STL file.\"\"\"\n    vertices_list = []\n    normals_list = []\n\n    with open(filepath, 'r') as f:\n        current_normal = None\n        current_verts = []\n\n        for line in f:\n            line = line.strip().split()\n            if not line:\n                continue\n\n            if line[0] == 'facet':\n                current_normal = [float(line[2]), float(line[3]), float(line[4])]\n                current_verts = []\n            elif line[0] == 'vertex':\n                current_verts.append([float(line[1]), float(line[2]), float(line[3])])\n            elif line[0] == 'endfacet':\n                if len(current_verts) == 3:\n                    normals_list.append(current_normal)\n                    vertices_list.append(current_verts)\n\n    vertices = np.array(vertices_list, dtype=np.float64)\n    normals = np.array(normals_list, dtype=np.float64)\n    return vertices, normals\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 2. CONNECTED COMPONENT ANALYSIS\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef _make_edge_key(v0, v1):\n    \"\"\"Create a hashable edge key from two vertices (order-independent).\"\"\"\n    # Round to avoid floating-point issues\n    v0 = tuple(np.round(v0, 8))\n    v1 = tuple(np.round(v1, 8))\n    return (min(v0, v1), max(v0, v1))\n\n\ndef find_connected_components(vertices):\n    \"\"\"\n    Find connected components by building an edge-adjacency graph.\n    Two triangles are connected if they share an edge (2 vertices).\n\n    Args:\n        vertices: np.ndarray of shape (N, 3, 3)\n\n    Returns:\n        labels: list of length N, where labels[i] = component ID for triangle i\n        num_components: int\n    \"\"\"\n    num_triangles = len(vertices)\n    if num_triangles == 0:\n        return [], 0\n\n    # Build edge -> triangle index mapping\n    edge_to_tri = defaultdict(list)\n\n    for i in range(num_triangles):\n        v0, v1, v2 = vertices[i]\n        edges = [\n            _make_edge_key(v0, v1),\n            _make_edge_key(v1, v2),\n            _make_edge_key(v2, v0),\n        ]\n        for edge in edges:\n            edge_to_tri[edge].append(i)\n\n    # Build adjacency list\n    adjacency = defaultdict(set)\n    for edge, tri_indices in edge_to_tri.items():\n        for j in range(len(tri_indices)):\n            for k in range(j + 1, len(tri_indices)):\n                adjacency[tri_indices[j]].add(tri_indices[k])\n                adjacency[tri_indices[k]].add(tri_indices[j])\n\n    # BFS to find connected components\n    labels = [-1] * num_triangles\n    component_id = 0\n\n    for start in range(num_triangles):\n        if labels[start] != -1:\n            continue\n        # BFS\n        queue = deque([start])\n        labels[start] = component_id\n        while queue:\n            current = queue.popleft()\n            for neighbor in adjacency[current]:\n                if labels[neighbor] == -1:\n                    labels[neighbor] = component_id\n                    queue.append(neighbor)\n        component_id += 1\n\n    return labels, component_id\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 3. VOLUME CALCULATION\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef compute_signed_volume(vertices):\n    \"\"\"\n    Compute the signed volume of a closed mesh using the divergence theorem.\n    Volume = (1/6) * \u03a3 (v0 \u00b7 (v1 \u00d7 v2)) for each triangle.\n\n    This works for watertight (manifold, closed) meshes.\n    For non-watertight meshes, it gives an approximation.\n\n    Args:\n        vertices: np.ndarray of shape (N, 3, 3)\n\n    Returns:\n        volume: float (absolute volume)\n    \"\"\"\n    if len(vertices) == 0:\n        return 0.0\n\n    v0 = vertices[:, 0, :]\n    v1 = vertices[:, 1, :]\n    v2 = vertices[:, 2, :]\n\n    # Signed volume of tetrahedra formed with origin\n    cross = np.cross(v1, v2)\n    signed_vols = np.sum(v0 * cross, axis=1)\n\n    total_signed_volume = np.sum(signed_vols) / 6.0\n    return abs(total_signed_volume)\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 4. MAIN ANALYSIS PIPELINE\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef analyze_stl(filepath):\n    \"\"\"\n    Full analysis pipeline:\n    1. Parse STL\n    2. Find connected components\n    3. Compute volume per component\n    4. Print summary\n    \"\"\"\n    print(f\"{'='*60}\")\n    print(f\"  STL Mesh Analysis: {os.path.basename(filepath)}\")\n    print(f\"{'='*60}\")\n\n    # Step 1: Parse\n    print(\"\\n[1] Parsing STL file...\")\n    vertices, normals = parse_stl(filepath)\n    num_triangles = len(vertices)\n    print(f\"    Triangles parsed: {num_triangles}\")\n\n    if num_triangles == 0:\n        print(\"    ERROR: No triangles found.\")\n        return\n\n    # Unique vertices count\n    all_verts = vertices.reshape(-1, 3)\n    unique_verts = np.unique(np.round(all_verts, 8), axis=0)\n    print(f\"    Unique vertices:  {len(unique_verts)}\")\n\n    # Bounding box\n    bbox_min = all_verts.min(axis=0)\n    bbox_max = all_verts.max(axis=0)\n    print(f\"    Bounding box min: ({bbox_min[0]:.4f}, {bbox_min[1]:.4f}, {bbox_min[2]:.4f})\")\n    print(f\"    Bounding box max: ({bbox_max[0]:.4f}, {bbox_max[1]:.4f}, {bbox_max[2]:.4f})\")\n\n    # Step 2: Connected components\n    print(\"\\n[2] Connected component analysis...\")\n    labels, num_components = find_connected_components(vertices)\n    print(f\"    Connected components found: {num_components}\")\n\n    # Group triangles by component\n    components = defaultdict(list)\n    for i, label in enumerate(labels):\n        components[label].append(i)\n\n    # Step 3: Volume per component\n    print(\"\\n[3] Volume calculation per component:\")\n    print(f\"    {'Component':<12} {'Triangles':<12} {'Volume':<20}\")\n    print(f\"    {'-'*12} {'-'*12} {'-'*20}\")\n\n    total_volume = 0.0\n    component_data = []\n\n    for comp_id in sorted(components.keys()):\n        tri_indices = components[comp_id]\n        comp_vertices = vertices[tri_indices]\n        vol = compute_signed_volume(comp_vertices)\n        total_volume += vol\n        component_data.append({\n            'id': comp_id,\n            'num_triangles': len(tri_indices),\n            'volume': vol,\n            'triangle_indices': tri_indices,\n        })\n        print(f\"    {comp_id:<12} {len(tri_indices):<12} {vol:<20.6f}\")\n\n    print(f\"    {'-'*12} {'-'*12} {'-'*20}\")\n    print(f\"    {'TOTAL':<12} {num_triangles:<12} {total_volume:<20.6f}\")\n\n    # Step 4: Summary\n    print(f\"\\n{'='*60}\")\n    print(f\"  SUMMARY\")\n    print(f\"{'='*60}\")\n    print(f\"  File:               {filepath}\")\n    print(f\"  Total triangles:    {num_triangles}\")\n    print(f\"  Unique vertices:    {len(unique_verts)}\")\n    print(f\"  Components:         {num_components}\")\n    print(f\"  Total volume:       {total_volume:.6f}\")\n\n    if num_components > 1:\n        print(f\"\\n  Component breakdown:\")\n        for cd in component_data:\n            pct = (cd['num_triangles'] / num_triangles) * 100\n            print(f\"    Component {cd['id']}: {cd['num_triangles']} tris \"\n                  f\"({pct:.1f}%), volume = {cd['volume']:.6f}\")\n\n    print(f\"{'='*60}\\n\")\n\n    return {\n        'num_triangles': num_triangles,\n        'num_unique_vertices': len(unique_verts),\n        'num_components': num_components,\n        'total_volume': total_volume,\n        'components': component_data,\n        'vertices': vertices,\n        'normals': normals,\n        'labels': labels,\n    }\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 5. DEMO: Generate test STL and analyze\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef generate_demo_stl(filepath):\n    \"\"\"\n    Generate a binary STL with two separate cubes (2 connected components)\n    to demonstrate the analysis.\n    \"\"\"\n    def cube_vertices(offset):\n        \"\"\"Return 12 triangles (2 per face) for a unit cube at given offset.\"\"\"\n        ox, oy, oz = offset\n        # 8 corners\n        v = [\n            (ox+0, oy+0, oz+0), (ox+1, oy+0, oz+0),\n            (ox+1, oy+1, oz+0), (ox+0, oy+1, oz+0),\n            (ox+0, oy+0, oz+1), (ox+1, oy+0, oz+1),\n            (ox+1, oy+1, oz+1), (ox+0, oy+1, oz+1),\n        ]\n        # 12 triangles (6 faces \u00d7 2 tris), CCW winding\n        faces = [\n            (0,3,2), (0,2,1),  # bottom\n            (4,5,6), (4,6,7),  # top\n            (0,1,5), (0,5,4),  # front\n            (2,3,7), (2,7,6),  # back\n            (0,4,7), (0,7,3),  # left\n            (1,2,6), (1,6,5),  # right\n        ]\n        triangles = []\n        for f in faces:\n            v0, v1, v2 = v[f[0]], v[f[1]], v[f[2]]\n            # Compute normal\n            a = np.array(v1) - np.array(v0)\n            b = np.array(v2) - np.array(v0)\n            n = np.cross(a, b)\n            norm = np.linalg.norm(n)\n            if norm > 0:\n                n = n / norm\n            triangles.append((n, v0, v1, v2))\n        return triangles\n\n    # Two cubes separated in space\n    all_triangles = []\n    all_triangles.extend(cube_vertices((0, 0, 0)))       # Cube 1 at origin\n    all_triangles.extend(cube_vertices((5, 5, 5)))       # Cube 2 offset\n\n    num_triangles = len(all_triangles)\n\n    with open(filepath, 'wb') as f:\n        # Header (80 bytes)\n        header = b'Demo STL - Two cubes (2 components)'\n        header = header.ljust(80, b'\\0')\n        f.write(header)\n        # Number of triangles\n        f.write(struct.pack('<I', num_triangles))\n        # Triangles\n        for normal, v0, v1, v2 in all_triangles:\n            f.write(struct.pack('<3f', *normal))\n            f.write(struct.pack('<3f', *v0))\n            f.write(struct.pack('<3f', *v1))\n            f.write(struct.pack('<3f', *v2))\n            f.write(struct.pack('<H', 0))  # attribute byte count\n\n    print(f\"Generated demo STL: {filepath} ({num_triangles} triangles, 2 cubes)\")\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# ENTRY POINT\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nif __name__ == '__main__':\n    if len(sys.argv) > 1:\n        stl_file = sys.argv[1]\n    else:\n        # Generate a demo file and analyze it\n        demo_path = '/tmp/demo_two_cubes.stl'\n        generate_demo_stl(demo_path)\n        stl_file = demo_path\n\n    result = analyze_stl(stl_file)\n\n    if result:\n        print(\"\\n\u2713 Analysis complete.\")\n    else:\n        print(\"\\n\u2717 Analysis failed.\")\n        sys.exit(1)\n```\n\n## How It Works\n\n### 1. STL Parsing\n- **Auto-detects** binary vs ASCII format by checking if file size matches the binary layout (`80 + 4 + N\u00d750` bytes)\n- **Binary**: reads 50-byte records (12 floats + 1 uint16 per triangle)\n- **ASCII**: parses `facet normal` / `vertex` / `endfacet` blocks\n\n### 2. Connected Component Analysis\n- Builds an **edge-to-triangle map** \u2014 each triangle contributes 3 edges (vertex pairs, rounded to 8 decimals for floating-point tolerance)\n- Two triangles sharing an edge are **adjacent**\n- **BFS** traverses the adjacency graph to label each triangle with its component ID\n\n### 3. Volume Calculation\n- Uses the **divergence theorem**: `V = (1/6) |\u03a3 v\u2080 \u00b7 (v\u2081 \u00d7 v\u2082)|`\n- Each triangle forms a signed tetrahedron with the origin; summing gives the enclosed volume\n- Works correctly for **watertight** (manifold closed) meshes\n\n### Usage\n\n```bash\n# Analyze an existing STL file\npython stl_analysis.py /path/to/mesh.stl\n\n# Run demo (generates 2 separate cubes \u2192 2 components)\npython stl_analysis.py\n```\n\n### Expected Demo Output\n```\n============================================================\n  STL Mesh Analysis: demo_two_cubes.stl\n============================================================\n\n[1] Parsing STL file...\n    Triangles parsed: 24\n    Unique vertices:  16\n\n[2] Connected component analysis...\n    Connected components found: 2\n\n[3] Volume calculation per component:\n    Component    Triangles    Volume\n    ------------ ------------ --------------------\n    0            12           1.000000\n    1            12           1.000000\n    ------------ ------------ --------------------\n    TOTAL        24           2.000000\n\n  SUMMARY\n  Total volume:       2.000000\n  Components:         2\n```\n\nEach unit cube has volume = 1.0, and the two cubes are correctly identified as **separate connected components**.", "solver_finish_reason": "stop"}
{"task": "3d-scan-calc", "condition": "gold_skill", "repeat": 0, "skill_ids": ["benchflow-ai--mesh-analysis"], "retrieval_correct": true, "judged_pass": false, "judged_score": 1, "judge_reason": "Agent's solution does not match the oracle's approach of using material ID from mesh attributes and calculating mass via density table lookup.", "solver_tokens": 2952, "judge_tokens": 2230, "solution_text": "To accomplish STL mesh parsing, connected component analysis, volume calculation, and debris filtering, we will use the `trimesh` library in Python. It provides robust tools for handling 3D meshes, calculating geometric properties, and performing graph-based connected component analysis.\n\n### Prerequisites\nInstall the required Python libraries:\n```bash\npip install trimesh numpy scipy\n```\n\n### Complete Python Solution\n\nSave the following code as `mesh_analysis.py`. This script loads an STL file, breaks it down into connected components, filters out small debris based on a volume threshold, calculates the total valid volume, and extracts geometric attribute data.\n\n```python\nimport trimesh\nimport numpy as np\nimport sys\nimport os\n\ndef analyze_stl_mesh(file_path, min_volume_threshold=1.0):\n    \"\"\"\n    Parses an STL mesh, performs connected component analysis, \n    filters debris, and calculates geometric properties.\n    \"\"\"\n    if not os.path.exists(file_path):\n        raise FileNotFoundError(f\"STL file not found at: {file_path}\")\n\n    # 1. Parse the STL mesh\n    print(f\"Loading mesh from {file_path}...\")\n    mesh = trimesh.load(file_path, process=False)\n    \n    if not isinstance(mesh, trimesh.Trimesh):\n        # If the STL contains multiple bodies natively, concatenate them\n        if isinstance(mesh, trimesh.Scene):\n            mesh = trimesh.util.concatenate(mesh.dump())\n        else:\n            raise ValueError(\"The loaded file is not a valid 3D mesh.\")\n            \n    print(f\"Total vertices: {len(mesh.vertices)}\")\n    print(f\"Total faces: {len(mesh.faces)}\")\n    \n    # 2. Extract Attribute Data\n    print(\"\\n--- Global Attribute Data ---\")\n    print(f\"Total surface area: {mesh.area:.4f}\")\n    print(f\"Bounding box min: {mesh.bounds[0]}\")\n    print(f\"Bounding box max: {mesh.bounds[1]}\")\n    print(f\"Bounding box extents (L x W x H): {mesh.extents}\")\n    \n    face_areas = mesh.area_faces\n    print(f\"Mean face area: {np.mean(face_areas):.6f}\")\n    print(f\"Max face area: {np.max(face_areas):.6f}\")\n\n    # 3. Connected Component Analysis\n    print(\"\\nPerforming connected component analysis...\")\n    # split() uses graph connectivity to separate disjoint meshes\n    components = mesh.split()\n    print(f\"Found {len(components)} connected components.\")\n    \n    # 4. Calculate Volume and Filter Debris\n    valid_components = []\n    total_valid_volume = 0.0\n    \n    print(f\"\\nFiltering debris (minimum volume threshold: {min_volume_threshold})...\")\n    for i, comp in enumerate(components):\n        # Attempt to fix mesh topology for accurate volume calculation\n        trimesh.repair.fix_normals(comp)\n        trimesh.repair.fix_winding(comp)\n        trimesh.repair.fill_holes(comp)\n        \n        # Calculate volume (returns 0 or inaccurate values if not watertight)\n        vol = comp.volume if comp.is_watertight else 0.0\n        \n        print(f\"Component {i+1:02d} | Faces: {len(comp.faces):<8} | \"\n              f\"Volume: {vol:<10.4f} | Watertight: {comp.is_watertight}\")\n        \n        if vol >= min_volume_threshold:\n            valid_components.append(comp)\n            total_valid_volume += vol\n        else:\n            print(f\"  -> Discarded as debris/noise.\")\n            \n    # 5. Output Final Results\n    print(\"\\n\" + \"=\"*40)\n    print(\"FINAL ANALYSIS RESULTS\")\n    print(\"=\"*40)\n    print(f\"Total components found:       {len(components)}\")\n    print(f\"Valid components (filtered):  {len(valid_components