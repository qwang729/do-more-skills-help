Current Value: {f['value']}\")\n        print(f\"  Position: {f['rect']}\")\n        print()\n```\n\n### 2. Fill PDF Form\n\n```python\n# fill_court_form.py\nfrom pdfrw import PdfReader, PdfWriter, PdfDict, PdfName\nfrom pdfrw.buildxobj import pagexobj\nimport copy\n\ndef fill_pdf_form(input_pdf, output_pdf, data_dict):\n    \"\"\"\n    Fill a PDF form with provided data.\n    \n    Args:\n        input_pdf: Path to the blank PDF form\n        output_pdf: Path for the filled output PDF\n        data_dict: Dictionary mapping field names to values\n    \"\"\"\n    reader = PdfReader(input_pdf)\n    writer = PdfWriter()\n    \n    # Process each page\n    for page in reader.pages:\n        annotations = page.get('/Annots', [])\n        \n        for annotation in annotations:\n            if annotation.get('/Subtype') == '/Widget':\n                field_name = annotation.get('/T')\n                if field_name:\n                    field_name_clean = field_name.strip('()')\n                    \n                    if field_name_clean in data_dict:\n                        value = data_dict[field_name_clean]\n                        \n                        # Set the field value\n                        annotation.update(PdfDict(V=f'({value})'))\n                        annotation.update(PdfDict(AP=''))\n                        \n                        # Mark as not needing appearance regeneration\n                        if '/AP' in annotation:\n                            del annotation['/AP']\n    \n    writer.addpages(reader.pages)\n    writer.write(output_pdf)\n    print(f\"Filled form saved to: {output_pdf}\")\n\n\ndef fill_pdf_with_fillpdf(input_pdf, output_pdf, data_dict):\n    \"\"\"\n    Alternative: Use the fillpdf library for more reliable filling.\n    \"\"\"\n    from fillpdf import fillpdfs\n    fillpdfs.write_fillable_pdf(input_pdf, output_pdf, data_dict)\n    print(f\"Filled form saved to: {output_pdf}\")\n\n\n# --- Court Form Data Templates ---\n\ndef get_case_data():\n    \"\"\"Example data for a typical court form.\"\"\"\n    return {\n        # Case information\n        'case_number': '2024-CV-001234',\n        'court_name': 'Superior Court of California, County of Los Angeles',\n        'date_filed': '01/15/2024',\n        \n        # Party information\n        'plaintiff_name': 'John A. Smith',\n        'plaintiff_address': '123 Main Street, Los Angeles, CA 90001',\n        'plaintiff_phone': '(555) 123-4567',\n        'plaintiff_email': 'john.smith@email.com',\n        \n        'defendant_name': 'Jane B. Doe',\n        'defendant_address': '456 Oak Avenue, Los Angeles, CA 90002',\n        'defendant_phone': '(555) 987-6543',\n        \n        # Attorney information\n        'attorney_name': 'Robert C. Johnson, Esq.',\n        'attorney_bar_number': '123456',\n        'attorney_firm': 'Johnson & Associates LLP',\n        'attorney_address': '789 Legal Blvd, Suite 200, Los Angeles, CA 90010',\n        \n        # Case details\n        'case_type': 'Civil',\n        'cause_of_action': 'Breach of Contract',\n        'amount_in_controversy': '$50,000.00',\n        'jury_demand': 'Yes',\n        \n        # Signature\n        'signature_date': '01/15/2024',\n        'signature_name': 'Robert C. Johnson',\n    }\n\n\ndef batch_fill_forms(template_pdf, cases, output_dir='output/'):\n    \"\"\"\n    Fill multiple court forms from a list of case data.\n    \n    Args:\n        template_pdf: Path to the blank court form template\n        cases: List of dictionaries with case data\n        output_dir: Directory for output files\n    \"\"\"\n    import os\n    os.makedirs(output_dir, exist_ok=True)\n    \n    for i, case_data in enumerate(cases):\n        case_num = case_data.get('case_number', f'case_{i+1}')\n        safe_name = case_num.replace('/', '-').replace(' ', '_')\n        output_path = os.path.join(output_dir, f'{safe_name}_filled.pdf')\n        \n        try:\n            fill_pdf_with_fillpdf(template_pdf, output_path, case_data)\n            print(f\"\u2713 Generated: {output_path}\")\n        except Exception as e:\n            print(f\"\u2717 Error processing {case_num}: {e}\")\n\n\nif __name__ == '__main__':\n    # Single form example\n    template = 'court_form_template.pdf'\n    output = 'filled_court_form.pdf'\n    data = get_case_data()\n    \n    # Try fillpdf first (more reliable), fall back to pdfrw\n    try:\n        fill_pdf_with_fillpdf(template, output, data)\n    except Exception:\n        print(\"Falling back to pdfrw method...\")\n        fill_pdf_form(template, output, data)\n```\n\n### 3. Batch Processing with CSV Input\n\n```python\n# batch_from_csv.py\nimport csv\nfrom fill_court_form import fill_pdf_with_fillpdf, fill_pdf_form\nimport os\n\ndef process_csv(csv_path, template_pdf, output_dir='output/'):\n    \"\"\"\n    Process a CSV file where:\n    - First row = field names (matching PDF form field names)\n    - Subsequent rows = data for each form\n    \"\"\"\n    os.makedirs(output_dir, exist_ok=True)\n    \n    with open(csv_path, 'r', encoding='utf-8') as f:\n        reader = csv.DictReader(f)\n        \n        for i, row in enumerate(reader):\n            # Use case_number or row index for filename\n            identifier = row.get('case_number', f'form_{i+1}')\n            safe_name = str(identifier).replace('/', '-').replace(' ', '_')\n            output_path = os.path.join(output_dir, f'{safe_name}.pdf')\n            \n            # Filter out empty values\n            data = {k: v for k, v in row.items() if v.strip()}\n            \n            try:\n                fill_pdf_with_fillpdf(template_pdf, output_path, data)\n                print(f\"\u2713 Row {i+1}: {output_path}\")\n            except Exception as e:\n                print(f\"\u2717 Row {i+1} error: {e}\")\n\nif __name__ == '__main__':\n    import sys\n    csv_file = sys.argv[1] if len(sys.argv) > 1 else 'cases.csv'\n    template = sys.argv[2] if len(sys.argv) > 2 else 'court_form_template.pdf'\n    process_csv(csv_file, template)\n```\n\n### 4. Flatten Form (Make Non-Editable)\n\n```python\n# flatten_pdf.py\nfrom pdfrw import PdfReader, PdfWriter\n\ndef flatten_pdf(input_pdf, output_pdf):\n    \"\"\"Flatten a filled PDF so fields become permanent text.\"\"\"\n    reader = PdfReader(input_pdf)\n    writer = PdfWriter()\n    \n    for page in reader.pages:\n        # Remove form annotations to flatten\n        if '/Annots' in page:\n            del page['/Annots']\n        if '/AcroForm' in reader.trailer['/Root']:\n            del reader.trailer['/Root']['/AcroForm']\n    \n    writer.addpages(reader.pages)\n    writer.write(output_pdf)\n    print(f\"Flattened PDF saved to: {output_pdf}\")\n\nif __name__ == '__main__':\n    import sys\n    flatten_pdf(sys.argv[1], sys.argv[2])\n```\n\n### 5. Example CSV Format (`cases.csv`)\n\n```csv\ncase_number,court_name,date_filed,plaintiff_name,plaintiff_address,defendant_name,defendant_address,attorney_name,case_type,cause_of_action,amount_in_controversy\n2024-CV-001,LA Superior Court,01/15/2024,John Smith,123 Main St LA CA,Jane Doe,456 Oak Ave LA CA,Robert Johnson,Civil,Breach of Contract,$50000\n2024-CV-002,LA Superior Court,01/16/2024,Alice Brown,789 Pine St LA CA,Bob White,321 Elm St LA CA,Robert Johnson,Civil,Personal Injury,$75000\n```\n\n## Usage\n\n```bash\n# 1. Discover fields in your court form\npython discover_fields.py court_form_template.pdf\n\n# 2. Fill a single form\npython fill_court_form.py\n\n# 3. Batch fill from CSV\npython batch_from_csv.py cases.csv court_form_template.pdf\n\n# 4. Flatten the filled form\npython flatten_pdf.py output/filled_form.pdf output/final_form.pdf\n```\n\n## Key Notes\n\n| Aspect | Detail |\n|--------|--------|\n| **Field names** | Must exactly match the PDF's internal field names (use `discover_fields.py` first) |\n| **Checkboxes** | Use `'Yes'`/`'True'` for checked, `'Off'` for unchecked |\n| **Dropdowns** | Value must match an existing option in the dropdown |\n| **Date fields** | Use the format the form expects (typically MM/DD/YYYY) |\n| **Flattening** | Always flatten before filing to prevent accidental edits |", "solver_finish_reason": "stop"}
