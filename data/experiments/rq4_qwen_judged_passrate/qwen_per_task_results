8601)) / 3600\n    else 0 end;\n\n  def avg(f): (map(f) | add) / length;\n\n  {\n    total_prs: length,\n    avg_time_to_merge_hours: avg(hours_since_created),\n    avg_comments: avg(.comments | length),\n    avg_commits: avg(.commits | length),\n    avg_additions: avg(.additions),\n    avg_deletions: avg(.deletions),\n    avg_changed_files: avg(.changedFiles),\n    total_additions: (map(.additions) | add),\n    total_deletions: (map(.deletions) | add),\n    total_changed_files: (map(.changedFiles) | add)\n  } |\n  \"Total PRs analyzed:      \\(.total_prs)\",\n  \"Avg time to merge:       \\(.avg_time_to_merge_hours | . * 100 | round / 100) hours\",\n  \"Avg comments per PR:     \\(.avg_comments | . * 100 | round / 100)\",\n  \"Avg commits per PR:      \\(.avg_commits | . * 100 | round / 100)\",\n  \"Avg additions per PR:    \\(.avg_additions | . * 100 | round / 100)\",\n  \"Avg deletions per PR:    \\(.avg_deletions | . * 100 | round / 100)\",\n  \"Avg changed files per PR:\\(.avg_changed_files | . * 100 | round / 100)\",\n  \"-----------------------------------------\",\n  \"Total additions:         \\(.total_additions)\",\n  \"Total deletions:         \\(.total_deletions)\",\n  \"Total changed files:     \\(.total_changed_files)\"\n'\n\necho \"\"\necho \"\ud83d\udd04 Fetching open pull requests...\"\nOPEN_DATA=$(gh pr list $REPO_ARG --state open --limit $LIMIT --json createdAt,comments,commits,additions,deletions,changedFiles,isDraft 2>/dev/null)\n\nif [ -z \"$OPEN_DATA\" ] || [ \"$OPEN_DATA\" = \"[]\" ]; then\n  echo \"\u2705 No open pull requests found.\"\n  exit 0\nfi\n\necho \"=========================================\"\necho \"\ud83d\udcc2 OPEN PULL REQUESTS ANALYTICS\"\necho \"=========================================\"\necho \"$OPEN_DATA\" | jq -r '\n  def hours_open:\n    if .createdAt != null then\n      (now - (.createdAt | fromdateiso8601)) / 3600\n    else 0 end;\n\n  def avg(f): (map(f) | add) / length;\n\n  {\n    total_prs: length,\n    draft_prs: (map(select(.isDraft)) | length),\n    avg_age_hours: avg(hours_open),\n    avg_comments: avg(.comments | length),\n    avg_commits: avg(.commits | length),\n    avg_additions: avg(.additions),\n    avg_deletions: avg(.deletions),\n    avg_changed_files: avg(.changedFiles)\n  } |\n  \"Total open PRs:          \\(.total_prs)\",\n  \"Draft PRs:               \\(.draft_prs)\",\n  \"Average age:             \\(.avg_age_hours | . * 100 | round / 100) hours\",\n  \"Avg comments per PR:     \\(.avg_comments | . * 100 | round / 100)\",\n  \"Avg commits per PR:      \\(.avg_commits | . * 100 | round / 100)\",\n  \"Avg additions per PR:    \\(.avg_additions | . * 100 | round / 100)\",\n  \"Avg deletions per PR:    \\(.avg_deletions | . * 100 | round / 100)\",\n  \"Avg changed files per PR:\\(.avg_changed_files | . * 100 | round / 100)\"\n'\n```\n\n### How to Use\n\n1. **Run for the current repository:**\n   ```bash\n   ./pr_analytics.sh\n   ```\n\n2. **Run for a specific repository:**\n   ```bash\n   ./pr_analytics.sh cli/cli\n   ```\n\n### Quick One-Liners\nIf you don't want to run the full script and just need a specific metric on the fly, use these `gh` + `jq` one-liners:\n\n**Average Time to Merge (in hours) for the last 100 PRs:**\n```bash\ngh pr list --state merged --limit 100 --json createdAt,mergedAt | jq '[.[] | select(.mergedAt != null) | ((.mergedAt | fromdateiso8601) - (.createdAt | fromdateiso8601)) / 3600] | add / length'\n```\n\n**Total Code Churn (Additions + Deletions) for the last 50 PRs:**\n```bash\ngh pr list --state merged --limit 50 --json additions,deletions | jq '[.[] | .additions + .deletions] | add'\n```\n\n**Find the longest open PR currently active:**\n```bash\ngh pr list --state open --json number,title,createdAt | jq 'sort_by(.createdAt) | .[0] | {number, title, days_open: ((now - (.createdAt | fromdateiso8601)) / 86400 | round)}'\n```", "solver_finish_reason": "stop"}
{"task": "gh-repo-analytics", "condition": "retrieved_top1_full", "repeat": 0, "skill_ids": ["benchflow-ai--gh-cli"], "retrieval_correct": true, "judged_pass": false, "judged_score": 1, "judge_reason": "Agent's solution does not match the required output format or compute the exact metrics specified in the verifier criteria.", "solver_tokens": 3880, "judge_tokens": 2169, "solution_text": "To perform comprehensive analytics on GitHub Pull Requests using the `gh` CLI, you can extract the data as JSON and process it using `jq`. \n\nBelow is a complete, actionable solution that includes a bash script to generate an analytics dashboard directly in your terminal, as well as a command to export the raw data to CSV for external analysis.\n\n### Prerequisites\n1. **GitHub CLI (`gh`)** installed and authenticated (`gh auth login`).\n2. **`jq`** installed for JSON processing (`brew install jq` on macOS, `sudo apt install jq` on Ubuntu).\n\n### 1. Terminal Analytics Dashboard Script\nSave the following script as `gh-pr-analytics.sh`, make it executable (`chmod +x gh-pr-analytics.sh`), and run it inside any GitHub repository directory.\n\n```bash\n#!/bin/bash\n\n# Fetch up to 1000 PRs with the necessary fields for analytics\necho \"\ud83d\udd04 Fetching pull requests from $(gh repo view --json nameWithOwner -q .nameWithOwner)...\"\nPR_DATA=$(gh pr list --state all --limit 1000 --json number,state,author,createdAt,mergedAt,additions,deletions,labels)\n\nif [ -z \"$PR_DATA\" ] || [ \"$PR_DATA\" == \"[]\" ]; then\n    echo \"\u274c No pull requests found or failed to fetch data.\"\n    exit 1\nfi\n\necho \"\ud83d\udcca Analyzing pull requests...\"\necho \"========================================================\"\n\n# 1. PR Status Summary\necho -e \"\\n\ud83d\udccc PR STATUS SUMMARY\"\necho \"$PR_DATA\" | jq -r '\n  group_by(.state) | \n  map({state: .[0].state, count: length}) | \n  sort_by(-.count) |\n  .[] | \n  \"  \\(.[state]): \\(.[count])\"\n'\n\n# 2. Average Time to Merge\necho -e \"\\n\u23f1\ufe0f  TIME TO MERGE\"\necho \"$PR_DATA\" | jq -r '\n  map(select(.state == \"MERGED\" and .mergedAt != null and .createdAt != null)) |\n  if length == 0 then \"  No merged PRs found to calculate time.\"\n  else\n    (map(\n      ((.mergedAt | sub(\"\\\\.[0-9]+Z$\"; \"Z\") | fromdateiso8601) - \n       (.createdAt | sub(\"\\\\.[0-9]+Z$\"; \"Z\") | fromdateiso8601)) / 86400\n    ) | add / length) as $avg_days |\n    \"  Average time to merge: \\($avg_days * 100 | round / 100) days\"\n  end\n'\n\n# 3. Top Contributors\necho -e \"\\n\ud83c\udfc6 TOP 5 CONTRIBUTORS (By Merged PRs)\"\necho \"$PR_DATA\" | jq -r '\n  map(select(.state == \"MERGED\")) |\n  group_by(.author.login) |\n  map({author: .[0].author.login, count: length}) |\n  sort_by(-.count) |\n  .[0:5] |\n  .[] |\n  \"  \\(.author): \\(.count) merged PRs\"\n'\n\n# 4. Average PR Size\necho -e \"\\n\ud83d\udccf PR SIZE METRICS\"\necho \"$PR_DATA\" | jq -r '\n  map(select(.additions != null and .deletions != null)) |\n  if length == 0 then \"  No size data available.\"\n  else\n    (map(.additions + .deletions) | add / length) as $avg_size |\n    (map(.additions) | add / length) as $avg_add |\n    (map(.deletions) | add / length) as $avg_del |\n    \"  Average lines changed per PR: \\($avg_size | round)\",\n    \"  Average additions per PR:     \\($avg_add | round)\",\n    \"  Average deletions per PR:     \\($avg_del | round)\"\n  end\n'\n\n# 5. Most Common Labels\necho -e \"\\n\ud83c\udff7\ufe0f  TOP 5 MOST COMMON LABELS\"\necho \"$PR_DATA\" | jq -r '\n  [.[].labels[].name] |\n  if length == 0 then \"  No labels found on PRs.\"\n  else\n    group_by(.) |\n    map({label: .[0], count: length}) |\n    sort_by(-.count) |\n    .[0:5] |\n    .[] |\n    \"  \\(.label): \\(.count) PRs\"\n  end\n'\necho -e \"\\n========================================================\"\n```\n\n### 2. Export to CSV for External Analytics (Excel, Python, etc.)\nIf you want to perform deeper statistical analysis or create visualizations in tools like Python (Pandas/Matplotlib) or Excel, you can export the raw PR data directly to a CSV file using `gh` and `jq`:\n\n```bash\ngh pr list --state all --limit 1000 \\\n  --json number,title,state,author,createdAt,mergedAt,closedAt,additions,deletions,labels \\\n  --jq '.[] | [\n    .number, \n    .title, \n    .state, \n    .author.login, \n    .createdAt, \n    .mergedAt, \n    .closedAt, \n    .additions, \n    .deletions, \n    ([.labels[].name] | join(\";\"))\n  ] | @csv' > pull_requests_analytics.csv\n```\n\n### How it works:\n1. **`gh pr list --state all`**: Queries the GitHub API for Open, Closed, and Merged PRs.\n2. **`--json ...`**: Restricts the API payload to only the exact fields needed, minimizing bandwidth and parsing time.\n3. **`jq` processing**: \n   - Converts ISO8601 timestamps into Unix epochs to calculate the exact delta (Time to Merge).\n   - Groups arrays by author/labels to calculate frequency distributions.\n   - Filters out null values to prevent math errors on open/unmerged PRs.", "solver_finish_reason": "stop"}
{"task": "gh-repo-analytics", "condition": "hard_distractor", "repeat": 0, "skill_ids": ["benchflow-ai--analyze-ci"], "retrieval_correct": false, "judged_pass": false, "judged_score": 0, "judge_reason": "The proposed solution analyzes CI failures, not pull request analytics as required.", "solver_tokens": 4853, "judge_tokens": 2013, "solution_text": "To analyze failed GitHub Action jobs for a pull request using the `gh` CLI, you can use the following bash script. It automatically identifies the PR (or accepts a PR number), finds the exact workflow runs for the PR's head commit, isolates the failed jobs/steps, and extracts the relevant error logs.\n\n### Prerequisites\n- [GitHub CLI (`gh`)](https://cli.github.com/) installed and authenticated (`gh auth login`).\n- [`jq`](https://jqlang.github.io/jq/) installed for JSON parsing.\n\n### Solution: `analyze-ci.sh`\n\nSave the following code to a file named `analyze-ci.sh` and make it executable (`chmod +x analyze-ci.sh`).\n\n```bash\n#!/usr/bin/env bash\nset -euo pipefail\n\n# Determine PR number from argument or current branch\nPR_NUMBER=${1:-}\nif [[ -z \"$PR_NUMBER\" ]]; then\n    PR_NUMBER=$(gh pr view --json number -q '.number' 2>/dev/null || echo \"\")\n    if [[ -z \"$PR_NUMBER\" ]]; then\n        echo \"Usage: $0 <PR_NUMBER>\"\n        echo \"Or run from a branch with an associated open PR.\"\n        exit 1\n    fi\nfi\n\necho \"\ud83d\udd0d Fetching CI status for PR #$PR_NUMBER...\"\n\n# Get the head SHA for the PR to ensure we get the exact runs for this specific PR state\nSHA=$(gh pr view \"$PR_NUMBER\" --json headRefOid -q '.headRefOid')\n\n# Get failed workflow runs for this specific commit\nRUNS_JSON=$(gh run list --commit \"$SHA\" --limit 10 --json databaseId,workflowName,conclusion,status)\n\nFAILED_RUNS=$(echo \"$RUNS_JSON\" | jq -c '.[] | select(.conclusion == \"failure\" or .conclusion == \"cancelled\")')\n\nif [[ -z \"$FAILED_RUNS\" ]]; then\n    echo \"\u2705 No failed CI runs found for PR #$PR_NUMBER.\"\n    exit 0\nfi\n\necho \"$FAILED_RUNS\" | while IFS= read -r run; do\n    RUN_ID=$(echo \"$run\" | jq -r '.databaseId')\n    WORKFLOW=$(echo \"$run\" | jq -r '.workflowName')\n    \n    echo \"==================================================\"\n    echo \"\u274c Failed Workflow: $WORKFLOW (Run ID: $RUN_ID)\"\n    echo \"==================================================\"\n    \n    # Get jobs for this run\n    JOBS_JSON=$(gh run view \"$RUN_ID\" --json jobs)\n    \n    FAILED_JOBS=$(echo \"$JOBS_JSON\" | jq -c '.jobs[] | select(.conclusion == \"failure\" or .conclusion == \"cancelled\")')\n    \n    if [[ -z \"$FAILED_JOBS\" ]]; then\n        echo \"No specific failed jobs identified. Dumping general failed logs:\"\n        gh run view \"$RUN_ID\" --log-failed | grep -iE \"error|fail|exception\" | head -n 20\n        continue\n    fi\n    \n    echo \"$FAILED_JOBS\" | while IFS= read -r job; do\n        JOB_NAME=$(echo \"$job\" | jq -r '.name')\n        echo \"--------------------------------------------------\"\n        echo \"\u26a0\ufe0f  Failed Job: $JOB_NAME\"\n        echo \"--------------------------------------------------\"\n        \n        # Identify failed steps\n        FAILED_STEPS=$(echo \"$job\" | jq -r '.steps[] | select(.conclusion == \"failure\") | .name')\n        if [[ -n \"$FAILED_STEPS\" ]]; then\n            echo \"Failed steps:\"\n            echo \"$FAILED_STEPS\" | sed 's/^/  - /'\n        fi\n        \n        # Extract logs for this specific job\n        # gh run view --log-failed outputs tab-separated values: JobName\\tStepName\\tLogMessage\n        echo \"\ud83d\udcdc Relevant Error Logs:\"\n        gh run view \"$RUN_ID\" --log-failed | awk -F'\\t' -v job=\"$JOB_NAME\" '\n            $1 == job {\n                if (tolower($0) ~ /error|fail|exception|fatal|traceback|panic|exit code|e: /) {\n                    print $3\n                }\n            }\n        ' | head -n 30\n        echo \"\"\n    done\ndone\n```\n\n### Usage\n\n**Option 1: Run from the PR's branch**\n```bash\n./analyze-ci.sh\n```\n\n**Option 2: Pass a specific PR number**\n```bash\n./analyze-ci.sh 1234\n```\n\n### How it works:\n1. **Targets the exact commit:** It fetches the `headRefOid` (commit SHA) of the PR and passes it to `gh run list --commit`. This prevents pulling failed runs from other branches or older commits.\n2. **Filters for failures:** It uses `jq` to filter workflow runs and jobs that have a `conclusion` of `failure` or `cancelled`.\n3. **Identifies failing steps:** It drills down into the specific job to list exactly which step(s) failed.\n4. **Extracts actionable logs:** It pulls the failed logs via `gh run view --log-failed`, parses the tab-delimited output to isolate the specific job, and uses `awk` to filter and print only the lines containing common error keywords (e.g., `error`, `traceback`, `exit code`), saving you from scrolling through thousands of lines of standard output.", "solver_finish_reason": "stop"}
{"task": "gh-repo-analytics", "condition": "random_wrong", "repeat": 0, "skill_ids": ["benchflow-ai--light-curve-preprocessing"], "retrieval_correct": false, "judged_pass": false, "judged_score": 1, "judge_reason": "The proposed solution does not match the required output structure or metrics specified in the verifier criteria and omits key fields like 'closed', 'bug' issues, and average merge days in days (not hours).", "solver_tokens": 5067, "judge_tokens": 1891, "solution_text": "To analyze GitHub pull requests using the `gh` CLI, you can combine the GitHub API with `jq` for JSON processing. The following bash script fetches closed pull requests, filters for merged ones, and computes key analytics such as average time to merge, code churn (additions/deletions), and top contributors.\n\n### Prerequisites\n1. **GitHub CLI (`gh`)**: Installed and authenticated (`gh auth login`).\n2. **`jq`**: A lightweight command-line JSON processor (install via `brew install jq`, `apt install jq`, etc.).\n\n### Analytics Script\n\nSave the following code as `pr_analytics.sh` and make it executable (`chmod +x pr_analytics.sh`).\n\n```bash\n#!/bin/bash\n\n# Usage: ./pr_analytics.sh [owner/repo] [limit]\n# Example: ./pr_analytics.sh cli/cli 250\n\nREPO=\"${1:-cli/cli}\"\nLIMIT=\"${2:-100}\"\n\necho \"Fetching up to $LIMIT closed pull requests for $REPO...\"\n\n# Fetch data with pagination, combine into a single array, and limit to $LIMIT\nDATA=$(gh api \"repos/$REPO/pulls?state=closed&per_page=100\" --paginate | jq -s \"add | .[0:$LIMIT]\")\n\n# Check if data is empty or null\nif [ -z \"$DATA\" ] || [ \"$DATA\" = \"null\" ] || [ \"$DATA\" = \"[]\" ]; then\n  echo \"No pull requests found for $REPO.\"\n  exit 1\nfi\n\necho \"$DATA\" | jq -r --arg repo \"$REPO\" '\n  # Filter only merged PRs (merged_at is not null)\n  map(select(.merged_at != null)) |\n  \n  if length == 0 then\n    \"No merged PRs found in the fetched data.\"\n  else\n    # Calculate metrics\n    {\n      total_merged: length,\n      avg_time_to_merge_hours: (map(\n        ((.merged_at | sub(\"\\\\.[0-9]+Z$\"; \"Z\") | fromdateiso8601) - \n         (.created_at | sub(\"\\\\.[0-9]+Z$\"; \"Z\") | fromdateiso8601)) / 3600\n      ) | add / length),\n      avg_additions: (map(.additions) | add / length),\n      avg_deletions: (map(.deletions) | add / length),\n      avg_changed_files: (map(.changed_files) | add / length),\n      top_authors: (sort_by(.user.login) | group_by(.user.login) | map({author: .[0].user.login, count: length}) | sort_by(-.count) | .[0:5])\n    } |\n    \n    # Output formatted results\n    \"=== Pull Request Analytics for \\($repo) ===\",\n    \"Total Merged PRs: \\(.total_merged)\",\n    \"Average Time to Merge: \\(.avg_time_to_merge_hours | . * 100 | round / 100) hours\",\n    \"Average Additions: \\(.avg_additions | round) lines\",\n    \"Average Deletions: \\(.avg_deletions | round) lines\",\n    \"Average Changed Files: \\(.avg_changed_files | . * 100 | round / 100)\",\n    \"Top 5 Contributors:\",\n    (.top_authors[] | \"  - \\(.author): \\(.count) merged PRs\")\n  end\n'\n```\n\n### How to Use\n\nRun the script from your terminal, optionally passing the target repository and the maximum number of PRs to analyze:\n\n```bash\n# Analyze the last 100 merged PRs in the default repo (cli/cli)\n./pr_analytics.sh\n\n# Analyze the last 300 merged PRs in a specific repository\n./pr_analytics.sh facebook/react 300\n```\n\n### How it Works\n1. **API Pagination**: Uses `gh api ... --paginate` to bypass the GitHub API's default 100-item limit per page, combining the results into a single JSON array via `jq -s \"add\"`.\n2. **Filtering**: Filters out PRs that were closed without being merged by checking if `merged_at != null`.\n3. **Time Calculation**: Strips milliseconds from the ISO8601 timestamps and uses `jq`'s `fromdateiso8601` to calculate the delta in seconds, then converts it to hours.\n4. **Grouping**: Uses `sort_by` and `group_by` to tally up merged PRs per author and extract the top 5 contributors.", "solver_finish_reason": "stop"}
{"task": "glm-lake-mendota", "condition": "no_skill", "repeat": 0, "skill_ids": [], "retrieval_correct": null, "judged_pass": false, "judged_score": 0, "judge_reason": "Agent's solution is a complete simulation framework but does not match the oracle's parameter calibration approach using NetCDF output comparison and optimization.", "solver_tokens": 8432, "judge_tokens": 5501, "solution_text": "# GLM Lake Simulation - NetCDF Hydrodynamic Model\n\nBelow is a complete implementation of a 1D lake hydrodynamic model (inspired by the General Lake Model - GLM) with NetCDF input/output. This includes meteorological forcing, morphometry, and the core hydrodynamic equations (temperature stratification, density-driven mixing, and surface heat fluxes).\n\n## 1. Project Structure\n\n```\nglm_lake_sim/\n\u251c\u2500\u2500 create_input_netcdf.py    # Generate meteorological & morphometric NetCDF inputs\n\u251c\u2500\u2500 glm_hydrodynamic.py       # Core 1D hydrodynamic model engine\n\u251c\u2500\u2500 run_simulation.py         # Main driver script\n\u251c\u2500\u2500 process_output.py         # Post-processing and visualization\n\u2514\u2500\u2500 requirements.txt\n```\n\n## 2. Requirements\n\n```txt\nnumpy>=1.21\nscipy>=1.7\nnetCDF4>=1.5\nmatplotlib>=3.4\nxarray>=0.19\n```\n\n## 3. Input NetCDF Generator (`create_input_netcdf.py`)\n\n```python\n\"\"\"\nGenerate GLM-compatible NetCDF input files:\n  - met_data.nc   : Meteorological forcing (air temp, wind, radiation, humidity)\n  - morphometry.nc: Lake bathymetry (area-depth relationship)\n  - inflow.nc     : Inflow/outflow time series\n  - init_cond.nc  : Initial temperature profile\n\"\"\"\n\nimport numpy as np\nfrom netCDF4 import Dataset, date2num\nfrom datetime import datetime, timedelta\nimport os\n\ndef create_meteorological_nc(filename, start_date, n_days, dt_hours=1):\n    \"\"\"Create meteorological forcing NetCDF file.\"\"\"\n    n_steps = int(n_days * 24 / dt_hours)\n    times = [start_date + timedelta(hours=i * dt_hours) for i in range(n_steps)]\n\n    # Generate synthetic meteorological data with seasonal cycle\n    day_of_year = np.array([t.timetuple().tm_yday for t in times])\n    hour_of_day = np.array([t.hour + t.minute / 60.0 for t in times])\n\n    # Air temperature (\u00b0C) - seasonal + diurnal cycle\n    T_annual = 15 + 12 * np.sin(2 * np.pi * (day_of_year - 80) / 365)\n    T_diurnal = 3 * np.sin(2 * np.pi * (hour_of_day - 6) / 24)\n    air_temp = T_annual + T_diurnal + np.random.normal(0, 0.5, n_steps)\n\n    # Wind speed (m/s) - Weibull-like distribution\n    wind_speed = np.abs(np.random.weibull(2, n_steps) * 3.5 + 1.0)\n    wind_speed = np.clip(wind_speed, 0.1, 15.0)\n\n    # Shortwave radiation (W/m\u00b2) - clear sky model\n    solar_declination = 23.45 * np.sin(2 * np.pi * (day_of_year - 172) / 365)\n    latitude = -31.95  # Example: Perth, Australia\n    lat_rad = np.radians(latitude)\n    dec_rad = np.radians(solar_declination)\n    hour_angle = np.radians(15 * (hour_of_day - 12))\n\n    cos_zenith = (np.sin(lat_rad) * np.sin(dec_rad) +\n                  np.cos(lat_rad) * np.cos(dec_rad) * np.cos(hour_angle))\n    cos_zenith = np.clip(cos_zenith, 0, 1)\n    solar_constant = 1361  # W/m\u00b2\n    shortwave = solar_constant * cos_zenith * 0.75  # atmospheric transmittance\n    shortwave = np.clip(shortwave, 0, 1100)\n\n    # Longwave radiation (W/m\u00b2)\n    longwave_in = 300 + 30 * np.sin(2 * np.pi * (day_of_year - 80) / 365)\n\n    # Relative humidity (fraction)\n    rel_humidity = 0.5 + 0.2 * np.sin(2 * np.pi * hour_of_day / 24) + np.random.normal(0, 0.05, n_steps)\n    rel_humidity = np.clip(rel_humidity, 0.1, 1.0)\n\n    # Precipitation (mm/day)\n    precip = np.zeros(n_steps)\n    rain_events = np.random.random(n_steps) < 0.02\n    precip[rain_events] = np.random.exponential(5, rain_events.sum())\n\n    # Snow (if temp < 0)\n    snow = np.where(air_temp < 0, precip * 0.8, 0.0)\n\n    # Cloud cover (fraction)\n    cloud_cover = 0.3 + 0.3 * np.random.random(n_steps)\n    cloud_cover = np.clip(cloud_cover, 0, 1)\n\n    # Write NetCDF\n    ds = Dataset(filename, 'w', format='NETCDF4')\n    ds.description = 'GLM Meteorological Forcing Data'\n    ds.history = f'Created {datetime.now().isoformat()}'\n\n    ds.createDimension('time', None)  # unlimited\n    ds.createDimension('time', n_steps)\n\n    time_var = ds.createVariable('time', 'f8', ('time',))\n    time_var.units = f'hours since {start_date.strftime(\"%Y-%m-%d %H:%M:%S\")}'\n    time_var.calendar = 'standard'\n    time_var[:] = np.arange(n_steps) * dt_hours\n\n    variables = {\n        'air_temp': ('Air temperature', 'degC', air_temp),\n        'wind_speed': ('Wind speed at 10m', 'm/s', wind_speed),\n        'shortwave': ('Downwelling shortwave radiation', 'W/m2', shortwave),\n        'longwave_in': ('Downwelling longwave radiation', 'W/m2', longwave_in),\n        'rel_humidity': ('Relative humidity', 'fraction', rel_humidity),\n        'precipitation': ('Precipitation rate', 'mm/day', precip),\n        'snow': ('Snowfall rate', 'mm/day', snow),\n        'cloud_cover': ('Cloud cover fraction', 'fraction', cloud_cover),\n    }\n\n    for varname, (longname, units, data) in variables.items():\n        var = ds.createVariable(varname, 'f4', ('time',), zlib=True)\n        var.long_name = longname\n        var.units = units\n        var[:] = data\n\n    ds.close()\n    print(f\"Created: {filename}\")\n\n\ndef create_morphometry_nc(filename, lake_name=\"Example Lake\"):\n    \"\"\"Create morphometry NetCDF file (area-depth curve).\"\"\"\n    # Define depth-area relationship (typical dimictic lake)\n    depths = np.array([0, 1, 2, 3, 4, 5, 7, 10, 15, 20, 25, 30, 35, 40])\n    # Area at each depth (km\u00b2) - parabolic basin shape\n    max_area = 10.0  # km\u00b2 at surface\n    max_depth = 40.0\n    areas = max_area * (1 - (depths / max_depth) ** 1.5)\n    areas = np.clip(areas, 0, max_area)\n    areas[0] = max_area\n\n    # Volume at each depth (cumulative, from surface down)\n    volumes = np.zeros_like(depths)\n    for i in range(1, len(depths)):\n        dz = depths[i] - depths[i - 1]\n        avg_area = 0.5 * (areas[i] + areas[i - 1])\n        volumes[i] = volumes[i - 1] + avg_area * dz * 1e6  # m\u00b3\n\n    ds = Dataset(filename, 'w', format='NETCDF4')\n    ds.description = f'GLM Morphometry - {lake_name}'\n\n    ds.createDimension('depth_level', len(depths))\n\n    depth_var = ds.createVariable('depth', 'f4', ('depth_level',))\n    depth_var.long_name = 'Depth below surface'\n    depth_var.units = 'm'\n    depth_var.positive = 'down'\n    depth_var[:] = depths\n\n    area_var = ds.createVariable('area', 'f4', ('depth_level',))\n    area_var.long_name = 'Lake surface area at given depth'\n    area_var.units = 'km2'\n    area_var[:] = areas\n\n    vol_var = ds.createVariable('volume', 'f4', ('depth_level',))\n    vol_var.long_name = 'Cumulative volume below given depth'\n    vol_var.units = 'm3'\n    vol_var[:] = volumes\n\n    # Global attributes\n    ds.lake_name = lake_name\n    ds.max_depth = float(max_depth)\n    ds.surface_area = float(max_area)\n    ds.latitude = -31.95\n    ds.longitude = 115.86\n    ds.elevation = 10.0  # m above sea level\n\n    ds.close()\n    print(f\"Created: {filename}\")\n\n\ndef create_inflow_nc(filename, start_date, n_days, dt_hours=24):\n    \"\"\"Create inflow/outflow NetCDF file.\"\"\"\n    n_steps = int(n_days * 24 / dt_hours)\n    times = [start_date + timedelta(hours=i * dt_hours) for i in range(n_steps)]\n\n    day_of_year = np.array([t.timetuple().tm_yday for t in times])\n\n    # Seasonal inflow pattern (higher in winter/spring)\n    base_flow = 2.0  # m\u00b3/s\n    seasonal_flow = 3.0 * np.sin(2 * np.pi * (day_of_year - 120) / 365)\n    inflow_rate = np.clip(base_flow + seasonal_flow + np.random.normal(0, 0.5, n_steps), 0.1, 15.0)\n\n    # Inflow temperature (approximate to air temp with lag and damping)\n    inflow_temp = 15 + 8 * np.sin(2 * np.pi * (day_of_year - 100) / 365) + np.random.normal(0, 0.5, n_steps)\n\n    # Inflow salinity (mg/L TDS)\n    inflow_salt = 200 + 100 * np.sin(2 * np.pi * (day_of_year - 60) / 365) + np.random.normal(0, 10, n_steps)\n    inflow_salt = np.clip(inflow_salt, 50, 500)\n\n    # Outflow (controlled, matches inflow with some lag for storage)\n    outflow_rate = np.roll(inflow_rate, 5) * 0.95  # slight lag, some storage\n    outflow_rate = np.clip(outflow_rate, 0.0, 12.0)\n\n    ds = Dataset(filename, 'w', format='NETCDF4')\n    ds.description = 'GLM Inflow/Outflow Data'\n\n    ds.createDimension('time', n_steps)\n\n    time_var = ds.createVariable('time', 'f8', ('time',))\n    time_var.units = f'hours since {start_date.strftime(\"%Y-%m-%d %H:%M:%S\")}'\n    time_var.calendar = 'standard'\n    time_var[:] = np.arange(n_steps) * dt_hours\n\n    for varname, longname, units, data in [\n        ('inflow_rate', 'Inflow volumetric rate', 'm3/s', inflow_rate),\n        ('inflow_temp', 'Inflow temperature', 'degC', inflow_temp),\n        ('inflow_salt', 'Inflow salinity', 'mg/L', inflow_salt),\n        ('outflow_rate', 'Outflow volumetric rate', 'm3/s', outflow_rate),\n    ]:\n        var = ds.createVariable(varname, 'f4', ('time',), zlib=True)\n        var.long_name = longname\n        var.units = units\n        var[:] = data\n\n    # Inflow depth (m below surface) - river enters at surface\n    inflow_depth_var = ds.createVariable('inflow_depth', 'f4', ('time',))\n    inflow_depth_var.long_name = 'Inflow insertion depth'\n    inflow_depth_var.units = 'm'\n    inflow_depth_var[:] = np.ones(n_steps) * 2.0  # 2m below surface\n\n    ds.close()\n    print(f\"Created: {filename}\")\n\n\ndef create_initial_conditions_nc(filename, max_depth=40, n_layers=40):\n    \"\"\"Create initial conditions NetCDF file.\"\"\"\n    depths = np.linspace(0, max_depth, n_layers + 1)\n    layer_centers = 0.5 * (depths[:-1] + depths[1:])\n    dz = np.diff(depths)\n\n    # Initial temperature profile (winter mixing - nearly isothermal