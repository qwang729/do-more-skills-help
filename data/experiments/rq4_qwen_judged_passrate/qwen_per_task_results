w data to Excel\nraw_excel_path = \"gdp_data.xlsx\"\ndf_raw.to_excel(raw_excel_path, index=False, sheet_name=\"RawData\")\nprint(f\"\u2713 Raw data saved to {raw_excel_path}\")\n\n# ============================================================\n# 2. READ DATA BACK AND APPLY HP FILTER\n# ============================================================\ndf = pd.read_excel(raw_excel_path, parse_dates=[\"Date\"])\ndf.set_index(\"Date\", inplace=True)\n\n# HP filter with lambda=1600 (standard for quarterly data)\n# lambda=1600 for quarterly, 6.25 for annual, 129600 for monthly\nlambd = 1600\ngdp_cycle, gdp_trend = hpfilter(df[\"GDP_Billions\"], lamb=lambd)\n\n# Build results DataFrame\ndf_results = pd.DataFrame({\n    \"GDP_Billions\": df[\"GDP_Billions\"],\n    \"HP_Trend\": np.round(gdp_trend, 2),\n    \"HP_Cycle\": np.round(gdp_cycle, 2),\n    \"Cycle_Pct\": np.round((gdp_cycle / gdp_trend) * 100, 4)\n})\ndf_results.index.name = \"Date\"\n\nprint(f\"\\n{'='*60}\")\nprint(f\"  HODRICK-PRESCOTT FILTER RESULTS  (\u03bb = {lambd})\")\nprint(f\"{'='*60}\")\nprint(f\"  Observations:  {len(df_results)}\")\nprint(f\"  Period:        {df_results.index[0].strftime('%Y-Q1')} to {df_results.index[-1].strftime('%Y-Q4')}\")\nprint(f\"\\n  GDP Range:     {df_results['GDP_Billions'].min():,.2f} \u2013 {df_results['GDP_Billions'].max():,.2f}\")\nprint(f\"  Cycle Range:   {df_results['HP_Cycle'].min():,.2f} \u2013 {df_results['HP_Cycle'].max():,.2f}\")\nprint(f\"\\n  First 10 rows:\")\nprint(df_results.head(10).to_string())\n\n# ============================================================\n# 3. WRITE FORMATTED EXCEL OUTPUT WITH CHARTS\n# ============================================================\noutput_path = \"hp_filter_results.xlsx\"\n\nwith pd.ExcelWriter(output_path, engine=\"xlsxwriter\") as writer:\n    # --- Sheet 1: Filtered Data ---\n    df_results.to_excel(writer, sheet_name=\"HP_Filtered_Data\")\n    workbook = writer.book\n    ws_data = writer.sheets[\"HP_Filtered_Data\"]\n\n