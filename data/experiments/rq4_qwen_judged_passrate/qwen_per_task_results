r m, d in job) + 1 if jobs else 0\n    \n    problem = JobShopProblem(jobs=jobs, num_machines=num_machines, num_jobs=len(jobs))\n    solver = JobShopSolver(problem, time_limit=time_limit)\n    return solver.solve()\n\n\n# Example usage and test\nif __name__ == \"__main__\":\n    # Classic 6x6 benchmark problem (Fisher and Thompson)\n    example_jobs = [\n        [(0, 1), (1, 3), (2, 6), (3, 7), (4, 3), (5, 6)],   # Job 0\n        [(1, 8), (2, 5), (0, 10), (4, 10), (5, 10), (3, 4)],  # Job 1\n        [(2, 5), (3, 4), (4, 8), (5, 9), (1, 1), (0, 7)],   # Job 2\n        [(3, 5), (4, 6), (5, 4), (0, 3), (1, 3), (2, 1)],   # Job 3\n        [(4, 5), (5, 5), (1, 5), (2, 3), (3, 8), (0, 9)],   # Job 4\n        [(5, 9), (0, 3), (3, 5), (1, 3), (2, 4), (4, 1)],   # Job 5\n    ]\n    \n    print(\"Solving 6x6 Job Shop Scheduling Problem...\")\n    print(f\"Jobs: {len(example_jobs)}, Machines: 6\")\n    \n    solution = solve_job_shop(example_jobs, time_limit=30)\n    \n    if solution:\n        print_solution(solution)\n    else:\n        print(\"No solution found within time limit.\")\n```\n\n## Installation\n\n```bash\npip install ortools\n```\n\n## Usage Examples\n\n### Basic Usage\n```python\n# Define your problem: each job is a list of (machine, duration) tuples\njobs = [\n    [(0, 3), (1, 2), (2, 2)],  # Job 0: machine 0 for 3 units, then 1 for 2, then 2 for 2\n    [(1, 2), (0, 3), (2, 4)],  # Job 1\n    [(2, 4), (1, 1), (0, 3)],  # Job 2\n]\n\nsolution = solve_job_shop(jobs, time_limit=30)\nprint(f\"Optimal makespan: {solution['makespan']}\")\n```\n\n### Parse from Email Text\n```python\nemail_text = \"\"\"\nJob 0: (0, 3), (1, 2), (2, 2)\nJob 1: (1, 2), (0, 3), (2, 4)\nJob 2: (2, 4), (1, 1), (0, 3)\n\"\"\"\n\nproblem = JobShopProblem.from_email_text(email_text)\nsolver = JobShopSolver(problem)\nsolution = solver.solve()\n```\n\n## Key Features\n\n1. **Constraint Types Supported**:\n   - Precedence constraints (operations within a job must be sequential)\n   - No-overlap