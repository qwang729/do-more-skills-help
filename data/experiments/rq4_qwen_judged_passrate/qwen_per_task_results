will automatically download the pretrained model weights\n    print(\"Loading SeisBench PhaseNet model...\")\n    model = sbm.PhaseNet.from_pretrained(\"original\")\n\n    # 4. Annotate the stream\n    # The annotate method returns an ObsPy stream containing picking probabilities.\n    # The channel code of annotation traces is modified to end with 'P', 'S', or 'N' (Noise).\n    print(\"Running seismic phase picking...\")\n    annotations = model.annotate(st)\n\n    # 5. Extract picks from annotations\n    picks = []\n    for trace in annotations:\n        # Identify phase by the last character of the channel code\n        phase_char = trace.stats.channel[-1]\n        if phase_char not in ['P', 'S']:\n            continue\n        \n        # Find peaks in the probability trace\n        # height=0.3 filters out low-confidence noise\n        # distance=100 samples (1 second at 100Hz) prevents duplicate picks for the same arrival\n        peaks, _ = find_peaks(trace.data, height=0.3, distance=100)\n        \n        for peak in peaks:\n            pick_time = trace.stats.starttime + peak * trace.stats.delta\n            picks.append({\n                \"time\": pick_time,\n                \"phase\": phase_char,\n                \"probability\": float(trace.data[peak])\n            })\n\n    # 6. Output the results\n    print(\"\\n\" + \"=\"*40)\n    print(\"SEISMIC PICKING RESULTS\")\n    print(\"=\"*40)\n    if not picks:\n        print(\"No confident picks found.\")\n    else:\n        for p in picks:\n            print(f\"Phase: {p['phase']} | Time: {p['time'].isoformat()} | Probability: {p['probability']:.3f}\")\n\nif __name__ == \"__main__\":\n    main()\n```\n\n### How it Works:\n1. **ObsPy FDSN Client**: Connects to the IRIS data center to fetch raw miniseed waveform data for a specific time window surrounding a known earthquake.\n2. **Preprocessing**: SeisBench models are trained on specific data distributions. We detrend, taper, bandpass filter, and resample the stream to the expected `100 Hz` sampling rate.\n3. **SeisBench PhaseNet**: Loads the pretrained PhaseNet deep learning model. The `model.annotate(stream)` method slides a window across the continuous waveform and outputs probability traces for P-wave, S-wave, and Noise.\n4. **Peak Picking**: Uses `scipy.signal.find_peaks` on the probability traces to extract discrete arrival times where the model's confidence exceeds the threshold (`0.3`).", "solver_finish_reason": "stop"}
{"task": "earthquake-phase-association", "condition": "random_wrong", "repeat": 0, "skill_ids": ["benchflow-ai--pause-detector"], "retrieval_correct": false, "judged_pass": false, "judged_score": 0, "judge_reason": "Agent's solution does not match the oracle's approach of using GaMMA for phase association and event detection, and fails to produce required outputs like results.csv.", "solver_tokens": 3114, "judge_tokens": 3514, "solution_text": "# SeisBench Seismic Picking on ObsPy MiniSEED Waveforms\n\nBelow is a complete, self-contained Python solution that reads a MiniSEED file with ObsPy, preprocesses the waveforms for SeisBench, runs a pretrained phase-picking model (e.g., **PhaseNet** or **EQTransformer**), and plots the picks.\n\n---\n\n## 1. Install Dependencies\n\n```bash\npip install seisbench obspy torch matplotlib numpy\n```\n\n---\n\n## 2. Complete Picking Script\n\n```python\n#!/usr/bin/env python3\n\"\"\"\nSeismic phase picking on MiniSEED waveforms using SeisBench + ObsPy.\nUses the PhaseNet model (pretrained on INSTANCE/STEAD) to detect P and S arrivals.\n\"\"\"\n\nimport obspy\nimport numpy as np\nimport matplotlib.pyplot as plt\nimport torch\nimport seisbench\nfrom seisbench.models import PhaseNet, EQTransformer\nfrom seisbench.util import pad_packed_sequence_to_length\n\n# \u2500\u2500 1. Read MiniSEED data with ObsPy \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nMSEED_FILE = \"waveform.mseed\"   # <-- replace with your file path\n\nst = obspy.read(MSEED_FILE)\nprint(f\"Loaded {len(st)} trace(s):\")\nfor tr in st:\n    print(f\"  {tr.id}  |  {tr.stats.npts} samples  |  \"\n          f\"{tr.stats.sampling_rate:.1f} Hz  |  \"\n          f\"{tr.stats.starttime} \u2013 {tr.stats.endtime}\")\n\n# \u2500\u2500 2. Preprocess \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Detrend, taper, and filter (typical bandpass for local events)\nst.detrend(\"demean\")\nst.detrend(\"linear\")\nst.taper(max_percentage=0.05, type=\"hann\")\nst.filter(\"bandpass\", freqmin=1.0, freqmax=20.0, corners=4, zerophase=True)\n\n# Merge / select 3 components (Z, N, E) \u2013 adjust to your network\n# SeisBench expects 3-component data in order [Z, N, E] or [E, N, Z]\n# depending on the model. PhaseNet default is ZNE.\ncomponent_order = \"ZNE\"\n\n# Build a 3-component numpy array (samples, 3)\n# If fewer than 3 components exist, zero-fill the missing ones.\nnpts = max(tr.stats.npts for tr in st)\nsampling_rate = st[0].stats.sampling_rate\nwaveform = np.zeros((npts, 3), dtype=np.float32)\n\nfor i, comp in enumerate(component_order):\n    matching = [tr for tr in st if tr.stats.channel.endswith(comp)]\n    if matching:\n        tr = matching[0]\n        waveform[: tr.stats.npts, i] = tr.data.astype(np.float32)\n\nprint(f\"\\nWaveform array shape: {waveform.shape}\")\n\n# \u2500\u2500 3. Load SeisBench PhaseNet model (pretrained) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# PhaseNet expects 3001-sample windows at 100 Hz (30.01 s).\n# We split the continuous record into overlapping windows, pick each, then merge.\n\nMODEL_SAMPLE_RATE = 100          # Hz \u2013 PhaseNet's training rate\nMODEL_WINDOW_LEN  = 3001         # samples (30.01 s at 100 Hz)\nMODEL_STRIDE      = 1500         # 50 % overlap\n\n# Resample if necessary\nif abs(sampling_rate - MODEL_SAMPLE_RATE) > 0.01:\n    print(f\"Resampling from {sampling_rate:.1f} Hz \u2192 {MODEL_SAMPLE_RATE} Hz\")\n    st_rs = st.copy()\n    st_rs.resample(MODEL_SAMPLE_RATE, no_filter=True)\n    npts = max(tr.stats.npts for tr in st_rs)\n    waveform = np.zeros((npts, 3), dtype=np.float32)\n    for i, comp in enumerate(component_order):\n        matching = [tr for tr in st_rs if tr.stats.channel.endswith(comp)]\n        if matching:\n            tr = matching[0]\n            waveform[: tr.stats.npts, i] = tr.data.astype(np.float32)\n    sampling_rate = MODEL_SAMPLE_RATE\n\n# \u2500\u2500 4. Run picking on sliding windows \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nmodel = PhaseNet.from_pretrained(\"instance_noise\")   # or \"stead\"\nmodel.eval()\nmodel.cuda() if torch.cuda.is_available() else None   # move to GPU if available\n\n# Storage for picks: list of (sample_index, phase, probability)\nall_picks = []\n\nn_total = waveform.shape[0]\nstart = 0\nwhile start + MODEL_WINDOW_LEN <= n_total:\n    window = waveform[start : start + MODEL_WINDOW_LEN]          # (3001, 3)\n    # SeisBench expects (batch, channels, samples)\n    x = torch.tensor(window.T[np.newaxis, :, :], dtype=torch.float32)\n    if next(model.parameters()).is_cuda:\n        x = x.cuda()\n\n    with torch.no_grad():\n        # model returns detection probabilities per phase\n        # PhaseNet output shape: (batch, 3, samples) \u2192 channels: P, S, N (noise)\n        pred = model(x)                          # (1, 3, 3001)\n        pred = pred.cpu().numpy()[0]             # (3, 3001)\n\n    p_prob = pred[0]   # P-wave probability\n    s_prob = pred[1]   # S-wave probability\n\n    # Simple peak-picking with a threshold\n    THRESHOLD_P = 0.3\n    THRESHOLD_S = 0.3\n    MIN_PEAK_DIST = 50   # samples\n\n    for phase_idx, (prob, phase_name, thr) in enumerate([\n        (p_prob, \"P\", THRESHOLD_P),\n        (s_prob, \"S\", THRESHOLD_S),\n    ]):\n        peaks = _pick_peaks(prob, thr, MIN_PEAK_DIST)\n        for pk in peaks:\n            all_picks.append((start + pk, phase_name, prob[pk]))\n\n    start += MODEL_STRIDE\n\n# Handle the last partial window\nif start < n_total:\n    tail_len = n_total - start\n    padded = np.zeros((MODEL_WINDOW_LEN, 3), dtype=np.float32)\n    padded[:tail_len] = waveform[start:]\n    x = torch.tensor(padded.T[np.newaxis, :, :], dtype=torch.float32)\n    if next(model.parameters()).is_cuda:\n        x = x.cuda()\n    with torch.no_grad():\n        pred = model(x).cpu().numpy()[0]\n    p_prob, s_prob = pred[0], pred[1]\n    for prob, phase_name, thr in [\n        (p_prob, \"P\", THRESHOLD_P),\n        (s_prob, \"S\", THRESHOLD_S),\n    ]:\n        peaks = _pick_peaks(prob[:tail_len], thr, MIN_PEAK_DIST)\n        for pk in peaks:\n            all_picks.append((start + pk, phase_name, prob[pk]))\n\n\ndef _pick_peaks(prob, threshold, min_dist):\n    \"\"\"Return sample indices of peaks above threshold, separated by \u2265 min_dist.\"\"\"\n    peaks = []\n    for i in range(1, len(prob) - 1):\n        if prob[i] > threshold and prob[i] >= prob[i - 1] and prob[i] >= prob[i + 1]:\n            if not peaks or (i - peaks[-1]) >= min_dist:\n                peaks.append(i)\n    return peaks\n\n\n# \u2500\u2500 5. Convert picks to UTCDateTime \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\norigin_time = st[0].stats.starttime\nprint(\"\\n\u2500\u2500\u2500 Picks \u2500\u2500\u2500\")\npicks_by_time = {}\nfor sample_idx, phase, prob in sorted(all_picks, key=lambda x: x[0]):\n    pick_time = origin_time + sample_idx / sampling_rate\n    picks_by_time.setdefault(phase, []).append((pick_time, prob))\n    print(f\"  {phase}-wave  |  {pick_time}  |  prob={prob:.3f}\")\n\n# \u2500\u2500 6. Plot results \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nfig, axes = plt.subplots(4, 1, figsize=(14, 10), sharex=True,\n                         gridspec_kw={\"height_ratios\": [1, 1, 1, 0.6]})\n\ntimes = np.arange(n_total) / sampling_rate\n\n# Waveforms\nfor i, (comp, color) in enumerate(zip(\"ZNE\", [\"black\", \"blue\", \"red\"])):\n    axes[i].plot(times, waveform[:, i], color=color, lw=0.5, label=comp)\n    axes[i].set_ylabel(comp)\n    axes[i].legend(loc=\"upper right\", fontsize=8)\n\n# Picking probabilities (last window shown as example, or overlay all)\n# For a clean overview we re-run on the full array in one go if it fits,\n# otherwise we just mark picks on the waveform axes.\nfor phase, color, marker in [(\"P\", \"red\", \"|\"), (\"S\", \"blue\", \"|\")]:\n    for pick_time, prob in picks_by_time.get(phase, []):\n        for ax in axes[:3]:\n            ax.axvline(pick_time - origin_time, color=color,\n                       linestyle=\"--\", alpha=0.6, lw=0.8)\n        axes[3].plot(pick_time - origin_time, prob, marker=marker,\n                     color=color, markersize=10)\n\naxes[3].set_ylabel(\"Pick prob\")\naxes[3].set_xlabel(\"Time (s)\")\naxes[3].set_ylim(0, 1)\naxes[0].set_title(f\"SeisBench PhaseNet Picks  \u2014  {MSEED_FILE}\")\nplt.tight_layout()\nplt.savefig(\"picks_result.png\", dpi=150)\nplt.show()\nprint(\"\\nPlot saved to picks_result.png\")\n```\n\n---\n\n## 3. Key Points\n\n| Step | Detail |\n|------|--------|\n| **Read** | `obspy.read(\"file.mseed\")` handles single/multi-component MiniSEED. |\n| **Preprocess** | Detrend \u2192 taper \u2192 bandpass (1\u201320 Hz) \u2192 resample to 100 Hz (PhaseNet's native rate). |\n| **Model** | `PhaseNet.from_pretrained(\"instance_noise\")` \u2014 also try `\"stead\"`, or swap in `EQTransformer`. |\n| **Windowing** | 3001-sample (30 s) windows with 50 % overlap; pad the tail. |\n| **Peak picking** | Local maxima above a probability threshold (tune `THRESHOLD_P`/`THRESHOLD_S`). |\n| **Output** | UTCDateTime picks printed to console + plotted with probability panel. |\n\n### Swapping to EQTransformer\n\n```python\nfrom seisbench.models import EQTransformer\nmodel = EQTransformer.from_pretrained(\"instance_noise\")\n# EQTransformer uses 6001-sample (60 s) windows at 100 Hz\nMODEL_WINDOW_LEN = 6001\nMODEL_STRIDE     = 4000\n```\n\n### Using SeisBench's Built-in Callback (simpler API)\n\n```python\nfrom seisbench.util import PickCallbackList\nfrom seisbench.data import WaveformData\n\n# If your data is already in a SeisBench-compatible dataset:\ndataset = WaveformData(...)          # or build from ObsPy Stream\nmodel.annotate(dataset, argdict={\"threshold\": 0.3})\n```\n\nThis script is ready to run against any 3-component MiniSEED file \u2014 just set `MSEED_FILE` and adjust the component mapping if your channels differ.", "solver_finish_reason": "stop"}
{"task": "earthquake-plate-calculation", "condition": "no_skill", "repeat": 0, "skill_ids": [], "retrieval_correct": null, "judged_pass": false, "judged_score": 0, "judge_reason": "Agent's solution does not process earthquake data or compute distances to plate boundaries as required; it lacks integration with the expected output format and test criteria.", "solver_tokens": 4447, "judge_tokens": 4554, "solution_text": "# Geopandas Plate Boundaries Geospatial Distance Calculation\n\nBelow is a complete, self-contained Python solution that downloads tectonic plate boundary data, loads it with GeoPandas, and computes geodesic distances between plate boundary segments.\n\n## Prerequisites\n\n```bash\npip install geopandas shapely pyproj requests pandas numpy matplotlib\n```\n\n## Complete Solution\n\n```python\n\"\"\"\nGeospatial Distance Calculation Between Tectonic Plate Boundaries\nusing GeoPandas and PyProj (geodesic distances on the WGS84 ellipsoid).\n\"\"\"\n\nimport geopandas as gpd\nimport pandas as pd\nimport numpy as np\nimport requests\nimport os\nimport tempfile\nimport zipfile\nfrom shapely.geometry import MultiLineString, LineString\nfrom pyproj import Geod\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 1. DOWNLOAD PLATE BOUNDARY DATA\n#    Source: Global Strain Rate Model (GSRM) / Peter Bird plate boundaries\n#    Alternative: tectonicplates GitHub repo (fraxen/tectonicplates)\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nPLATE_BOUNDARY_URL = (\n    \"https://raw.githubusercontent.com/fraxen/tectonicplates/master/\"\n    \"PB2002_boundaries.csv\"\n)\n\n# We also grab the plate polygons for context\nPLATE_POLYGON_URL = (\n    \"https://raw.githubusercontent.com/fraxen/tectonicplates/master/\"\n    \"PB2002_plates.csv\"\n)\n\n\ndef download_plate_boundaries():\n    \"\"\"Download plate boundary polyline data and return a GeoDataFrame.\"\"\"\n    print(\"Downloading plate boundary data...\")\n    resp = requests.get(PLATE_BOUNDARY_URL, timeout=30)\n    resp.raise_for_status()\n\n    tmp = tempfile.NamedTemporaryFile(suffix=\".csv\", delete=False)\n    tmp.write(resp.content)\n    tmp.close()\n\n    # The CSV has columns: longitude, latitude, plate1, plate2, type, ...\n    # We parse it manually because it has no header in some versions\n    df = pd.read_csv(\n        tmp.name,\n        header=None,\n        names=[\"lon\", \"lat\", \"plate1\", \"plate2\", \"bound_type\", \"ref\"],\n        skiprows=0,\n    )\n    os.unlink(tmp.name)\n\n    # Group consecutive points by plate pair to form LineStrings\n    df[\"group\"] = (df[[\"plate1\", \"plate2\"]] != df[[\"plate1\", \"plate2\"]].shift()).any(\n        axis=1\n    ).cumsum()\n\n    lines = []\n    meta = []\n    for grp_id, grp_df in df.groupby(\"group\"):\n        coords = list(zip(grp_df[\"lon\"].values, grp_df[\"lat\"].values))\n        if len(coords) >= 2:\n            lines.append(LineString(coords))\n            meta.append(\n                {\n                    \"plate1\": grp_df[\"plate1\"].iloc[0],\n                    \"plate2\": grp_df[\"plate2\"].iloc[0],\n                    \"bound_type\": grp_df[\"bound_type\"].iloc[0],\n                }\n            )\n\n    gdf = gpd.GeoDataFrame(meta, geometry=lines, crs=\"EPSG:4326\")\n    print(f\"  Loaded {len(gdf)} plate boundary segments.\")\n    return gdf\n\n\ndef download_plate_polygons():\n    \"\"\"Download plate polygon data and return a GeoDataFrame.\"\"\"\n    print(\"Downloading plate polygon data...\")\n    resp = requests.get(PLATE_POLYGON_URL, timeout=30)\n    resp.raise_for_status()\n\n    tmp = tempfile.NamedTemporaryFile(suffix=\".csv\", delete=False)\n    tmp.write(resp.content)\n    tmp.close()\n\n    df = pd.read_csv(\n        tmp.name,\n        header=None,\n        names=[\"lon\", \"lat\", \"plate\", \"cont\", \"xlat\", \"xlon\", \"xang\"],\n    )\n    os.unlink(tmp.name)\n\n    df[\"group\"] = (df[\"plate\"] != df[\"plate\"].shift()).cumsum()\n\n    polys = []\n    plate_names = []\n    for grp_id, grp_df in df.groupby(\"group\"):\n        coords = list(zip(grp_df[\"lon\"].values, grp_df[\"lat\"].values))\n        if len(coords) >= 3:\n            from shapely.geometry import Polygon\n\n            try:\n                poly = Polygon(coords)\n                if poly.is_valid:\n                    polys.append(poly)\n                    plate_names.append(grp_df[\"plate\"].iloc[0])\n            except Exception:\n                pass\n\n    gdf = gpd.GeoDataFrame({\"plate\": plate_names}, geometry=polys, crs=\"EPSG:4326\")\n    print(f\"  Loaded {len(gdf)} plate polygons.\")\n    return gdf\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 2. GEODESIC DISTANCE CALCULATION\n#    Uses pyproj.Geod for accurate ellipsoidal (WGS84) distances.\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ngeod = Geod(ellps=\"WGS84\")\n\n\ndef geodesic_distance_between_linestrings(geom1, geom2, n_samples=50):\n    \"\"\"\n    Compute the minimum geodesic distance (in km) between two LineStrings\n    by sampling points along each geometry and computing all pairwise\n    geodesic distances.\n\n    Parameters\n    ----------\n    geom1, geom2 : shapely.geometry.LineString\n    n_samples : int\n        Number of evenly-spaced sample points per geometry.\n\n    Returns\n    -------\n    min_dist_km : float\n        Minimum geodesic distance in kilometres.\n    \"\"\"\n    # Sample points along each line\n    pts1 = _sample_line(geom1, n_samples)\n    pts2 = _sample_line(geom2, n_samples)\n\n    if len(pts1) == 0 or len(pts2) == 0:\n        return np.nan\n\n    # Compute pairwise geodesic distances\n    lons1, lats1 = zip(*pts1)\n    lons2, lats2 = zip(*pts2)\n\n    min_dist = float(\"inf\")\n    for lon1, lat1 in pts1:\n        # Vectorised via pyproj\n        _, _, dists = geod.inv(\n            np.full(len(pts2), lon1),\n            np.full(len(pts2), lat1),\n            np.array(lons2),\n            np.array(lats2),\n        )\n        d = np.min(np.abs(dists))\n        if d < min_dist:\n            min_dist = d\n\n    return min_dist / 1000.0  # metres \u2192 km\n\n\ndef _sample_line(geom, n):\n    \"\"\"Return n evenly-spaced (lon, lat) tuples along a LineString.\"\"\"\n    if geom.geom_type == \"MultiLineString\":\n        # Use the longest sub-line\n        geom = max(geom.geoms, key=lambda g: g.length)\n    length = geom.length\n    if length == 0:\n        return []\n    fractions = np.linspace(0, 1, n)\n    return [(geom.interpolate(f * length).x, geom.interpolate(f * length).y) for f in fractions]\n\n\ndef geodesic_distance_point_to_line(lon, lat, geom, n_samples=100):\n    \"\"\"Geodesic distance (km) from a single point to a LineString.\"\"\"\n    pts = _sample_line(geom, n_samples)\n    if not pts:\n        return np.nan\n    lons2, lats2 = zip(*pts)\n    _, _, dists = geod.inv(\n        np.full(len(pts), lon), np.full(len(pts), lat), np.array(lons2), np.array(lats2)\n    )\n    return np.min(np.abs(dists)) / 1000.0\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 3. PAIRWISE DISTANCE MATRIX BETWEEN ALL BOUNDARY SEGMENTS\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n\ndef compute_pairwise_distance_matrix(gdf, n_samples=30):\n    \"\"\"\n    Compute an N\u00d7N matrix of minimum geodesic distances (km) between\n    every pair of plate boundary segments in the GeoDataFrame.\n\n    Returns a pandas DataFrame with plate-pair labels as index/columns.\n    \"\"\"\n    n = len(gdf)\n    labels = [\n        f\"{r.plate1}\u2013{r.plate2} ({r.bound_type})\" for r in gdf.itertuples()\n    ]\n    dist_matrix = np.full((n, n), np.nan)\n\n    print(f\"Computing {n*(n-1)//2} pairwise geodesic distances...\")\n    for i in range(n):\n        for j in range(i + 1, n):\n            d = geodesic_distance_between_linestrings(\n                gdf.geometry.iloc[i], gdf.geometry.iloc[j], n_samples=n_samples\n            )\n            dist_matrix[i, j] = d\n            dist_matrix[j, i] = d\n\n    # Diagonal = 0\n    np.fill_diagonal(dist_matrix, 0.0)\n\n    return pd.DataFrame(dist_matrix, index=labels, columns=labels)\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 4. NEAREST BOUNDARY FOR EACH PLATE PAIR\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n\ndef find_nearest_boundaries(gdf, n_samples=30):\n    \"\"\"\n    For each boundary segment, find the nearest *other* segment and\n    the geodesic distance to it.\n    \"\"\"\n    results = []\n    n = len(gdf)\n    for i in range(n):\n        best_dist = float(\"inf\")\n        best_j = -1\n        for j in range(n):\n            if i == j:\n                continue\n            d = geodesic_distance_between_linestrings(\n                gdf.geometry.iloc[i], gdf.geometry.iloc[j], n_samples=n_samples\n            )\n            if d < best_dist:\n                best_dist = d\n                best_j = j\n        row = gdf.iloc[i]\n        results.append(\n            {\n                \"plate1\": row[\"plate1\"],\n           