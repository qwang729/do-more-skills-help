n_estimates\n\n\ndef compute_trajectory(motion_estimates):\n    \"\"\"\n    Compute cumulative camera trajectory from per-frame motion estimates.\n    Returns cumulative (x, y) position and rotation over time.\n    \"\"\"\n    if not motion_estimates:\n        return None\n    \n    cum_tx = np.zeros(len(motion_estimates) + 1)\n    cum_ty = np.zeros(len(motion_estimates) + 1)\n    cum_rot = np.zeros(len(motion_estimates) + 1)\n    \n    for i, m in enumerate(motion_estimates):\n        if m['valid']:\n            cum_tx[i + 1] = cum_tx[i] + m['tx']\n            cum_ty[i + 1] = cum_ty[i] + m['ty']\n            cum_rot[i + 1] = cum_rot[i] + m['rotation']\n        else:\n            cum_tx[i + 1] = cum_tx[i]\n            cum_ty[i + 1] = cum_ty[i]\n            cum_rot[i + 1] = cum_rot[i]\n    \n    return {\n        'x': cum_tx,\n        'y': cum_ty,\n        'rotation': cum_rot,\n        'total_displacement': np.sqrt(cum_tx[-1]**2 + cum_ty[-1]**2),\n        'total_rotation': cum_rot[-1]\n    }\n\n\ndef visualize_flow(frame, good_old, good_new, motion, output_path=None):\n    \"\"\"Visualize optical flow and motion estimate on frame.\"\"\"\n    vis = frame.copy()\n    \n    if good_old is not None and len(good_old) > 0:\n        for i, (p_old, p_new) in enumerate(zip(good_old.reshape(-1, 2), good_new.reshape(-1, 2))):\n            x_old, y_old = int(p_old[0]), int(p_old[1])\n            x_new, y_new = int(p_new[0]), int(p_new[1])\n            \n            # Draw points\n            cv2.circle(vis, (x_old, y_old), 3, (0, 255, 0), -1)\n            # Draw flow arrows\n            cv2.arrowedLine(vis, (x_old, y_old), (x_new, y_new), (0, 0, 255), 1, tipLength=0.3)\n    \n    # Add motion info text\n    if motion:\n        info = (f\"tx={motion['tx']:.1f} ty={motion['ty']:.1f} \"\n                f\"rot={motion['rotation']:.2f}deg\")\n        cv2.putText(vis, info, (10, 30), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 255, 255), 2)\n    \n    if output_path:\n        cv2.imwrite(ou