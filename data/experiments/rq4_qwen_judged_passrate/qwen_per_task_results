   # --- Plot 4: Summary table ---\n    ax4 = axes[1, 1]\n    ax4.axis('off')\n    table_data = []\n    headers = ['Return\\nPeriod (yr)', 'Flood\\nThreshold (cfs)',\n               '95% CI\\nLower (cfs)', '95% CI\\nUpper (cfs)']\n    for T in return_periods:\n        row = [\n            f'{T}',\n            f'{quantiles[T]:,.0f}',\n            f'{ci[T][\"lower\"]:,.0f}' if T in ci else 'N/A',\n            f'{ci[T][\"upper\"]:,.0f}' if T in ci else 'N/A'\n        ]\n        table_data.append(row)\n\n    table = ax4.table(cellText=table_data, colLabels=headers,\n                      cellLoc='center', loc='center',\n                      colWidths=[0.2, 0.25, 0.25, 0.25])\n    table.auto_set_font_size(False)\n    table.set_fontsize(10)\n    table.scale(1, 1.8)\n\n    # Style header\n    for j in range(len(headers)):\n        table[0, j].set_facecolor('#2c3e50')\n        table[0, j].set_text_props(color='white', fontweight='bold')\n\n    # Style data rows\n    for i in range(1, len(table_data) + 1):\n        for j in range(len(headers)):\n            color = '#ecf0f1' if i % 2 == 0 else '#ffffff'\n            table[i, j].set_facecolor(color)\n\n    ax4.set_title('Flood Threshold Summary', fontsize=12, pad=20)\n\n    plt.tight_layout(rect=[0, 0, 1, 0.95])\n    plt.savefig('flood_frequency_analysis.png', dpi=150, bbox_inches='tight')\n    plt.show()\n    print(\"\\nPlot saved to 'flood_frequency_analysis.png'\")\n\n\n# ============================================================\n# 7. MAIN ANALYSIS\n# ============================================================\n\ndef main():\n    # --- Configuration ---\n    SITE_NUMBER = \"01646500\"  # USGS site: Potomac River at Little Falls, MD\n    # Other example sites:\n    # \"09380000\" - Colorado River at Lees Ferry, AZ\n    # \"07010000\" - Mississippi River at St. Louis, MO\n    START_DATE = \"1990-01-01\"\n    END_DATE = \"2024-12-31\"\n    RETURN_PERIODS = [2, 5, 10, 25, 50, 100, 200, 500]\n\n    print(\"=\" * 60)\n    p