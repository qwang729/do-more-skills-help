wing.ProcessWindowFunction;\nimport org.apache.flink.streaming.api.windowing.assigners.EventTimeSessionWindows;\nimport org.apache.flink.streaming.api.windowing.time.Time;\nimport org.apache.flink.streaming.api.windowing.windows.TimeWindow;\nimport org.apache.flink.util.Collector;\n\nimport java.time.Duration;\n\npublic class SessionWindowJob {\n\n    public static void main(String[] args) throws Exception {\n        // 1. Set up the streaming execution environment\n        final StreamExecutionEnvironment env = StreamExecutionEnvironment.getExecutionEnvironment();\n\n        // 2. Read from socket stream (Format: \"userId,timestamp\")\n        DataStream<Tuple2<String, Long>> inputStream = env.socketTextStream(\"localhost\", 9999)\n                .map(new MapFunction<String, Tuple2<String, Long>>() {\n                    @Override\n                    public Tuple2<String, Long> map(String value) throws Exception {\n                        String[] parts = value.split(\",\");\n                        return new Tuple2<>(parts[0].trim(), Long.parseLong(parts[1].trim()));\n                    }\n                });\n\n        // 3. Assign Timestamps and Watermarks (Bounded Out-of-Orderness = 2 seconds)\n        DataStream<Tuple2<String, Long>> withWatermarks = inputStream\n                .assignTimestampsAndWatermarks(\n                        WatermarkStrategy.<Tuple2<String, Long>>forBoundedOutOfOrderness(Duration.ofSeconds(2))\n                                .withTimestampAssigner((event, timestamp) -> event.f1)\n                );\n\n        // 4. Key by User ID, apply Session Window (10s gap), and process\n        DataStream<String> result = withWatermarks\n                .keyBy(value -> value.f0)\n                .window(EventTimeSessionWindows.withGap(Time.seconds(10)))\n                .process(new ProcessWindowFunction<Tuple2<String, Long>, String, String, TimeWindow>() {\n                    @Override\n                    public void process(String userId, Context context, Iterable<Tuple2<String, Long>> elements, Collector<String> out) throws Exception {\n                        long count = 0;\n                        for (Tuple2<String, Long> e : elements) {\n                            count++;\n                        }\n                        // Output the aggregated session data\n                        out.collect(String.format(\"User: %-5s | Events in Session: %d | Window: [%d, %d)\",\n                                userId, count, context.window().getStart(), context.window().getEnd()));\n                    }\n                });\n\n        // 5. Sink: Print results to standard out\n        result.print();\n\n        // 6. Execute the job\n        env.execute(\"Flink Session Window Processing Job\");\n    }\n}\n```\n\n### 3. Steps to Run and Test\n\n**Step 1: Start a local Netcat server** to act as the socket source. Open a terminal and run:\n```bash\nnc -lk 9999\n```\n\n**Step 2: Run the Flink Job** from your IDE or via Maven:\n```bash\nmvn clean package exec:java -Dexec.mainClass=\"com.example.flink.SessionWindowJob\"\n```\n\n**Step 3: Send test data** into the `nc` terminal. \n*Send the following lines sequentially (timestamps are in milliseconds):*\n```text\nuser1,1000\nuser1,2000\nuser2,3000\nuser1,15000\nuser2,16000\n```\n\n**Expected Output in Flink Console:**\nBecause the gap between `2000` and `15000` is greater than the 10-second session gap, `user1`'s events will be split into two distinct sessions.\n```text\nUser: user2 | Events in Session: 1 | Window: [3000, 13000)\nUser: user1 | Events in Session: 2 | Window: [1000, 12000)\nUser: user1 | Events in Session: 1 | Window: [15000, 25000)\nUser: user2 | Events in Session: 1 | Window: [16000, 26000)\n```", "solver_finish_reason": "stop"}
