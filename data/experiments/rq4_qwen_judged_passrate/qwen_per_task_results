pe[0]} samples, {X.shape[1]} features\")\n    \n    # Estimate eps range\n    eps_min, eps_max, eps_knee = estimate_eps_range(X, k=5)\n    print(f\"Estimated eps knee point: {eps_knee:.4f}\")\n    print(f\"Search range: [{eps_min:.4f}, {eps_max:.4f}]\")\n    \n    # Define parameter grid\n    eps_range = np.linspace(eps_min, eps_max, 15)\n    min_samples_range = range(3, 15)\n    \n    print(f\"\\nGrid search: {len(eps_range)} eps values \u00d7 {len(min_samples_range)} min_samples\")\n    \n    # Grid search\n    results_df = grid_search_dbscan(X, eps_range, min_samples_range)\n    \n    # Filter valid results (at least 2 clusters)\n    valid_df = results_df[(results_df['n_clusters'] >= 2) & (results_df['silhouette'] > 0)].copy()\n    print(f\"Valid configurations: {len(valid_df)}/{len(results_df)}\")\n    \n    if len(valid_df) == 0:\n        print(\"No valid configurations found. Adjusting criteria...\")\n        valid_df = results_df[results_df['n_clusters'] >= 2].copy()\n    \n    # Find Pareto frontier\n    # Objectives: maximize silhouette, minimize noise ratio\n    objectives = [\n        ('silhouette', 'max'),\n        ('noise_ratio', 'min')\n    ]\n    \n    pareto_df = find_pareto_frontier(valid_df, objectives)\n    print(f\"\\nPareto frontier solutions: {len(pareto_df)}\")\n    \n    # Select best solution\n    best_params = select_best_pareto_solution(pareto_df)\n    \n    print(\"\\n\" + \"=\" * 60)\n    print(\"BEST SOLUTION (Pareto-optimal)\")\n    print(\"=\" * 60)\n    print(f\"  eps:            {best_params['eps']:.4f}\")\n    print(f\"  min_samples:    {int(best_params['min_samples'])}\")\n    print(f\"  n_clusters:     {int(best_params['n_clusters'])}\")\n    print(f\"  n_noise:        {int(best_params['n_noise'])}\")\n    print(f\"  noise_ratio:    {best_params['noise_ratio']:.4f}\")\n    print(f\"  silhouette:     {best_params['silhouette']:.4f}\")\n    \n    # Display Pareto frontier\n    print(\"\\n\" + \"-\" * 60)\n    print(\"Pareto Frontier (top 5 by silhouette):\")\n    print(\"-\" * 60)\n    print(pareto_df.nlargest(5, 'silhouette')[\n        ['eps', 'min_samples', 'n_clusters', 'n_noise', 'silhouette', 'noise_ratio']\n    ].to_string(index=False))\n    \n    # Plot results\n    plot_results(X, best_params, pareto_df, results_df)\n    \n    # Save results\n    results_df.to_csv('dbscan_grid_search_results.csv', index=False)\n    pareto_df.to_csv('dbscan_pareto_frontier.csv', index=False)\n    print(\"\\nResults saved to CSV files.\")\n    print(\"Plot saved as 'dbscan_pareto_results.png'\")\n    \n    return best_params, pareto_df, results_df\n\nif __name__ == \"__main__\":\n    best_params, pareto_df, all_results = main()\n```\n\n## Key Features\n\n1. **Automatic eps estimation** using k-distance graph knee point detection\n2. **Grid search** over eps and min_samples parameters\n3. **Multi-objective Pareto frontier** optimization (silhouette score vs noise ratio)\n4. **Weighted scoring** to select best solution from Pareto frontier\n5. **Visualization** of clustering results and parameter space\n\n## Output Files\n\n- `dbscan_grid_search_results.csv` - All evaluated configurations\n- `dbscan_pareto_frontier.csv` - Pareto-optimal solutions\n- `dbscan_pareto_results.png` - Visualization plots\n\n## Usage\n\n```bash\npython dbscan_pareto_optimization.py\n```\n\nThe script automatically:\n1. Generates sample data (make_moons dataset)\n2. Estimates reasonable parameter ranges\n3. Performs grid search with clustering quality metrics\n4. Identifies Pareto-optimal parameter combinations\n5. Selects and reports the best configuration", "solver_finish_reason": "stop"}
