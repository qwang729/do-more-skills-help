   # P m m m (#47)\n    _WYCKOFF_DB[\"P m m m\"] = [\n        WyckoffEntry(\"t\", 8,  \"1\",    [\"x,y,z\"]),\n        WyckoffEntry(\"s\", 4,  \"mm2\",  [\"x,1/2,z\"]),\n        WyckoffEntry(\"r\", 4,  \"mm2\",  [\"1/2,y,z\"]),\n        WyckoffEntry(\"q\", 4,  \"mm2\",  [\"x,y,1/2\"]),\n        WyckoffEntry(\"p\", 4,  \"m.mm\", [\"x,y,0\"]),\n        WyckoffEntry(\"o\", 4,  \"m..m\", [\"x,0,z\"]),\n        WyckoffEntry(\"n\", 4,  \".mm.\", [\"0,y,z\"]),\n        WyckoffEntry(\"m\", 2,  \"mmm\",  [\"1/2,1/2,1/2\"]),\n        WyckoffEntry(\"l\", 2,  \"mmm\",  [\"1/2,1/2,0\"]),\n        WyckoffEntry(\"k\", 2,  \"mmm\",  [\"1/2,0,1/2\"]),\n        WyckoffEntry(\"j\", 2,  \"mmm\",  [\"0,1/2,1/2\"]),\n        WyckoffEntry(\"i\", 2,  \"mmm\",  [\"1/2,0,0\"]),\n        WyckoffEntry(\"h\", 2,  \"mmm\",  [\"0,1/2,0\"]),\n        WyckoffEntry(\"g\", 2,  \"mmm\",  [\"0,0,1/2\"]),\n        WyckoffEntry(\"f\", 2,  \"mm2\",  [\"1/2,y,0\"]),\n        WyckoffEntry(\"e\", 2,  \"mm2\",  [\"x,0,0\"]),\n        WyckoffEntry(\"d\", 2,  \"mm2\",  [\"0,y,0\"]),\n        WyckoffEntry(\"c\", 2,  \"mmm\",  [\"0,0,0\"]),\n    ]\n\n    # F m -3 m (#225) \u2014 selected Wyckoff positions\n    _WYCKOFF_DB[\"F m -3 m\"] = [\n        WyckoffEntry(\"a\", 4,   \"m-3m\",  [\"0,0,0\"]),\n        WyckoffEntry(\"b\", 4,   \"m-3m\",  [\"1/2,1/2,1/2\"]),\n        WyckoffEntry(\"c\", 8,   \"-43m\",  [\"1/4,1/4,1/4\"]),\n        WyckoffEntry(\"d\", 8,   \"m3m\",   [\"1/2,1/2,1/2\"]),  # actually 3m\n        WyckoffEntry(\"e\", 16,  \"m-3m\",  [\"x,x,x\"]),\n        WyckoffEntry(\"f\", 16,  \"m-3.\",  [\"x,0,0\"]),\n        WyckoffEntry(\"g\", 192, \"1\",     [\"x,y,z\"]),\n        WyckoffEntry(\"h\", 96,  \"m..m\",  [\"x,x,0\"]),\n        WyckoffEntry(\"i\", 48,  \"m.m.\",  [\"x,1/4,1/4\"]),\n        WyckoffEntry(\"j\", 48,  \".2.\",   [\"0,x,x\"]),\n        WyckoffEntry(\"k\", 32,  \"-43m\",  [\"x,x,x\"]),\n        WyckoffEntry(\"l\", 24,  \"4/mmm.\",[\"x,0,0\"]),\n        WyckoffEntry(\"m\", 24,  \"mm2.\",