00\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n@dataclass\nclass Plot:\n    \"\"\"A single hex tile on the Civ6 map.\"\"\"\n    x: int\n    y: int\n    terrain: str = \"TERRAIN_GRASS\"\n    feature: str = \"NO_FEATURE\"\n    resource: str = \"NO_RESOURCE\"\n    elevation: int = 0\n    continent: int = 0\n    is_water: bool = False\n    is_impassable: bool = False\n    # Adjacency (filled in later)\n    neighbors: List[Tuple[int, int]] = field(default_factory=list)\n\n    @property\n    def key(self) -> Tuple[int, int]:\n        return (self.x, self.y)\n\n\n@dataclass\nclass DistrictType:\n    \"\"\"Definition of a district type and its adjacency bonus rules.\"\"\"\n    name: str\n    base_yield: float = 0.0\n    # Each rule: (adjacent_thing, bonus_per_adjacent)\n    # adjacent_thing can be: \"TERRAIN_*\", \"FEATURE_*\", \"RESOURCE_*\",\n    #   \"DISTRICT_*\", \"MOUNTAIN\", \"WONDER\", \"COAST\", \"RIVER\", \"WOODS\", \"REEF\"\n    bonus_rules: List[Tuple[str, float]] = field(default_factory=list)\n    adjacency_cap: float = float('inf')\n    must_be_on: Optional[str] = None  # e.g. \"COAST\" for Holy Site... no, for Harbor\n    cannot_be_on: Optional[str] = None\n\n    def compute_bonus(self, neighboring_plots: List[Plot],\n                      placed_districts: Dict[Tuple[int,int], str]) -> float:\n        \"\"\"Compute total adjacency bonus for placing this district given neighbors.\"\"\"\n        bonus = 0.0\n        for nbr in neighboring_plots:\n            for rule_target, rule_bonus in self.bonus_rules:\n                matched = False\n                if rule_target == \"MOUNTAIN\":\n                    matched = (nbr.terrain == \"TERRAIN_MOUNTAIN\")\n                elif rule_target == \"COAST\":\n                    matched = nbr.is_water and not nbr.is_impassable\n                elif rule_target == \"RIVER\":\n                    matched = False  # simplified; would need river data\n                elif rule_target == \"WOODS\":\n                    matched = (nbr.feature == \"FEATURE_FOREST\" or\n                               nbr.feature == \"FEATURE_RAINFOREST\")\n                elif rule_target == \"REEF\":\n                    matched = (nbr.feature == \"FEATURE_REEF\")\n                elif rule_target.startswith(\"TERRAIN_\"):\n                    matched = (nbr.terrain == rule_target)\n                elif rule_target.startswith(\"FEATURE_\"):\n                    matched = (nbr.feature == rule_target)\n                elif rule_target.startswith(\"RESOURCE_\"):\n                    matched = (nbr.resource == rule_target)\n                elif rule_target.startswith(\"DISTRICT_\"):\n                    dist_name = rule_target.replace(\"DISTRICT_\", \"\")\n                    matched = (placed_districts.get(nbr.key, \"\") == dist_name)\n                elif rule_target == \"ANY_DISTRICT\":\n                    matched = (nbr.key in placed_districts)\n                if matched:\n                    bonus += rule_bonus\n        return min(bonus, self.adjacency_cap)\n\n\n# Standard Civ6 district definitions (simplified adjacency rules)\nSTANDARD_DISTRICTS = {\n    \"Campus\": DistrictType(\n        name=\"Campus\",\n        bonus_rules=[\n            (\"MOUNTAIN\", 1.0),\n            (\"FEATURE_REEF\", 1.0),\n            (\"FEATURE_GEOTHERMAL_FISSURE\", 1.0),\n            (\"DISTRICT_CityCenter\", 0.5),\n            (\"ANY_DISTRICT\", 0.5),  # per every 2 districts (simplified)\n        ],\n        adjacency_cap=6.0,\n    ),\n    \"HolySite\": DistrictType(\n        name=\"HolySite\",\n        bonus_rules=[\n            (\"MOUNTAIN\", 1.0),\n            (\"FEATURE_WOODS\", 1.0),  # natural wonder adjacency\n            (\"TERRAIN_NATURAL_WONDER\", 2.0),\n            (\"DISTRICT_CityCenter\", 0.5),\n        ],\n        adjacency_cap=6.0,\n    ),\n    \"CommercialHub\": DistrictType(\n        name=\"CommercialHub\",\n        bonus_rules=[\n            (\"RIVER\", 2.0),\n            (\"COAST\", 2.0),\n            (\"DISTRICT_Harbor\", 1.0),\n            (\"DISTRICT_CityCenter\", 0.5),\n        ],\n        adjacency_cap=6.0,\n    ),\n    \"Harbor\": DistrictType(\n        name=\"Harbor\",\n        must_be_on=\"COAST\",\n        bonus_rules=[\n            (\"DISTRICT_CityCenter\", 1.0),\n            (\"RESOURCE_FISH\", 1.0),\n            (\"RESOURCE_PEARLS\", 1.0),\n            (\"DISTRICT_CommercialHub\", 1.0),\n        ],\n        adjacency_cap=6.0,\n    ),\n    \"IndustrialZone\": DistrictType(\n        name=\"IndustrialZone\",\n        bonus_rules=[\n            (\"RESOURCE_COAL\", 1.0),\n            (\"RESOURCE_IRON\", 1.0),\n            (\"RESOURCE_ALUMINUM\", 1.0),\n            (\"MOUNTAIN\", 1.0),\n            (\"DISTRICT_Aqueduct\", 1.0),\n            (\"DISTRICT_Dam\", 1.0),\n            (\"DISTRICT_Canal\", 1.0),\n            (\"DISTRICT_CityCenter\", 0.5),\n        ],\n        adjacency_cap=6.0,\n    ),\n    \"TheaterSquare\": DistrictType(\n        name=\"TheaterSquare\",\n        bonus_rules=[\n            (\"WONDER\", 2.0),\n            (\"DISTRICT_CityCenter\", 0.5),\n            (\"FEATURE_WOODS\", 0.5),  # simplified\n        ],\n        adjacency_cap=6.0,\n    ),\n    \"Encampment\": DistrictType(\n        name=\"Encampment\",\n        bonus_rules=[\n            (\"MOUNTAIN\", 1.0),\n            (\"DISTRICT_CityCenter\", 0.5),\n        ],\n        adjacency_cap=6.0,\n    ),\n    \"CityCenter\": DistrictType(\n        name=\"CityCenter\",\n        base_yield=3.0,\n        bonus_rules=[],\n        adjacency_cap=0.0,\n    ),\n}\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2