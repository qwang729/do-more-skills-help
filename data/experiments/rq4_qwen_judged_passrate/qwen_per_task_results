e[int, List[Task], List[Constraint]]:\n        \"\"\"Parse constraint text and return problem definition\"\"\"\n        tasks = []\n        constraints = []\n        \n        # Parse tasks\n        for match in self.task_pattern.finditer(text):\n            job_id, task_id, machine, duration = map(int, match.groups())\n            tasks.append(Task(job_id, task_id, machine, duration))\n        \n        # Parse deadlines\n        for match in self.deadline_pattern.finditer(text):\n            job_id, deadline = map(int, match.groups())\n            constraints.append(Constraint(ConstraintType.DEADLINE, {'job_id': job_id, 'deadline': deadline}))\n        \n        # Parse precedence constraints\n        for match in self.precedence_pattern.finditer(text):\n            j1, t1, j2, t2 = map(int, match.groups())\n            constraints.append(Constraint(ConstraintType.PRECEDENCE, {\n                'before': (j1, t1), 'after': (j2, t2)\n            }))\n        \n        # Parse release times\n        for match in self.release_pattern.finditer(text):\n            job_id, release_time = map(int, match.groups())\n            constraints.append(Constraint(ConstraintType.RELEASE_TIME, {'job_id': job_id, 'release_time': release_time}))\n        \n        # Determine number of machines\n        machines_match = self.machines_pattern.search(text)\n        num_machines = int(machines_match.group(1)) if machines_match else max(t.machine for t in tasks) + 1\n        \n        return num_machines, tasks, constraints\n\n\nclass JobShopSolver:\n    \"\"\"Constraint optimization solver for job shop scheduling\"\"\"\n    \n    def __init__(self, horizon: int = 1000):\n        self.horizon = horizon\n        self.model = cp_model.CpModel()\n        self.tasks: Dict[Tuple[int, int], cp_model.IntVar] = {}\n        self.task_ends: Dict[Tuple[int, int], cp_model.IntVar] = {}\n        self.machine_intervals: Dict[int, List[cp_model.IntervalVar]] = {}\n        self.all_jobs: Dict[int, List