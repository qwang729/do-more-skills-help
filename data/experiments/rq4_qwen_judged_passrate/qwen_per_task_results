f f\"{col}_excel\" in matching.columns else col\n            \n            if pdf_col in matching.columns and excel_col in matching.columns:\n                diff_mask = ~(\n                    (matching[pdf_col] == matching[excel_col]) | \n                    (matching[pdf_col].isna() & matching[excel_col].isna())\n                )\n                diffs = matching.loc[diff_mask, key_cols + [pdf_col, excel_col]]\n                if not diffs.empty:\n                    results['value_differences'].append({\n                        'column': col,\n                        'count': len(diffs),\n                        'differences': diffs.to_dict('records')[:10]  # Limit output\n                    })\n    \n    return results\n\ndef generate_comparison_report(pdf_path: str, excel_path: str, \n                                key_columns: List[str] = None,\n                                output_path: str = 'comparison_report.xlsx') -> pd.ExcelWriter:\n    \"\"\"Generate a full comparison report between PDF and Excel.\"\"\"\n    \n    # Extract data\n    pdf_tables = extract_tables_from_pdf(pdf_path)\n    excel_sheets = load_excel_sheets(excel_path)\n    \n    if not pdf_tables:\n        print(\"No tables found in PDF\")\n        return None\n    \n    if not excel_sheets:\n        print(\"No data found in Excel\")\n        return None\n    \n    # Combine all PDF tables\n    pdf_combined = pd.concat(pdf_tables, ignore_index=True)\n    \n    # Compare with each Excel sheet\n    all_results = []\n    for sheet_name, excel_df in excel_sheets.items():\n        print(f\"\\nComparing PDF with Excel sheet: {sheet_name}\")\n        result = compare_dataframes(pdf_combined, excel_df, key_columns)\n        result['sheet_name'] = sheet_name\n        all_results.append(result)\n        \n        # Print summary\n        print(f\"  PDF shape: {result['pdf_shape']}\")\n        print(f\"  Excel shape: {result['excel_shape']}\")\n        print(f\"  Shape match: {result['shape_match'