[best_category]\n    \n    return best_category, confidence\n\ndef extract_key_info(text: str, category: str) -> Dict:\n    \"\"\"Extract key information based on document category.\"\"\"\n    info = {}\n    \n    # Date extraction\n    date_patterns = [\n        r'\\b(\\d{1,2}[/-]\\d{1,2}[/-]\\d{2,4})\\b',\n        r'\\b(\\d{4}[/-]\\d{1,2}[/-]\\d{1,2})\\b',\n        r'\\b((?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*\\.?\\s+\\d{1,2},?\\s+\\d{4})\\b'\n    ]\n    for pattern in date_patterns:\n        match = re.search(pattern, text, re.IGNORECASE)\n        if match:\n            info[\"date\"] = match.group(1)\n            break\n    \n    # Amount extraction (for invoices/financial)\n    if category in [\"invoice\", \"financial\"]:\n        amount_match = re.search(r'(?:total|amount|balance)[:\\s]*\\$?([\\d,]+\\.?\\d*)', text, re.IGNORECASE)\n        if amount_match:\n            info[\"amount\"] = amount_match.group(1)\n    \n    # Email extraction\n    email_match = re.search(r'\\b[\\w\\.-]+@[\\w\\.-]+\\.\\w+\\b', text)\n    if email_match:\n        info[\"email\"] = email_match.group(0)\n    \n    # Phone extraction\n    phone_match = re.search(r'\\b(?:\\+?1[-.]?)?\\(?\\d{3}\\)?[-.]?\\d{3}[-.]?\\d{4}\\b', text)\n    if phone_match:\n        info[\"phone\"] = phone_match.group(0)\n    \n    return info\n\ndef process_pdfs(input_dir: str, output_dir: str) -> List[Dict]:\n    \"\"\"Process all PDFs in input directory and sort into categories.\"\"\"\n    \n    # Create output directories\n    for category in CLASSIFICATION_RULES.keys():\n        os.makedirs(os.path.join(output_dir, category), exist_ok=True)\n    \n    results = []\n    input_path = Path(input_dir)\n    \n    pdf_files = list(input_path.glob(\"*.pdf\"))\n    print(f\"Found {len(pdf_files)} PDF files to process\")\n    \n    for pdf_file in pdf_files:\n        print(f\"\\nProcessing: {pdf_file.name}\")\n        \n        # Extract text and metadata\n        text = extract_text_from_pdf(str(pdf_file))\n        metadata = extract_metadata(str(pdf_file))\n        \n        # Classify\n        category, confidence = classify_document(text, metadata)\n        \n        # Extract key info\n        key_info = extract_key_info(text, category)\n        \n        # Copy to appropriate folder\n        dest_path = os.path.join(output_dir, category, pdf_file.name)\n        shutil.copy2(str(pdf_file), dest_path)\n        \n        result = {\n            \"filename\": pdf_file.name,\n            \"category\": category,\n            \"confidence\": round(confidence, 3),\n            \"page_count\": metadata.get(\"page_count\", 0),\n            \"key_info\": key_info,\n            \"destination\": dest_path\n        }\n        results.append(result)\n        \n        print(f\"  \u2192 Classified as: {category} (confidence: {confidence:.2%})\")\n        if key_info:\n            print(f\"  \u2192 Key info: {key_info}\")\n    \n    return results\n\ndef generate_report(results: List[Dict], output_file: str = \"classification_report.txt\"):\n    \"\"\"Generate a summary report of classification results.\"\"\"\n    \n    # Sort results by category, then by filename\n    sorted_results = sorted(results, key=lambda x: (x[\"category\"], x[\"filename\"]))\n    \n    # Category counts\n    category_counts = defaultdict(int)\n    for r in results:\n        category_counts[r[\"category\"]] += 1\n    \n    with open(output_file, \"w\") as f:\n        f.write(\"=\" * 60 + \"\\n\")\n        f.write(\"PDF CLASSIFICATION REPORT\\n\")\n        f.write(\"=\" * 60 + \"\\n\\n\")\n        \n        f.write(\"SUMMARY BY CATEGORY:\\n\")\n        f.write(\"-\" * 40 + \"\\n\")\n        for cat, count in sorted(category_counts.items()):\n            f.write(f\"  {cat.capitalize():<15}: {count} documents\\n\")\n        f.write(f\"\\n  Total: {len(results)} documents\\n\\n\")\n        \n        f.write(\"DETAILED RESULTS:\\n\")\n        f.write(\"-\" * 40 + \"\\n\")\n        for r in sorted_results:\n            f.write(f\"\\nFile: {r['filename']}\\n\")\n            f.write(f\"  Category: {r['category']}\\n\")\n            f.write(f\"  Confidence: {r['confidence']:.2%}\\n\")\n            f.write(f\"  Pages: {r['page_count']}\\n\")\n            if r['key_info']:\n                f.write(f\"  Key Info: {r['key_info']}\\n\")\n            f.write(f\"  Destination: {r['destination']}\\n\")\n    \n    print(f\"\\nReport saved to: {output_file}\")\n    return sorted_results\n\ndef main():\n    \"\"\"Main entry point.\"\"\"\n    print(\"PDF Text Extraction and Classification Tool\")\n    print(\"=\" * 50)\n    \n    # Create sample input directory if needed\n    os.makedirs(INPUT_DIR, exist_ok=True)\n    \n    # Process all PDFs\n    results = process_pdfs(INPUT_DIR, OUTPUT_DIR)\n    \n    # Generate report\n    if results:\n        sorted_results = generate_report(results)\n        \n        print(\"\\n\" + \"=\" * 50)\n        print(\"PROCESSING COMPLETE\")\n        print(\"=\" * 50)\n        print(f\"Processed: {len(results)} documents\")\n        print(f\"Output directory: {OUTPUT_DIR}\")\n        \n        # Print category breakdown\n        from collections import Counter\n        categories = Counter(r[\"category\"] for r in results)\n        print(\"\\nCategory breakdown:\")\n        for cat, count in sorted(categories.items()):\n            print(f\"  {cat}: {count}\")\n\nif __name__ == \"__main__\":\n    main()\n```\n\n## Installation\n\n```bash\n# Install required packages\npip install pdfplumber PyPDF2\n\n# Create input directory and add your PDFs\nmkdir -p input_pdfs\n```\n\n## Usage\n\n1. Place your PDF files in the `input_pdfs/` directory\n2. Run the script: `python pdf_classifier.py`\n3. Find sorted PDFs in `sorted_pdfs/<category>/`\n4. Review `classification_report.txt` for details\n\n## Customization\n\nEdit `CLASSIFICATION_RULES` dictionary to add your own categories and keywords:\n\n```python\nCLASSIFICATION_RULES = {\n    \"your_category\": [\"keyword1\", \"keyword2\", \"keyword3\"],\n    # Add more categories as needed\n}\n```", "solver_finish_reason": "stop"}
