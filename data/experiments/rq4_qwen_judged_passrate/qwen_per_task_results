n    return nodes, edges\n\ndef to_json_graph(nodes, edges):\n    \"\"\"Converts parsed nodes and edges into a JSON graph structure.\"\"\"\n    graph = {\n        \"nodes\": list(nodes.values()),\n        \"edges\": edges\n    }\n    return json.dumps(graph, indent=2)\n\ndef to_graphviz_dot(nodes, edges):\n    \"\"\"Generates a Graphviz DOT string for visualizing the dialogue tree.\"\"\"\n    dot = [\n        \"digraph DialogueTree {\",\n        \"  rankdir=TB;\",\n        \"  node [shape=box, style=rounded, fontname=\\\"Helvetica\\\", fontsize=12];\",\n        \"  edge [color=\\\"#555555\\\"];\"\n    ]\n    \n    for node_id, node in nodes.items():\n        # Escape double quotes for DOT syntax\n        text = node['text'].replace('\"', '\\\\\"')\n        dot.append(f'  \"{node_id}\" [label=\"{node_id}: {text}\"];')\n        \n    for edge in edges:\n        dot.append(f'  \"{edge[\"source\"]}\" -> \"{edge[\"target\"]}\";')\n        \n    dot.append(\"}\")\n    return \"\\n\".join(dot)\n\ndef generate_tts_for_nodes(nodes, output_dir=\"tts_audio\"):\n    \"\"\"Uses ElevenLabs TTS to generate audio files for each dialogue node.\"\"\"\n    os.makedirs(output_dir, exist_ok=True)\n    \n    api_key = os.getenv(\"ELEVENLABS_API_KEY\")\n    if not api_key:\n        print(\"Warning: ELEVENLABS_API_KEY environment variable not set. Skipping TTS generation.\")\n        return\n    \n    set_api_key(api_key)\n    \n    for node_id, node in nodes.items():\n        try:\n            print(f\"Synthesizing speech for Node {node_id}...\")\n            audio = generate(\n                text=node['text'],\n                voice=\"Rachel\",  # You can change this to any available ElevenLabs voice ID\n                model=\"eleven_monolingual_v1\"\n            )\n            file_path = os.path.join(output_dir, f\"node_{node_id}.mp3\")\n            save(audio, file_path)\n            print(f\"Saved audio to {file_path}\")\n        except Exception as e:\n            print(f\"Failed to generate TTS for node {node_id}: {e}\")\n\nif __name__ == \"__main__\":\n    # Sample Dialogue Tree Text\n    dialogue_text = \"\"\"\n    [1] Hello, traveler! Welcome to the woods.\n      -> [2] Who are you?\n      -> [3] I must be going, goodbye.\n    [2] I am the guardian of this ancient forest.\n      -> [4] What exactly do you guard?\n      -> [3] I must be going, goodbye.\n    [3] Farewell, and safe travels!\n    [4] I guard the World Tree from those who seek its power.\n      -> [5] That sounds dangerous.\n    [5] I will leave you to your duties then.\n      -> [3] I must be going, goodbye.\n    \"\"\"\n    \n    # 1. Parse the dialogue tree\n    nodes, edges = parse_dialogue_tree(dialogue_text)\n    \n    # 2. Generate and save JSON Graph\n    json_graph = to_json_graph(nodes, edges)\n    with open(\"dialogue_graph.json\", \"w\", encoding=\"utf-8\") as f:\n        f.write(json_graph)\n    print(\"\u2705 JSON Graph saved to dialogue_graph.json\")\n    \n    # 3. Generate and save Graphviz DOT file\n    dot_graph = to_graphviz_dot(nodes, edges)\n    with open(\"dialogue_graph.dot\", \"w\", encoding=\"utf-8\") as f:\n        f.write(dot_graph)\n    print(\"\u2705 Graphviz DOT saved to dialogue_graph.dot\")\n    print(\"   (Render with: `dot -Tpng dialogue_graph.dot -o dialogue_graph.png`)\")\n    \n    # 4. Generate TTS Audio using ElevenLabs\n    generate_tts_for_nodes(nodes)\n```\n\n### How to use the outputs:\n1. **JSON Graph (`dialogue_graph.json`)**: Can be loaded into frontend frameworks (like React/D3.js) or game engines to dynamically render dialogue UI and handle branching logic.\n2. **Graphviz DOT (`dialogue_graph.dot`)**: Run `dot -Tpng dialogue_graph.dot -o graph.png` in your terminal (requires Graphviz installed) to generate a visual flowchart of your dialogue tree.\n3. **TTS Audio (`tts_audio/`)**: Contains `.mp3` files mapped to each node ID (e.g., `node_1.mp3`), ready to be triggered in your game engine or app when the specific dialogue node i