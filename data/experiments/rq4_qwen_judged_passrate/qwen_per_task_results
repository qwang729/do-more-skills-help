      speaker = header_match.group(2)\n            graph.add_node(current_node_id, speaker, \"\")\n            continue\n            \n        # Choice format: -> target_node_id (Optional choice text)\n        choice_match = re.match(r'^->\\s+(\\w+)\\s*(?:\\((.*)\\))?', line)\n        if choice_match and current_node_id:\n            flush_text()\n            target_id = choice_match.group(1)\n            choice_text = choice_match.group(2) or \"\"\n            graph.add_choice(current_node_id, target_id, choice_text)\n            continue\n            \n        # Dialogue text\n        if current_node_id:\n            current_text_lines.append(line.strip())\n            \n    flush_text()\n    graph.validate()\n    return graph\n\n\nif __name__ == \"__main__\":\n    if len(sys.argv) < 2:\n        print(\"Usage: python dialogue_graph.py <input.txt> [output.json] [output.dot]\")\n        sys.exit(1)\n        \n    input_file = sys.argv[1]\n    json_out = sys.argv[2] if len(sys.argv) > 2 else \"graph.json\"\n    dot_out = sys.argv[3] if len(sys.argv) > 3 else \"graph.dot\"\n    \n    with open(input_file, 'r', encoding='utf-8') as f:\n        text = f.read()\n        \n    try:\n        graph = parse_dialogue_text(text)\n    except ValueError as e:\n        print(f\"Validation Error: {e}\", file=sys.stderr)\n        sys.exit(1)\n        \n    # Serialize to JSON\n    with open(json_out, 'w', encoding='utf-8') as f:\n        json.dump(graph.to_json(), f, indent=2, ensure_ascii=False)\n        \n    # Generate Graphviz DOT\n    with open(dot_out, 'w', encoding='utf-8') as f:\n        f.write(graph.to_dot())\n        \n    print(f\"Successfully parsed dialogue tree.\")\n    print(f\" -> JSON Graph saved to: {json_out}\")\n    print(f\" -> Graphviz DOT saved to: {dot_out}\")\n```\n\n### 2. Example Input (`example.txt`)\n\n```text\n[start] Innkeeper\n  Welcome to the Rusty Boar, traveler! What brings you to our humble village?\n  -> ask_quest (I'm looking for work)\n  -> a