place=True)\n    \n    # Filter out negative/zero flows for log/GEV calculations\n    df_valid = df[df['discharge_cfs'] > 0]\n\n    # 2. Calculate Statistical Flood Thresholds (Percentiles)\n    thresholds = {\n        'Mean Flow': df_valid['discharge_cfs'].mean(),\n        '90th Percentile (Action Stage)': df_valid['discharge_cfs'].quantile(0.90),\n        '95th Percentile (Flood Stage)': df_valid['discharge_cfs'].quantile(0.95),\n        '99th Percentile (Major Flood)': df_valid['discharge_cfs'].quantile(0.99),\n        'Maximum Observed (Flood of Record)': df_valid['discharge_cfs'].max()\n    }\n\n    # 3. Calculate 100-Year Flood Threshold using Generalized Extreme Value (GEV)\n    # Extract Annual Maximums\n    annual_max = df_valid['discharge_cfs'].resample('YE').max().dropna()\n    \n    if len(annual_max) >= 10:\n        # Fit GEV distribution to annual maximums\n        c, loc, scale = genextreme.fit(annual_max)\n        # Calculate 100-year flood (1% annual exceedance probability -> 0.99 CDF)\n        thresholds['100-Year Flood (GEV Model)'] = genextreme.ppf(0.99, c, loc, scale)\n    else:\n        thresholds['100-Year Flood (GEV Model)'] = np.nan\n        print(\"Warning: Not enough annual data to fit GEV model for 100-year flood.\")\n\n    # 4. Print Results\n    print(f\"\\n--- Flood Threshold Analysis for Site {site_id} ---\")\n    for label, value in thresholds.items():\n        if not np.isnan(value):\n            print(f\"{label}: {value:,.2f} cfs\")\n\n    # 5. Visualization\n    plt.figure(figsize=(12, 7))\n    \n    # Plot historical daily discharge\n    plt.plot(df_valid.index, df_valid['discharge_cfs'], label='Daily Discharge', color='skyblue', alpha=0.7, zorder=1)\n    \n    # Plot thresholds\n    colors = ['green', 'gold', 'orange', 'red', 'darkred', 'purple']\n    for (label, value), color in zip(thresholds.items(), colors):\n        if not np.isnan(value):\n            plt.axhline(y=value, color=color, linestyle='--', linewidth=1.5, label=f'{label}: {value:,.0f} cfs', zorder=2)\n\n    plt.title(f'USGS Streamflow & Flood Thresholds\\nSite {site_id} ({start_date} to {end_date})', fontsize=14)\n    plt.xlabel('Date', fontsize=12)\n    plt.ylabel('Discharge (cfs) - Log Scale', fontsize=12)\n    \n    # Use log scale for better visualization of extreme events\n    plt.yscale('log')\n    plt.legend(loc='upper left', fontsize=9, framealpha=0.9)\n    plt.grid(True, which=\"both\", ls=\"--\", alpha=0.5)\n    plt.tight_layout()\n    plt.show()\n\nif __name__ == \"__main__\":\n    # Example: Potomac River at Washington, DC\n    SITE_ID = '01646500' \n    START_DATE = '1990-01-01'\n    END_DATE = '2023-12-31'\n    \n    analyze_flood_thresholds(SITE_ID, START_DATE, END_DATE)\n```\n\n### Methodology Breakdown\n1. **Data Retrieval**: Uses the `dataretrieval` package to query the USGS NWIS API for daily values (DV) of discharge (`00060`) in cubic feet per second (cfs).\n2. **Empirical Percentiles**: Calculates the 90th, 95th, and 99th percentiles of the historical record. These are standard hydrological benchmarks used to define \"Action\", \"Flood\", and \"Major Flood\" stages.\n3. **Extreme Value Theory (GEV)**: To estimate a **100-year flood** (a flow expected to be exceeded once every 100 years on average), the script extracts the annual maximum flows and fits a Generalized Extreme Value (GEV) distribution. The 99th percentile of this fitted distribution yields the 100-year threshold.\n4. **Logarithmic Visualization**: Streamflow data is highly right-skewed. Plotting the Y-axis on a logarithmic scale ensures that both baseflow conditions and extreme flood peaks are clearly visible and analyzable on the same chart.", "solver_finish_reason": "stop"}
{"task": "flood-risk-analysis", "condition": "random_wrong", "repeat": 0, "skill_ids": ["benchflow-ai--lean4-theorem-proving"], "retrieval_correct": false, "judged_pass": false, "judged_score": 0, "judge_reason": "Agent's solution does not match the task requirements: it performs flood frequency analysis using Log-Pearson III instead of counting days exceeding NWS flood thresholds and does not process multiple Michigan stations from input file", "solver_tokens": 5635, "judge_tokens": 5432, "solution_text": "# USGS Streamflow Data Flood Threshold Analysis\n\nBelow is a complete Python solution that retrieves USGS streamflow data, performs flood frequency analysis using the Log-Pearson Type III distribution (the standard method per USGS Bulletin 17C), and computes flood thresholds for various return periods.\n\n## Prerequisites\n\n```bash\npip install dataretrieval numpy scipy pandas matplotlib\n```\n\n## Complete Solution\n\n```python\n\"\"\"\nUSGS Streamflow Flood Threshold Analysis\n=========================================\nRetrieves annual peak streamflow data from USGS NWIS,\nfits a Log-Pearson Type III distribution (per USGS Bulletin 17C),\nand computes flood thresholds for specified return periods.\n\"\"\"\n\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nfrom scipy import stats\nfrom dataretrieval import nwis\nimport warnings\nwarnings.filterwarnings('ignore')\n\n\n# ============================================================\n# CONFIGURATION\n# ============================================================\nSITE_ID = '01646500'          # Example: Potomac River at Little Falls, MD\nSTART_DATE = '1930-01-01'\nEND_DATE = '2024-12-31'\nRETURN_PERIODS = [2, 5, 10, 25, 50, 100, 200, 500]  # years\n\n\n# ============================================================\n# 1. DATA RETRIEVAL\n# ============================================================\ndef retrieve_peak_flow_data(site_id, start_date, end_date):\n    \"\"\"Retrieve annual peak streamflow data from USGS NWIS.\"\"\"\n    print(f\"Retrieving annual peak flow data for site {site_id}...\")\n    \n    # Get annual peak streamflow (parameter 00060 = discharge)\n    peaks_df, metadata = nwis.get_info(\n        site=site_id,\n        parameterCd='00060',\n        statCd='00003'  # annual peak\n    )\n    \n    # Alternative: use get_dv or direct peak retrieval\n    # Using the peak flow service\n    peak_df, _ = nwis.get_record(\n        sites=site_id,\n        service='peaks',\n        start=start_date,\n        end=end_date\n    )\n    \n    if peak_df.empty:\n        raise ValueError(f\"No peak flow data found for site {site_id}\")\n    \n    # Clean and prepare data\n    peak_df = peak_df.reset_index()\n    \n    # Standardize column names\n    date_col = [c for c in peak_df.columns if 'date' in c.lower()][0]\n    value_col = [c for c in peak_df.columns if 'peak_va' in c.lower() or '00060' in c][0]\n    \n    peak_df = peak_df.rename(columns={date_col: 'date', value_col: 'peak_cfs'})\n    peak_df['date'] = pd.to_datetime(peak_df['date'])\n    peak_df['year'] = peak_df['date'].dt.year\n    peak_df['peak_cfs'] = pd.to_numeric(peak_df['peak_cfs'], errors='coerce')\n    \n    # Remove missing values\n    peak_df = peak_df.dropna(subset=['peak_cfs'])\n    peak_df = peak_df[peak_df['peak_cfs'] > 0]\n    \n    # Keep only the maximum peak per year\n    annual_peaks = peak_df.groupby('year')['peak_cfs'].max().reset_index()\n    annual_peaks = annual_peaks.sort_values('year')\n    \n    print(f\"  Retrieved {len(annual_peaks)} years of annual peak flow data\")\n    print(f\"  Period: {annual_peaks['year'].min()} - {annual_peaks['year'].max()}\")\n    print(f\"  Range: {annual_peaks['peak_cfs'].min():.0f} - {annual_peaks['peak_cfs'].max():.0f} cfs\")\n    \n    return annual_peaks, metadata\n\n\n# ============================================================\n# 2. LOG-PEARSON TYPE III FREQUENCY ANALYSIS (Bulletin 17C)\n# ============================================================\ndef log_pearson_type_iii_analysis(annual_peaks):\n    \"\"\"\n    Perform Log-Pearson Type III flood frequency analysis.\n    Returns flood magnitude estimates for given return periods.\n    \"\"\"\n    peaks = annual_peaks['peak_cfs'].values\n    n = len(peaks)\n    \n    # Step 1: Transform to logarithms (base 10)\n    log_peaks = np.log10(peaks)\n    \n    # Step 2: Compute statistical parameters\n    mean_log = np.mean(log_peaks)\n    std_log = np.std(log_peaks, ddof=1)\n    \n    # Coefficient of skewness (moment-based)\n    skew = (n / ((n - 1) * (n - 2))) * np.sum(((log_peaks - mean_log) / std_log) ** 3)\n    \n    print(f\"\\n  Statistical Parameters (log10 scale):\")\n    print(f\"    Mean:     {mean_log:.4f}\")\n    print(f\"    Std Dev:  {std_log:.4f}\")\n    print(f\"    Skewness: {skew:.4f}\")\n    \n    # Step 3: Compute frequency factors K_T for each return period\n    # Using the Wilson-Hilferty approximation for the Pearson Type III distribution\n    results = []\n    \n    for T in RETURN_PERIODS:\n        # Non-exceedance probability\n        p = 1.0 - 1.0 / T\n        \n        # Standard normal variate (inverse CDF)\n        z = stats.norm.ppf(p)\n        \n        # Wilson-Hilferty approximation for K_T\n        # K_T = (2/g) * [(1 + g*z/6 - g^2/36)^3 - 1]  where g = skewness\n        g = skew\n        if abs(g) < 1e-10:\n            K_T = z  # Normal distribution if no skew\n        else:\n            term = 1.0 + (g * z / 6.0) - (g**2 / 36.0)\n            if term <= 0:\n                # Fallback: use scipy's pearson3\n                K_T = stats.pearson3.ppf(p, g)\n            else:\n                K_T = (2.0 / g) * (term**3 - 1.0)\n        \n        # Flood magnitude: log(Q) = mean + K_T * std\n        log_Q = mean_log + K_T * std_log\n        Q = 10.0 ** log_Q\n        \n        results.append({\n            'return_period': T,\n            'exceedance_prob': 1.0 / T,\n            'K_T': K_T,\n            'log_Q': log_Q,\n            'flood_cfs': Q\n        })\n        \n        print(f\"    T={T:>4d} yr: K_T={K_T:>7.3f}, Q={Q:>12,.0f} cfs\")\n    \n    results_df = pd.DataFrame(results)\n    \n    return results_df, mean_log, std_log, skew\n\n\n# ============================================================\n# 3. CONFIDENCE INTERVALS (Bootstrap)\n# ============================================================\ndef bootstrap_confidence_intervals(annual_peaks, n_bootstrap=1000, alpha=0.05):\n    \"\"\"Compute 95% confidence intervals via bootstrap resampling.\"\"\"\n    peaks = annual_peaks['peak_cfs'].values\n    n = len(peaks)\n    \n    bootstrap_results = {T: [] for T in RETURN_PERIODS}\n    \n    print(f\"\\n  Running {n_bootstrap} bootstrap iterations for confidence intervals...\")\n    \n    for _ in range(n_bootstrap):\n        # Resample with replacement\n        sample = np.random.choice(peaks, size=n, replace=True)\n        log_sample = np.log10(sample)\n        \n        mean_log = np.mean(log_sample)\n        std_log = np.std(log_sample, ddof=1)\n        skew = (n / ((n - 1) * (n - 2))) * np.sum(((log_sample - mean_log) / std_log) ** 3)\n        \n        for T in RETURN_PERIODS:\n            p = 1.0 - 1.0 / T\n            z = stats.norm.ppf(p)\n            g = skew\n            \n            if abs(g) < 1e-10:\n                K_T = z\n            else:\n                term = 1.0 + (g * z / 6.0) - (g**2 / 36.0)\n                if term <= 0:\n                    K_T = stats.pearson3.ppf(p, g)\n                else:\n                    K_T = (2.0 / g) * (term**3 - 1.0)\n            \n            log_Q = mean_log + K_T * std_log\n            Q = 10.0 ** log_Q\n            bootstrap_results[T].append(Q)\n    \n    # Compute confidence intervals\n    ci_results = []\n    for T in RETURN_PERIODS:\n        values = np.array(bootstrap_results[T])\n        lower = np.percentile(values, 100 * alpha / 2)\n        upper = np.percentile(values, 100 * (1 - alpha / 2))\n        median = np.median(values)\n        ci_results.append({\n            'return_period': T,\n            'lower_95': lower,\n            'median': median,\n            'upper_95': upper\n        })\n        print(f\"    T={T:>4d} yr: [{lower:>12,.0f} - {upper:>12,.0f}] cfs\")\n    \n    return pd.DataFrame(ci_results)\n\n\n# ============================================================\n# 4. GOODNESS OF FIT\n# ============================================================\ndef goodness_of_fit(annual_peaks, mean_log, std_log, skew):\n    \"\"\"Evaluate goodness of fit using probability plot correlation.\"\"\"\n    peaks = annual_peaks['peak_cfs'].values\n    n = len(peaks)\n    \n    # Sort peaks\n    sorted_peaks = np.sort(peaks)\n    log_sorted = np.log10(sorted_peaks)\n    \n    # Compute plotting positions (Weibull)\n    ranks = np.arange(1, n + 1)\n    exceedance_prob = ranks / (n + 1)\n    non_exceedance = 1.0 - exceedance_prob\n    \n    # Theoretical quantiles from fitted LP3\n    theoretical_log = []\n    for p in non_exceedance:\n        z = stats.norm.ppf(p)\n        g = skew\n        if abs(g) < 1e-10:\n            K_T = z\n        else:\n            term = 1.0 + (g * z / 6.0) - (g**2 / 36.0)\n            if term <= 0:\n                K_T = stats.pearson3.ppf(p, g)\n            else:\n                K_T = (2.0 / g) * (term**3 - 1.0)\n        theoretical_log.append(mean_log + K_T * std_log)\n    \n    theoretical_log = np.array(theoretical_log)\n    \n    # Correlation coefficient (PPCC)\n    ppcc = np.corrcoef(log_sorted, theoretical_log)[0, 1]\n    \n    print(f\"\\n  Goodness of Fit:\")\n    print(f\"    Probability Plot Correlation Coefficient (PPCC): {ppcc:.4f}\")\n    print(f\"    (Values > 0.95 indicate good fit)\")\n    \n    return ppcc, non_exceedance, log_sorted, theoretical_log\n\n\n# ============================================================\n# 5. VISUALIZATION\n# ============================================================\ndef plot_flood_frequency(annual_peaks, results_df, ci_df, site_id, metadata, ppcc):\n    \"\"\"Create comprehensive flood frequency analysis plot.\"\"\"\n    \n    fig, axes = plt.subplots(2, 2, figsize=(16, 12))\n    fig.suptitle(f'USGS Flood Frequency Analysis\\nSite {site_id}', \n                 fontsize=16, fontweight='bold')\n    \n    # --- Plot 1: Flood Frequency Curve ---\n    ax1 = axes[0, 0]\n    ax1.set_xscale('log')\n    ax1.set_yscale('log')\n    \n    # Plot historical data\n    sorted_peaks = np.sort(annual_peaks['peak_cfs'].values)\n    n = len(sorted_peaks)\n    exceedance = np.arange(1, n + 1) / (n + 1)\n    return_periods_data = 1.0 / exceedance\n    \n    ax1.scatter(return_periods_data, sorted_peaks, c='steelblue', \n                s=30, alpha=0.6, label='Historical Annual Peaks', zorder=3)\n    \n    # Plot fitted curve\n    T_fine = np.logspace(np.log10(1.1), np.log10(1000), 200)\n    ax1.plot(T_fine, results_df['flood_cfs'].values, 'r-', linewidth=2, \n             label='LP3 Fitted Curve', zorder=4)\n    \n    # Plot confidence intervals\n    ax1.fill_between(ci_df['return_period'], ci_df['lower_95'], ci_df['upper_95'],\n                     alpha=0.2, color='red', label='95% CI (Bootstrap)')\n    \n    # Plot specific return period points\n    ax1.scatter(results_df['return_period'], results_df['flood_cfs'], \n                c='red', s=80, marker='D', zorder=5, label='Return Period Estimates')\n    \n    ax1.set_xlabel('Return Period (years)', fontsize=11)\n    ax1.set_ylabel('Peak Discharge (cfs)', fontsize=11)\n    ax1.set_title('Flood Frequency Curve', fontsize=12)\n    ax1.legend(fontsize=9, loc='upper left')\n    ax1.grid(True, which='both', alpha=0.3)\n    ax1.set_xlim(1, 1000)\n    \n    # --- Plot 2: Time Series of Annual Peaks ---\n    ax2 = axes[0, 1]\n    ax2.bar(annual_peaks['year'], annual_peaks['peak_cfs'], \n            color='steelblue', alpha=0.7, width=0.8)\n    \n    # Add trend line\n    z = np.polyfit(annual_peaks['year'], annua