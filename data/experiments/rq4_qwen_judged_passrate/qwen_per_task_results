ents(img1)\n    It = img2 - img1  # Temporal derivative (approximation)\n\n    n_points = len(points)\n    new_points = points.copy()\n    status = np.ones(n_points, dtype=bool)\n\n    for idx in range(n_points):\n        x0, y0 = points[idx]\n        x, y = x0, y0\n        converged = False\n\n        for iteration in range(max_iter):\n            ix0, iy0 = int(round(x)), int(round(y))\n\n            # Check bounds\n            if (ix0 - half_w < 0 or ix0 + half_w >= img1.shape[1] or\n                iy0 - half_w < 0 or iy0 + half_w >= img1.shape[0]):\n                status[idx] = False\n                break\n\n            # Extract window\n            x_slice = slice(ix0 - half_w, ix0 + half_w + 1)\n            y_slice = slice(iy0 - half_w, iy0 + half_w + 1)\n\n            # Gradient matrices in window\n            Ix_win = Ix[y_slice, x_slice].flatten()\n            Iy_win = Iy[y_slice, x_slice].flatten()\n            It_win = It[y_slice, x_slice].flatten()\n\n            A = np.column_stack([Ix_win, Iy_win])\n            b = -It_win\n\n            # Solve normal equations: A^T A v = A^T b\n            ATA = A.T @ A\n            ATb = A.T @ b\n\n            det = ATA[0, 0] * ATA[1, 1] - ATA[0, 1] * ATA[1, 0]\n            if abs(det) < 1e-7:\n                status[idx] = False\n                break\n\n            # 2x2 inverse\n            inv_ATA = np.array([\n                [ATA[1, 1], -ATA[0, 1]],\n                [-ATA[1, 0], ATA[0, 0]]\n            ]) / det\n\n            v = inv_ATA @ ATb\n            dx, dy = v[0], v[1]\n\n            x += dx\n            y += dy\n\n            if dx * dx + dy * dy < tol * tol:\n                converged = True\n                break\n\n        new_points[idx] = [x, y]\n\n        # Validate: check if point is still in bounds and flow is reasonable\n        if status[idx]:\n            nx, ny = int(round(x)), int(round(y))\n            if (nx < 0 or nx >= img1.shape[1] or ny < 0 or ny >= img1.shape[0]):\n                status[idx] = False\n            # Check flow magnitude\n            flow_mag = norm([x - x0, y - y0])\n            if flow_mag > max(img1.shape) * 0.2:\n                status[idx] = False\n\n    return new_points, status\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 4. Camera Motion Estimation from Optical Flow\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef estimate_camera_motion(points1, points2, status, image_shape):\n    \"\"\"\n    Estimate camera motion (translation + rotation) from sparse optical flow.\n    \n    Uses a rigid motion model:\n        [x']   [cos(\u03b8)  -sin(\u03b8)] [x]   [tx]\n        [y'] = [sin(\u03b8)   cos(\u03b8)] [y] + [ty]\n    \n    For small angles: cos(\u03b8)\u22481, sin(\u03b8)\u2248\u03b8\n        dx = -\u03b8*y + tx\n        dy =  \u03b8*x + ty\n    \n    Args:\n        points1: (N, 2) original points\n        points2: (N, 2) tracked points\n        status: (N,) validity mask\n        image_shape: (H, W) for normalization\n    \n    Returns:\n        motion: dict with keys 'tx', 'ty', 'theta', 'scale', 'flow_vectors'\n    \"\"\"\n    valid = status.astype(bool)\n    if valid.sum() < 3:\n        return {\n            'tx': 0.0, 'ty': 0.0, 'theta': 0.0, 'scale': 1.0,\n            'flow_vectors': np.zeros((len(points1), 2)),\n            'inliers': 0\n        }\n\n    p1 = points1[valid]\n    p2 = points2[valid]\n    flow = p2 - p1  # (N, 2) displacement vectors\n\n    h, w = image_shape[:2]\n    cx, cy = w / 2.0, h / 2.0\n\n    # \u2500\u2500 Method 1: Affine model (6 DOF) \u2500\u2500\n    # [dx]   [a11  a12  a13] [x]\n    # [dy] = [a21  a22  a23] [y]\n    #                    [1]\n    N = len(p1)\n    A = np.zeros((2 * N, 6))\n    b = np.zeros(2 * N)\n\n    for i in range(N):\n        x, y = p1[i]\n        dx, dy = flow[i]\n        # dx = a11*x + a12*y + a13\n        A[2 * i, 0] = x\n        A[2 * i, 1] = y\n        A[2 * i, 2] = 1.0\n        b[2 * i] = dx\n        # dy = a21*x + a22*y + a23\n        A[2 * i + 1, 3] = x\n        A[2 * i + 1, 4] = y\n        A[2 * i + 1, 5] = 1.0\n        b[2 * i + 1] = dy\n\n    params, residuals, rank, sv = lstsq(A, b, rcond=None)\n    a11, a12, a13, a21, a22, a23 = params\n\n    # \u2500\u2500 Method 2: Rigid model (3 DOF: tx, ty, \u03b8) \u2500\u2500\n    # dx = -\u03b8*y + tx  (small angle approx)\n    # dy =  \u03b8*x + ty\n    A_rigid = np.zeros((2 * N, 3))\n    b_rigid = np.zeros(2 * N)\n\n    for i in range(N):\n        x, y = p1[i]\n        dx, dy = flow[i]\n        A_rigid[2 * i, 0] = 1.0      # tx\n        A_rigid[2 * i, 1] = 0.0      # ty\n        A_rigid[2 * i, 2] = -y       # theta\n        b_rigid[2 * i] = dx\n\n        A_rigid[2 * i + 1, 0] = 0.0  # tx\n        A_rigid[2 * i + 1, 1] = 1.0  # ty\n        A_rigid[2 * i + 1, 2] = x    # theta\n        b_rigid[2 * i + 1] = dy\n\n    params_rigid, _, _, _ = lstsq(A_rigid, b_rigid, rcond=None)\n    tx, ty, theta = params_rigid\n\n    # \u2500\u2500 Method 3: Similarity model (4 DOF: tx, ty, \u03b8, s) \u2500\u2500\n    # dx = (s-1)*x - \u03b8*y + tx\n    # dy = \u03b8*x + (s-1)*y + ty\n    A_sim = np.zeros((2 * N, 4))\n    b_sim = np.zeros(2 * N)\n\n    for i in range(N):\n        x, y = p1[i]\n        dx, dy = flow[i]\n        A_sim[2 * i, 0] = 1.0\n        A_sim[2 * i, 1] = 0.0\n        A_sim[2 * i, 2] = -y\n        A_sim[2 * i, 3] = x\n        b_sim[2 * i] = dx\n\n        A_sim[2 * i + 1, 0] = 0.0\n        A_sim[2 * i + 1, 1] = 1.0\n        A_sim[2 * i + 1, 2] = x\n        A_sim[2 * i + 1, 3] = y\n        b_sim[2 * i + 1] = dy\n\n    params_sim, _, _, _ = lstsq(A_sim, b_sim, rcond=None)\n    tx_s, ty_s, theta_s, s_minus_1 = params_sim\n    scale = 1.0 + s_minus_1\n\n    # \u2500\u2500 RANSAC-like inlier counting for rigid model \u2500\u2500\n    predicted_flow = np.zeros_like(flow)\n    for i in range(N):\n        x, y = p1[i]\n        predicted_flow[i, 0] = -theta * y + tx\n        predicted_flow[i, 1] = theta * x + ty\n\n    errors = norm(flow - predicted_flow, axis=1)\n    inlier_threshold = 2.0  # pixels\n    inliers = np.sum(errors < inlier_threshold)\n\n    # \u2500\u2500 Full flow vectors for all points \u2500\u2500\n    full_flow = np.zeros((len(points1), 2))\n    full_flow[valid] = flow\n\n    return {\n        'tx': tx,\n        'ty': ty,\n        'theta': theta,\n        'scale': scale,\n        'affine_params': params,\n        'flow_vectors': full_flow,\n        'inliers': int(inliers),\n        'total_valid': int(valid.sum()),\n        'mean_error': float(np.mean(errors)),\n        'median_error': float(np.median(errors)),\n    }\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 5. Full Pipeline\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef estimate_camera_motion_from_frames(frame1, frame2, sparse_mask=None,\n                                        k_harris=0.04, threshold=0.01,\n                                        max_corners=500, window_size=15):\n    \"\"\"\n    Complete pipeline: detect features \u2192 apply mask \u2192 track \u2192 estimate motion.\n    \n    Args:\n        frame1, frame2: Grayscale images as numpy arrays (H, W)\n        sparse_mask: Optional binary mask (H, W). If None, uses all features.\n        k_harris: Harris corner detector sensitivity\n        threshold: Harris corner threshold (fraction of max response)\n        max_corners: Maximum number of corners to detect\n        window_size: Lucas-Kanade window size\n    \n    Returns:\n        motion: dict with camera motion parameters\n        points1: detected feature locations in frame1\n        points2: tracked locations in frame2\n        status: tracking success mask\n    \"\"\"\n    # Step 1: Detect features in frame1\n    corners = harris_corners(frame1, k=k_harris, threshold=threshold,\n                             max_corners=max_corners)\n    print(f\"  Detected {len(corners)} Harris corners\")\n\n    # Step 2: Apply sparse mask\n    if sparse_mask is not None:\n        corners = apply_sparse_mask(corners, sparse_mask, frame1.shape)\n        print(f\"  After sparse mask: {len(corners)} points\")\n\n    if len(corners) < 3:\n        print(\"  WARNING: Too few points for motion estimation!\")\n        return None, corners, None, None\n\n    # Step 3: Track points using Lucas-Kanade\n    new_points, status = lucas_kanade_flow(frame1, frame2, corners,\n                                            window_size=window_size)\n    n_tracked = status.sum()\n    print(f\"  Successfully tracked: {n_tracked} / {len(corners)} points\")\n\n    # Step 4: Estimate camera motion\n    motion = estimate_camera_motion(corners, new_points, status, frame1.shape)\n\n    return motion, corners, new_points, status\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 6. Demo / Test with Synthetic Data\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2