ples):\n    \"\"\"Evaluate DBSCAN with given parameters.\"\"\"\n    dbscan = DBSCAN(eps=eps, min_samples=min_samples)\n    labels = dbscan.fit_predict(X)\n    \n    n_clusters = len(set(labels)) - (1 if -1 in labels else 0)\n    n_noise = list(labels).count(-1)\n    noise_ratio = n_noise / len(labels)\n    \n    # Metrics (only valid if we have 2+ clusters)\n    if n_clusters >= 2:\n        mask = labels != -1\n        if mask.sum() > n_clusters:\n            sil_score = silhouette_score(X[mask], labels[mask])\n            ch_score = calinski_harabasz_score(X[mask], labels[mask])\n            db_score = davies_bouldin_score(X[mask], labels[mask])\n        else:\n            sil_score = -1\n            ch_score = 0\n            db_score = float('inf')\n    else:\n        sil_score = -1\n        ch_score = 0\n        db_score = float('inf')\n    \n    return {\n        'eps': eps,\n        'min_samples': min_samples,\n        'n_clusters': n_clusters,\n        'n_noise': n_noise,\n        'noise_ratio': noise_ratio,\n        'silhouette': sil_score,\n        'calinski_harabasz': ch_score,\n        'davies_bouldin': db_score\n    }\n\ndef grid_search_dbscan(X, eps_range, min_samples_range):\n    \"\"\"Perform grid search over DBSCAN parameters.\"\"\"\n    results = []\n    for eps, min_samples in product(eps_range, min_samples_range):\n        result = evaluate_dbscan(X, eps, min_samples)\n        results.append(result)\n    return pd.DataFrame(results)\n\ndef find_pareto_frontier(df, objectives):\n    \"\"\"\n    Find Pareto frontier for multi-objective optimization.\n    objectives: list of tuples (column_name, 'max' or 'min')\n    \"\"\"\n    is_pareto = np.ones(len(df), dtype=bool)\n    \n    for i in range(len(df)):\n        if not is_pareto[i]:\n            continue\n        \n        for j in range(len(df)):\n            if i == j or not is_pareto[j]:\n                continue\n            \n            dominated = True\n            for col, direction in objectives:\n                if direction == 'max':\n                    if df.iloc[j][col] > df.iloc[i][col]:\n                        dominated = False\n                        break\n                else:  # min\n                    if df.iloc[j][col] < df.iloc[i][col]:\n                        dominated = False\n                        break\n            \n            if dominated:\n                is_pareto[j] = False\n    \n    return df[is_pareto].copy()\n\ndef select_best_pareto_solution(pareto_df, weights=None):\n    \"\"\"Select best solution from Pareto frontier using weighted scoring.\"\"\"\n    if weights is None:\n        weights = {'silhouette': 0.4, 'n_clusters': 0.3, 'noise_ratio': 0.3}\n    \n    # Normalize objectives\n    pareto_df = pareto_df.copy()\n    \n    # For n_clusters, prefer reasonable number (2-10)\n    pareto_df['cluster_score'] = 1 - np.abs(pareto_df['n_clusters'] - 5) / 10\n    pareto_df['cluster_score'] = pareto_df['cluster_score'].clip(0, 1)\n    \n    # Normalize silhouette (already in [-1, 1])\n    pareto_df['sil_norm'] = (pareto_df['silhouette'] + 1) / 2\n    \n    # Noise ratio (lower is better)\n    pareto_df['noise_norm'] = 1 - pareto_df['noise_ratio']\n    \n    # Combined score\n    pareto_df['score'] = (\n        weights['silhouette'] * pareto_df['sil_norm'] +\n        weights['n_clusters'] * pareto_df['cluster_score'] +\n        weights['noise_ratio'] * pareto_df['noise_norm']\n    )\n    \n    return pareto_df.loc[pareto_df['score'].idxmax()]\n\ndef plot_results(X, best_params, pareto_df, all_results):\n    \"\"\"Plot clustering results and Pareto frontier.\"\"\"\n    fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n    \n    # Plot 1: Clustering result\n    dbscan = DBSCAN(eps=best_params['eps'], min_samples=best_params['min_samples'])\n    labels = dbscan.fit_predict(X)\n    \n    scatter = axes[0].scatter(X[:, 0], X[:, 1], c=labels, cmap='viridis', alpha=0.6)\n    axes[0].set_title(f\"DBSCAN: eps={best_params['eps']:.3f}, 