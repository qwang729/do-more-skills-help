   def __init__(self, \n                 eps_range: Tuple[float, float] = (0.1, 2.0),\n                 min_samples_range: Tuple[int, int] = (3, 15),\n                 n_samples: int = 50,\n                 metric: str = 'euclidean',\n                 custom_metric: Callable = None,\n                 random_state: int = 42):\n        self.eps_range = eps_range\n        self.min_samples_range = min_samples_range\n        self.n_samples = n_samples\n        self.metric = metric\n        self.custom_metric = custom_metric\n        self.random_state = random_state\n        self.results_ = None\n        self.pareto_frontier_ = None\n        self.best_params_ = None\n        \n    def fit(self, X: np.ndarray) -> 'DBSCANParetoOptimizer':\n        \"\"\"Run DBSCAN with various hyperparameters and compute Pareto frontier.\"\"\"\n        np.random.seed(self.random_state)\n        \n        # Generate hyperparameter grid\n        eps_values = np.linspace(self.eps_range[0], self.eps_range[1], \n                                  int(np.sqrt(self.n_samples)))\n        min_samples_values = np.arange(self.min_samples_range[0], \n                                        self.min_samples_range[1] + 1)\n        \n        results = []\n        \n        for eps in eps_values:\n            for min_samples in min_samples_values:\n                # Prepare metric\n                if self.custom_metric is not None:\n                    metric = self.custom_metric\n                else:\n                    metric = self.metric\n                \n                # Fit DBSCAN\n                dbscan = DBSCAN(eps=eps, min_samples=min_samples, metric=metric)\n                labels = dbscan.fit_predict(X)\n                \n                # Compute metrics\n                n_clusters = len(set(labels)) - (1 if -1 in labels else 0)\n                n_noise = np.sum(labels == -1)\n                noise_ratio = n_noise / len(labels)\n                \n                # Quality metrics (only valid