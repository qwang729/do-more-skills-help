0), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 255, 0), 2)\n        \n        return frame\n\n\ndef main():\n    # Initialize tracker\n    tracker = PedestrianTracker()\n    \n    # Open video source (0 for webcam, or path to video file)\n    video_source = 0  # Change to 'pedestrians.mp4' for video file\n    cap = cv2.VideoCapture(video_source)\n    \n    if not cap.isOpened():\n        print(\"Error: Cannot open video source\")\n        return\n    \n    # Get video properties for output\n    width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n    height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n    fps = int(cap.get(cv2.CAP_PROP_FPS))\n    \n    # Initialize video writer\n    fourcc = cv2.VideoWriter_fourcc(*'mp4v')\n    out = cv2.VideoWriter('output_pedestrians.mp4', fourcc, fps, (width, height))\n    \n    print(\"Press 'q' to quit\")\n    \n    while True:\n        ret, frame = cap.read()\n        if not ret:\n            break\n        \n        # Process frame\n        processed_frame = tracker.process_frame(frame)\n        \n        # Write to output\n        out.write(processed_frame)\n        \n        # Display\n        cv2.imshow('Pedestrian Detection & Tracking', processed_frame)\n        \n        if cv2.waitKey(1) & 0xFF == ord('q'):\n            break\n    \n    # Cleanup\n    cap.release()\n    out.release()\n    cv2.destroyAllWindows()\n    print(\"Output saved to output_pedestrians.mp4\")\n\n\nif __name__ == \"__main__\":\n    main()\n```\n\n## Usage Instructions\n\n1. **Save the script** as `pedestrian_detection.py`\n\n2. **Run with webcam**:\n   ```bash\n   python pedestrian_detection.py\n   ```\n\n3. **Run with video file** - change line 97:\n   ```python\n   video_source = 'your_video.mp4'\n   ```\n\n4. **Press 'q' to quit** the application\n\n## Features\n\n| Feature | Description |\n|---------|-------------|\n| **Detection** | HOG + SVM pedestrian detector |\n| **Tracking** | IoU-based track association with unique IDs |\n| **Output** | Annotated vide