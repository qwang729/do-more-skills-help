ategy;\nimport org.apache.flink.api.common.functions.MapFunction;\nimport org.apache.flink.api.common.serialization.SimpleStringSchema;\nimport org.apache.flink.connector.kafka.source.KafkaSource;\nimport org.apache.flink.connector.kafka.source.enumerator.initializer.OffsetsInitializer;\nimport org.apache.flink.streaming.api.datastream.DataStream;\nimport org.apache.flink.streaming.api.environment.StreamExecutionEnvironment;\nimport org.apache.flink.streaming.api.functions.windowing.ProcessWindowFunction;\nimport org.apache.flink.streaming.api.window.assigners.EventTimeSessionWindows;\nimport org.apache.flink.streaming.api.window.time.Time;\nimport org.apache.flink.streaming.api.window.windows.TimeWindow;\nimport org.apache.flink.util.Collector;\n\nimport java.time.Duration;\n\npublic class SessionWindowJob {\n\n    public static void main(String[] args) throws Exception {\n        // 1. Set up the streaming execution environment\n        final StreamExecutionEnvironment env = StreamExecutionEnvironment.getExecutionEnvironment();\n        \n        // Enable checkpointing (Required for fault tolerance and state backend)\n        env.enableCheckpointing(60000); \n\n        // 2. Define the Kafka Source\n        KafkaSource<String> source = KafkaSource.<String>builder()\n                .setBootstrapServers(\"localhost:9092\")\n                .setTopics(\"user-events\")\n                .setGroupId(\"session-window-consumer-group\")\n                .setStartingOffsets(OffsetsInitializer.earliest())\n                .setValueOnlyDeserializer(new SimpleStringSchema())\n                .build();\n\n        DataStream<String> rawStream = env.fromSource(\n                source, \n                WatermarkStrategy.noWatermarks(), \n                \"Kafka Source\"\n        );\n\n        // 3. Parse JSON/CSV and assign Timestamps & Watermarks\n        // Watermarks are CRITICAL for session windows to know when the \"gap\" has passed\n        DataStream<UserEvent> eventStream = rawStream\n                .map(new EventParser())\n                .assignTimestampsAndWatermarks(\n                        WatermarkStrategy.<UserEvent>forBoundedOutOfOrderness(Duration.ofSeconds(5))\n                                .withTimestampAssigner((event, timestamp) -> event.getTimestamp())\n                );\n\n        // 4. Key by userId and apply the Session Window\n        DataStream<SessionResult> sessionStream = eventStream\n                .keyBy(UserEvent::getUserId)\n                .window(EventTimeSessionWindows.withGap(Time.minutes(10))) // 10 min inactivity gap\n                .process(new SessionWindowProcessor());\n\n        // 5. Sink the results (Printing to stdout for demonstration)\n        sessionStream.print(\"SessionOutput\");\n\n        // 6. Execute the job\n        env.execute(\"Flink User Session Window Job\");\n    }\n\n    // ==========================================\n    // Data Models\n    // ==========================================\n\n    public static class UserEvent {\n        private String userId;\n        private String eventType;\n        private long timestamp;\n\n        public UserEvent() {}\n\n        public UserEvent(String userId, String eventType, long timestamp) {\n            this.userId = userId;\n            this.eventType = eventType;\n            this.timestamp = timestamp;\n        }\n\n        public String getUserId() { return userId; }\n        public void setUserId(String userId) { this.userId = userId; }\n        public String getEventType() { return eventType; }\n        public void setEventType(String eventType) { this.eventType = eventType; }\n        public long getTimestamp() { return timestamp; }\n        public void setTimestamp(long timestamp) { this.timestamp = timestamp; }\n    }\n\n    public static class SessionResult {\n        private String userId;\n        private long windowStart;\n        private long windowEnd;\n        private int eventCount;\n        private String eventTypes;\n\n        public SessionResult(String userId, long windowStart, long windowEnd, int eventCount, String eventTypes) {\n            this.userId = userId;\n            this.windowStart = windowStart;\n            this.windowEnd = windowEnd;\n            this.eventCount = eventCount;\n            this.eventTypes = eventTypes;\n        }\n\n        @Override\n        public String toString() {\n            return String.format(\"User: %s | Session: [%d - %d] | Events: %d | Types: %s\",\n                    userId, windowStart, windowEnd, eventCount, eventTypes);\n        }\n    }\n\n    // ==========================================\n    // Flink Functions\n    // ==========================================\n\n    /**\n     * Parses raw string into UserEvent POJO.\n     * Expected format: \"userId,eventType,timestamp\"\n     */\n    public static class EventParser implements MapFunction<String, UserEvent> {\n        @Override\n        public UserEvent map(String value) throws Exception {\n            String[] parts = value.split(\",\");\n            if (parts.length != 3) {\n                throw new IllegalArgumentException(\"Invalid event format: \" + value);\n            }\n            return new UserEvent(parts[0].trim(), parts[1].trim(), Long.parseLong(parts[2].trim()));\n        }\n    }\n\n    /**\n     * Processes the session window once it closes (after the 10-minute gap).\n     */\n    public static class SessionWindowProcessor extends ProcessWindowFunction<UserEvent, SessionResult, String, TimeWindow> {\n        \n        @Override\n        public void process(String userId, Context context, Iterable<UserEvent> elements, Collector<SessionResult> out) throws Exception {\n            int count = 0;\n            StringBuilder eventTypes = new StringBuilder();\n            \n            for (UserEvent event : elements) {\n                count++;\n                if (eventTypes.length() > 0) {\n                    eventTypes.append(\" -> \");\n                }\n                eventTypes.append(event.getEventType());\n            }\n\n            out.collect(new SessionResult(\n                    userId,\n                    context.window().getStart(),\n                    context.window().getEnd(),\n                    count,\n                    eventTypes.toString()\n            ));\n        }\n    }\n}\n```\n\n### 3. Key Engineering Concepts Applied\n\n1. **Event Time vs Processing Time**: We use `EventTimeSessionWindows`. This ensures that even if events arrive late or out-of-order from Kafka, they are grouped into the correct session based on when the user *actually* performed the action.\n2. **Watermark Strategy**: `forBoundedOutOfOrderness(Duration.ofSeconds(5))` tells Flink to expect events up to 5 seconds late. The watermark advancing is the exact trigger mechanism Flink uses to realize the 10-minute gap has passed and the session window should close.\n3. **State Management**: Session windows are stateful. Flink maintains the state of active sessions in the configured State Backend (e.g., RocksDB). Checkpointing is enabled to guarantee no session data is lost during failures.\n4. **Merging Windows**: Unlike tumbling or sliding windows, session windows can merge. If a late event arrives that bridges the gap between two existing sessions for the same user, Flink will automatically merge them into a single, larger session window.\n\n### 4. How to Test Locally\n\n1. Start a local Kafka broker and create the topic:\n   ```bash\n   kafka-topics.sh --create --topic user-events --bootstrap-server localhost:9092 --partitions 1 --replication-factor 1\n   ```\n2. Start a console producer to feed mock data:\n   ```bash\n   kafka-console-producer.sh --topic user-events --bootstrap-server localhost:9092\n   ```\n3. Paste the following mock data (Format: `userId,eventType,epoch_millis`):\n   ```text\n   user1,page_view,1690000000000\n   user1,click,1690000060000\n   user2,page_view,1690000000000\n   user1,logout,1690000120000\n   ```\n   *(Note: To see the window trigger immediately in testing, you can temporarily change the gap to `Time.seconds(5)` and use current epoch timestamps).*", "solver_finish_reason": "stop"}
