.items():\n            matches = re.finditer(pattern, page_text, re.IGNORECASE)\n            for match in matches:\n                # Find the exact bounding boxes of the text to redact\n                text_instances = page.search_for(match.group(0))\n                for inst in text_instances:\n                    # Add redaction annotation with black fill\n                    page.add_redact_annot(inst, fill=(0, 0, 0)) \n            \n            # Track redaction statistics\n            count = len(re.findall(pattern, page_text, re.IGNORECASE))\n            if count > 0:\n                redaction_stats.append({\n                    'Page': page_num + 1,\n                    'Pattern': pattern_name,\n                    'Matches': count\n                })\n        \n        # Apply the redactions permanently to the page\n        page.apply_redactions()\n        \n    # Save the anonymized PDF\n    doc.save(output_pdf_path)\n    doc.close()\n    \n    return pd.DataFrame(redaction_stats)\n\ndef extract_and_analyze_pdf(pdf_path):\n    \"\"\"\n    Parses and extracts text/metadata from a PDF, then calculates basic statistics.\n    \"\"\"\n    text_content = []\n    metadata = {}\n    num_pages = 0\n    \n    with pdfplumber.open(pdf_path) as pdf:\n        metadata = pdf.metadata\n        num_pages = len(pdf.pages)\n        for i, page in enumerate(pdf.pages):\n            text = page.extract_text() or \"\"\n            text_content.append({\n                'Page': i + 1,\n                'Text': text,\n                'Word_Count': len(text.split()),\n                'Char_Count': len(text)\n            })\n            \n    df_text = pd.DataFrame(text_content)\n    \n    # Calculate aggregate statistics\n    total_words = df_text['Word_Count'].sum()\n    total_chars = df_text['Char_Count'].sum()\n    avg_words_per_page = df_text['Word_Count'].mean() if not df_text.empty else 0\n    \n    analysis_data = {\n        'Metric': ['Total Pages', 'Total Words', 'Total Characters', 'Avg Words per Page', 'Title', 'Author', 'Subject'],\n        'Value': [\n            num_pages, \n            total_words, \n            total_chars, \n            avg_words_per_page,\n            metadata.get('Title', 'N/A'),\n            metadata.get('Author', 'N/A'),\n            metadata.get('Subject', 'N/A')\n        ]\n    }\n    df_analysis = pd.DataFrame(analysis_data)\n    \n    return df_text, df_analysis\n\ndef main():\n    # File paths\n    input_pdf = \"academic_paper.pdf\"\n    redacted_pdf = \"anonymous_paper.pdf\"\n    output_excel = \"pdf_analysis_report.xlsx\"\n    \n    # Ensure a dummy input file exists for demonstration if needed\n    if not os.path.exists(input_pdf):\n        print(f\"Please place your target PDF at '{input_pdf}' and run the script again.\")\n        return\n\n    # 1. Define redaction patterns for blind review anonymization\n    redaction_patterns = {\n        'Author_Names': r'\\b[A-Z][a-z]+\\s+[A-Z][a-z]+\\b', # Simplified regex for First Last names\n        'Affiliations': r'University of \\w+|Department of \\w+|Institute of \\w+',\n        'Acknowledgments': r'Acknowledgments.*?(?=\\n\\n|\\Z)',\n        'Self_Citations': r'\\[self-citation\\]|\\(Author, \\d{4}\\)|\\(we, \\d{4}\\)'\n    }\n    \n    print(\"Extracting and analyzing original PDF...\")\n    df_text, df_analysis = extract_and_analyze_pdf(input_pdf)\n    \n    print(\"Redacting PDF for blind review anonymization...\")\n    df_redaction_stats = redact_pdf_for_blind_review(input_pdf, redacted_pdf, redaction_patterns)\n    \n    # Summarize redaction stats by category\n    if not df_redaction_stats.empty:\n        df_redaction_summary = df_redaction_stats.groupby('Pattern')['Matches'].sum().reset_index()\n        df_redaction_summary.columns = ['Redaction_Category', 'Total_Redactions']\n    else:\n        df_redaction_summary = pd.DataFrame({'Redaction_Category': ['None'], 'Total_Redactions': [0]})\n        \n    # 2. Export Analysis to Excel with mu