history[i-1] and T_history[i] > T_history[i+1]:\n            peaks.append((i, T_history[i]))\n    \n    # Need at least 3 peaks to analyze\n    if len(peaks) < 3:\n        continue\n    \n    # Get last 3 peaks\n    _, T1 = peaks[-3]\n    _, T2 = peaks[-2]\n    _, T3 = peaks[-1]\n    \n    # Calculate amplitude (distance from setpoint) at peaks\n    A1 = abs(T1 - setpoint)\n    A2 = abs(T2 - setpoint)\n    A3 = abs(T3 - setpoint)\n    \n    # Check for constant amplitude and period\n    if (abs(A1 - A2) <= 0.5 and abs(A2 - A3) <= 0.5 and \n        len(peaks) >= 3 and \n        abs(peaks[-2][0] - peaks[-3][0]) > 0 and \n        abs(peaks[-1][0] - peaks[-2][0]) > 0):\n        \n        # Calculate periods (in time steps) between consecutive peaks\n        period1 = (peaks[-2][0] - peaks[-3][0]) * time_step\n        period2 = (peaks[-1][0] - peaks[-2][0]) * time_step\n        \n        # Check period consistency\n        if abs(period1 - period2) / period1 < 0.05:\n            Kc = Kp\n            Pc = (period1 + period2) / 2.0\n            break\n\n# If critical gain found, compute PID parameters\nif Kc > 0 and Pc > 0:\n    Kp = 0.6 * Kc\n    Ki = 1.2 * Kc / Pc\n    Kd = 0.075 * Kc * Pc\n    print(f\"Tuned PID parameters: Kp={Kp:.4f}, Ki={Ki:.4f}, Kd={Kd:.4f}\")\nelse:\n    print(\"Tuning failed: Critical oscillation not found. Increase max_Kp or check system model.\")\n```", "solver_finish_reason": "stop"}
