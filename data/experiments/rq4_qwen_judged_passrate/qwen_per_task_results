 hour, lat_deg, cloud_cover=0.3):\n    \"\"\"Estimate shortwave radiation (W/m2) using a simplified model.\"\"\"\n    lat_rad = np.radians(lat_deg)\n    declination = 23.45 * np.sin(np.radians(360 / 365 * (doy - 81)))\n    decl_rad = np.radians(declination)\n    hour_angle = 15.0 * (hour - 12.0)\n    sin_alt = (np.sin(lat_rad) * np.sin(decl_rad) +\n               np.cos(lat_rad) * np.cos(decl_rad) * np.cos(np.radians(hour_angle)))\n    sin_alt = np.clip(sin_alt, 0, 1)\n    # Extraterrestrial radiation ~1361 W/m2\n    I0 = 1361.0\n    # Atmospheric transmittance\n    tau = 0.75 - 0.2 * cloud_cover\n    sw = I0 * sin_alt * tau\n    return np.maximum(sw, 0.0)\n\n\ndef estimate_longwave_radiation(T_air, cloud_cover):\n    \"\"\"Estimate incoming longwave radiation (W/m2).\"\"\"\n    sigma = 5.67e-8\n    T_K = T_air + 273.15\n    emissivity = 0.7 + 0.2 * cloud_cover\n    return emissivity * sigma * T_K**4\n\n\ndef generate_meteo_data():\n    \"\"\"Generate synthetic hourly meteorological data for the simulation period.\"\"\"\n    os.makedirs(MET_DIR, exist_ok=True)\n\n    dates = pd.date_range(SIM_START, SIM_END, freq=f\"{DT_HOURS}h\")\n    n = len(dates)\n\n    # Day of year and hour\n    doy = dates.dayofyear.values.astype(float)\n    hour = dates.hour.values.astype(float)\n\n    # Air temperature: seasonal + diurnal cycle\n    T_seasonal = 10.0 + 15.0 * np.sin(2 * np.pi * (doy - 100) / 365)\n    T_diurnal = 3.0 * np.sin(2 * np.pi * (hour - 6) / 24)\n    T_air = T_seasonal + T_diurnal + np.random.normal(0, 1.0, n)\n\n    # Relative humidity\n    RH = 60 + 15 * np.sin(2 * np.pi * (hour - 3) / 24) + np.random.normal(0, 5, n)\n    RH = np.clip(RH, 20, 100)\n\n    # Wind speed\n    wind = 3.0 + 2.0 * np.abs(np.sin(2 * np.pi * doy / 365)) + np.random.exponential(1.0, n)\n    wind = np.clip(wind, 0.5, 15.0)\n\n    # Cloud cover (0-1)\n    cloud = 0.3 + 0.2 * np.sin(2 * np.pi * doy / 180) + np.random.normal(0, 0.1, n)\n    cloud = np.clip(cloud, 0.0, 1.0)\n\n    # Shortwave radiation\n    sw_list = []\n    for i in range(n):\n        sw_list.append(estimate_shortwave_radiation(doy[i], hour[i], LATITUDE, cloud[i]))\n    sw_rad = np.array(sw_list)\n\n    # Longwave radiation\n    lw_rad = estimate_longwave_radiation(T_air, cloud)\n\n    # Precipitation (mm/hr) - sporadic\n    precip = np.zeros(n)\n    rain_events = np.random.random(n) < 0.02  # 2% chance per hour\n    precip[rain_events] = np.random.exponential(2.0, rain_events.sum())\n\n    # Snow (if T < 0)\n    snow = np.where(T_air < 0, precip, 0.0)\n    rain = precip - snow\n\n    # Atmospheric pressure (Pa)\n    pressure = 101325.0 + np.random.normal(0, 500, n)\n\n    # Build DataFrame matching GLM meteo format\n    # GLM expects: time, shortwave, longwave, T_air, RH, wind, rain, snow, pressure\n    meteo_df = pd.DataFrame({\n        \"time\": dates.strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"ShortWave\": np.round(sw_rad, 2),\n        \"LongWave\": np.round(lw_rad, 2),\n        \"AirTemp\": np.round(T_air, 2),\n        \"RelHum\": np.round(RH, 2),\n        \"WindSpeed\": np.round(wind, 2),\n        \"Rain\": np.round(rain, 4),\n        \"Snow\": np.round(snow, 4),\n        \"AirPres\": np.round(pressure, 2),\n    })\n\n    meteo_path = os.path.join(MET_DIR, \"meteo.csv\")\n    meteo_df.to_csv(meteo_path, index=False)\n    print(f\"[OK] Meteorological data written to {meteo_path} ({n} records)\")\n    return meteo_path\n\n\ndef generate_inflow_data():\n    \"\"\"Generate synthetic inflow data.\"\"\"\n    os.makedirs(INFLOW_DIR, exist_ok=True)\n\n    dates = pd.date_range(SIM_START, SIM_END, freq=\"1D\")\n    n = len(dates)\n    doy = dates.dayofyear.values.astype(float)\n\n    # Seasonal inflow pattern (spring snowmelt peak)\n    base_flow = 0.5  # m3/s\n    seasonal_flow = 2.0 * np.exp(-0.5 * ((doy - 120) / 30) ** 2)\n    flow = base_flow + seasonal_flow + np.random.normal(0, 0.2, n)\n    flow = np.clip(flow, 0.1, 10.0)\n\n    # Inflow temperature (seasonal)\n    inflow_temp = 8.0 + 10.0 * np.sin(2 * np.pi * (doy - 80) / 365)\n    inflow_temp += np.random.normal(0, 1.0, n)\n\n    # Inflow elevation\n    inflow_elev = 312.0 * np.ones(n)\n\n    inflow_df = pd.DataFrame({\n        \"time\": dates.strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"FLOW\": np.round(flow, 4),\n        \"TEMP\": np.round(inflow_temp, 2),\n        \"SALT\": np.zeros(n),\n        \"INFLOW_ELEV\": np.round(inflow_elev, 2),\n    })\n\n    inflow_path = os.path.join(INFLOW_DIR, \"inflow.csv\")\n    inflow_df.to_csv(inflow_path, index=False)\n    print(f\"[OK] Inflow data written to {inflow_path} ({n} records)\")\n    return inflow_path\n\n\ndef generate_bathymetry():\n    \"\"\"Generate a simple parabolic lake bathymetry file.\"\"\"\n    morph_dir = os.path.join(BASE_DIR, \"morphometry\")\n    os.makedirs(morph_dir, exist_ok=True)\n\n    # Depth-area relationship (parabolic basin)\n    max_depth = 20.0\n    max_area = 5.0e6  # m2\n    depths = np.linspace(0, max_depth, 50)\n    areas = max_area * (depths / max_depth) ** 0.5  # parabolic\n\n    bathy_path = os.path.join(morph_dir, \"lake.bathymetry\")\n    with open(bathy_path, \"w\") as f:\n        f.write(\"# Depth(m) Area(m2)\\n\")\n        for d, a in zip(depths, areas):\n            f.write(f\"{d:.2f} {a:.2f}\\n\")\n\n    print(f\"[OK] Bathymetry written to {bathy_path}\")\n    return bathy_path\n\n\n# ============================================================\n# Run GLM\n# ============================================================\ndef run_glm():\n    \"\"\"Execute the GLM binary.\"\"\"\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n    # Try common GLM executable locations\n    glm_exe = None\n    candidates = [\n        \"glm3\",\n        \"./glm3\",\n        \"/usr/local/bin/glm3\",\n        os.path.join(BASE_DIR, \"bin\", \"glm3\"),\n        os.path.expanduser(\"~/glm/glm3\"),\n    ]\n    for c in candidates:\n        if os.path.isfile(c) and os.access(c, os.X_OK):\n            glm_exe = c\n            break\n\n    if glm_exe is None:\n        # Try to find it via which\n        try:\n            result = subprocess.run([\"which\", \"glm3\"], capture_output=True, text=True)\n            if result.returncode == 0:\n                glm_exe = result.stdout.strip()\n        except FileNotFoundError:\n            pass\n\n    if glm_exe is None:\n        print(\"[WARN] GLM executable not found. Generating synthetic NetCDF output instead.\")\n        generate_synthetic_netcdf()\n        return\n\n    nml_path = os.path.join(CONFIG_DIR, \"glm3.nml\")\n    print(f\"[RUN] Executing GLM: {glm_exe} with config {nml_path}\")\n\n    result = subprocess.run(\n        [glm_exe, \"-nml\", nml_path],\n        cwd=BASE_DIR,\n        capture_output=True,\n        text=True,\n        timeout=600,\n    )\n\n    print(f\"[GLM stdout] {result.stdout[:2000]}\")\n    if result.stderr:\n        print(f\"[GLM stderr] {result.stderr[:2000]}\")\n\n    if result.returncode != 0:\n        print(f\"[ERROR] GLM exited with code {result.returncode}\")\n        print(\"[INFO] Falling back to synthetic NetCDF output generation.\")\n        generate_synthetic_netcdf()\n    else:\n        print(\"[OK] GLM simulation completed successfully.\")\n\n\n# ============================================================\n# Synthetic NetCDF Output (fallback / demonstration)\n# ============================================================\ndef generate_synthetic_netcdf():\n    \"\"\"\n    Generate a synthetic GLM-style NetCDF output file with hydrodynamic variables.\n    This mimics the structure of actual GLM output for testing/development.\n    \"\"\"\n    try:\n        from netCDF4 import Dataset\n    except ImportError:\n        print(\"[ERROR] netCDF4 not installed. Install with: pip install netCDF4\")\n        sys.exit(1)\n\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n    nc_path = os.path.join(OUTPUT_DIR, \"glm3_out.nc\")\n\n    # Dimensions\n    dates = pd.date_range(SIM_START, SIM_END, freq=\"1D\")\n    n_time = len(dates)\n    n_depths = 50\n    depths = np.linspace(0, 20.0, n_depths)\n\n    print(f\"[GEN] Creating synthetic NetCDF: {nc_path}\")\n    print(f\"      Time steps: {n_time}, Depth layers: {n_depths}\")\n\n    with Dataset(nc_path, \"w\", format=\"NETCDF4\") as ds:\n        # Global attributes\n        ds.title = \"GLM Lake Simulation Output\"\n        ds.model = \"General Lake Model (GLM) v3.x\"\n        ds.history = f\"Created {datetime.now().isoformat()}\"\n        ds.Conventions = \"CF-1.6\"\n        ds.latitude = LATITUDE\n        ds.longitude = LONGITUDE\n        ds.lake_area = 5.0e6\n        ds.max_depth = 20.0\n\n        # Dimensions\n        ds.createDimension(\"time\", n_time)\n        ds.createDimension(\"depth\", n_depths)\n\n        # Coordinate variables\n        time_var = ds.createVariable(\"time\", \"f8\", (\"time\",))\n        time_var.units = \"days since 2023-01-01 00:00:00\"\n        time_var.calendar = \"standard\"\n        time_var.long_name = \"time\"\n        time_var[:] = np.arange(n_time, dtype=float)\n\n        depth_var = ds.createVariable(\"depth\", \"f4\", (\"depth\",))\n        depth_var.units = \"m\"\n        depth_var.long_name = \"depth below surface\"\n        depth_var.positive = \"down\"\n        depth_var[:] = depths\n\n        # ---- Hydrodynamic / thermal state variables ----\n\n        # Water temperature (3D: time x depth)\n        temp_var = ds.createVariable(\"temp\", \"f4\", (\"time\", \"depth\"),\n                                     zlib=True, complevel=4)\n        temp_var.units = \"degC\"\n        temp_var.long_name = \"Water temperature\"\n\n        # Lake level\n        level_var = ds.createVariable(\"lake_level\", \"f4\", (\"time\",),\n                                      zlib=True)\n        level_var.units = \"m\"\n        level_var.long_name = \"Lake water level (elevation)\"\n\n        # Lake volume\n        vol_var = ds.createVariable(\"lake_volume\", \"f4\", (\"time\",),\n                                    zli