  }\n        .node text {\n            pointer-events: none;\n            font-size: 11px;\n            text-anchor: middle;\n            fill: #ffffff;\n            font-weight: 600;\n            text-shadow: 0px 1px 2px rgba(0,0,0,0.5);\n        }\n        .tooltip {\n            position: absolute;\n            padding: 8px 12px;\n            background: rgba(0, 0, 0, 0.8);\n            color: #fff;\n            border-radius: 4px;\n            pointer-events: none;\n            font-size: 13px;\n            opacity: 0;\n            transition: opacity 0.2s;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"chart\"></div>\n    <div class=\"tooltip\" id=\"tooltip\"></div>\n\n    <script>\n        // ==========================================\n        // 1. CSV DATA PROCESSING\n        // ==========================================\n        \n        // Inline CSV string for demonstration. \n        // To use an external file, replace the parsing logic below with:\n        // d3.csv(\"your_data.csv\").then(function(data) { initChart(data); });\n        \n        const csvString = `name,category,value\nApple,Fruit,50\nBanana,Fruit,30\nCarrot,Vegetable,40\nBroccoli,Vegetable,60\nChicken,Meat,80\nBeef,Meat,100\nPork,Meat,70\nSpinach,Vegetable,20\nOrange,Fruit,45\nGrapes,Fruit,25`;\n\n        // Parse the CSV string into an array of objects\n        const rawData = d3.csvParse(csvString);\n\n        // Process and cast data types (D3 parses everything as strings by default)\n        const data = rawData.map(d => {\n            return {\n                name: d.name,\n                category: d.category,\n                value: +d.value // Cast to number\n            };\n        });\n\n        initChart(data);\n\n        // ==========================================\n        // 2. CHART INITIALIZATION & RENDERING\n        // ==========================================\n        function initChart(data) {\n            const width = 800;\n            const height = 600;\n            const margin = 20;\n\n            const svg = d3.select(\"#chart\")\n                .append(\"svg\")\n                .attr(\"width\", width)\n                .attr(\"height\", height);\n\n            const tooltip = d3.select(\"#tooltip\");\n\n            // Scales\n            // Use scaleSqrt so the area of the bubble is proportional to the value\n            const radiusScale = d3.scaleSqrt()\n                .domain([0, d3.max(data, d => d.value)])\n                .range([15, 60]); \n\n            const colorScale = d3.scaleOrdinal()\n                .domain(data.map(d => d.category))\n                .range(d3.schemeTableau10);\n\n            // Force Simulation\n            const simulation = d3.forceSimulation(data)\n                .force(\"x\", d3.forceX(width / 2).strength(0.05))\n                .force(\"y\", d3.forceY(height / 2).strength(0.05))\n                // Prevent bubbles from overlapping\n                .force(\"collide\", d3.forceCollide(d => radiusScale(d.value) + 2)) \n                .on(\"tick\", ticked);\n\n            // Draw Nodes (Groups containing circle + text)\n            const node = svg.selectAll(\".node\")\n                .data(data)\n                .enter().append(\"g\")\n                .attr(\"class\", \"node\")\n                .call(d3.drag()\n                    .on(\"start\", dragstarted)\n                    .on(\"drag\", dragged)\n                    .on(\"end\", dragended));\n\n            // Append Circles\n            node.append(\"circle\")\n                .attr(\"r\", d => radiusScale(d.value))\n                .attr(\"fill\", d => colorScale(d.category))\n                .attr(\"stroke\", \"#fff\")\n                .attr(\"stroke-width\", 2)\n                .style(\"cursor\", \"grab\")\n                .on(\"mouseover\", function(event, d) {\n                    d3.select(this).attr(\"stroke\", \"#333\").attr(\"stroke-width\", 3);\n                    tooltip.style(\"opacity\", 1)\n                        .html(`<strong>${d.name}</strong><br/>Category: ${d.category}<br/>Value: ${d.value}`)\n                        .style(\"left\", (event.pageX + 15) + \"px\")\n                        .style(\"top\", (event.pageY - 10) + \"px\");\n                })\n                .on(\"mousemove\", function(event) {\n                    tooltip.style(\"left\", (event.pageX + 15) + \"px\")\n                           .style(\"top\", (event.pageY - 10) + \"px\");\n                })\n                .on(\"mouseout\", function() {\n                    d3.select(this).attr(\"stroke\", \"#fff\").attr(\"stroke-width\", 2);\n                    tooltip.style(\"opacity\", 0);\n                });\n\n            // Append Labels\n            node.append(\"text\")\n                .attr(\"dy\", \".35em\")\n                .attr(\"text-anchor\", \"middle\")\n                .text(d => d.name);\n\n            // Tick function to update positions on every simulation step\n            function ticked() {\n                node.attr(\"transform\", d => {\n                    // Keep nodes within the SVG boundaries\n                    const r = radiusScale(d.value);\n                    d.x = Math.max(r + margin, Math.min(width - r - margin, d.x));\n                    d.y = Math.max(r + margin, Math.min(height - r - margin, d.y));\n                    return `translate(${d.x},${d.y})`;\n                });\n            }\n\n            // Drag functions\n            function dragstarted(event, d) {\n                if (!event.active) simulation.alphaTarget(0.3).restart();\n                d.fx = d.x;\n                d.fy = d.y;\n                d3.select(this).select(\"circle\").style(\"cursor\", \"grabbing\");\n            }\n\n            function dragged(event, d) {\n                d.fx = event.x;\n                d.fy = event.y;\n            }\n\n            function dragended(event, d) {\n                if (!event.active) simulation.alphaTarget(0);\n                d.fx = null;\n                d.fy = null;\n                d3.select(this).select(\"circle\").style(\"cursor\", \"grab\");\n            }\n        }\n    </script>\n</body>\n</html>\n```\n\n### 3. How to use an External CSV File\nIf you want to load a real `.csv` file instead of the inline string, replace the data processing block (Step 1) with the asynchronous `d3.csv` fetch method:\n\n```javascript\n// Replace the inline string parsing with this:\nd3.csv(\"data.csv\").then(function(rawData) {\n    // Process and cast data types\n    const data = rawData.map(d => {\n        return {\n            name: d.name,\n            category: d.category,\n            value: +d.value \n        };\n    });\n    \n    // Initialize the chart\n    initChart(data);\n}).catch(function(error) {\n    console.error(\"Error loading CSV:\", error);\n});\n```\n*(Note: If loading an external file, you must run the HTML file via a local web server like `python -m http.server` or VS Code Live Server to avoid CORS restrictions).*", "solver_finish_reason": "stop"}
{"task": "dialogue-parser", "condition": "no_skill", "repeat": 0, "skill_ids": [], "retrieval_correct": null, "judged_pass": true, "judged_score": 5, "judge_reason": "The solution correctly parses dialogue text into JSON and generates Graphviz DOT with proper structure and styling.", "solver_tokens": 3670, "judge_tokens": 3930, "solution_text": "# Dialogue Tree Parser \u2192 JSON Graph \u2192 Graphviz DOT\n\nBelow is a complete Python solution that parses a text-based dialogue tree, converts it to a JSON graph, and generates Graphviz DOT output.\n\n## Input Text Format\n\n```\nSTART: Welcome, traveler! What brings you here?\n  -> \"I'm looking for work.\" -> WORK\n  -> \"Just passing through.\" -> LEAVE\nWORK: I have a task for you. Slay the dragon!\n  -> \"I accept!\" -> ACCEPT\n  -> \"No thanks.\" -> LEAVE\nACCEPT: Here's your reward. Gold coins: 500.\nLEAVE: Farewell, traveler!\n```\n\n## Complete Python Script\n\n```python\n#!/usr/bin/env python3\n\"\"\"\nDialogue Tree Parser\nParses text dialogue trees \u2192 JSON graph \u2192 Graphviz DOT\n\"\"\"\n\nimport re\nimport json\nimport sys\nfrom typing import Dict, List, Optional, Tuple\n\n\n# \u2500\u2500\u2500 Data Structures \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nclass DialogueNode:\n    def __init__(self, node_id: str, text: str):\n        self.id = node_id\n        self.text = text\n        self.choices: List[Dict] = []  # [{\"label\": str, \"target\": str}]\n\n    def to_dict(self) -> dict:\n        return {\n            \"id\": self.id,\n            \"text\": self.text,\n            \"choices\": self.choices\n        }\n\n\nclass DialogueGraph:\n    def __init__(self):\n        self.nodes: Dict[str, DialogueNode] = {}\n        self.start_node: Optional[str] = None\n\n    def to_json(self) -> dict:\n        return {\n            \"start_node\": self.start_node,\n            \"nodes\": {nid: node.to_dict() for nid, node in self.nodes.items()},\n            \"edges\": self._build_edges()\n        }\n\n    def _build_edges(self) -> List[dict]:\n        edges = []\n        for node in self.nodes.values():\n            for choice in node.choices:\n                edges.append({\n                    \"source\": node.id,\n                    \"target\": choice[\"target\"],\n                    \"label\": choice[\"label\"]\n                })\n        return edges\n\n\n# \u2500\u2500\u2500 Text Parser \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nclass DialogueParser:\n    \"\"\"\n    Parses dialogue text format:\n        NODE_ID: Dialogue text here\n          -> \"Choice label\" -> TARGET_NODE_ID\n          -> \"Another choice\" -> ANOTHER_NODE\n    \"\"\"\n\n    NODE_PATTERN = re.compile(r'^([A-Za-z_][A-Za-z0-9_]*)\\s*:\\s*(.+)$')\n    CHOICE_PATTERN = re.compile(r'^\\s*->\\s*\"([^\"]*)\"\\s*->\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*$')\n    CHOICE_NO_LABEL = re.compile(r'^\\s*->\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*$')\n\n    def __init__(self):\n        self.graph = DialogueGraph()\n\n    def parse(self, text: str) -> DialogueGraph:\n        lines = text.strip().split('\\n')\n        current_node: Optional[DialogueNode] = None\n        first_node = True\n\n        for line in lines:\n            line_stripped = line.rstrip()\n            if not line_stripped:\n                continue\n\n            # Try to match a node definition\n            node_match = self.NODE_PATTERN.match(line_stripped)\n            if node_match:\n                node_id = node_match.group(1)\n                node_text = node_match.group(2).strip()\n                current_node = DialogueNode(node_id, node_text)\n                self.graph.nodes[node_id] = current_node\n                if first_node:\n                    self.graph.start_node = node_id\n                    first_node = False\n                continue\n\n            # Try to match a choice with label\n            choice_match = self.CHOICE_PATTERN.match(line_stripped)\n            if choice_match and current_node:\n                label = choice_match.group(1)\n                target = choice_match.group(2)\n                current_node.choices.append({\"label\": label, \"target\": target})\n                # Ensure target node exists (even if not yet defined)\n                if target not in self.graph.nodes:\n                    self.graph.nodes[target] = DialogueNode(target, \"\")\n                continue\n\n            # Try to match a choice without label (just -> TARGET)\n            no_label_match = self.CHOICE_NO_LABEL.match(line_stripped)\n            if no_label_match and current_node:\n                target = no_label_match.group(1)\n                current_node.choices.append({\"label\": \"\", \"target\": target})\n                if target not in self.graph.nodes:\n                    self.graph.nodes[target] = DialogueNode(target, \"\")\n                continue\n\n        return self.graph\n\n\n# \u2500\u2500\u2500 JSON Graph Output \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef graph_to_json(graph: DialogueGraph, indent: int = 2) -> str:\n    return json.dumps(graph.to_json(), indent=indent, ensure_ascii=False)\n\n\n# \u2500\u2500\u2500 Graphviz DOT Generation \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef _escape_dot(text: str) -> str:\n    \"\"\"Escape special characters for DOT labels.\"\"\"\n    text = text.replace('\\\\', '\\\\\\\\')\n    text = text.replace('\"', '\\\\\"')\n    text = text.replace('\\n', '\\\\n')\n    return text\n\n\ndef _wrap_text(text: str, max_width: int = 40) -> str:\n    \"\"\"Wrap long text for DOT labels.\"\"\"\n    if len(text) <= max_width:\n        return text\n    words = text.split()\n    lines = []\n    current_line = \"\"\n    for word in words:\n        if len(current_line) + len(word) + 1 > max_width:\n            lines.append(current_line)\n            current_line = word\n        else:\n            current_line = f\"{current_line} {word}\".strip()\n    if current_line:\n        lines.append(current_line)\n    return '\\\\n'.join(lines)\n\n\ndef graph_to_dot(graph: DialogueGraph, title: str = \"Dialogue Tree\") -> str:\n    \"\"\"Generate Graphviz DOT from a DialogueGraph.\"\"\"\n    data = graph.to_json()\n    lines = []\n\n    lines.append(f'digraph \"{_escape_dot(title)}\" {{')\n    lines.append('    rankdir=TB;')\n    lines.append('    node [shape=box, style=\"rounded,filled\", fillcolor=\"#E8E8E8\",')\n    lines.append('          fontname=\"Helvetica\", fontsize=11, margin=\"0.2,0.1\"];')\n    lines.append('    edge [fontname=\"Helvetica\", fontsize=9, color=\"#555555\"];')\n    lines.append('')\n\n    # Start node marker\n    if data[\"start_node\"]:\n        lines.append(f'    __start__ [shape=circle, label=\"\", width=0.3,')\n        lines.append(f'               fillcolor=\"#4CAF50\", style=filled];')\n        lines.append(f'    __start__ -> \"{_escape_dot(data[\"start_node\"])}\"')\n        lines.append(f'               [color=\"#4CAF50\", penwidth=2.0];')\n        lines.append('')\n\n    # Nodes\n    for node_id, node_data in data[\"nodes\"].items():\n        escaped_id = _escape_dot(node_id)\n        text = _escape_dot(node_data[\"text\"])\n        wrapped = _wrap_text(text)\n        label = f\"{node_id}\\\\n\\\\n{wrapped}\" if node_data[\"text\"] else node_id\n\n        # Color terminal nodes differently\n        if not node_data[\"choices\"]:\n            fillcolor = \"#FFCC80\"  # Orange for terminal\n            shape = \"box, style=\\\"rounded,filled\\\"\"\n        else:\n            fillcolor = \"#E3F2FD\"  # Light blue for non-terminal\n            shape = \"box, style=\\\"rounded,filled\\\"\"\n\n        lines.append(f'    \"{escaped_id}\" [label=\"{label}\", fillcolor=\"{fillcolor}\"];')\n\n    lines.append('')\n\n    # Edges\n    for edge in data[\"edges\"]:\n        src = _escape_dot(edge[\"source\"])\n        tgt = _escape_dot(edge[\"target\"])\n        label = _escape_dot(edge[\"label\"])\n        if label:\n            lines.append(f'    \"{src}\" -> \"{tgt}\" [label=\" {label} \"];')\n        else:\n            lines.append(f'    \"{src}\" -> \"{tgt}\";')\n\n    lines.append('}')\n    return '\\n'.join(lines)\n\n\n# \u2500\u2500\u2500 JSON \u2192 DOT (from serialized JSON) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef json_to_dot(json_str: str, title: str = \"Dialogue Tree\") -> str:\n    \"\"\"Convert a JSON graph string directly to DOT.\"\"\"\n    data = json.loads(json_str)\n    graph = DialogueGraph()\n    graph.start_node = data.get(\"start_node\")\n\n    for node_id, node_data in data.get(\"nodes\", {}).items():\n        node = DialogueNode(node_id, node_data[\"text\"])\n        node.choices = node_data.get(\"choices\", [])\n        graph.nodes[node_id] = node\n\n    return graph_to_dot(graph, title)\n\n\n# \u2500\u2500\u2500 Main / CLI \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nSAMPLE_DIALOGUE = \"\"\"\nSTART: Welcome, brave traveler! What brings you to our humble village?\n  -> \"I'm looking for work. Got any quests?\" -> QUEST_OFFER\n  -> \"I'm just passing through.\" -> LEAVE\n  -> \"Tell me about this place.\" -> LORE\n\nQUEST_OFFER: Excellent! A dragon has been terrorizing our farms. Will you slay it?\n  -> \"I accept the challenge!\" -> QUEST_ACCEPT\n  -> \"That sounds too dangerous.\" -> QUEST_DECLINE\n\nLORE: This village was founded centuries ago by the Elders of the Mountain.\n  -> \"Fascinating. Now about that quest?\" -> QUEST_OFFER\n  -> \"I should be going.\" -> LEAVE\n\nQUEST_ACCEPT: Wonderful! Take this enchanted sword. You'll need it.\n  -> \"Thank you. I won't let you down.\" -> QUEST_START\n  -> \"What's the reward?\" -> REWARD_INFO\n\nREWARD_INFO: The village will reward you with 500 gold pieces and our eternal gratitude.\n  -> \"Deal! I'm on my way.\" -> QUEST_START\n  -> \"I need to think about it.\" -> QUEST_OFFER\n\nQUEST_DECLINE: Perhaps another time then. The offer stands if you change your mind.\n  -> \"Actually, I'll do it.\" -> QUEST_ACCEPT\n  -> \"Goodbye.\" -> LEAVE\n\nQUEST_START: May the gods protect you on your journey. The dragon's lair is to the north.\nLEAVE: Farewell, traveler. May your roads be safe.\n\"\"\"\n\n\ndef main():\n    # Read from file or use sample\n    if len(sys.argv) > 1:\n        with open(sys.argv[1], 'r') as f:\n            dialogue_text = f.read()\n    else:\n        dialogue_text = SAMPLE_DIALOGUE\n        print(\"=\" * 60)\n        print(\"INPUT: Dialogue Tree Text\")\n        print(\"=\" * 60)\n        print(dialogue_text.strip())\n        print()\n\n    # Step 1: Parse text \u2192 Graph object\n    parser = DialogueParser()\n    graph = parser.parse(dialogue_text)\n\n    # Step 2: Graph \u2192 JSON\n    json_output = graph_to_json(graph)\n    print(\"=\" * 60)\n    print(\"OUTPUT: JSON Graph\")\n    print(\"=\" * 60)\n    print(json_output)\n    print()\n\n    # Step 3: Graph \u2192 DOT\n    dot_output = graph_to_dot(graph, title=\"Dialogue Tree\")\n    print(\"=\" * 60)\n    print(\"OUTPUT: Graphviz DOT\")\n    print(\"=\" * 60)\n    print(dot_output)\n    print()\n\n    # Step 4: Verify round-trip (JSON \u2192 DOT)\n    dot_from_json = json_to_dot(json_output, title=\"Dialogue Tree (from JSON)\")\n    print(\"=\" * 60)\n    print(\"VERIFICATION: DOT from JSON (round-trip)\")\n    print(\"=\" * 60)\n    print(dot_from_json)\n\n    # Optionally write outputs to files\n    if len(sys.argv) > 2:\n        base = sys.argv[2]\n        with open(f\"{base}.json\", 'w') as f:\n            f.write(json_output)\n        with open(f\"{base}.dot\", 'w') as f:\n            f.write(dot_output)\n        print(f\"\\nFiles written: {base}.json, {base}.dot\")\n        print(f\"Render with: dot -Tpng {base}.dot -o {base}.png\")\n\n\nif __name__ == \"__main__\":\n    main()\n```\n\n## Usage\n\n```bash\n# Run with built-in sample dialogue\npython dialogue_parser.py\n\n# Parse a custom dialogue file\npython dialogue_parser.py my_dialogue.txt\n\n# Parse and save outputs to files\npython dialogue_parser.py my_dialogue.txt output\n# \u2192 creates output.json and output.dot\n# Render: dot -Tpng output.dot -o output.png\n```\n\n## How It Works\n\n| Stage | Description |\n|-------|-------------|\n| **Text \u2192 Parse** | Regex-based parser reads `NODE_ID: text` lines and `-> \"label\" -> TARGET` choice lines |\n| **Parse \u2192 JSON** | `DialogueGraph.to_json()` serializes nodes, edges, and start node |\n| **JSON \u2192 DOT** | `graph_to_dot()` generates styled Graphviz with color-coded terminal/choice nodes |\n| **Round-trip** | `json_to_dot()` proves JSON is a complete intermediate representation |\n\n## JSON Output Structure\n\n```json\n{\n  \"start_node\": \"START\",\n  \"nodes\": {\n    \"START\": {\n      \"id\": \"START\",\n      \"text\": \"Welcome, brave traveler!...\",\n      \"choices\": [\n        {\"label\": \"I'm looking for work...\", \"target\": \"QUEST_OFFER\"},\n        {\"label\": \"I'm just passing through.\", \"target\": \"LEAVE\"}\n      ]\n    }\n  },\n  \"edges\": [\n    {\"source\": \"START\", \"target\": \"QUEST_OFFER\", \"label\": \"I'm looking for work...\"}\n  ]\n}\n```\n\n## DOT Output Features\n\n- **Green circle** = start node marker\n- **Light blue boxes** = dialogue nodes with choices\n- **Orange boxes** = terminal/end nodes\n- **Labeled edges** = player choices\n- **Text wrapping** for long dialogue lines\n- **Rounded, filled** node styling", "solver_finish_reason": "stop"}
