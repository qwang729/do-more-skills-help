t.mp4\n\n# Add TTS audio at specific timestamp (e.g., at 5 seconds)\nffmpeg -i input_video.mp4 -i tts_output.wav -filter_complex \"[1:a]adelay=5000|5000[tts];[0:a][tts]amix=inputs=2:duration=longest[aout]\" -map 0:v -map \"[aout]\" -c:v copy delayed_tts_output.mp4\n```\n\n### 4. Complete TTS Video Pipeline Script\n\n```bash\n#!/bin/bash\n# complete_tts_pipeline.sh\n\nINPUT_VIDEO=\"input.mp4\"\nTEXT_FILE=\"speech.txt\"\nOUTPUT_VIDEO=\"final_output.mp4\"\n\n# Step 1: Generate TTS from text file\nespeak -v en -f \"$TEXT_FILE\" -w tts_temp.wav\n\n# Step 2: Extract original audio (optional, for mixing)\nffmpeg -i \"$INPUT_VIDEO\" -vn -acodec pcm_s16le -ar 44100 -ac 2 original_audio.wav\n\n# Step 3: Combine video with TTS (replace audio)\nffmpeg -i \"$INPUT_VIDEO\" -i tts_temp.wav -c:v copy -map 0:v:0 -map 1:a:0 -shortest \"$OUTPUT_VIDEO\"\n\n# Cleanup\nrm tts_temp.wav original_audio.wav\n\necho \"TTS video created: $OUTPUT_VIDEO\"\n```\n\n### 5. Adjust TTS Audio Properties\n\n```bash\n# Change TTS speed and pitch with espeak\nespeak -v en -s 150 -p 50 \"Text here\" -w output.wav\n# -s 150 : Speed (words per minute)\n# -p 50  : Pitch (0-99)\n\n# Normalize TTS audio volume\nffmpeg -i tts_output.wav -af \"loudnorm=I=-16:TP=-1.5:LRA=11\" normalized_tts.wav\n\n# Adjust volume of TTS\nffmpeg -i tts_output.wav -af \"volume=2.0\" louder_tts.wav\n```\n\n### Quick One-Liner Examples\n\n```bash\n# Create video from image + TTS\nffmpeg -loop 1 -i image.png -i tts_output.wav -c:v libx264 -tune stillimage -c:a aac -b:a 128k -pix_fmt yuv420p -shortest output.mp4\n\n# Extract and analyze audio from video\nffmpeg -i video.mp4 -vn -acodec pcm_s16le -ar 44100 -ac 2 audio.wav && ffprobe -v quiet -show_format audio.wav\n```", "solver_finish_reason": "stop"}
