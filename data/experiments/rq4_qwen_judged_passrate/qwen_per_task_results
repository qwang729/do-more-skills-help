un.text = new_text\n        else:\n            run.text = ''\n\n\ndef fix_split_placeholders(paragraph, placeholder_pattern=r'\\{\\{[^}]+\\}\\}'):\n    \"\"\"Fix placeholders split across multiple runs.\"\"\"\n    full_text = get_full_text(paragraph)\n    matches = list(re.finditer(placeholder_pattern, full_text))\n    \n    if not matches:\n        return\n    \n    # Rebuild paragraph with fixed placeholders\n    new_text = full_text\n    set_paragraph_text(paragraph, new_text)\n\n\ndef process_paragraph(paragraph, replacements, placeholder_pattern=r'\\{\\{(\\w+)\\}\\}'):\n    \"\"\"Process a single paragraph for placeholder replacement.\"\"\"\n    full_text = get_full_text(paragraph)\n    \n    # Fix split placeholders first\n    fix_split_placeholders(paragraph)\n    full_text = get_full_text(paragraph)\n    \n    # Find and replace placeholders\n    matches = re.findall(placeholder_pattern, full_text)\n    for match in matches:\n        if match in replacements:\n            full_text = full_text.replace('{{' + match + '}}', str(replacements[match]))\n    \n    set_paragraph_text(paragraph, full_text)\n\n\ndef process_table(table, replacements):\n    \"\"\"Process table including nested tables.\"\"\"\n    for row in table.rows:\n        for cell in row.cells:\n            # Process paragraphs in cell\n            for paragraph in cell.paragraphs:\n                process_paragraph(paragraph, replacements)\n            \n            # Handle nested tables\n            for nested_table in cell.tables:\n                process_table(nested_table, replacements)\n\n\ndef process_header_footer(part, replacements):\n    \"\"\"Process header or footer sections.\"\"\"\n    if part is None:\n        return\n    \n    for paragraph in part.paragraphs:\n        process_paragraph(paragraph, replacements)\n    \n    for table in part.tables:\n        process_table(table, replacements)\n\n\ndef fill_template(input_path, output_path, replacements):\n    \"\"\"\n    Fill Word t