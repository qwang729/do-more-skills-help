u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef find_embedded_excel_objects(pptx_path):\n    \"\"\"\n    Return a list of dicts describing every embedded Excel OLE object\n    found in the presentation:\n        { 'slide_index', 'shape', 'shape_id', 'rId', 'target_partname' }\n    \"\"\"\n    prs = Presentation(pptx_path)\n    results = []\n\n    for slide_idx, slide in enumerate(prs.slides):\n        for shape in slide.shapes:\n            # OLE objects show up as shapes with an ole_object element\n            # or as GraphicFrame with an embedded OLE reference.\n            sp = shape._element\n            # Check for <p:oleObj> or <mc:AlternateContent> containing OLE\n            ole_objs = sp.findall(\n                \".//{http://schemas.openxmlformats.org/drawingml/2006/spreadsheetDrawing}*\"\n            )\n            # More reliable: walk the shape's relationships looking for OLE\n            if not hasattr(shape, \"part\"):\n                continue\n            shape_part = shape.part\n            for rel in shape_part.rels.values():\n                if rel.reltype == OLE_REL_TYPE:\n                    target_part = rel.target_part\n                    content_type = target_part.content_type\n                    if \"spreadsheetml\" in content_type or \"excel\" in content_type.lower():\n                        results.append({\n                            \"slide_index\": slide_idx,\n                            \"shape\": shape,\n                            \"shape_id\": shape.shape_id,\n                            \"rId\": rel.rId,\n                            \"target_partname\": target_part.partname,\n                            \"target_part\": target_part,\n                        })\n    return results\n\n\n# \u2500\u2500 2. Extract the embedded Excel blob \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef extract_excel_bytes(ole_info):\n    \"\"\"Return the raw .xlsx bytes of the embedded Excel object.\"\"\"\n    part = ole_info[\"target_part\"]\n    return part.blob\n\n\n# \u2500\u2500 3. Edit the Excel data with openpyxl \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef edit_excel_bytes(excel_bytes, edit_func):\n    \"\"\"\n    Load the Excel blob into openpyxl, call `edit_func(wb)` to mutate it,\n    then return the modified .xlsx bytes.\n\n    `edit_func` receives an openpyxl Workbook and should modify it in-place.\n    \"\"\"\n    wb = load_workbook(io.BytesIO(excel_bytes))\n    edit_func(wb)\n    buf = io.BytesIO()\n    wb.save(buf)\n    return buf.getvalue()\n\n\n# \u2500\u2500 4. Write the modified Excel back into the PPTX \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef replace_embedded_excel(pptx_path, output_path, ole_info, new_excel_bytes):\n    \"\"\"\n    Replace the embedded Excel blob inside the PPTX package and save.\n    Uses low-level ZIP manipulation to preserve all other parts.\n    \"\"\"\n    target_partname = str(ole_info[\"target_partname\"]).lstrip(\"/\")\n\n    # Read original PPTX as ZIP\n    with zipfile.ZipFile(pptx_path, \"r\") as zin:\n        with zipfile.ZipFile(output_path, \"w\", zipfile.ZIP_DEFLATED) as zout:\n            for item in zin.infolist():\n                data = zin.read(item.filename)\n                if item.filename == target_partname:\n                    # Replace with our modified Excel blob\n                    zout.writestr(item, new_excel_bytes)\n                    print(f\"  \u2713 Replaced {item.filename} \"\n                          f\"({len(data)} \u2192 {len(new_excel_bytes)} bytes)\")\n                else:\n                    zout.writestr(item, data)\n\n\n# \u2500\u2500 5. Also update the table cells visible on the slide \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef update_slide_table_from_excel(slide, shape, wb):\n    \"\"\"\n    If the OLE object also has a visible table representation on the slide,\n    sync the table cell text from the openpyxl workbook.\n    \"\"\"\n    if not shape.has_table:\n        return\n\n    table = shape.table\n    ws = wb.active  # or wb[wb.sheetnames[0]]\n\n    for row_idx, row in enumerate(table.rows, start=1):\n        for col_idx, cell in enumerate(row.cells, start=1):\n            try:\n                excel_val = ws.cell(row=row_idx, column=col_idx).value\n                if excel_val is not None:\n                    cell.text = str(excel_val)\n            except Exception:\n                pass\n\n\n# \u2500\u2500 6. High-level convenience function \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef edit_pptx_embedded_excel(pptx_path, output_path, edit_func,\n                              slide_index=None, update_table=True):\n    \"\"\"\n    One-call helper:\n      1. Find all embedded Excel OLE objects (optionally filtered by slide).\n      2. Extract each one, run `edit_func(wb)` on it.\n      3. Write the modified PPTX to `output_path`.\n      4. Optionally sync visible table cells on the slide.\n\n    Parameters\n    ----------\n    pptx_path : str\n        Path to the source .pptx file.\n    output_path : str\n        Path where the modified .pptx will be saved.\n    edit_func : callable\n        A function that receives an openpyxl.Workbook and mutates it.\n    slide_index : int or None\n        If given, only edit the embedded Excel on that slide (0-based).\n    update_table : bool\n        If True, also update visible table text on the slide.\n    \"\"\"\n    prs = Presentation(pptx_path)\n    ole_objects = find_embedded_excel_objects(pptx_path)\n\n    if slide_index is not None:\n        ole_objects = [o for o in ole_objects if o[\"slide_index\"] == slide_index]\n\n    if not ole_objects:\n        print(\"No embedded Excel objects found.\")\n        return\n\n    # We need to rebuild the PPTX ZIP with replaced parts.\n    # Collect all replacements first.\n    replacements = {}  # partname -> new bytes\n    modified_wbs = {}  # partname -> openpyxl Workbook (for table sync)\n\n    for ole_info in ole_objects:\n        print(f\"Processing slide {ole_info['slide_index']}, \"\n              f\"shape_id={ole_info['shape_id']}, \"\n              f\"part={ole_info['target_partname']}\")\n\n        excel_bytes = extract_excel_bytes(ole_info)\n        print(f\"  Extracted {len(excel_bytes)} bytes of Excel data\")\n\n        # Edit\n        wb = load_workbook(io.BytesIO(excel_bytes))\n        edit_func(wb)\n\n        buf = io.BytesIO()\n        wb.save(buf)\n        new_bytes = buf.getvalue()\n\n        partname = str(ole_info[\"target_partname\"]).lstrip(\"/\")\n        replacements[partname] = new_bytes\n        modified_wbs[partname] = wb\n\n    # Rebuild the PPTX ZIP\n    with zipfile.ZipFile(pptx_path, \"r\") as zin:\n        with zipfile.ZipFile(output_path, \"w\", zipfile.ZIP_DEFLATED) as zout:\n            for item in zin.infolist():\n                data = zin.read(item.filename)\n                if item.filename in replacements:\n                    zout.writestr(item, replacements[item.filename])\n                    print(f\"  \u2713 Replaced {item.filename}\")\n                else:\n                    zout.writestr(item, data)\n\n    # Optionally sync visible table cells\n    if update_table:\n        prs_out = Presentation(output_path)\n        for ole_info in ole_objects:\n            partname = str(ole_info[\"target_partname\"]).lstrip(\"/\")\n            slide = prs_out.slides[ole_info[\"slide_index\"]]\n            for shape in slide.shapes:\n                if shape.shape_id == ole_info[\"shape_id\"]:\n                    update_slide_table_from_excel(\n                        slide, shape, modified_wbs[partname]\n                    )\n        prs_out.save(output_path)\n        print(\"  \u2713 Synced visible table cells\")\n\n    print(f\"Saved to {output_path}\")\n\n\n# \u2500\u2500 EXAMPLE USAGE \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nif __name__ == \"__main__\":\n\n    INPUT_PPTX = \"input.pptx\"\n    OUTPUT_PPTX = \"output.pptx\"\n\n    # \u2500\u2500 Example edit function: change cell A1 and add a new row \u2500\u2500\n    def my_edit(wb):\n        ws = wb.active\n        print(f\"    Sheet '{ws.title}': {ws.max_row} rows \u00d7 {ws.max_column} cols\")\n\n        # Print current contents\n        for row in ws.iter_rows(min_row=1, max_row=min(ws.max_row, 10), values_only=False):\n            vals = [str(c.value) if c.value is not None else \"\" for c in row]\n            print(f\"      {vals}\")\n\n        # \u2500\u2500 Make your edits here \u2500\u2500\n        ws[\"A1\"] = \"Updated by python-pptx script\"\n        ws[\"B1\"] = 42\n\n        # Add a summary row at the bottom\n        next_row = ws.max_row + 1\n        ws.cell(row=next_row, column=1, value=\"TOTAL\")\n        # Sum column B if it has numbers\n        total = sum(\n            c.value for c in ws[\"B\"][1:ws.max_row]\n            if isinstance(c.value, (int, float))\n        )\n        ws.cell(row=next_row, column=2, value=total)\n\n    # \u2500\u2500 Run it \u2500\u2500\n    if os.path.exists(INPUT_PPTX):\n        edit_pptx_embedded_excel(\n            pptx_path=INPUT_PPTX,\n            output_path=OUTPUT_PPTX,\n            edit_func=my_edit,\n            slide_index=0,       # only first slide (or None for all)\n            update_table=True,   # sync visible table text\n        )\n    else:\n        print(f\"'{INPUT_PPTX}' not found. Place a PPTX with an embedded \"\n              f\"Excel object in the working directory and re-run.\")\n\n\n# \u2500\u2500 BONUS: Create a test PPTX with an embedded Excel table \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef create_test_pptx_with_embedded_excel(output_path=\"input.pptx\"):\n    \"\"\"\n    Creates a minimal PPTX containing a table (simulating an embedded Excel\n    object) for testing purposes. Note: python-pptx cannot create true OLE\n    embedded Excel objects, but this creates a table that can be edited.\n    \"\"\"\n    from pptx.util import Inches, Pt\n\n    prs = Presentation()\n    slide = prs.slides.add_slide(prs.slide_layouts[5])  # blank layout\n\n    # Add a table\n    rows, cols = 4, 3\n    left = Inches(1)\n    top = Inches(1)\n    width = Inches(6)\n    height = Inches(3)\n\n    table_shape = slide.shapes.add_table(rows, cols, left, top, width, height)\n    table = table_shape.table\n\n    # Populate\n    headers = [\"Item\", \"Qty\", \"Price\"]\n    data = [\n        [\"Widget A\", 10, 5.99],\n        [\"Widget B\", 25, 3.49],\n        [\"Widget C\", 7, 12.00],\n    ]\n\n    for col_idx, header in enumerate(headers):\n        table.cell(0, col_idx).text = header\n\n    for row_idx, row_data in enumerate(data, start=1):\n        for col_idx, value in enumerate(row_data):\n            table.cell(row_idx, col_idx).text = str(value)\n\n    prs.save(output_path)\n    print(f\"Created test PPTX: {output_path}\")\n\n\n# \u2500\u2500 BONUS: Direct table editing (no OLE needed) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef edit_table_directly(pptx_path, output_path, slide_index=0):\n    \"\"\"\n    Edit a regular PowerPoint table directly (no embedded Excel OLE needed).\n    Useful when the table is just a native PPTX table.\n    \"\"\"\n    prs = Presentation(pptx_path)\n    slide = prs.slides[slide_index]\n\n    for shape in slide.shapes:\n        if not shape.has_table:\n            continue\n\n        table = shape.table\n        print(f\"Found table: {len(table.rows)} rows \u00d7 {len(table.columns)} cols\")\n\n        # Read all cells\n        for row_idx, row in enumerate(table.rows):\n            for col_idx, cell in enumerate(row.cells):\n                print(f\"  [{row_idx},{col_idx}] = '{cell.text}'\")\n\n        # Modify cells\n        table.cell(0, 0).text = \"MODIFIED HEADER\"\n\n        # Format a cell\n        cell = table.cell(1, 2)\n        cell.text = \"$99.99\"\n        for paragraph in cell.text_frame.paragraphs:\n            for run in paragraph.runs:\n                run.font.bold = True\n                run.font.color.rgb = None  # reset to default\n                run.font.size = Pt(12)\n\n    prs.save(output_path)\n    print(f\"Saved modified table to {output_path}\")\n```\n\n## Key Points\n\n| Challenge | Solution |\n|-----------|----------|\n| python-pptx can't natively edit OLE Excel objects | Extract the raw `.xlsx` blob from the PPTX ZIP package via `target_part.blob` |\n| Need to modify Excel data | Use `openpyxl` on the extracted bytes |\n| Re-embedding modified Excel | Rebuild the PPTX ZIP, replacing only the target part's bytes |\n| Visible table out of sync with Excel data | After saving, re-open with python-pptx and copy cell values into `shape.table` cells |\n| Finding OLE objects | Walk each shape's `part.rels` looking for `reltype == OLE_REL_TYPE` with spreadsheet content type |\n\n## Quick Start\n\n```bash\npip install python-pptx openpyxl lxml\n```\n\n```python\nfrom edit_embedded_excel import edit_pptx_embedded_excel\n\ndef my_changes(wb):\n    ws = wb.active\n    ws[\"A1\"] = \"New Value\"\n    ws.cell(row=2, column=1, value=\"Added row\")\n\nedit_pptx_embedded_excel(\n    \"presentation.pptx\",\n    \"presentation_edited.pptx\",\n    edit_func=my_changes,\n    slide_index=0,\n)\n```\n\nThe script handles the full round-trip: **find OLE \u2192 extract xlsx bytes \u2192 edit with openpyxl \u2192 repackage into PPTX \u2192 sync visible table text**.", "solver_finish_reason": "stop"}
{"task": "exoplanet-detection-period", "condition": "no_skill", "repeat": 0, "skill_ids": [], "retrieval_correct": null, "judged_pass": false, "judged_score": 1, "judge_reason": "Agent uses synthetic data and hardcoded TIC ID instead of processing the provided TESS lightcurve file with quality filtering and period refinement as in the reference.", "solver_tokens": 3324, "judge_tokens": 3626, "solution_text": "# TESS Lightcurve Transit Period Detection with Astropy Timeseries\n\nHere's a complete solution for detecting transit periods in TESS lightcurve data using astropy timeseries:\n\n```python\nimport numpy as np\nimport matplotlib.pyplot as plt\nfrom astropy.timeseries import LombScargle, BoxLeastSquares\nfrom astropy import units as u\nimport lightkurve as lk\nfrom astropy.time import Time\n\n# Method 1: Using real TESS data with lightkurve\ndef analyze_tess_lightcurve_real_data(tic_id='25155310'):\n    \"\"\"\n    Analyze real TESS lightcurve data for transit detection\n    \"\"\"\n    print(f\"Downloading TESS data for TIC {tic_id}...\")\n    \n    # Search and download TESS lightcurve\n    search_result = lk.search_lightcurve(tic_id, mission='TESS')\n    lc_collection = search_result.download_all()\n    \n    # Combine all sectors\n    lc = lc_collection.stitch()\n    \n    # Remove NaN values and outliers\n    lc = lc.remove_nans()\n    lc = lc.remove_outliers(sigma=5)\n    \n    # Flatten the lightcurve (remove long-term trends)\n    lc_flat = lc.flatten(window_length=101)\n    \n    print(f\"Lightcurve contains {len(lc)} data points\")\n    print(f\"Time baseline: {lc.time.value.max() - lc.time.value.min():.2f} days\")\n    \n    # Perform Box Least Squares periodogram (optimal for transits)\n    print(\"Running BLS periodogram...\")\n    \n    # Define period range to search (0.5 to 20 days typical for transits)\n    periods = np.linspace(0.5, 20, 10000) * u.day\n    \n    # Create BLS model\n    bls = BoxLeastSquares(lc.time.value * u.day, lc_flat.flux.value)\n    \n    # Run BLS with typical transit duration\n    bls_result = bls.power(periods, duration=[0.05, 0.1, 0.15] * u.day)\n    \n    # Find best period\n    best_period = bls_result.period[np.argmax(bls_result.power)]\n    best_duration = bls_result.duration[np.argmax(bls_result.power)]\n    best_t0 = bls_result.transit_time[np.argmax(bls_result.power)]\n    \n    print(f\"\\nBest transit parameters:\")\n    print(f\"Period: {best_period:.4f}\")\n    print(f\"Duration: {best_duration:.4f}\")\n    print(f\"Epoch (T0): {best_t0:.4f}\")\n    \n    # Create folded lightcurve\n    lc_folded = lc_flat.fold(period=best_period, epoch_time=best_t0)\n    \n    # Plot results\n    fig, axes = plt.subplots(3, 1, figsize=(12, 10))\n    \n    # Plot 1: Original lightcurve\n    axes[0].scatter(lc.time.value, lc.flux.value, s=1, alpha=0.5)\n    axes[0].set_xlabel('Time (BJD)')\n    axes[0].set_ylabel('Flux')\n    axes[0].set_title('Original TESS Lightcurve')\n    \n    # Plot 2: BLS Periodogram\n    axes[1].plot(bls_result.period.value, bls_result.power)\n    axes[1].axvline(best_period.value, color='r', linestyle='--', \n                    label=f'Best Period: {best_period.value:.3f} days')\n    axes[1].set_xlabel('Period (days)')\n    axes[1].set_ylabel('BLS Power')\n    axes[1].set_title('Box Least Squares Periodogram')\n    axes[1].legend()\n    \n    # Plot 3: Folded lightcurve\n    axes[2].scatter(lc_folded.time.value, lc_folded.flux.value, s=10, alpha=0.7)\n    axes[2].set_xlabel('Phase (days)')\n    axes[2].set_ylabel('Flux')\n    axes[2].set_title(f'Folded Lightcurve (Period = {best_period.value:.3f} days)')\n    axes[2].axvline(0, color='r', linestyle='--', alpha=0.5)\n    \n    plt.tight_layout()\n    plt.savefig('tess_transit_analysis.png', dpi=150, bbox_inches='tight')\n    plt.show()\n    \n    return bls_result, lc_folded, best_period\n\n\n# Method 2: Using synthetic data (for demonstration without download)\ndef analyze_tess_lightcurve_synthetic():\n    \"\"\"\n    Demonstrate transit detection with synthetic TESS-like data\n    \"\"\"\n    print(\"Generating synthetic TESS lightcurve with transit...\")\n    \n    # Generate time array (27 days, typical TESS sector)\n    np.random.seed(42)\n    time = np.linspace(0, 27, 2000)  # days\n    \n    # Add noise\n    flux = 1.0 + np.random.normal(0, 0.001, len(time))\n    \n    # Add transit signal\n    true_period = 3.5  # days\n    true_duration = 0.15  # days\n    true_depth = 0.01  # 1% depth\n    true_t0 = 2.0  # days\n    \n    # Create transit model\n    for i in range(int(time.max() / true_period) + 1):\n        transit_center = true_t0 + i * true_period\n        in_transit = np.abs(time - transit_center) < true_duration / 2\n        flux[in_transit] -= true_depth\n    \n    # Add some systematic trends\n    flux += 0.002 * np.sin(2 * np.pi * time / 15)\n    \n    # Flatten the lightcurve\n    from scipy.ndimage import median_filter\n    trend = median_filter(flux, size=101)\n    flux_flat = flux / trend\n    \n    print(f\"Synthetic lightcurve: {len(time)} points, {time.max():.1f} days\")\n    \n    # BLS periodogram\n    periods = np.linspace(0.5, 10, 5000) * u.day\n    bls = BoxLeastSquares(time * u.day, flux_flat)\n    bls_result = bls.power(periods, duration=[0.1, 0.15, 0.2] * u.day)\n    \n    # Find best period\n    best_idx = np.argmax(bls_result.power)\n    best_period = bls_result.period[best_idx]\n    best_duration = bls_result.duration[best_idx]\n    best_t0 = bls_result.transit_time[best_idx]\n    \n    print(f\"\\nDetected transit parameters:\")\n    print(f\"Period: {best_period:.4f} days (true: {true_period} days)\")\n    print(f\"Duration: {best_duration:.4f} days (true: {true_duration} days)\")\n    print(f\"Epoch: {best_t0:.4f} days (true: {true_t0} days)\")\n    \n    # Fold lightcurve\n    phase = ((time - best_t0.value) % best_period.value) / best_period.value\n    phase[phase > 0.5] -= 1.0\n    sort_idx = np.argsort(phase)\n    \n    # Plot results\n    fig, axes = plt.subplots(3, 1, figsize=(12, 10))\n    \n    # Original lightcurve\n    axes[0].plot(time, flux, 'k.', markersize=2, alpha=0.5)\n    axes[0].set_xlabel('Time (days)')\n    axes[0].set_ylabel('Flux')\n    axes[0].set_title('Synthetic TESS Lightcurve with Transit')\n    \n    # BLS Periodogram\n    axes[1].plot(bls_result.period.value, bls_result.power, 'b-')\n    axes[1].axvline(best_period.value, color='r', linestyle='--', \n                    label=f'Detected: {best_period.value:.3f} days')\n    axes[1].axvline(true_period, color='g', linestyle=':', \n                    label=f'True: {true_period} days', alpha=0.7)\n    axes[1].set_xlabel('Period (days)')\n    axes[1].set_ylabel('BLS Power')\n    axes[1].set_title('Box Least Squares Periodogram')\n    axes[1].legend()\n    \n    # Folded lightcurve\n    axes[2].plot(phase[sort_idx], flux_flat[sort_idx], 'k.', markersize=3, alpha=0.6)\n    axes[2].set_xlabel('Phase')\n    axes[2].set_ylabel('Flux')\n    axes[2].set_title(f'Folded Lightcurve (Period = {best_period.value:.3f} days)')\n    axes[2].axvline(0, color='r', linestyle='--', alpha=0.5)\n    \n    plt.tight_layout()\n    plt.savefig('synthetic_transit_analysis.png', dpi=150, bbox_inches='tight')\n    plt.show()\n    \n    return bls_result, best_period\n\n\n# Method 3: Advanced analysis with multiple transit detection\ndef advanced_transit_analysis(time, flux, period_range=(0.5, 20)):\n    \"\"\"\n    Advanced transit detection with multiple planet search\n    \"\"\"\n    from scipy.signal import medfilt\n    \n    # Preprocessing\n    flux_clean = flux[~np.isnan(flux)]\n    time_clean = time[~np.isnan(flux)]\n    \n    # Detrend\n    trend = medfilt(flux_clean, kernel_size=101)\n    flux_flat = flux_clean / trend\n    \n    # First transit detection\n    periods = np.linspace(period_range[0], period_range[1], 10000) * u.day\n    bls = BoxLeastSquares(time_clean * u.day, flux_flat)\n    bls_result = bls.power(periods, duration=[0.05