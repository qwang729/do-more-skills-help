{"task": "jpg-ocr-stat", "condition": "hard_distractor", "repeat": 0, "skill_ids": ["benchflow-ai--FFmpeg Audio Processing"], "retrieval_correct": false, "judged_pass": false, "judged_score": 1, "judge_reason": "Agent's solution lacks essential functionality like date parsing, currency extraction, and Excel output required by the verifier.", "solver_tokens": 1023, "judge_tokens": 1114, "solution_text": "```python\nimport cv2\nimport pytesseract\nfrom PIL import Image\nimport numpy as np\n\n# Install required packages: pip install pytesseract opencv-python pillow\n# Ensure Tesseract OCR is installed (https://tesseract-ocr.github.io/tessdoc/Installation.html)\n\ndef extract_receipt_text(image_path):\n    # Read image\n    img = cv2.imread(image_path)\n    \n    # Preprocess: Grayscale, threshold, and denoise\n    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)\n    blurred = cv2.GaussianBlur(gray, (5, 5), 0)\n    thresh = cv2.adaptiveThreshold(blurred, 255, cv2.ADAPTIVE_THRESH_GAUSSIAN_C, \n                                cv2.THRESH_BINARY, 11, 2)\n    \n    # Apply OCR\n    text = pytesseract.image_to_string(thresh, config='--psm 6 --oem 3')\n    \n    # Clean up and return\n    lines = [line.strip() for line in text.split('\\n') if line.strip()]\n    return \"\\n\".join(lines)\n\n# Example usage\nreceipt_text = extract_receipt_text(\"receipt.jpg\")\nprint(receipt_text)\n```", "solver_finish_reason": "stop"}
{"task": "jpg-ocr-stat", "condition": "random_wrong", "repeat": 0, "skill_ids": ["benchflow-ai--python-scala-functional"], "retrieval_correct": false, "judged_pass": false, "judged_score": 1, "judge_reason": "Agent's solution only extracts text without parsing date, amounts, or writing to Excel as required by the oracle.", "solver_tokens": 1542, "judge_tokens": 1149, "solution_text": "```python\nimport pytesseract\nfrom PIL import Image\nimport os\n\n# Ensure tesseract is installed (run this command in terminal before execution if needed)\n# sudo apt-get install tesseract-ocr\n# pip install pytesseract pillow\n\ndef process_receipt_image(image_path):\n    try:\n        # Open image and convert to grayscale\n        img = Image.open(image_path).convert('L')\n        \n        # Apply Otsu's thresholding for better text contrast\n        img = img.point(lambda x: 0 if x < 128 else 255, '1')\n        \n        # Extract text with Tesseract (PSM 6 = single column text)\n        text = pytesseract.image_to_string(\n            img,\n            config='--psm 6 --oem 3 -c tessedit_char_whitelist=0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ .,-$%#@'\n        )\n        \n        # Clean up empty lines\n        cleaned_text = \"\\n\".join(line for line in text.splitlines() if line.strip())\n        return cleaned_text\n    except Exception as e:\n        return f\"Error: {str(e)}\"\n\n# Example usage (replace with actual image path)\nif __name__ == \"__main__\":\n    image_path = \"receipt.jpg\"  # Replace with your image file\n    result = process_receipt_image(image_path)\n    print(result)\n```", "solver_finish_reason": "stop"}
