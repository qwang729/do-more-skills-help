ownload_tess_lightcurve(tic_id=\"261136679\", sector=14):\n    \"\"\"\n    Download TESS lightcurve for a given TIC ID and sector.\n    Default: TIC 261136679 (known planet host) Sector 14.\n    \"\"\"\n    print(f\"Downloading TESS data for TIC {tic_id}, Sector {sector}...\")\n    search_result = lk.search_lightcurve(\n        f\"TIC {tic_id}\",\n        mission=\"TESS\",\n        exptime=120  # 2-minute cadence\n    )\n    if len(search_result) == 0:\n        raise ValueError(f\"No data found for TIC {tic_id}\")\n\n    # Pick the requested sector or the first available\n    for i, row in enumerate(search_result):\n        if sector in str(row):\n            lc = search_result[i].download()\n            break\n    else:\n        lc = search_result[0].download()\n\n    print(f\"Downloaded {len(lc)} data points.\")\n    return lc\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 2. CONVERT TO ASTROPY TIMESERIES\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef to_astropy_timeseries(lc):\n    \"\"\"\n    Convert a lightkurve TPF/LightCurve object to an Astropy TimeSeries.\n    \"\"\"\n    # Clean NaNs and infinities\n    mask = np.isfinite(lc.time) & np.isfinite(lc.flux)\n    time_jd = lc.time[mask].value  # JD values\n    flux = lc.flux[mask].value\n    flux_err = lc.flux_err[mask].value if lc.flux_err is not None else np.ones_like(flux) * np.nanmedian(flux) * 0.001\n\n    # Normalize flux\n    median_flux = np.nanmedian(flux)\n    flux_norm = flux / median_flux\n    flux_err_norm = flux_err / median_flux\n\n    # Create Astropy Time object\n    time_obj = Time(time_jd, format='jd', scale='tdb')\n\n    # Build Astropy TimeSeries\n    ts = TimeSeries(\n        time=time_obj,\n        data={\n            'flux': flux_norm * u.dimensionless_unscaled,\n            'flux_err': flux_err_norm * u.dimensionless_unscaled,\n        }\n    )\n    print(f\"Astropy TimeSeries created with {len(ts)} entries.\")\n    print(f\"  Time range: {ts.time[0].iso} to {ts.time[-1].iso}\")\n    return ts\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 3. DETREND THE LIGHTCURVE\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef detrend_timeseries(ts, window_length=101, polyorder=2):\n    \"\"\"\n    Remove long-term trends using a Savitzky-Golay filter\n    (via scipy) applied to the Astropy TimeSeries.\n    \"\"\"\n    from scipy.signal import savgol_filter\n\n    flux = ts['flux'].value.copy()\n    time_days = (ts.time.jd - ts.time[0].jd)\n\n    # Sigma-clip outliers before fitting trend\n    clipped = sigma_clip(flux, sigma=3.0, maxiters=5)\n    good = ~clipped.mask\n\n    # Fit trend on clean data\n    trend = savgol_filter(flux[good], window_length=window_length, polyorder=polyorder)\n\n    # Interpolate trend to all points\n    from scipy.interpolate import interp1d\n    trend_interp = interp1d(\n        time_days[good], trend,\n        kind='linear', fill_value='extrapolate'\n    )\n    trend_all = trend_interp(time_days)\n\n    # Detrend\n    flux_detrended = flux / trend_all\n\n    # Create detrended TimeSeries\n    ts_detrended = TimeSeries(\n        time=ts.time,\n        data={\n            'flux': flux_detrended * u.dimensionless_unscaled,\n            'flux_err': ts['flux_err'].value / trend_all * u.dimensionless_unscaled,\n            'flux_raw': flux * u.dimensionless_unscaled,\n        }\n    )\n    print(\"Lightcurve detrended with Savitzky-Golay filter.\")\n    return ts_detrended\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 4. BLS PERIODOGRAM (TRANSIT DETECTION)\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef run_bls_periodogram(ts, min_period=0.5, max_period=15.0, nfreq=50000):\n    \"\"\"\n    Run Box Least Squares periodogram on the detrended lightcurve\n    to detect periodic transits.\n    \"\"\"\n    from astropy.timeseries import BoxLeastSquares\n\n    time_days = (ts.time.jd - ts.time[0].jd) * u.day\n    flux = ts['flux'].value\n    flux_err = ts['flux_err'].value\n\n    # Set up BLS model\n    bls = BoxLeastSquares(time_days, flux, dy=flux_err)\n\n    # Define period grid (logarithmically spaced for better coverage)\n    periods = np.linspace(min_period, max_period, nfreq) * u.day\n\n    # Duration grid: typical transit durations for close-in planets\n    durations = np.linspace(0.02, 0.3, 20) * u.day\n\n    print(f\"Running BLS periodogram over {nfreq} frequencies...\")\n    print(f\"  Period range: {min_period} - {max_period} days\")\n    print(f\"  Duration range: 0.02 - 0.3 days\")\n\n    # Compute periodogram\n    periodogram = bls.power(periods, durations)\n\n    # Find best period\n    best_idx = np.argmax(periodogram.power)\n    best_period = periodogram.period[best_idx].value\n    best_duration = periodogram.duration[best_idx].value\n    best_power = periodogram.power[best_idx]\n    best_depth = periodogram.depth[best_idx].value\n    best_t0 = periodogram.transit_time[best_idx].value\n\n    # Compute stats\n    stats = bls.compute_stats(best_period, best_duration * u.day, best_t0)\n\n    results = {\n        'period': best_period,\n        'period_err': (periodogram.period[1] - periodogram.period[0]).value,\n        'duration': best_duration,\n        'depth': best_depth,\n        'power': best_power,\n        't0': best_t0,\n        'periodogram': periodogram,\n        'stats': stats,\n    }\n\n    print(f\"\\n{'='*50}\")\n    print(f\"  BEST TRANSIT CANDIDATE\")\n    print(f\"{'='*50}\")\n    print(f\"  Period:       {best_period:.6f} days\")\n    print(f\"  Duration:     {best_duration:.4f} days ({best_duration*24:.2f} hours)\")\n    print(f\"  Depth:        {best_depth*1e3:.2f} ppt ({best_depth*100:.4f}%)\")\n    print(f\"  Power (S/N):  {best_power:.2f}\")\n    print(f\"  T0 (BJD-2457000): {best_t0:.4f}\")\n    if 'depth_sig' in stats:\n        print(f\"  Depth S/N:    {stats['depth_sig']:.2f}\")\n    print(f\"{'='*50}\\n\")\n\n    return results\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 5. PHASE-FOLD AND PLOT\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef plot_results(ts, results):\n    \"\"\"\n    Generate diagnostic plots: raw lightcurve, detrended,\n    periodogram, and phase-folded transit.\n    \"\"\"\n    time_days = (ts.time.jd - ts.time[0].jd)\n    flux = ts['flux'].value\n    period = results['period']\n    t0 = results['t0']\n    duration = results['duration']\n\n    fig, axes = plt.subplots(2, 2, figsize=(16, 10))\n    fig.suptitle(\"TESS Transit Detection Analysis\", fontsize=16, fontweight='bold')\n\n    # --- Panel 1: Detrended lightcurve ---\n    ax1 = axes[0, 0]\n    ax1.scatter(time_days, flux, s=1, alpha=0.3, c='steelblue', label='Data')\n    # Mark transit windows\n    n_transits = int((time_days[-1] - t0) / period) + 1\n    for i in range(n_transits):\n        tc = t0 + i * period\n        ax1.axvspan(tc - duration/2, tc + duration/2, alpha=0.15, color='red')\n    ax1.set_xlabel(\"Time (days)\")\n    ax1.set_ylabel(\"Normalized Flux\")\n    ax1.set_title(\"Detrended Lightcurve with Transit Windows\")\n    ax1.legend()\n\n    # --- Panel 2: BLS Periodogram ---\n    ax2 = axes[0, 1]\n    pg = results['periodogram']\n    ax2.plot(pg.period.value, pg.power, 'k-', lw=0.5, alpha=0.7)\n    ax2.axvline(results['period'], color='red', ls='--', lw=2,\n                label=f\"P = {results['period']:.4f} d\")\n    ax2.set_xlabel(\"Period (days)\")\n    ax2.set_ylabel(\"BLS Power\")\n    ax2.set_title(\"BLS Periodogram\")\n    ax2.legend()\n\n    # --- Panel 3: Phase-folded transit ---\n    ax3 = axes[1, 0]\n    phase = ((time_days - t0) / period) % 1.0\n    phase[phase > 0.5] -= 1.0  # center on transit\n    sort_idx = np.argsort(phase)\n    ax3.scatter(phase[sort_idx] * 24, flux[sort_idx], s=2, alpha=0.3, c='steelblue')\n\n    # Bin the phase-folded data\n    n_bins = 50\n    bin_edges = np.linspace(-0.5, 0.5, n_bins + 1)\n    bin_centers = 0.5 * (bin_edges[:-1] + bin_edges[1:])\n    bin_means = np.zeros(n_bins)\n    for i in range(n_bins):\n        mask = (phase >= bin_edges[i]) & (phase < bin_edges[i+1])\n        if np.any(mask):\n            bin_means[i] = np.mean(flux[mask])\n        else:\n            bin_means[i] = np.nan\n    ax3.plot(bin_centers * 24, bin_means, 'ro-', ms=4, lw=2, label='Binned')\n    ax3.set_xlabel(\"Phase (hours from mid-transit)\")\n    ax3.set_ylabel(\"Normalized Flux\")\n    ax3.set_title(f\"Phase-folded Transit (P={results['period']:.4f} d)\")\n    ax3.legend()\n\n    # --- Panel 4: Transit model overlay ---\n    ax4 = axes[1, 1]\n    # Create a simple box model\n    model = np.ones_like(phase)\n    in_transit = np.abs(phase) < (duration / period / 2)\n    model[in_transit] = 1.0 - results['depth']\n    ax4.scatter(phase * 24, flux, s=1, alpha=0.2, c='steelblue')\n    ax4.plot(phase[sort_idx] * 24, model[sort_idx], 'r-', lw=2, label='Box Model')\n    ax4.set_xlabel(\"Phase (hours)\")\n    ax4.set_ylabel(\"Normalized Flux\")\n    ax4.set_title(\"Transit Model Fit\")\n    ax4.legend()\n    ax4.set_ylim(1 - 2*results['depth'], 1 + 0.5*results['depth'])\n\n    plt.tight_layout()\n    plt.savefig(\"tess_transit_analysis.png\", dpi=150, bbox_inches='tight')\n    plt.show()\n    print(\"Plot saved to tess_transit_analysis.png\")\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# 6. MULTI-TRANSIT VERIFICATION\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef verify_transit(ts, results, min_transits=2, snr_threshold=7.0):\n    \"\"\"\n    Verify the detected transit by checking:\n    - Multiple transits observed\n    - S/N ratio above threshold\n    - Consistent depth across transits\n    \"\"\"\n    time_days = (ts.time.jd - ts.time[0].jd)\n    flux = ts['flux'].value\n    period = results['period']\n    t0 = results['t0']\n    duration = results['duration']\n    depth = results['depth']\n\n    # Count transits\n    n_transits = 0\n    transit_depths = []\n    for i in range(100):\n        tc = t0 + i * period\n        if tc > time_days[-1]:\n            break\n        mask = np.abs(time_days - tc) < duration / 2\n        if np.sum(mask) > 3:\n            n_transits += 1\n            transit_depths.append(1.0 - np.median(flux[mask]))\n\n    transit_depths = np.array(transit_depths)\n\n    # S/N calculation\n    out_of_transit = np.ones_like(flux, dtype=bool)\n    for i in range(100):\n        tc = t0 + i * period\n        if tc > time_days[-1]:\n            break\n        mask = np.abs(time_days - tc) < duration / 2\n        out_of_transit &= ~mask\n    noise = np.std(flux[out_of_transit])\n    snr = depth / noise * np.sqrt(np.sum(~out_of_transit))\n\n    print(f\"\\n{'='*50}\")\n    print(f\"  TRANSIT VERIFICATION\")\n    print(f\"{'='*50}\")\n    print(f\"  Number of transits:  {n_transits}\")\n    print(f\"  Mean depth:          {np.mean(transit_depths)*1e3:.2f} ppt\")\n    print(f\"  Depth scatter:       {np.std(transit_depths)*1e3:.2f} ppt\")\n    print(f\"  S/N ratio:           {snr:.2f}\")\n    print(f\"  Noise (per point):   {noise*1e6:.1f} ppm\")\n\n    if n_transits >= min_transits and snr >= snr_threshold:\n        print(f\"  Status: \u2705 CANDIDATE CONFIRMED\")\n    else:\n        print(f\"  Status: \u26a0\ufe0f  NEEDS FURTHER VALIDATION\")\n        if n_transits < min_transits:\n            print(f\"    - Only {n_transits} transit(s) observed (need \u2265{min_transits})\")\n        if snr < snr_threshold:\n            print(f\"    - S/N = {snr:.1f} below threshold {snr_threshold}\")\n    print(f\"{'='*50}\\n\")\n\n    return {\n        'n_transits': n_transits,\n        'snr': snr,\n        'noise_ppm': noise * 1e6,\n        'confirmed': n_transits >= min_transits and snr >= snr_threshold,\n    }\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# MAIN PIPELINE\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\ndef main():\n    print(\"=\" * 60)\n    print(\"  TESS LIGHTCURVE TRANSIT DETECTION PIPELINE\")\n    print(\"  Using Astropy Timeseries + BLS Periodogram\")\n    print(\"=\" * 60)\n\n    # Step 1: Download data\n    lc = download_tess_lightcurve(tic_id=\"261136679\", sector=14)\n\n    # Step 2: Convert to Astropy TimeSeries\n    ts = to_astropy_timeseries(lc)\n\n    # Step 3: Detrend\n    ts_detrended = detrend_timeseries(ts, window_length=101, polyorder=2)\n\n    # Step 4: BLS Periodogram\n    results = run_bls_periodogram(\n        ts_detrended,\n        min_period=0.5,\n        max_period=15.0,\n        nfreq=50000\n    )\n\n    # Step 5: Verify transit\n    verification = verify_transit(ts_detrended, results)\n\n    # Step 6: Plot\n    plot_results(ts_detrended, results)\n\n    # Summary\n    print(\"\\n\" + \"=\" * 60)\n    print(\"  ANALYSIS COMPLETE\")\n    print(\"=\" * 60)\n    print(f\"  Target: TIC 261136679\")\n    print(f\"  Detected Period: {results['period']:.6f} days\")\n    print(f\"  Transit Depth:   {results['depth']*1e3:.2f} ppt\")\n    print(f\"  S/N:             {verification['snr']:.1f}\")\n    print(f\"  Confirmed:       {verification['confirmed']}\")\n    print(\"=\" * 60)\n\n    return ts_detrended, results, verification\n\n\nif __name__ == \"__main__\":\n    ts, results, verification = main()\n```\n\n## How It Works\n\n| Step | Description | Key Astropy Component |\n|------|-------------|----------------------|\n| **1. Download** | Fetches 2-min cadence TESS data via `lightkurve` | `lk.search_lightcurve()` |\n| **2. Convert** | Builds an `astropy.timeseries.TimeSeries` with `Time` objects | `TimeSeries`, `Time` |\n| **3. Detrend** | Removes stellar variability with Savitzky-Golay filter | `sigma_clip`, `savgol_filter` |\n| **4. BLS** | Box Least Squares periodogram scans for periodic dips | `BoxLeastSquares` |\n| **5. Verify** | Checks multi-transit consistency and S/N | Custom verification |\n| **6. Plot** | Phase-folded transit + periodogram diagnostics | `matplotlib` |\n\n## Key Astropy Timeseries Features Used\n\n- **`astropy.timeseries.TimeSeries`** \u2014 Core container with `Time` index and column data with units\n- **`astropy.timeseries.BoxLeastSquares`** \u2014 Optimized BLS periodogram for transit detection\n- **`astropy.time.Time`** \u2014 Proper BJD/TDB time handling for precise ephemeris\n- **`astropy.stats.sigma_clip`** \u2014 Robust outlier rejection\n- **`astropy.units`** \u2014 Dimensional analysis throughout the pipeline\n\n## Expected Output\n\nFor TIC 261136679 (TOI-1726), the pipeline should detect:\n- **Period \u2248 7.17 days** (known hot Jupiter)\n- **Depth \u2248 2\u20133 ppt** (~0.2\u20130.3%)\n- **Multiple transits** across the sector baseline\n- Diagnostic plot saved as `tess_transit_analysis.png`", "solver_finish_reason": "stop"}
