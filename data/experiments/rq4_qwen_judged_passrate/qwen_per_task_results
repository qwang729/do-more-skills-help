.debug(f\"  Include dirs: {ext.include_dirs}\")\n+        logger.debug(f\"  Library dirs: {ext.library_dirs}\")\n+        logger.debug(f\"  Libraries: {ext.libraries}\")\n+        logger.debug(f\"  Extra compile args: {ext.extra_compile_args}\")\n+        logger.debug(f\"  Extra link args: {ext.extra_link_args}\")\n+\n         # Add debug flags\n         if hasattr(ext, 'extra_compile_args'):\n             ext.extra_compile_args.extend(['-g', '-O0', '-DDEBUG'])\n@@ -30,6 +45,8 @@\n         if sys.platform == 'win32':\n             ext.extra_compile_args.extend(['/Zi', '/Od'])\n \n+        logger.debug(f\"Final compile args: {ext.extra_compile_args}\")\n+\n         super().build_extension(ext)\n \n setup(\nPATCH\n\n# Generate a patch for Makefile debugging\ncat > \"$PATCH_DIR/002-debug-makefile.patch\" << 'PATCH'\ndiff --git a/Makefile b/Makefile\nindex 111aaaa..222bbbb 100644\n--- a/Makefile\n+++ b/Makefile\n@@ -5,6 +5,12 @@\n PYTHON ?= python3\n PIP ?= pip3\n \n+# Debug variables\n+VERBOSE := 1\n+DEBUG_FLAGS := -g -O0 -DDEBUG_BUILD\n+BUILD_LOG := build_debug.log\n+\n+.PHONY: debug-build debug-clean debug-info\n \n all: build\n \n@@ -15,8 +21,24 @@\n build:\n \t$(PYTHON) setup.py build\n \n+debug-build:\n+\t@echo \"=== Debug Build Started ===\" | tee $(BUILD_LOG)\n+\t@echo \"Python: $$(python3 --version)\" | tee -a $(BUILD_LOG)\n+\t@echo \"Platform: $$(uname -a)\" | tee -a $(BUILD_LOG)\n+\t@echo \"Compiler: $$(cc --version | head -1)\" | tee -a $(BUILD_LOG)\n+\t@echo \"CFLAGS: $(CFLAGS)\" | tee -a $(BUILD_LOG)\n+\t@echo \"LDFLAGS: $(LDFLAGS)\" | tee -a $(BUILD_LOG)\n+\t@echo \"LD_LIBRARY_PATH: $(LD_LIBRARY_PATH)\" | tee -a $(BUILD_LOG)\n+\tCFLAGS=\"$(CFLAGS) $(DEBUG_FLAGS)\" \\\n+\tLDFLAGS=\"$(LDFLAGS) -g\" \\\n+\t$(PYTHON) setup.py build --verbose 2>&1 | tee -a $(BUILD_LOG)\n+\t@echo \"=== Debug Build Complete ===\" | tee -a $(BUILD_LOG)\n+\n clean:\n \t$(PYTHON) setup.py clean --all\n \trm -rf build/ dist/ *.egg-info/\n \n+debug-clean: clean\n+\trm -f $(BUILD_LOG) build_debug.log\n+\n+debug-info:\n+\t@$(PYTHON) -c \"import sysconfig; print(sysconfig.get_config_vars())\"\n+\t@$(PYTHON) -c \"import sys; print(sys.path)\"\n+\n test:\n \t$(PYTHON) -m pytest tests/\nPATCH\n\n# Generate a patch for conftest.py build debugging\ncat > \"$PATCH_DIR/003-debug-conftest.patch\" << 'PATCH'\ndiff --git a/tests/conftest.py b/tests/conftest.py\nindex 333cccc..444dddd 100644\n--- a/tests/conftest.py\n+++ b/tests/conftest.py\n@@ -1,5 +1,42 @@\n import pytest\n+import sys\n+import os\n+import subprocess\n+import logging\n+\n+logger = logging.getLogger('build_test_debug')\n+\n+\n+def pytest_configure(config):\n+    \"\"\"Log build environment at test start.\"\"\"\n+    logger.info(\"=== Build Debug Info ===\")\n+    logger.info(f\"Python executable: {sys.executable}\")\n+    logger.info(f\"Python version: {sys.version}\")\n+    logger.info(f\"Platform: {sys.platform}\")\n+    logger.info(f\"Path: {sys.path}\")\n+\n+    # Check if our extension modules are importable\n+    try:\n+        import importlib\n+        for module_name in _get_extension_modules():\n+            try:\n+                mod = importlib.import_module(module_name)\n+                logger.info(f\"Module {module_name}: OK (file: {mod.__file__})\")\n+            except ImportError as e:\n+                logger.error(f\"Module {module_name}: FAILED - {e}\")\n+    except Exception as e:\n+        logger.warning(f\"Could not check extension modules: {e}\")\n+\n+\n+def _get_extension_modules():\n+    \"\"\"Discover extension modules from setup.py.\"\"\"\n+    modules = []\n+    try:\n+        result = subprocess.run(\n+            [sys.executable, 'setup.py', '--name'],\n+            capture_output=True, text=True, timeout=10\n+        )\n+        if result.returncode == 0:\n+            pkg_name = result.stdout.strip()\n+            modules.append(pkg_name)\n+    except Exception:\n+        pass\n+    return modules\n \n \n @pytest.fixture\nPATCH\n\necho \"=== Patches generated in $PATCH_DIR ===\"\nls -la \"$PATCH_DIR\"\necho \"\"\necho \"To apply a patch:\"\necho \"  git apply $PATCH_DIR/001-debug-setup.patch\"\necho \"  git apply $PATCH_DIR/002-debug-makefile.patch\"\necho \"  git apply $PATCH_DIR/003-debug-conftest.patch\"\necho \"\"\necho \"To reverse a patch:\"\necho \"  git apply -R $PATCH_DIR/001-debug-setup.patch\"\n```\n\n## 2. Python Build Debug Analyzer\n\n```python\n#!/usr/bin/env python3\n\"\"\"\nbuild_debug_analyzer.py - Analyze Python build failures and generate fix patches.\n\nUsage:\n    python3 build_debug_analyzer.py <build_log_file>\n    python3 build_debug_analyzer.py --generate-patch <error_type>\n\"\"\"\n\nimport sys\nimport os\nimport re\nimport subprocess\nimport argparse\nfrom pathlib import Path\nfrom datetime import datetime\n\n\nclass BuildErrorAnalyzer:\n    \"\"\"Analyzes Python build logs and generates diagnostic patches.\"\"\"\n\n    COMMON_ERRORS = {\n        'missing_header': {\n            'pattern': r'fatal error: (\\S+\\.h): No such file or directory',\n            'fix': 'Add missing development package (e.g., python3-dev, libssl-dev)',\n            'patch_template': '''diff --git a/setup.py b/setup.py\n--- a/setup.py\n+++ b/setup.py\n@@ -EXT@@\n+import subprocess\n+import sysconfig\n+\n+def check_header(header_name):\n+    \"\"\"Check if a C header is available.\"\"\"\n+    include_dirs = sysconfig.get_path('include')\n+    for inc_dir in [include_dirs, '/usr/include', '/usr/local/include']:\n+        if os.path.exists(os.path.join(inc_dir, header_name)):\n+            return True\n+    return False\n+\n # In your Extension definition:\n+# if not check_header('{HEADER}'):\n+#     print(f\"WARNING: {HEADER} not found. Install the development package.\")\n+#     sys.exit(1)\n'''\n        },\n        'linker_error': {\n            'pattern': r'undefined reference to `(\\w+)\\'',\n            'fix': 'Add missing library to libraries list in Extension',\n            'patch_template': '''diff --git a/set