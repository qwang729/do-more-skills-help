gerprint\n        fp = AllChem.GetHashedTopologicalTorsionFingerprintAsBitVect(mol, nBits=n_bits)\n    else:\n        raise ValueError(f\"Unknown fingerprint type: {fp_type}\")\n    \n    return fp\n\n\ndef tanimoto_similarity(fp1, fp2):\n    \"\"\"\n    Compute Tanimoto similarity between two fingerprints.\n    \n    Tanimoto coefficient = c / (a + b - c)\n    where a = bits set in fp1, b = bits set in fp2, c = bits set in both\n    \"\"\"\n    if fp1 is None or fp2 is None:\n        return 0.0\n    return DataStructs.TanimotoSimilarity(fp1, fp2)\n\n\ndef bulk_tanimoto_similarity(query_fp, target_fps):\n    \"\"\"\n    Compute Tanimoto similarity of a query fingerprint against a list of target fingerprints.\n    Uses RDKit's optimized BulkTanimotoSimilarity for speed.\n    \"\"\"\n    if query_fp is None:\n        return [0.0] * len(target_fps)\n    return DataStructs.BulkTanimotoSimilarity(query_fp, target_fps)\n\n\ndef similarity_search(query_smiles, database_smiles, fp_type=\"morgan\", radius=2, \n                      n_bits=2048, top_n=10):\n    \"\"\"\n    Perform a Tanimoto similarity search of a query SMILES against a database of SMILES.\n    \n    Parameters:\n        query_smiles: SMILES string of the query molecule\n        database_smiles: List of SMILES strings to search against\n        fp_type: Fingerprint type ('morgan', 'rdkit', 'maccs', 'topological')\n        radius: Morgan fingerprint radius\n        n_bits: Fingerprint bit length\n        top_n: Number of top results to return\n    \n    Returns:\n        List of tuples: (smiles, similarity_score, mol_name) sorted by descending similarity\n    \"\"\"\n    # Parse query\n    query_mol = smiles_to_mol(query_smiles)\n    if query_mol is None:\n        raise ValueError(f\"Invalid query SMILES: {query_smiles}\")\n    \n    query_fp = generate_fingerprint(query_mol, fp_type=fp_type, radius=radius, n_bits=n_bits)\n    \n    # Parse database and generate fingerprints\n    database_fps = []\n    valid_smiles = []\n    for smi in database_smiles:\n        mol = smiles_to_mol(smi)\n        if mol is not None:\n            fp = generate_fingerprint(mol, fp_type=fp_type, radius=radius, n_bits=n_bits)\n            database_fps.append(fp)\n            valid_smiles.append(smi)\n    \n    # Bulk similarity computation\n    similarities = bulk_tanimoto_similarity(query_fp, database_fps)\n    \n    # Sort results by descending similarity\n    results = list(zip(valid_smiles, similarities))\n    results.sort(key=lambda x: x[1], reverse=True)\n    \n    return results[:top_n]\n\n\n# ============================================================\n# Example Usage with PubChem-style SMILES\n# ============================================================\n\nif __name__ == \"__main__\":\n    # Sample PubChem compounds (SMILES from PubChem database)\n    pubchem_compounds = {\n        \"Aspirin\": \"CC(=O)Oc1ccccc1C(=O)O\",\n        \"Ibuprofen\": \"CC(C)Cc1ccc(cc1)C(C)C(=O)O\",\n        \"Acetaminophen\": \"CC(=O)Nc1ccc(O)cc1\",\n        \"Caffeine\": \"Cn1c(=O)c2c(ncn2C)n(C)c1=O\",\n        \"Naproxen\": \"COc1ccc2cc(ccc2c1)[C@@H](C)C(=O)O\",\n        \"Penicillin_G\": \"CC1(C)SC2C(NC(=O)Cc3ccccc3)C(=O)N2C1C(=O)O\",\n        \"Morphine\": \"CN1CCC23C4C1CC5=C2C(=C(C=C5)O)OC3C(C=C4)O\",\n        \"Diazepam\": \"CN1C(=O)CN=C(c2ccccc2)c3ccClc(Cl)c13\",\n        \"Omeprazole\": \"COc1nc(C)cs1C(S(=O)Cc2ncc(C)nc2O)Nc3ncc(C)sc3C\",\n        \"Metformin\": \"CN(C)C(=N)NC(=N)N\",\n        \"Atorvastatin\": \"CC(C)c1n(C)c(c(c1C(=O)Nc2ccc(F)cc2)C)C[C@@H](C[C@@H](CC(=O)O)O)O\",\n        \"Lisinopril\": \"C[C@H](N[C@@H](CCC(=O)O)C(=O)N1CCCC1C(=O)O)CC(=O)O\",\n        \"Warfarin\": \"CC(=O)CC(c1ccccc1)c2ccccc2O\",\n        \"Clopidogrel\": \"Clc1ccccc1C2CCSC(C(=O)OC)=N2\",\n        \"Losartan\": \"CCCCc1nc(c(c1CC2C(=O)N(C2)C)c3ccc(Cl)cc3)c4ccc(C)cc4\",\n        \"Sildenafil\": \"CCCC1=NN(C2=C1N=C(NC2=O)C3=C(C=CC(=C3)S(=O)(=O)CC)N4CCN(CC4)C)C\",\n        \"Fluoxetine\": \"CNCCC(C1=CC=CC=C1)OC2=CC=C