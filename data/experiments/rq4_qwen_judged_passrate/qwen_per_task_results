    \"\"\"\n        self.num_docs = len(documents)\n        self.doc_ids = list(documents.keys())\n        \n        # Prepare data for parallel processing\n        doc_items = list(documents.items())\n        \n        # Process documents in parallel\n        with mp.Pool(processes=self.num_workers) as pool:\n            results = pool.map(process_document, doc_items)\n        \n        # Aggregate results\n        document_freq = defaultdict(int)  # term -> number of docs containing term\n        doc_term_freq = {}  # doc_id -> {term: frequency}\n        \n        for doc_id, term_freq, unique_terms in results:\n            doc_term_freq[doc_id] = term_freq\n            self.doc_lengths[doc_id] = sum(term_freq.values())\n            \n            for term in unique_terms:\n                document_freq[term] += 1\n        \n        # Calculate IDF for each term\n        for term, df in document_freq.items():\n            self.idf[term] = math.log(self.num_docs / df)\n        \n        # Build inverted index with TF-IDF scores\n        for doc_id, term_freq in doc_term_freq.items():\n            doc_len = self.doc_lengths[doc_id]\n            \n            for term, freq in term_freq.items():\n                # TF: normalized term frequency\n                tf = freq / doc_len if doc_len > 0 else 0\n                # TF-IDF score\n                tfidf = tf * self.idf[term]\n                \n                if term not in self.inverted_index:\n                    self.inverted_index[term] = []\n                self.inverted_index[term].append((doc_id, tfidf))\n        \n        # Sort postings by doc_id for each term\n        for term in self.inverted_index:\n            self.inverted_index[term].sort(key=lambda x: x[0])\n    \n    def search(self, query: str, top_k: int = 10) -> List[Tuple[int, float]]:\n        \"\"\"Search for documents matching the query.\n        \n        Returns: List of (doc_id, score) tuples sorted by score descending\n        \"\"\"\n   