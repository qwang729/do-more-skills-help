   cv2.circle(vis, p0, 3, (0, 255, 0), -1)\n            cv2.line(vis, p0, p1, (0, 128, 255), 1)\n\n    if motion is not None:\n        info = [\n            f\"Translation: ({motion['dx']:.1f}, {motion['dy']:.1f})\",\n            f\"Rotation: {motion['angle']:.2f} deg\",\n            f\"Scale: {motion['scale']:.4f}\",\n            f\"Mean flow: {motion['mean_flow']:.2f} px\",\n            f\"Points tracked: {motion['num_points']}\"\n        ]\n        for i, text in enumerate(info):\n            cv2.putText(vis, text, (10, 30 + i * 25),\n                        cv2.FONT_HERSHEY_SIMPLEX, 0.6, (255, 255, 255), 2)\n    return vis\n\n\ndef process_video(video_path, output_path=None, grid_spacing=50, show=True):\n    \"\"\"\n    Main pipeline: estimate camera motion from video using sparse optical flow.\n    \n    Args:\n        video_path: path to input video\n        output_path: optional path to save output video with flow visualization\n        grid_spacing: spacing of sparse mask grid\n        show: whether to display frames in a window\n    \"\"\"\n    cap, fps, width, height = load_video(video_path)\n    print(f\"Video: {width}x{height} @ {fps:.1f} fps\")\n\n    # Create sparse mask\n    sparse_mask = create_sparse_mask(height, width, grid_spacing=grid_spacing)\n    print(f\"Sparse mask coverage: {np.sum(sparse_mask > 0) / sparse_mask.size * 100:.1f}%\")\n\n    # Video writer for output\n    writer = None\n    if output_path:\n        fourcc = cv2.VideoWriter_fourcc(*'mp4v')\n        writer = cv2.VideoWriter(output_path, fourcc, fps, (width, height))\n\n    ret, prev_frame = cap.read()\n    if not ret:\n        raise ValueError(\"Cannot read first frame\")\n    prev_gray = cv2.cvtColor(prev_frame, cv2.COLOR_BGR2GRAY)\n\n    # Detect initial features within sparse mask\n    prev_points = detect_features(prev_gray, sparse_mask)\n    print(f\"Initial features detected: {len(prev_points)}\")\n\n    # Accumulate camera trajectory\n    trajectory = np.array([[0.0, 0.0]])  # cumulative translation\n    all_motions = []\n\n    frame_idx = 0\n    while True:\n        ret, curr_frame = cap.read()\n        if not ret:\n            break\n\n        curr_gray = cv2.cvtColor(curr_frame, cv2.COLOR_BGR2GRAY)\n\n        # Compute sparse optical flow\n        good_prev, good_curr = compute_sparse_optical_flow(\n            prev_gray, curr_gray, prev_points, sparse_mask\n        )\n\n        # Estimate camera motion\n        motion = estimate_camera_motion(good_prev, good_curr)\n\n        if motion is not None:\n            # Update cumulative trajectory\n            new_pos = trajectory[-1] + motion['translation']\n            trajectory = np.vstack([trajectory, new_pos])\n            all_motions.append(motion)\n\n            if frame_idx % 30 == 0:\n                print(f\"Frame {frame_idx}: dx={motion['dx']:.2f}, \"\n                      f\"dy={motion['dy']:.2f}, \"\n                      f\"angle={motion['angle']:.3f}\u00b0, \"\n                      f\"scale={motion['scale']:.4f}, \"\n                      f\"pts={motion['num_points']}\")\n\n        # Visualize\n        vis = visualize_flow(curr_frame, good_prev, good_curr, motion)\n        if writer:\n            writer.write(vis)\n        if show:\n            cv2.imshow('Camera Motion Estimation', vis)\n            if cv2.waitKey(1) & 0xFF == 27:\n                break\n\n        # Prepare next iteration\n        prev_gray = curr_gray.copy()\n\n        # Re-detect features periodically or when too few are tracked\n        if good_curr is not None and len(good_curr) > 10:\n            prev_points = good_curr.reshape(-1, 1, 2)\n        else:\n            prev_points = detect_features(prev_gray, sparse_mask)\n\n        frame_idx += 1\n\n    cap.release()\n    if writer:\n        writer.release()\n    if show:\n        cv2.destroyAllWindows()\n\n    # --- Summary ---\n    print(f\"\\n{'='*50}\")\n    print(f\"Processed {frame_idx} frames\")\n    print(f\"Total frames with motion estimate