summary: Dict[str, int] = field(default_factory=dict)\n\n\n# \u2500\u2500\u2500 BibTeX Parser \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nclass BibTeXParser:\n    \"\"\"Robust BibTeX parser handling common formatting variations.\"\"\"\n\n    # Regex patterns\n    ENTRY_PATTERN = re.compile(\n        r'@(\\w+)\\s*\\{([^,]*),', re.IGNORECASE\n    )\n    FIELD_PATTERN = re.compile(\n        r'(\\w+)\\s*=\\s*(?:\\{((?:[^{}]|\\{[^{}]*\\})*)\\}|\"([^\"]*)\"|(\\d+))',\n        re.IGNORECASE | re.DOTALL\n    )\n    COMMENT_PATTERN = re.compile(r'%.*$', re.MULTILINE)\n    STRING_DEF_PATTERN = re.compile(\n        r'@\\w*string\\s*\\{\\s*(\\w+)\\s*=\\s*\\{([^}]*)\\}', re.IGNORECASE\n    )\n\n    def __init__(self):\n        self.string_defs: Dict[str, str] = {}\n        self.entries: List[BibEntry] = []\n        self.preamble: str = \"\"\n\n    def parse(self, text: str) -> List[BibEntry]:\n        \"\"\"Parse a BibTeX string and return list of entries.\"\"\"\n        # Remove comments\n        text_clean = self.COMMENT_PATTERN.sub('', text)\n\n        # Extract @string definitions\n        for m in self.STRING_DEF_PATTERN.finditer(text_clean):\n            self.string_defs[m.group(1).lower()] = m.group(2)\n\n        # Extract entries\n        self.entries = []\n        pos = 0\n        while pos < len(text_clean):\n            match = self.ENTRY_PATTERN.search(text_clean, pos)\n            if not match:\n                break\n\n            entry_type = match.group(1).lower()\n            cite_key = match.group(2).strip()\n            line_num = text_clean[:match.start()].count('\\n') + 1\n\n            if entry_type in ('string', 'preamble', 'comment'):\n                pos = match.end()\n                continue\n\n            # Find the matching closing brace\n            brace_start = match.end() - 1\n            brace_end = self._find_matching_brace(text_clean, brace_start)\n            if brace_end == -1:\n                pos = match.end()\n                continue\n\n            entry_body = text_clean[brace_start + 1:brace_end]\n            fields = self._parse_fields(entry_body)\n\n            entry = BibEntry(\n                entry_type=entry_type,\n                cite_key=cite_key,\n                fields=fields,\n                line_number=line_num,\n                raw=text_clean[match.start():brace_end + 1]\n            )\n            self.entries.append(entry)\n            pos = brace_end + 1\n\n        return self.entries\n\n    def parse_file(self, filepath: str) -> List[BibEntry]:\n        \"\"\"Parse a .bib file.\"\"\"\n        with open(filepath, 'r', encoding='utf-8', errors='replace') as f:\n            return self.parse(f.read())\n\n    def _find_matching_brace(self, text: str, start: int) -> int:\n        \"\"\"Find the matching closing brace for an opening brace at `start`.\"\"\"\n        depth = 0\n        i = start\n        while i < len(text):\n            if text[i] == '{':\n                depth += 1\n            elif text[i] == '}':\n                depth -= 1\n                if depth == 0:\n                    return i\n            i += 1\n        return -1\n\n    def _parse_fields(self, body: str) -> Dict[str, str]:\n        \"\"\"Parse key=value fields from an entry body.\"\"\"\n        fields = {}\n        for m in self.FIELD_PATTERN.finditer(body):\n            key = m.group(1).lower()\n            # Value is in group 2 (braced), 3 (quoted), or 4 (numeric)\n            value = m.group(2) or m.group(3) or m.group(4) or \"\"\n            value = value.strip()\n            # Resolve string definitions\n            if value.lower() in self.string_defs:\n                value = self.string_defs[value.lower()]\n            fields[key] = value\n        return fields\n\n\n# \u2500\u2500\u2500 Citation Verifier \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nclass CitationVerifier:\n    \"\"\"Verifies BibTeX entries for academic citation standards.\"\"\"\n\n    # Required fields per entry type (based on standard BibTeX conventions)\n    REQUIRED_FIELDS = {\n        'article':    ['author', 'title', 'journal', 'year'],\n        'book':       ['author', 'title', 'publisher', 'year'],\n        'inproceedings': ['author', 'title', 'booktitle', 'year'],\n        'conference': ['author', 'title', 'booktitle', 'year'],\n        'incollection': ['author', 'title', 'booktitle', 'publisher', 'year'],\n        'phdthesis':  ['author', 'title', 'school', 'year'],\n        'mastersthesis': ['author', 'title', 'school', 'year'],\n        'techreport': ['author', 'title', 'institution', 'year'],\n        'misc':       [],\n        'unpublished':['author', 'title', 'note'],\n        'proceedings':['title', 'year'],\n        'booklet':    ['title'],\n        'manual':     ['title'],\n    }\n\n    # Optional but recommended fields\n    RECOMMENDED_FIELDS = {\n        'article':    ['volume', 'number', 'pages', 'doi', 'url'],\n        'book':       ['editor', 'volume', 'series', 'address', 'edition', 'isbn', 'doi'],\n        'inproceedings': ['editor', 'pages', 'publisher', 'address', 'doi', 'url'],\n        'conference': ['editor', 'pages', 'publisher', 'address', 'doi', 'url'],\n        'incollection': ['editor', 'chapter', 'pages', 'address', 'edition', 'doi'],\n        'phdthesis':  ['address', 'month', 'type'],\n        'mastersthesis': ['address', 'month', 'type'],\n        'techreport': ['number', 'address', 'month'],\n    }\n\n    # DOI pattern\n    DOI_PATTERN = re.compile(r'^10\\.\\d{4,9}/[^\\s]+$')\n    # ISBN pattern (simplified)\n    ISBN_PATTERN = re.compile(r'^(?:97[89])?\\d{9}[\\dXx]$')\n    # URL pattern\n    URL_PATTERN = re.compile(r'^https?://[^\\s]+$')\n    # Year pattern\n    YEAR_PATTERN = re.compile(r'^\\d{4}$')\n    # Author name pattern (Last, First or First Last)\n    AUTHOR_PATTERN = re.compile(r'^[A-Za-z\u00c0-\u00ff\\s\\.\\-\\']+(,\\s*[A-Za-z\u00c0-\u00ff\\s\\.\\-\\']+)*$')\n\n    def __init__(self):\n        self.report = VerificationReport()\n\n    def verify(self, entries: List[BibEntry]) -> VerificationReport:\n        \"\"\"Run all verification checks on a list of BibTeX entries.\"\"\"\n        self.report = VerificationReport()\n        self.report.total_entries = len(entries)\n\n        # Count entries by type\n        type_counts = Counter(e.entry_type for e in entries)\n        self.report.entries_by_type = dict(type_counts)\n\n        # Run checks\n        self._check_duplicates(entries)\n        for entry in entries:\n            self._check_required_fields(entry)\n            self._check_recommended_fields(entry)\n            self._check_year(entry)\n            self._check_authors(entry)\n            self._check_title(entry)\n            self._check_doi(entry)\n            self._check_url(entry)\n            self._check_isbn(entry)\n            self._check_pages(entry)\n            self._check_cite_key(entry)\n            self._check_crossref(entries, entry)\n            self._check_empty_fields(entry)\n\n        # Build summary\n        self.report.summary = {\n            'errors': sum(1 for i in self.report.issues if i.severity == 'ERROR'),\n            'warnings': sum(1 for i in self.report.issues if i.severity == 'WARNING'),\n            'info': sum(1 for i in self.report.issues if i.severity == 'INFO'),\n            'total_issues': len(self.report.issues),\n        }\n\n        return self.report\n\n    def _add_issue(self, cite_key: str, severity: str, category: str,\n                   message: str, line: int = 0):\n        self.report.issues.append(\n            VerificationIssue(cite_key, severity, category, message, line)\n        )\n\n    # \u2500\u2500 Individual Checks \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n    def _check_duplicates(self, entries: List[BibEntry]):\n        \"\"\"Detect duplicate cite keys.\"\"\"\n        key_map = defaultdict(list)\n        for e in entries:\n            key_map[e.cite_key.lower()].append(e)\n        for key, elist in key_map.items():\n            if len(elist) > 1:\n                self.report.duplicates.append([e.cite_key for e in elist])\n                for e in elist:\n                    self._add_issue(\n                        e.cite_key, \"ERROR\", \"DUPLICATE\",\n                        f\"Duplicate cite key '{e.cite_key}' \"\n                        f\"(found {len(elist)} times)\",\n                        e.line_number\n                    )\n\n    def _check_required_fields(self, entry: BibEntry):\n        \"\"\"Check that all required fields are present and non-empty.\"\"\"\n        required = self.REQUIRED_FIELDS.get(entry.entry_type, [])\n        for f in required:\n            if f not in entry.fields or not entry.fields[f].strip():\n                self._add_issue(\n                    entry.cite_key, \"ERROR\", \"MISSING_FIELD\",\n                    f\"Missing required field '{f}' for @{entry.entry_type}\",\n                    entry.line_number\n                )\n\n    def _check_recommended_fields(self, entry: BibEntry):\n        \"\"\"Warn about missing recommended fields.\"\"\"\n        recommended = self.RECOMMENDED_FIELDS.get(entry.entry_type, [])\n        present = [f for f in recommended if f in entry.fields and entry.fields[f].strip()]\n        if len(present) == 0 and len(recommended) > 0:\n            self._add_issue(\n                entry.cite_key, \"WARNING\", \"MISSING_RECOMMENDED\",\n                f\"No recommended fields present. Consider adding: \"\n                f\"{', '.join(recommended[:3])}\",\n                entry.line_number\n            )\n\n    def _check_year(self, entry: BibEntry):\n        \"\"\"Validate the year field.\"\"\"\n        if 'year' not in entry.fields:\n            return\n        year = entry.fields['year'].strip()\n        if not self.YEAR_PATTERN.match(year):\n            self._add_issue(\n                entry.cite_key, \"ERROR\", \"INVALID_YEAR\",\n                f\"Year '{year}' is not a valid 4-digit year\",\n                entry.line_number\n            )\n        else:\n            y = int(year)\n            current_year = datetime.now().year\n            if y < 1400:\n                self._add_issue(\n                    entry.cite_key, \"WARNING\", \"SUSPICIOUS_YEAR\",\n                    f\"Year {y} seems unusually old\",\n                    entry.line_number\n                )\n            elif y > current_year + 1:\n                self._add_issue(\n                    entry.cite_key, \"WARNING\", \"FUTURE_YEAR\",\n                    f\"Year {y} is in the future\",\n                    entry.line_number\n                )\n\n    def _check_authors(self, entry: BibEntry):\n        \"\"\"Validate author field formatting.\"\"\"\n        if 'author' not in entry.fields:\n            return\n        author_str = entry.fields['author'].strip()\n        if not author_str:\n            return\n\n        # Split by 'and'\n        authors = [a.strip() for a in re.split(r'\\s+and\\s+', author_str, flags=re.IGNORECASE)]\n        for author in authors:\n            if not author:\n                continue\n            # Check for common issues\n            if author.lower() in ('others', 'et al', 'et al.'):\n                continue  # acceptable\n            # Check for missing commas (Last, First format preferred)\n            if ',' not in author and ' ' in author:\n                # Could be \"First Last\" format \u2014 warn\n                self._add_issue(\n                    entry.cite_key, \"INFO\", \"AUTHOR_FORMAT\",\n                    f\"Author '{author}' may be in 'First Last' format. \"\n                    f\"Preferred: 'Last, First'\",\n                    entry.line_number\n                )\n                break  # one warning per entry is enough\n\n    def _check_title(self, entry: BibEntry):\n        \"\"\"Validate title field.\"\"\"\n        if 'title' not in entry.fields:\n            return\n        title = entry.fields['title'].strip()\n        if len(title) < 3:\n            self._add_issue(\n                entry.cite_key, \"ERROR\", \"INVALID_TITLE\",\n                f\"Title is suspiciously short: '{title}'\",\n                entry.line_number\n            )\n        if title == title.upper() and len(title) > 10:\n            self._add_issue(\n                entry.cite_key, \"WARNING\", \"TITLE_CASE\",\n                \"Title appears to be ALL CAPS\",\n                entry.line_number\n            )\n\n    def _check_doi(self, entry: BibEntry):\n        \"\"\"Validate DOI format.\"\"\"\n        if 'doi' not in entry.fields:\n            return\n        doi = entry.fields['doi'].strip()\n        # Remove URL prefix if present\n        doi_clean = re.sub(r'^https?://(dx\\.)?doi\\.org/', '', doi)\n        if not self.DOI_PATTERN.match(doi_clean):\n            self._add_issue(\n                entry.cite_key, \"WARNING\", \"INVALID_DOI\",\n                f\"DOI format looks invalid: '{doi}'\",\n                entry.line_number\n            )\n\n    def _check_url(self, entry: BibEntry):\n        \"\"\"Validate URL format.\"\"\"\n        if 'url' not in entry.fields:\n            return\n        url = entry.fields['url'].strip()\n        if not self.URL_PATTERN.match(url):\n            self._add_issue(\n                entry.cite_key, \"WARNING\", \"INVALID_URL\",\n                f\"URL format looks invalid: '{url}'\",\n                entry.line_number\n            )\n\n    def _check_isbn(self, entry: BibEntry):\n        \"\"\"Validate ISBN format.\"\"\"\n        if 'isbn' not in entry.fields:\n            return\n        isbn = entry.fields['isbn'].strip().replace('-', '').replace(' ', '')\n        if not self.ISBN_PATTERN.match(isbn):\n            self._add_issue(\n                entry.cite_key, \"WARNING\", \"INVALID_ISBN\",\n                f\"ISBN format looks invalid: '{entry.fields['isbn']}'\",\n                entry.line_number\n            )\n\n    def _check_pages(self, entry: BibEntry):\n        \"\"\"Validate pages field format.\"\"\"\n        if 'pages' not in entry.fields:\n            return\n        pages = entry.fields['pages'].strip()\n        # Should be like \"1--10\" or \"1-10\" or just a number\n        if not re.match(r'^\\d+[\\s]*[-\u2013\u2014][\\s]*\\d+$', pages) and not pages.isdigit():\n            self._add_issue(\n                entry.cite_key, \"INFO\", \"PAGES_FORMAT\",\n                f\"Pages format unusual: '{pages}'. Expected: 'start--end'\",\n                entry.line_number\n            )\n\n    def _check_cite_key(self, entry: BibEntry):\n        \"\"\"Validate cite key format.\"\"\"\n        key = entry.cite_key\n        if not key:\n            self._add_issue(\n                entry.cite_key or \"(empty)\", \"ERROR\", \"EMPTY_KEY\",\n                \"Cite key is empty\",\n                entry.line_number\n            )\n            return\n        if re.search(r'[\\s,{}]', key):\n            self._add_issue(\n                key, \"WARNING\", \"KEY_FORMAT\",\n                f\"Cite key contains special characters: '{key}'\",\n                entry.line_number\n            )\n\n    def _check_crossref(self, a