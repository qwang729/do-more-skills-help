on}</version>\n        </dependency>\n    </dependencies>\n\n    <build>\n        <plugins>\n            <plugin>\n                <groupId>org.apache.maven.plugins</groupId>\n                <artifactId>maven-shade-plugin</artifactId>\n                <version>3.4.1</version>\n                <executions>\n                    <execution>\n                        <phase>package</phase>\n                        <goals><goal>shade</goal></goals>\n                        <configuration>\n                            <transformers>\n                                <transformer implementation=\"org.apache.maven.plugins.shade.resource.ManifestResourceTransformer\">\n                                    <mainClass>com.example.SessionWindowJob</mainClass>\n                                </transformer>\n                            </transformers>\n                        </configuration>\n                    </execution>\n                </executions>\n            </plugin>\n        </plugins>\n    </build>\n</project>\n```\n\n## 2. `SessionWindowJob.java`\n\n```java\npackage com.example;\n\nimport org.apache.flink.api.common.eventtime.WatermarkStrategy;\nimport org.apache.flink.api.common.functions.AggregateFunction;\nimport org.apache.flink.api.common.functions.MapFunction;\nimport org.apache.flink.api.java.tuple.Tuple2;\nimport org.apache.flink.api.java.tuple.Tuple3;\nimport org.apache.flink.streaming.api.datastream.DataStream;\nimport org.apache.flink.streaming.api.environment.StreamExecutionEnvironment;\nimport org.apache.flink.streaming.api.functions.windowing.ProcessWindowFunction;\nimport org.apache.flink.streaming.api.windowing.assigners.EventTimeSessionWindows;\nimport org.apache.flink.streaming.api.windowing.assigners.ProcessingTimeSessionWindows;\nimport org.apache.flink.streaming.api.windowing.windows.TimeWindow;\nimport org.apache.flink.util.Collector;\n\nimport java.time.Duration;\n\n/**\n * Flink Session Window Example\n *\n * Reads events from a socket (host:port) in the format:\n *   user,timestamp,eventType\n *\n * Example input (send via: nc -lk 9999):\n *   alice,1000,click\n *   alice,2000,view\n *   alice,15000,click\n *   bob,3000,click\n *   bob,20000,view\n *\n * Session gap = 5 seconds (5000 ms).\n * Events for the same user separated by > 5s start a new session.\n *\n * Output: (user, sessionStart, sessionEnd, eventCount)\n */\npublic class SessionWindowJob {\n\n    // \u2500\u2500 Data model \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    public static class Event {\n        public String user;\n        public long timestamp;\n        public String eventType;\n\n        public Event() {}\n\n        public Event(String user, long timestamp, String eventType) {\n            this.user = user;\n            this.timestamp = timestamp;\n            this.eventType = eventType;\n        }\n\n        @Override\n        public String toString() {\n            return String.format(\"Event(%s, %d, %s)\", user, timestamp, eventType);\n        }\n    }\n\n    // \u2500\u2500 Aggregate accumulator \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    public static class SessionAccumulator {\n        public long minTimestamp = Long.MAX_VALUE;\n        public long maxTimestamp = Long.MIN_VALUE;\n        public long count = 0;\n\n        public SessionAccumulator() {}\n    }\n\n    // \u2500\u2500 Aggregate function (incremental) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    public static class SessionAggregate\n            implements AggregateFunction<Event, SessionAccumulator, Tuple3<String, Long, Long>> {\n\n        @Override\n        public SessionAccumulator createAccumulator() {\n            return new SessionAccumulator();\n        }\n\n        @Override\n        public SessionAccumulator add(Event event, SessionAccumulator acc) {\n            acc.minTimestamp = Math.min(acc.minTimestamp, event.timestamp);\n            acc.maxTimestamp = Math.max(acc.maxTimestamp, event.timestamp);\n            acc.count++;\n            return acc;\n        }\n\n        @Override\n        public Tuple3<String, Long, Long> getResult(SessionAccumulator acc) {\n            return Tuple3.of(acc.minTimestamp, acc.maxTimestamp, acc.count);\n        }\n\n        @Override\n        public SessionAccumulator merge(SessionAccumulator a, SessionAccumulator b) {\n            SessionAccumulator merged = new SessionAccumulator();\n            merged.minTimestamp = Math.min(a.minTimestamp, b.minTimestamp);\n            merged.maxTimestamp = Math.max(a.maxTimestamp, b.maxTimestamp);\n            merged.count = a.count + b.count;\n            return merged;\n        }\n    }\n\n    // \u2500\u2500 Process window function (full context) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    public static class SessionWindowProcess\n            extends ProcessWindowFunction<\n                    Tuple3<String, Long, Long>,   // input  (from aggregate)\n                    String,                        // key\n                    String,                        // key type\n                    TimeWindow> {\n\n        @Override\n        public void process(\n                String user,\n                Context context,\n                Iterable<Tuple3<String, Long, Long>> elements,\n                Collector<String> out) {\n\n            Tuple3<String, Long, Long> result = elements.iterator().next();\n            long sessionStart = result.f0;\n            long sessionEnd   = result.f1;\n            long eventCount   = result.f2;\n\n            out.collect(String.format(\n                    \"User: %-8s | Session: [%d \u2192 %d] | Events: %d | Window: [%d \u2192 %d]\",\n                    user, sessionStart, sessionEnd, eventCount,\n                    context.window().getStart(), context.window().getEnd()));\n        }\n    }\n\n    // \u2500\u2500 Parser \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    public static class EventParser implements MapFunction<String, Event> {\n        @Override\n        public Event map(String line) throws Exception {\n            String[] parts = line.split(\",\");\n            if (parts.length != 3) {\n                throw new IllegalArgumentException(\"Bad input: \" + line);\n            }\n            return new Event(\n                    parts[0].trim(),\n                    Long.parseLong(parts[1].trim()),\n                    parts[2].trim()\n            );\n        }\n    }\n\n    // \u2500\u2500 Main \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    public static void main(String[] args) throws Exception {\n\n        // Configuration\n        final String host = args.length > 0 ? args[0] : \"localhost\";\n        final int    port = args.length > 1 ? Integer.parseInt(args[1]) : 9999;\n        final long   sessionGapMs = 5_000L; // 5-second session gap\n\n        // 1. Set up the streaming environment\n        StreamExecutionEnvironment env = StreamExecutionEnvironment