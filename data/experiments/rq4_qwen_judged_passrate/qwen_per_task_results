          continue\n            # Remove comments\n            line = re.sub(r'%.*', '', line).strip()\n            if not line:\n                continue\n            values = [float(x) for x in line.split()]\n            rows.append(values)\n        return np.array(rows) if rows else None\n\n    case = {}\n    case['bus'] = extract_matrix('bus')\n    case['gen'] = extract_matrix('gen')\n    case['branch'] = extract_matrix('branch')\n    case['gencost'] = extract_matrix('gencost')\n    case['baseMVA'] = float(re.search(r'mpc\\.baseMVA\\s*=\\s*([\\d.]+)', content).group(1))\n\n    # Extract bus names if available\n    bus_names = re.findall(r'mpc\\.bus_names\\s*=\\s*\\{(.*?)\\};', content, re.DOTALL)\n    if bus_names:\n        case['bus_names'] = [n.strip().strip(\"'\\\"\") for n in bus_names[0].split(';') if n.strip()]\n\n    return case\n\n\ndef build_network_matrices(case):\n    \"\"\"\n    Build the network matrices (B, Bf, Pt) needed for DC-OPF from parsed case data.\n    \"\"\"\n    baseMVA = case['baseMVA']\n    bus = case['bus']\n    gen = case['gen']\n    branch = case['branch']\n\n    nb = bus.shape[0]   # number of buses\n    ng = gen.shape[0]   # number of generators\n    nl = branch.shape[0] # number of branches\n\n    # Bus indices (1-based in MATPOWER, convert to 0-based)\n    bus_idx = bus[:, 0].astype(int) - 1\n    bus_i2n = {int(bus_idx[i]): i for i in range(nb)}\n    bus_n2i = {i: int(bus_idx[i]) for i in range(nb)}\n\n    # Generator bus indices (0-based)\n    gen_bus = gen[:, 0].astype(int) - 1\n    gen_bus_idx = np.array([bus_i2n[int(b)] for b in gen_bus])\n\n    # Branch from/to bus indices (0-based)\n    f_bus = branch[:, 0].astype(int) - 1\n    t_bus = branch[:, 1].astype(int) - 1\n    f_bus_idx = np.array([bus_i2n[int(b)] for b in f_bus])\n    t_bus_idx = np.array([bus_i2n[int(b)] for b in t_bus])\n\n    # Branch parameters\n    tap = branch[:, 8].copy()\n    tap[tap == 0] = 1.0  # default tap = 1\n    x = branch[:, 3]  # reactance\n\n    # Build DC power flow matrices\n    # B = sum(1/x) for each bus (diagonal of bus admittance matrix for DC)\n    b = 1.0 / x\n    b = b / tap  # account for tap ratio\n\n    # Bus admittance matrix (B matrix) - nb x nb\n    B = np.zeros((nb, nb))\n    for i in range(nl):\n        fi = f_bus_idx[i]\n        ti = t_bus_idx[i]\n        B[fi, fi] += b[i]\n        B[ti, ti] += b[i]\n        B[fi, ti] -= b[i]\n        B[ti, fi] -= b[i]\n\n    # Branch admittance matrix (Bf) - nl x nb\n    Bf = np.zeros((nl, nb))\n    for i in range(nl):\n        fi = f_bus_idx[i]\n        ti = t_bus_idx[i]\n        Bf[i, fi] += b[i]\n        Bf[i, ti] -= b[i]\n\n    # Generator connection matrix (Cg) - nb x ng\n    Cg = np.zeros((nb, ng))\n    for i in range(ng):\n        Cg[gen_bus_idx[i], i] = 1.0\n\n    # Reference bus\n    ref_bus = int(np.where(bus[:, 1] == 1)[0][0])\n\n    return {\n        'nb': nb, 'ng': ng, 'nl': nl,\n        'baseMVA': baseMVA,\n        'B': B, 'Bf': Bf, 'Cg': Cg,\n        'ref_bus': ref_bus,\n        'gen_bus_idx': gen_bus_idx,\n        'f_bus_idx': f_bus_idx,\n        't_bus_idx': t_bus_idx,\n        'bus': bus, 'gen': gen, 'branch': branch,\n    }\n\n\n# ============================================================\n# 2. DC-OPF FORMULATION AND SOLVER\n# ============================================================\n\ndef solve_dc_opf(case, net):\n    \"\"\"\n    Solve DC-OPF for market clearing.\n\n    DC-OPF formulation:\n        min  sum_i (c2_i * Pg_i^2 + c1_i * Pg_i + c0_i)\n        s.t. Cg * Pg - B * theta = Pd        (power balance)\n             Bf * theta <= Pf_max              (line flow limits, from side)\n            -Bf * theta <= Pf_max              (line flow limits, to side)\n             Pg_min <= Pg <= Pg_max            (generator limits)\n             theta_ref = 0                     (reference bus angle)\n\n    For linear cost (DC-OPF with linear costs), we use LP.\n    For quadratic costs, we use QP. Here we handle both.\n    \"\"\"\n    baseMVA = net['baseMVA']\n    bus = net['bus']\n    gen = net['gen']\n    branch = net['branch']\n    gencost = case['gencost']\n    nb, ng, nl = net['nb'], net['ng'], net['nl']\n    B = net['B']\n    Bf = net['Bf']\n    Cg = net['Cg']\n    ref_bus = net['ref_bus']\n\n    # Load (Pd) and generation limits\n    Pd = bus[:, 2] / baseMVA  # real power demand in p.u.\n    Qd = bus[:, 3] / baseMVA  # reactive power (not used in DC)\n\n    Pmax = gen[:, 8] / baseMVA  # max real power generation\n    Pmin = gen[:, 9] / baseMVA  # min real power generation\n\n    # Line flow limits (from-side)\n    Pf_max = branch[:, 5] / baseMVA  # rate A\n    # If rate A is 0, set a large value\n    Pf_max[Pf_max == 0] = 999.0\n\n    # Generator cost data\n    # gencost format: [model startup shutdown n c(n-1) ... c0]\n    # model=1: polynomial, model=2: piecewise linear\n    cost_model = gencost[:, 0].astype(int)\n    is_polynomial = (cost_model == 1)\n    n_coeffs = gencost[:, 4].astype(int)\n\n    # Extract polynomial coefficients (c2, c1, c0) for each generator\n    # For DC-OPF with quadratic costs, we solve as QP\n    # For linear costs (c2=0), we solve as LP\n    c2 = np.zeros(ng)\n    c1 = np.zeros(ng)\n    c0 = np.zeros(ng)\n\n    for i in range(ng):\n        nc = n_coeffs[i]\n        coeffs = gencost[i, 5:5+nc]\n        if nc >= 3:\n            c2[i] = coeffs[0] * baseMVA**2  # convert to per-unit\n            c1[i] = coeffs[1] * baseMVA\n            c0[i] = coeffs[2]\n        elif nc == 2:\n            c2[i] = 0.0\n            c1[i] = coeffs[0] * baseMVA\n            c0[i] = coeffs[1]\n        elif nc == 1:\n            c2[i] = 0.0\n            c1[i] = 0.0\n            c0[i] = coeffs[0]\n\n    # Decision variables: x = [Pg (ng), theta (nb)]\n    # Total variables: ng + nb\n    n_vars = ng + nb\n\n    # ---- Objective function ----\n    # Check if any quadratic terms exist\n    has_quadratic = np.any(c2 > 0)\n\n    if has_quadratic:\n        # Solve as QP using scipy\n        from 