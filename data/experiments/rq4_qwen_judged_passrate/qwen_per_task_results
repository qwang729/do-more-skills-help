one\n        \n        if self.openai_api_key and OPENAI_AVAILABLE:\n            self.openai_client = OpenAI(api_key=self.openai_api_key)\n        \n        if self.elevenlabs_api_key and ELEVENLABS_AVAILABLE:\n            set_api_key(self.elevenlabs_api_key)\n    \n    def text_to_speech(self, text, output_path, voice=None):\n        \"\"\"Convert text to speech with automatic fallback.\"\"\"\n        \n        # Try ElevenLabs first (highest quality)\n        if self.elevenlabs_api_key and ELEVENLABS_AVAILABLE:\n            try:\n                return self._elevenlabs_tts(text, output_path, voice or 'Rachel')\n            except Exception as e:\n                print(f\"ElevenLabs failed: {e}, trying OpenAI...\")\n        \n        # Try OpenAI TTS\n        if self.openai_client and OPENAI_AVAILABLE:\n            try:\n                return self._openai_tts(text, output_path, voice or 'alloy')\n            except Exception as e:\n                print(f\"OpenAI TTS failed: {e}, trying gTTS...\")\n\")\n        \n        # Fallback to gTTS\n        if GTTS_AVAILABLE:\n            return self._gtts_tts(text, output_path)\n        \n        raise RuntimeError(\"No TTS service available\")\n    \n    def _elevenlabs_tts(self, text, output_path, voice):\n        \"\"\"ElevenLabs TTS conversion.\"\"\"\n        # Chunk text (ElevenLabs has limits)\n        chunks = self._chunk_text(text, max_chars=5000)\n        audio_segments = []\n        \n        for i, chunk in enumerate(chunks):\n            audio = generate(\n                text=chunk,\n                voice=voice,\n                model='eleven_monolingual_v1'\n            )\n            with tempfile.NamedTemporaryFile(suffix='.mp3', delete=False) as f:\n                f.write(audio)\n                audio_segments.append(f.name)\n        \n        self._concatenate_audio(audio_segments, output_path)\n        return output_path\n    \n    def _openai_tts(self, text, output_path, voice):\n        \"\"\"OpenAI TTS conversion.\"\"\"\n        chunks = self._chunk_text(text, max_chars=4000)\n        audio_segments = []\n        \n        for chunk in chunks:\n            response = self.openai_client.audio.speech.create(\n                model='tts-1',\n                voice=voice,\n                input=chunk\n            )\n            with tempfile.NamedTemporaryFile(suffix='.mp3', delete=False) as f:\n                f.write(response.content)\n                audio_segments.append(f.name)\n        \n        self._concatenate_audio(audio_segments, output_path)\n        return output_path\n    \n    def _gtts_tts(self, text, output_path):\n        \"\"\"gTTS conversion (free, no API key needed).\"\"\"\n        chunks = self._chunk_text(text, max_chars=5000)\n        audio_segments = []\n        \n        for chunk in chunks:\n            tts = gTTS(text=chunk, lang='en', slow=False)\n            with tempfile.NamedTemporaryFile(suffix='.mp3', delete=False) as f:\n                tts.save(f.name)\n                audio_segments.append(f.name)\n        \n        self._concatenate_audio(audio_segments, output_path)\n        return output_path\n    \n    def _chunk_text(self, text, max_chars=4000):\n        \"\"\"Split text into chunks at sentence boundaries.\"\"\"\n        sentences = re.split(r'(?<=[.!?])\\s+', text)\n        chunks = []\n        current_chunk = \"\"\n        \n        for sentence in sentences:\n            if len(current_chunk) + len(sentence) < max_chars:\n                current_chunk += sentence + \" \"\n            else:\n                if current_chunk:\n                    chunks.append(current_chunk.strip())\n                current_chunk = sentence + \" \"\n        \n        if current_chunk:\n            chunks.append(current_chunk.strip())\n        \n        return chunks\n    \n    def _concatenate_audio(self, audio_files, output_path):\n        \"\"\"Concatenate multiple audio files.\"\"\"\n        combined = AudioSegment.empty()\n        \n  