       if not table or len(table) < 2:\n                    continue\n                \n                # Use the first row as headers\n                headers = [str(h).strip() for h in table[0]]\n                data = table[1:]\n                df = pd.DataFrame(data, columns=headers)\n                \n                # Identify table type based on column headers\n                header_str = \" \".join(headers).lower()\n                \n                if 'pload' in header_str or ('bus_id' in header_str and 'type' in header_str):\n                    bus_df = df\n                elif 'pg_mw' in header_str or ('gen_id' in header_str and 'bus_id' in header_str):\n                    gen_df = df\n                elif 'r_pu' in header_str or ('from_bus' in header_str and 'to_bus' in header_str):\n                    branch_df = df\n\n    # Clean and cast data types\n    for df in [bus_df, gen_df, branch_df]:\n        if df is not None:\n            # Drop completely empty rows if any\n            df.dropna(how='all', inplace=True)\n            # Convert numeric columns\n            for col in df.columns:\n                if col not in ['Name', 'Type']:\n                    df[col] = pd.to_numeric(df[col], errors='coerce')\n                    \n    return bus_df, gen_df, branch_df\n\n# ==============================================================================\n# 3. PANDAS ANALYSIS & TOPOLOGY CHECK\n# ==============================================================================\ndef analyze_power_system(bus_df, gen_df, branch_df):\n    \"\"\"Performs power balance and basic topology analysis.\"\"\"\n    analysis = {}\n    \n    # 1. Load Analysis\n    total_pload = bus_df['Pload_MW'].sum()\n    total_qload = bus_df['Qload_MVAr'].sum()\n    analysis['Total Active Load (MW)'] = total_pload\n    analysis['Total Reactive Load (MVAr)'] = total_qload\n    \n    # 2. Generation Analysis\n    total_pgen = gen_df['Pg_MW'].sum()\n    total_qgen = gen_df['Qg_MVAr'].sum()\n    analysis['Total Active Generation (MW)'] = total_pgen\n    analysis['Total Reactive Generation (MVAr)'] = total_qgen\n    \n    # 3. Power Balance Check (Assuming no losses for simple check, or calculating mismatch)\n    # In a real solved case, Pgen = Pload + Ploss. Here we just calculate the raw mismatch.\n    analysis['Active Power Mismatch (MW)'] = total_pgen - total_pload\n    analysis['Reactive Power Mismatch (MVAr)'] = total_qgen - total_qload\n    \n    # 4. Topology Analysis\n    num_buses = len(bus_df)\n    num_branches = len(branch_df)\n    \n    # Find connected buses\n    connected_buses = set(branch_df['From_Bus'].unique()).union(set(branch_df['To_Bus'].unique()))\n    all_buses = set(bus_df['Bus_ID'].unique())\n    isolated_buses = all_buses - connected_buses\n    \n    analysis['Total Buses'] = num_buses\n    analysis['Total Branches'] = num_branches\n    analysis['Isolated Buses'] = list(isolated_buses) if isolated_buses else \"None\"\n    \n    # Calculate degree of each bus (number of connections)\n    branch_connections = pd.concat([branch_df['From_Bus'], branch_df['To_Bus']]).value_counts().reset_index()\n    branch_connections.columns = ['Bus_ID', 'Connections']\n    \n    return analysis, branch_connections\n\n# ==============================================================================\n# 4. EXCEL EXPORT\n# ==============================================================================\ndef export_to_excel(bus_df, gen_df, branch_df, analysis, connections_df, excel_path):\n    \"\"\"Exports parsed data and analysis results to a multi-sheet Excel file.\"\"\"\n    with pd.ExcelWriter(excel_path, engine='openpyxl') as writer:\n        # Write raw parsed data\n        bus_df.to_excel(writer, sheet_name='Bus Data', index=False)\n        gen_df.to_excel(writer, sheet_name='Generator Data', index=False)\n        branch_df.to_excel(writer, sheet_name='Branch Data', index=False)\n        \n        # Write analysis results\n        analysis_df = pd.DataFrame(list(analysis.items()), columns=['Metric', 'Value'])\n        analysis_df.to_excel(writer, sheet_name='System Analysis', index=False)\n        \n        # Write topology connections\n        connections_df.to_excel(writer, sheet_name='Bus Topology', index=False)\n        \n        # Auto-adjust column widths for better readability\n        for sheet_name in writer.sheets:\n            worksheet = writer.sheets[sheet_name]\n            for i, col in enumerate(worksheet.columns):\n                max_length = 0\n                column = col[0].column_letter \n                for cell in col:\n                    try:\n                        if len(str(cell.value)) > max_length:\n                            max_length = len(str(cell.value))\n                    except:\n                        pass\n                adjusted_width = (max_length + 2)\n                worksheet.column_dimensions[column].width = adjusted_width\n\n# ==============================================================================\n# MAIN EXECUTION\n# ==============================================================================\nif __name__ == \"__main__\":\n    pdf_file = \"power_flow_data.pdf\"\n    excel_file = \"power_flow_analysis.xlsx\"\n    \n    print(\"1. Generating dummy power flow PDF...\")\n    generate_dummy_power_flow_pdf(pdf_file)\n    \n    print(\"2. Extracting data from PDF...\")\n    buses, generators, branches = extract_power_data_from_pdf(pdf_file)\n    \n    if buses is None or generators is None or branches is None:\n        raise ValueError(\"Failed to extract all required tables from the PDF.\")\n        \n    print(\"3. Analyzing power system topology and balance...\")\n    sys_analysis, bus_connections = analyze_power_system(buses, generators, branches)\n    \n    print(\"4. Exporting results to Excel...\")\n    export_to_excel(buses, generators, branches, sys_analysis, bus_connections, excel_file)\n    \n    print(f\"\\nSuccess! Data extracted, analyzed, and saved to '{excel_file}'.\")\n    print(\"\\n--- System Analysis Summary ---\")\n    for k, v in sys_analysis.items():\n        print(f\"{k}: {v}\")\n```\n\n### How this solution addresses the requirements:\n1. **PDF Parsing Extraction:** Uses `pdfplumber` to robustly extract tabular data from the PDF. It dynamically identifies Bus, Generator, and Branch tables by scanning the column headers, making it resilient to slight formatting changes.\n2. **Power-Flow-Data Skill Guide:** Strictly adheres to standard power system network data formats. It parses Bus data (Types, Vm, Va, Loads), Generator data (Pg, Qg, Limits), and Branch data (R, X, B, Tap) required for power flow analysis.\n3. **Pandas Analysis:** Cleans the extracted data, casts it to proper numeric types, and calculates critical system metrics: Total Load, Total Generation, Active/Reactive Power Mismatches, and Topology checks (identifying isolated buses and connection degrees).\n4. **Excel Export:** Uses `pandas.ExcelWriter` to output a cleanly formatted, multi-sheet Excel workbook containing the raw parsed data, the system analysis summary, and the topology map, with auto-adjusted column widths.", "solver_finish_reason": "stop"}
