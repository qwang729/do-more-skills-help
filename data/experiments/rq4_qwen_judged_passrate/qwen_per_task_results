/null) || {\n    echo \"Error: not in a GitHub repo and no repo argument given.\" >&2\n    exit 1\n  }\nfi\n\necho \"\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\"\necho \"  Pull Request Analytics for: $REPO\"\necho \"  State filter : $STATE\"\necho \"  Limit        : $LIMIT\"\n[[ -n \"$DAYS\" ]] && echo \"  Time window  : last $DAYS days\"\necho \"\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\"\necho \"\"\n\n# \u2500\u2500 Build the gh command \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nGH_ARGS=(pr list --repo \"$REPO\" --state \"$STATE\" --limit \"$LIMIT\"\n         --json number,title,author,state,createdAt,mergedAt,closedAt,\n                updatedAt,labels,reviews,additions,deletions,changedFiles,\n                isDraft,headRefName,baseRefName,reviewRequests)\n\n# If --days is set, compute a since date\nSINCE=\"\"\nif [[ -n \"$DAYS\" ]]; then\n  SINCE=$(date -u -d \"-${DAYS} days\" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \\\n       || date -u -v-${DAYS}d +%Y-%m-%dT%H:%M:%SZ 2>/dev/null)\n  GH_ARGS+=(--search \"created:>=${SINCE}\")\nfi\n\n# 