\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\necho \"\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\"\necho \"\u2502  4. Code Churn (additions / deletions)  \u2502\"\necho \"\u251c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2524\"\necho \"$PR_JSON\" | jq -r '\n  {\n    total_additions:  (map(.additions)  | add // 0),\n    total_deletions:  (map(.deletions)  | add // 0),\n    total_files:      (map(.changedFiles) | add // 0),\n    avg_additions:    ((map(.additions)  | add // 0) / length * 100 | round / 100),\n    avg_deletions:    ((map(.deletions)  | add // 0) / length * 100 | round / 100),\n    avg_files:        ((map(.changedFiles) | add // 0) / length * 100 | round / 100)\n  } |\n  \"\u2502  Total additions  : \\(.total_additions)\\n\u2502  Total deletions  : \\(.total_deletions)\\n\u2502  Total files changed: \\(.total_files)\\n\u2502  Avg additions/PR : \\(.avg_additions)\\n\u2502  Avg deletions/PR : \\(.avg_deletions)\\n\u2502  Avg files/PR     : \\(.avg_files)\"\n' | sed 's/$/                                        \u2502/'\necho \"\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\"\necho \"\"\n\n# \u2500\u2500 5. PRs by Label \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u