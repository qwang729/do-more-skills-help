, 'report', 'study', 'research'],\n        'form': ['form', 'application', 'submit', 'fill', 'signature', 'date', 'name', 'address'],\n        'presentation': ['slide', 'presentation', 'overview', 'agenda', 'bullet', 'key points'],\n        'resume': ['experience', 'education', 'skills', 'resume', 'cv', 'employment', 'qualification'],\n        'academic': ['abstract', 'introduction', 'methodology', 'references', 'citation', 'journal', 'research']\n    }\n    \n    def __init__(self):\n        self.vectorizer = TfidfVectorizer(max_features=1000, stop_words='english')\n        self.classifier = MultinomialNB()\n        self.pipeline = Pipeline([\n            ('tfidf', self.vectorizer),\n            ('clf', self.classifier)\n        ])\n        self._train_default_classifier()\n    \n    def _train_default_classifier(self):\n        \"\"\"Train with default category examples.\"\"\"\n        training_data = []\n        labels = []\n        \n        for category, keywords in self.CATEGORIES.items():\n            # Create synthetic training examples from keywords\n            for _ in range(10):\n                example = ' '.join(np.random.choice(keywords, size=min(5, len(keywords)), replace=True))\n                training_data.append(example)\n                labels.append(category)\n        \n        self.pipeline.fit(training_data, labels)\n    \n    def classify(self, text):\n        \"\"\"Classify document text into a category.\"\"\"\n        if not text or len(text.strip()) < 10:\n            return 'uncategorized'\n        \n        try:\n            prediction = self.pipeline.predict([text])[0]\n            confidence = max(self.pipeline.predict_proba([text])[0])\n            return prediction, confidence\n        except:\n            return 'uncategorized', 0.0\n    \n    def classify_by_keywords(self, text):\n        \"\"\"Simple keyword-based classification.\"\"\"\n        text_lower = text.lower()\n        scores = {}\n        \n        for category, keywords in self.CATEGORIES.items():\n            score = sum(1 for kw in keywords if kw in text_lower)\n            scores[category] = score\n        \n        if max(scores.values()) > 0:\n            return max(scores, key=scores.get)\n        return 'uncategorized'\n\n\nclass FileOrganizer:\n    \"\"\"Organize classified documents into folders.\"\"\"\n    \n    def __init__(self, output_base='organized_documents'):\n        self.output_base = Path(output_base)\n        self.output_base.mkdir(parents=True, exist_ok=True)\n    \n    def organize(self, documents, method='copy'):\n        \"\"\"Organize documents into category folders.\"\"\"\n        import shutil\n        \n        results = {\n            'organized': [],\n            'errors': []\n        }\n        \n        for doc in documents:\n            category = doc.get('category', 'uncategorized')\n            \n            # Create category folder\n            category_path = self.output_base / category\n            category_path.mkdir(exist_ok=True)\n            \n            # Handle duplicate filenames\n            src_path = Path(doc['path'])\n            dest_path = category_path / src_path.name\n            \n            counter = 1\n            while dest_path.exists():\n                stem = src_path.stem\n                dest_path = category_path / f\"{stem}_{counter}{src_path.suffix}\"\n                counter += 1\n            \n            try:\n                if method == 'move':\n                    shutil.move(str(src_path), str(dest_path))\n                else:\n                    shutil.copy2(str(src_path), str(dest_path))\n                \n                results['organized'].append({\n                    'original': doc['path'],\n                    'new_location': str(dest_path),\n                    'category': category\n                })\n                \n            except Exception as e:\n                results['errors'].append({\n                    'file': doc['path'],\n    