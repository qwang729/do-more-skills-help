_flow(prev_gray, curr_gray, prev_points, mask):\n    \"\"\"\n    Compute sparse optical flow using Lucas-Kanade method.\n    Returns tracked points and their status (1=tracked, 0=lost).\n    \"\"\"\n    if len(prev_points) == 0:\n        return None, None\n\n    curr_points, status, error = cv2.calcOpticalFlowPyrLK(\n        prev_gray,\n        curr_gray,\n        prev_points,\n        None,\n        winSize=(21, 21),\n        maxLevel=3,\n        criteria=(cv2.TERM_CRITERIA_EPS | cv2.TERM_CRITERIA_COUNT, 30, 0.01)\n    )\n\n    # Filter by status and apply mask\n    if curr_points is not None:\n        good_prev = prev_points[status.flatten() == 1]\n        good_curr = curr_points[status.flatten() == 1]\n\n        # Apply sparse mask filter\n        if mask is not None and len(good_curr) > 0:\n            h, w = mask.shape\n            x_coords = good_curr[:, 0, 0].astype(int)\n            y_coords = good_curr[:, 0, 1].astype(int)\n            x_coords = np.clip(x_coords, 0, w - 1)\n            y_coords = np.clip(y_coords, 0, h - 1)\n            mask_vals = mask[y_coords, x_coords]\n            in_mask = mask_vals > 0\n            good_prev = good_prev[in_mask]\n            good_curr = good_curr[in_mask]\n\n        return good_prev, good_curr\n    return None, None\n\n\ndef estimate_camera_motion(prev_pts, curr_pts):\n    \"\"\"\n    Estimate camera motion (translation + rotation) from sparse optical flow.\n    Uses numpy to compute the affine transformation via least squares.\n    \n    Returns:\n        motion: dict with 'dx', 'dy' (translation), 'angle' (rotation in degrees),\n                'scale' (zoom factor), and 'flow_vectors' (raw displacement vectors)\n    \"\"\"\n    if prev_pts is None or len(prev_pts) < 3:\n        return None\n\n    # Extract coordinates as numpy arrays\n    p0 = prev_pts[:, 0, :].astype(np.float64)  # (N, 2)\n    p1 = curr_pts[:, 0, :].astype(np.float64)  # (N, 2)\n\n    # Compute displacement vectors\n    flow_vectors = p1 - p0  #