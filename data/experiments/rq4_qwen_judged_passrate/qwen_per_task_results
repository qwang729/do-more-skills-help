     \n        print(f\"Training complete! Model saved to {config['out_dir']}\")\n        return config[\"out_dir\"]\n    \n    @modal.method()\n    def generate(self, prompt: str = \"\\n\", max_new_tokens: int = 500):\n        import subprocess\n        import os\n        \n        os.chdir(self.work_dir)\n        ckpt_dir = f\"{self.data_dir}/out-shakespeare-char\"\n        \n        result = subprocess.run([\n            \"python\", \"-m\", \"sample\",\n            f\"--ckpt_dir={ckpt_dir}\",\n            f\"--prompt={prompt}\",\n            f\"--max_new_tokens={max_new_tokens}\",\n        ], capture_output=True, text=True)\n        \n        return result.stdout\n\n# Local entry point\n@app.local_entrypoint()\ndef main(\n    action: str = \"train\",\n    max_iters: int = 5000,\n    prompt: str = \"\\n\",\n):\n    trainer = NanoGPTTrainer()\n    \n    if action == \"prepare\":\n        trainer.prepare_data.remote()\n    elif action == \"train\":\n        trainer.prepare_data.remote()\n        out_dir = trainer.train.remote(max_iters=max_iters)\n        print(f\"Model saved to: {out_dir}\")\n    elif action == \"generate\":\n        output = trainer.generate.remote(prompt=prompt)\n        print(\"Generated text:\")\n        print(output)\n    else:\n        print(\"Usage: modal run train_nanogpt.py --action [prepare|train|generate]\")\n\nif __name__ == \"__main__\":\n    print(\"Run with: modal run train_nanogpt.py\")\n```\n\n## 3. Run Training\n\n```bash\n# Train the model (default 5000 iterations)\nmodal run train_nanogpt.py --action train --max-iter 5000\n\n# Generate text after training\nmodal run train_nanogpt.py --action generate --prompt \"ROMEO:\"\n```\n\n## 4. Alternative: Simple One-File Training Script\n\nFor a simpler approach, save as `simple_train.py`:\n\n```python\nimport modal\n\napp = modal.App(\"nanogpt-simple\")\n\n@app.function(\n    image=modal.Image.from_registry(\"pytorch/pytorch:2.1.0-cuda12.1-cudnn8-devel\")\n        .pip_install(\"numpy\"