_Mean': 'discharge_cfs'\n})\ndf['date'] = pd.to_datetime(df['date'])\ndf = df.sort_values('date').reset_index(drop=True)\n\n# ==========================================\n# 2. Download NWS Flood Thresholds (Skill Guide #2)\n# ==========================================\nprint(f\"Fetching NWS flood thresholds for site {SITE_ID}...\")\n\ndef get_nws_flood_stages(site_no):\n    \"\"\"Fetches action, minor, moderate, and major flood stages from the NWS API.\"\"\"\n    url = f\"https://api.water.noaa.gov/nwps/v1/gauges/{site_no}\"\n    try:\n        response = requests.get(url, timeout=10)\n        response.raise_for_status()\n        data = response.json()\n        flood_data = data.get('flood', {})\n        \n        # Extract primary threshold values (in feet)\n        return {\n            'action': flood_data.get('action', {}).get('primary'),\n            'minor': flood_data.get('minor', {}).get('primary'),\n            'moderate': flood_data.get('moderate', {}).get('primary'),\n            'major': flood_data.get('major', {}).get('primary')\n        }\n    except Exception as e:\n        print(f\"Warning: Could not fetch NWS data ({e}). Proceeding without thresholds.\")\n        return {'action': None, 'minor': None, 'moderate': None, 'major': None}\n\nstages = get_nws_flood_stages(SITE_ID)\nprint(f\"Flood Stages (ft): Action={stages['action']}, Minor={stages['minor']}, \"\n      f\"Moderate={stages['moderate']}, Major={stages['major']}\\n\")\n\n# ==========================================\n# 3. Detect Flood Events & Classify Severity (Skill Guide #1)\n# ==========================================\n\ndef classify_severity(row, thresholds):\n    \"\"\"Classifies daily gage height into flood severity categories.\"\"\"\n    gh = row['gage_height_ft']\n    if pd.isna(gh):\n        return 'No Data'\n    \n    # Evaluate from highest severity down to lowest\n    if thresholds['major'] is not None and gh >= thresholds['major']:\n        return 'Major'\n    if thresholds['moderate'] is not None and gh >= thresholds['moderate']:\n        return 'Moderate'\n    if thresholds['minor'] is not None and gh >= thresholds['minor']:\n        return 'Minor'\n    if thresholds['action'] is not None and gh >= thresholds['action']:\n        return 'Action'\n    return 'No Flood'\n\n# Apply classification\ndf['severity'] = df.apply(lambda row: classify_severity(row, stages), axis=1)\ndf['is_flooding'] = df['severity'] != 'No Flood'\n\n# Aggregate daily counts by severity\ndaily_flood_summary = df.groupby('severity').size().reset_index(name='days')\nprint(\"--- Flood Days by Severity ---\")\nprint(daily_flood_summary[daily_flood_summary['severity'] != 'No Flood'].to_string(index=False))\n\n# Identify distinct flood events (continuous periods where is_flooding == True)\ndf['flood_event_id'] = (df['is_flooding'] != df['is_flooding'].shift(1)).cumsum()\n\nflood_events = df[df['is_flooding']].groupby('flood_event_id').agg(\n    start_date=('date', 'min'),\n    end_date=('date', 'max'),\n    duration_days=('date', 'count'),\n    peak_gage_height=('gage_height_ft', 'max'),\n    peak_discharge=('discharge_cfs', 'max'),\n    max_severity=('severity', lambda x: x.value_counts().index[0])\n).reset_index(drop=True)\n\nprint(\"\\n--- Distinct Flood Events Summary ---\")\nif not flood_events.empty:\n    print(flood_events.to_string(index=False))\nelse:\n    print(\"No flood events detected in the specified date range.\")\n```\n\n### How this works:\n1. **USGS Data Download**: Uses `dataretrieval.nwis.get_record` to pull daily mean gage height and discharge directly from the USGS NWIS database.\n2. **NWS Threshold Matching**: Queries the NWS `api.water.noaa.gov` endpoint using the USGS Site ID to dynamically pull the exact Action, Minor, Moderate, and Major flood stage thresholds (in feet) for that specific gage.\n3. **Flood Detection & Aggregation**: \n   - Compares daily gage heights against the NWS thresholds to classify severity.\n   - Tallies the total number of days spent in each flood category.\n   - Groups consecutive days of flooding into distinct \"Flood Events\" to calculate event duration, peak gage height, peak discharge, and the maximum severity reached during that specific event.", "solver_finish_reason": "stop"}
{"task": "flood-risk-analysis", "condition": "retrieved_top1_full", "repeat": 0, "skill_ids": ["benchflow-ai--usgs-data-download"], "retrieval_correct": true, "judged_pass": false, "judged_score": 0, "judge_reason": "Agent solution does not process Michigan stations or output flood_results.csv as required by the verifier", "solver_tokens": 5678, "judge_tokens": 5602, "solution_text": "# USGS Streamflow Data Flood Threshold Analysis\n\nBelow is a complete Python solution that downloads USGS streamflow data using the `dataretrieval` package, performs flood frequency analysis, and determines flood thresholds.\n\n```python\n#!/usr/bin/env python3\n\"\"\"\nUSGS Streamflow Data Flood Threshold Analysis\n----------------------------------------------\nDownloads daily streamflow data from USGS, performs flood frequency analysis,\nand determines flood thresholds (action, minor, moderate, major flood stages)\nusing statistical methods including Log-Pearson Type III distribution.\n\"\"\"\n\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nfrom scipy import stats\nfrom dataretrieval import nwis\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# ============================================================\n# 1. DOWNLOAD USGS STREAMFLOW DATA\n# ============================================================\n\n# USGS Station: 01646500 - Potomac River at Washington, DC\n# (A well-known station with long historical record)\nSITE_ID = \"01646500\"\nSTART_DATE = \"1930-01-01\"\nEND_DATE = \"2024-12-31\"\n\nprint(f\"Downloading daily streamflow data for USGS Station {SITE_ID}...\")\nprint(f\"Date range: {START_DATE} to {END_DATE}\")\n\n# Download daily discharge data (parameter 00060 = discharge, ft\u00b3/s)\ndf, metadata = nwis.get_iv(\n    sites=SITE_ID,\n    start=START_DATE,\n    end=END_DATE,\n    parameterCd=\"00060\",\n    statCd=\"00003\"  # daily mean\n)\n\n# If IV doesn't return enough data, try DV (daily values)\nif df.empty or len(df) < 1000:\n    print(\"Trying daily values (dv) endpoint...\")\n    df, metadata = nwis.get_dv(\n        sites=SITE_ID,\n        start=START_DATE,\n        end=END_DATE,\n        parameterCd=\"00060\"\n    )\n\n# Clean up the dataframe\nif df.empty:\n    raise ValueError(\"No data retrieved. Check station ID and date range.\")\n\n# Rename columns for clarity\ndischarge_col = [c for c in df.columns if '00060' in c][0]\ndf = df.rename(columns={discharge_col: 'discharge_cfs'})\ndf['discharge_cfs'] = pd.to_numeric(df['discharge_cfs'], errors='coerce')\ndf = df.dropna(subset=['discharge_cfs'])\ndf = df[df['discharge_cfs'] > 0]  # Remove zero/negative flows\n\nprint(f\"\\nData retrieved: {len(df)} daily records\")\nprint(f\"Date range: {df.index.min()} to {df.index.max()}\")\nprint(f\"\\nBasic Statistics:\")\nprint(df['discharge_cfs'].describe())\n\n# ============================================================\n# 2. EXTRACT ANNUAL PEAK FLOWS\n# ============================================================\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"EXTRACTING ANNUAL PEAK FLOWS\")\nprint(\"=\"*60)\n\n# Extract annual maximum daily discharge\nannual_peaks = df['discharge_cfs'].resample('YE').max()\nannual_peaks = annual_peaks.dropna()\nannual_peaks = annual_peaks[annual_peaks > 0]\n\n# Also try to get official annual peaks from NWIS\ntry:\n    peaks_df, peaks_meta = nwis.get_record(\n        sites=SITE_ID,\n        service='peaks',\n        start=START_DATE,\n        end=END_DATE\n    )\n    if not peaks_df.empty and 'peak_va' in peaks_df.columns:\n        peaks_df['peak_va'] = pd.to_numeric(peaks_df['peak_va'], errors='coerce')\n        peaks_df['peak_dt'] = pd.to_datetime(peaks_df['peak_dt'])\n        peaks_df = peaks_df.dropna(subset=['peak_va'])\n        annual_peak_values = peaks_df['peak_va'].values\n        annual_peak_dates = peaks_df['peak_dt'].values\n        print(f\"Using official USGS annual peak data: {len(annual_peak_values)} peaks\")\n    else:\n        annual_peak_values = annual_peaks.values\n        annual_peak_dates = annual_peaks.index.values\n        print(f\"Using extracted annual maxima: {len(annual_peak_values)} peaks\")\nexcept Exception as e:\n    print(f\"Could not retrieve official peaks ({e}), using extracted annual maxima\")\n    annual_peak_values = annual_peaks.values\n    annual_peak_dates = annual_peaks.index.values\n\n# Sort peaks in descending order for plotting position\nsorted_peaks = np.sort(annual_peak_values)[::-1]\nn = len(sorted_peaks)\n\nprint(f\"\\nNumber of annual peaks: {n}\")\nprint(f\"Maximum peak flow: {sorted_peaks[0]:,.0f} cfs\")\nprint(f\"Minimum peak flow: {sorted_peaks[-1]:,.0f} cfs\")\nprint(f\"Mean annual peak: {np.mean(sorted_peaks):,.0f} cfs\")\n\n# ============================================================\n# 3. FLOOD FREQUENCY ANALYSIS (Log-Pearson Type III)\n# ============================================================\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"FLOOD FREQUENCY ANALYSIS - Log-Pearson Type III\")\nprint(\"=\"*60)\n\n# Take logarithms of peak flows\nlog_peaks = np.log10(sorted_peaks)\n\n# Compute statistics of log-transformed data\nmean_log = np.mean(log_peaks)\nstd_log = np.std(log_peaks, ddof=1)\nskew_log = stats.skew(log_peaks, bias=False)\n\nprint(f\"\\nLog10(Peak Flow) Statistics:\")\nprint(f\"  Mean:   {mean_log:.4f}\")\nprint(f\"  Std Dev: {std_log:.4f}\")\nprint(f\"  Skewness: {skew_log:.4f}\")\n\n# Compute frequency factors (K) for various return periods\n# Using the Bulletin 17C approximation for LP3 distribution\ndef compute_k_factor(T, skew):\n    \"\"\"\n    Compute the frequency factor K for the Log-Pearson Type III distribution\n    using the Wilson-Hilferty approximation.\n    T = return period (years)\n    skew = skewness coefficient\n    \"\"\"\n    # Exceedance probability\n    p = 1.0 / T\n    \n    # Standard normal deviate (using approximation)\n    # For the normal distribution, find z such that P(Z > z) = p\n    z = stats.norm.ppf(1 - p)\n    \n    if abs(skew) < 1e-6:\n        return z\n    \n    # Wilson-Hilferty transformation\n    k = (2.0 / skew) * (\n        ((1.0 + (skew * z / 6.0) - (skew**2 / 36.0))**3) - 1.0\n    )\n    return k\n\n# Define return periods of interest\nreturn_periods = [2, 5, 10, 25, 50, 100, 200, 500]\n\nprint(f\"\\n{'Return Period (yrs)':<22} {'Exceedance Prob (%)':<22} {'K-Factor':<12} {'Flow (cfs)':<15}\")\nprint(\"-\" * 71)\n\nflood_thresholds = {}\nfor T in return_periods:\n    k = compute_k_factor(T, skew_log)\n    log_q = mean_log + k * std_log\n    q = 10**log_q\n    exceed_prob = (1.0 / T) * 100\n    flood_thresholds[T] = q\n    print(f\"{T:<22} {exceed_prob:<22.2f} {k:<12.4f} {q:<15,.0f}\")\n\n# ============================================================\n# 4. CLASSIFY FLOOD CATEGORIES\n# ============================================================\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"FLOOD CATEGORY CLASSIFICATION\")\nprint(\"=\"*60)\n\n# Define flood categories based on return periods\n# (Standard USGS/NWS classification approach)\nflood_categories = {\n    'Bankfull (1.5-yr)': 1.5,\n    'Action Stage': 2,\n    'Minor Flooding (5-yr)': 5,\n    'Moderate Flooding (10-yr)': 10,\n    'Major Flooding (25-yr)': 25,\n    'Record/Extreme (50-yr)': 50,\n    '500-yr Flood': 500\n}\n\nprint(f\"\\n{'Flood Category':<30} {'Return Period (yr)':<20} {'Threshold (cfs)':<18}\")\nprint(\"-\" * 68)\nfor category, T in flood_categories.items():\n    k = compute_k_factor(T, skew_log)\n    log_q = mean_log + k * std_log\n    q = 10**log_q\n    print(f\"{category:<30} {T:<20.1f} {q:<18,.0f}\")\n\n# ============================================================\n# 5. PLOTTING PROBABILITY PAPER\n# ============================================================\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"GENERATING PLOTS\")\nprint(\"=\"*60)\n\nfig, axes = plt.subplots(2, 2, figsize=(16, 12))\nfig.suptitle(f'USGS Station {SITE_ID} - Flood Threshold Analysis', \n             fontsize=16, fontweight='bold')\n\n# --- Plot 1: Annual Peak Flows Time Series ---\nax1 = axes[0, 0]\nyears = pd.DatetimeIndex(annual_peak_dates).year\nax1.bar(years, annual_peak_values, color='steelblue', alpha=0.7, edgecolor='navy', linewidth=0.5)\n\n# Add flood threshold lines\ncolors = {'green': 2, 'yellow': 5, 'orange': 10, 'red': 25, 'darkred': 100}\nlabels_map = {2: '2-yr (Action)', 5: '5-yr (Minor)', 10: '10-yr (Moderate)', \n              25: '25-yr (Major)', 100: '100-yr (Extreme)'}\nfor color, T in colors.items():\n    ax1.axhline(y=flood_thresholds[T], color=color, linestyle='--', linewidth=1.5, \n                alpha=0.8, label=labels_map[T])\n\nax1.set_xlabel('Year', fontsize=11)\nax1.set_ylabel('Peak Discharge (cfs)', fontsize=11)\nax1.set_title('Annual Peak Streamflow with Flood Thresholds', fontsize=12)\nax1.legend(fontsize=8, loc='upper left')\nax1.grid(True, alpha=0.3)\n\n# --- Plot 2: Flood Frequency Curve (Log-Pearson Type III) ---\nax2 = axes[0, 1]\n# Plotting positions (Weibull formula)\nranks = np.arange(1, n + 1)\nexceedance_prob = ranks / (n + 1)\nreturn_period_plot = 1.0 / exceedance_prob\n\nax2.scatter(return_period_plot, sorted_peaks, c='steelblue', s=30, zorder=5, \n            edgecolors='navy', linewidth=0.5, label='Observed Peaks')\n\n# Plot fitted LP3 curve\nT_fit = np.logspace(np.log10(1.2), np.log10(max(return_periods) * 1.5), 200)\nQ_fit = []\nfor T in T_fit:\n    k = compute_k_factor(T, skew_log)\n    log_q = mean_log + k * std_log\n    Q_fit.append(10**log_q)\n\nax2.plot(T_fit, Q_fit, 'r-', linewidth=2.5, label='Log-Pearson Type III Fit')\n\n# Mark specific return periods\nfor T in [2, 5, 10, 25, 50, 100, 500]:\n    ax2.scatter(T, flood_thresholds[T], c='red', s=80, marker='D', zorder=6,\n                edgecolors='darkred', linewidth=1)\n    ax2.annotate(f'{T}-yr\\n{flood_thresholds[T]:,.0f} cfs', \n                 xy=(T, flood_thresholds[T]),\n                 xytext=(10, 10), textcoords='offset points',\n                 fontsize=7, color='darkred',\n                 arrowprops=dict(arrowstyle='->', color='darkred', lw=0.8))\n\nax2.set_xscale('log')\nax2.set_xlabel('Return Period (years)', fontsize=11)\nax2.set_ylabel('Peak Discharge (cfs)', fontsize=11)\nax2.set_title('Flood Frequency Curve (Log-Pearson Type III)', fontsize=12)\nax2.legend(fontsize=9)\nax2.grid(True, which='both', alpha=0.3)\n\n# --- Plot 3: Log-Pearson Type III Probability Paper ---\nax3 = axes[1, 0]\n# Standard probability paper plot\nz_values = stats.norm.ppf(1 - exceedance_prob)\n\nax3.scatter(z_values, np.log10(sorted_peaks), c='steelblue', s=30, zorder=5,\n            edgecolors='navy', linewidth=0.5, label='Observed (log Q)')\n\n# Fitted line\nz_fit = np.linspace(-2.5, 3.5, 200)\nlog_q_fit = mean_log + skew_log / 6.0 * ((1 + skew_log * z_fit / 6.0)**3 - 1) + std_log * z_fit\n# Simplified: use the K-factor approach\nlog_q_fit_line = []\nfor z in z_fit:\n    # Convert z back to return period\n    p = 1 - stats.norm.cdf(z)\n    if p > 0 and p < 1:\n        T_temp = 1.0 / p\n        k = compute_k_factor(T_temp, skew_log)\n        log_q_fit_line.append(mean_log + k * std_log)\n    else:\n        log_q_fit_line.append(np.nan)\n\nax3.plot(z_fit, log_q_fit_line, 'r-', linewidth=2, label='LP3 Fitted Line')\nax3.axhline(y=mean_log, color='gray', linestyle=':', alpha=0.5, label=f'Mean log Q = {mean_log:.3f}')\n\nax3.set_xlabel('Standard Normal Deviate (z)', fontsize=11)\nax3.set_ylabel('log\u2081\u2080(Peak Discharge)', fontsize=11)\nax3.set_title('Log-Pearson Type III Probability Plot', fontsize=12)\nax3.legend(fontsize=9)\nax3.grid(True, alpha=0.3)\n\n# --- Plot 4: Flow Duration / Exceedance Probability ---\nax4 = axes[1, 1]\n\n# Use all daily data for flow duration curve\nall_discharge = df['discharge_cfs'].sort_values(ascending=False).values\nn_daily = len(all_discharge)\nexceedance_daily = np.arange(1, n_daily + 1) / (n_daily + 1) * 100\n\nax4.semilogy(exceedance_daily, all_discharge, 'b-', linewidth=0.8, alpha=0.7, \n             label='Daily Flow Duration')\n\n# Mark flood thresholds on flow duration\nfor T in [2, 5, 10, 25, 100]:\n    ax4.axhline(y=flood_thresholds[T], color='red', linestyle='--', alpha=0.6, linewidth=1)\n    # Find exceedance percentage for this threshold\n    pct_exceed = np.sum(all_discharge >= flood_thresholds[T]) / n_daily * 100\n    ax4.annotate(f'{T}-yr: {flood_thresholds[T]:,.0f} cfs\\n({pct_exceed:.2f}% exceedance)',\n                 xy=(pct_exceed, flood_thresholds[T]),\n                 xytext=(5, 15), textcoords='offset points',\n                 fontsize=7, color='darkred',\n                 arrowprops=dict(arrowstyle='->', color='darkred', lw=0.8))\n\nax4.set_xlabel('Percent Exceedance (%)', fontsize=11)\nax4.set_ylabel('Discharge (cfs)', fontsize=11)\nax4.set_title('Flow Duration Curve with Flood Thresholds', fontsize=12)\nax4.legend(fontsize=9, loc='upper right')\nax4.grid(True, alpha=0.3)\nax4.set_xlim([0.01, 100])\n\nplt.tight_layout()\nplt.savefig('flood_threshold_analysis.png', dpi=150, bbox_inches='tight')\nplt.show()\n\nprint(\"\\nPlot saved as 'flood_threshold_analysis.png'\")\n\n# ============================================================\n# 6. SUMMARY TABLE\n# ============================================================\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"FLOOD THRESHOLD SUMMARY\")\nprint(\"=\"*60)\n\nprint(f\"\\nUSGS Station: {SITE_ID}\")\nprint(f\"Station Name: {metadata.get('siteName', ['Unknown'])[0] if isinstance(metadata.get('siteName'), list) else metadata.get('siteName', 'Unknown')}\")\nprint(f\"Analysis Period: {df.index.min().strftime('%Y-%m-%d')} to {df.index.max().strftime('%Y-%m-%d')}\")\nprint(f\"Total Daily Records: {len(df):,}\")\nprint(f\"Annual Peaks Analyzed: {n}\")\nprint(f\"\\nLog-Pearson Type III Parameters:\")\nprint(f\"  Mean of log\u2081\u2080(Q):  {mean_log:.4f}\")\nprint(f\"  Std Dev of log\u2081\u2080(Q): {std_log:.4f}\")\nprint(f\"  Skewness of log\u2081\u2080(Q): {skew_log:.4f}\")\n\nprint(f\"\\n{'\u2500'*60}\")\nprint(f\"{'Flood Threshold Summary (cfs)':^60}\")\nprint(f\"{'\u2500'*60}\")\nprint(f\"{'Return Period':<20} {'Discharge (cfs)':<20} {'Category'}\")\nprint(f\"{'\u2500'*60}\")\n\ncategory_labels = {\n    2: 'Action / Bankfull',\n    5: 'Minor Flooding',\n    10: 'Moderate Flooding',\n    25: 'Major Flooding',\n    50: 'Record Flooding',\n    100: 'Extreme (100-yr)',\n    200: 'Extreme (200-yr)',\n    500: 'Extreme (500-yr)'\n}\n\nfor T in return_periods:\n    cat = category_labels.get(T, '')\n    print(f\"{T:>5}-year{'':<11} {flood_thresholds[T]:>15,.0f}{'':<5} {cat}\")\n\nprint(f\"{'\u2500'*60}\")\n\n# ============================================================\n# 7. RECENT FLOOD EVENTS ANALYSIS\n# ============================================================\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"RECENT FLOOD EVENTS (Last 10 Years)\")\nprint(\"=\"*60)\n\nrecent = df[df.index >= '2014-01-01'].copy()\nrecent_peaks = recent['discharge_cfs'].resample('YE').max()\n\nprint(f\"\\n{'Year':<8} {'Peak Flow (cfs)':<20} {'Flood Category'}\")\nprint(\"-\" * 55)\n\nfor date, flow in recent_peaks.items():\n    if pd.isna(flow) or flow <= 0:\n        continue\n    # Determine category\n    if flow >= flood_thresholds.get(100, float('inf')):\n        cat = \"Extreme (>100-yr)\"\n    elif flow >= flood_thresholds.get(50, float('inf')):\n        cat = \"Record (50-yr)\"\n    elif flow >= flood_thresholds.get(25, float('inf')):\n        cat = \"Major (25-yr)\"\n    elif flow >= flood_thresholds.get(10, float('inf')):\n        cat = \"Moderate (10-yr)\"\n    elif flow >= flood_thresholds.get(5, float('inf')):\n        cat = \"Minor (5-yr)\"\n    elif flow >= flood_thresholds.get(2, float('inf')):\n        cat = \"Action (2-yr)\"\n    else:\n        cat = \"Below Action\"\n    \n    print(f\"{date.year:<8} {flow:>15,.0f}{'':<5} {cat}\")\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"ANALYSIS COMPLETE\")\nprint(\"=\"*60)\n```\n\n## How to Run\n\n```bash\npip install dataretrieval numpy pandas matplotlib scipy\npython