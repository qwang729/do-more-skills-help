f.filepath, 'r') as zf:\n            # Try common filenames\n            candidates = [\n                'Map.civ6map',\n                'map.civ6map',\n                'MapSetup.civ6map',\n                'GameSetup.civ6map',\n            ]\n            names = zf.namelist()\n\n            target = None\n            for c in candidates:\n                if c in names:\n                    target = c\n                    break\n\n            if target is None:\n                # Try any .civ6map or .xml file\n                for n in names:\n                    if n.lower().endswith('.civ6map') or n.lower().endswith('.xml'):\n                        target = n\n                        break\n\n            if target is None:\n                raise ValueError(\n                    f\"No map XML found in archive. Contents: {names}\")\n\n            return zf.read(target)\n\n    def _parse_metadata(self, root: ET.Element):\n        \"\"\"Extract map dimensions and settings.\"\"\"\n        # Try various tag names\n        for tag in ['Width', 'width', 'MapWidth']:\n            el = root.find(f'.//{tag}')\n            if el is not None and el.text:\n                self.width = int(el.text)\n                break\n\n        for tag in ['Height', 'height', 'MapHeight']:\n            el = root.find(f'.//{tag}')\n            if el is not None and el.text:\n                self.height = int(el.text)\n                break\n\n        # World wrap\n        wrap_el = root.find('.//WorldWrap')\n        if wrap_el is not None and wrap_el.text:\n            self.world_wrap = wrap_el.text.lower() in ('true', '1', 'yes')\n\n        print(f\"[Parser] Map size: {self.width} x {self.height}, \"\n              f\"wrap={self.world_wrap}\")\n\n    def _parse_plots(self, root: ET.Element):\n        \"\"\"Parse all plot elements.\"\"\"\n        # Find plot container\n        plots_container = None\n        for tag in ['Plots', 'plots', 'PlotData', 'MapPlots']:\n            plots_container = 