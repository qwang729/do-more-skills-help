rror checking DOI: {str(e)}\"\n\ndef validate_year(year):\n    \"\"\"Validates that the year is a reasonable integer.\"\"\"\n    if not year:\n        return False, \"Missing year\"\n    try:\n        y = int(year)\n        current_year = datetime.now().year\n        if 1900 <= y <= current_year + 1:\n            return True, \"Valid year\"\n        else:\n            return False, f\"Year {y} out of reasonable range (1900-{current_year+1})\"\n    except ValueError:\n        return False, \"Year is not a valid integer\"\n\ndef validate_authors(authors):\n    \"\"\"Basic validation for author field formatting.\"\"\"\n    if not authors:\n        return False, \"Missing authors\"\n    # BibTeX authors are typically separated by ' and '\n    if ' and ' not in authors and len(authors.split()) < 2:\n        return False, \"Author format might be incorrect (expected 'Last, First and Last, First')\"\n    return True, \"Valid authors\"\n\ndef verify_bibtex_file(file_path):\n    \"\"\"Parses and verifies all entries in a BibTeX file.\"\"\"\n    with open(file_path, encoding='utf-8') as bibtex_file:\n        bib_database = bibtexparser.load(bibtex_file)\n    \n    report = []\n    # Define required fields per entry type\n    required_fields = {\n        'article': ['author', 'title', 'journal', 'year'],\n        'inproceedings': ['author', 'title', 'booktitle', 'year'],\n        'book': ['author', 'title', 'publisher', 'year'],\n        'phdthesis': ['author', 'title', 'school', 'year'],\n        'mastersthesis': ['author', 'title', 'school', 'year'],\n        'techreport': ['author', 'title', 'institution', 'year'],\n        'misc': ['author', 'title']\n    }\n    \n    for entry in bib_database.entries:\n        entry_id = entry.get('ID', 'Unknown ID')\n        entry_type = entry.get('ENTRYTYPE', 'unknown').lower()\n        issues = []\n        \n        # 1. Check required fields\n        req_fields = required_fields.get(entry_type, ['author', 'title', 'year'])\n        for field in req_fields:\n            if not entry.get(field):\n                issues.append(f\"Missing required field: '{field}'\")\n                \n        # 2. Validate specific fields\n        if entry.get('year'):\n            valid, msg = validate_year(entry['year'])\n            if not valid:\n                issues.append(f\"Year error: {msg}\")\n                \n        if entry.get('author'):\n            valid, msg = validate_authors(entry['author'])\n            if not valid:\n                issues.append(f\"Author error: {msg}\")\n                \n        if entry.get('doi'):\n            valid, msg = validate_doi(entry['doi'])\n            if not valid:\n                issues.append(f\"DOI error: {msg}\")\n                \n        status = \"PASS\" if not issues else \"FAIL\"\n        report.append({\n            'id': entry_id,\n            'type': entry_type,\n            'status': status,\n            'issues': issues\n        })\n        \n    return report\n\ndef doi_to_bibtex(doi):\n    \"\"\"Fetches a properly formatted BibTeX entry from CrossRef using a DOI.\"\"\"\n    url = f\"http://doi.org/{doi}\"\n    headers = {'Accept': 'application/x-bibtex'}\n    try:\n        response = requests.get(url, headers=headers, timeout=10)\n        if response.status_code == 200:\n            return response.text\n        else:\n            return f\"Error: Could not fetch BibTeX for DOI {doi} (HTTP {response.status_code})\"\n    except requests.RequestException as e:\n        return f\"Network error: {str(e)}\"\n\ndef print_report(report):\n    \"\"\"Prints the verification report to the console.\"\"\"\n    print(f\"{'Citation ID':<30} | {'Type':<15} | {'Status':<5} | Issues\")\n    print(\"-\" * 90)\n    for res in report:\n        issues_str = \"; \".join(res['issues']) if res['issues'] else \"None\"\n        print(f\"{res['id']:<30} | {res['type']:<15} | {res['status']:<5} | {issues_str}\")\n\nif __name__ == \"__main__\":\n    if len(sys.argv) < 2:\n        print(\"Usage:\")\n        print(\"  Verify a file: python citation_manager.py verify <path_to_bibtex_file>\")\n        print(\"  Get BibTeX:    python citation_manager.py fetch <DOI>\")\n        sys.exit(1)\n        \n    command = sys.argv[1]\n    \n    if command == \"verify\" and len(sys.argv) == 3:\n        file_path = sys.argv[2]\n        print(f\"Verifying citations in: {file_path}\\n\")\n        results = verify_bibtex_file(file_path)\n        print_report(results)\n        \n    elif command == \"fetch\" and len(sys.argv) == 3:\n        doi = sys.argv[2]\n        print(f\"Fetching BibTeX for DOI: {doi}\\n\")\n        bibtex_entry = doi_to_bibtex(doi)\n        print(bibtex_entry)\n        \n    else:\n        print(\"Invalid command or arguments.\")\n        print(\"Usage:\")\n        print(\"  Verify a file: python citation_manager.py verify <path_to_bibtex_file>\")\n        print(\"  Get BibTeX:    python citation_manager.py fetch <DOI>\")\n```\n\n### Example Usage\n\n#### 1. Verify an existing BibTeX file\nCreate a test file named `references.bib`:\n```bibtex\n@article{einstein1905,\n  author = {Albert Einstein},\n  title = {On the Electrodynamics of Moving Bodies},\n  journal = {Annalen der Physik},\n  year = {1905},\n  doi = {10.1002/andp.19053221004}\n}\n\n@article{missing_fields,\n  title = {A paper with missing data},\n  year = {1850}\n}\n\n@inproceedings{bad_year,\n  author = {John Doe and Jane Smith},\n  title = {Future Paper},\n  booktitle = {Proceedings of the Future},\n  year = {2099},\n  doi = {invalid-doi-format}\n}\n```\n\nRun the verification command:\n```bash\npython citation_manager.py verify references.bib\n```\n\n**Expected Output:**\n```text\nVerifying citations in: references.bib\n\nCitation ID                    | Type            | Status | Issues\n------------------------------------------------------------------------------------------\neinstein1905                   | article         | PASS  | None\nmissing_fields         