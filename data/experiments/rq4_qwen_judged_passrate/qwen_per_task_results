Dependencies\": {\n    \"@types/node\": \"^20.0.0\",\n    \"@types/react\": \"^18.3.0\",\n    \"@types/react-dom\": \"^18.3.0\",\n    \"typescript\": \"^5.4.0\",\n    \"tailwindcss\": \"^3.4.0\",\n    \"postcss\": \"^8.4.0\",\n    \"autoprefixer\": \"^10.4.0\"\n  }\n}\n```\n\n### `next.config.js`\n\n```js\n/** @type {import('next').NextConfig} */\nconst nextConfig = {\n  experimental: {\n    serverActions: true,\n  },\n};\n\nmodule.exports = nextConfig;\n```\n\n### `tsconfig.json`\n\n```json\n{\n  \"compilerOptions\": {\n    \"target\": \"es2017\",\n    \"lib\": [\"dom\", \"dom.iterable\", \"esnext\"],\n    \"allowJs\": true,\n    \"skipLibCheck\": true,\n    \"strict\": true,\n    \"noEmit\": true,\n    \"esModuleInterop\": true,\n    \"module\": \"esnext\",\n    \"moduleResolution\": \"bundler\",\n    \"resolveJsonModule\": true,\n    \"isolatedModules\": true,\n    \"jsx\": \"preserve\",\n    \"incremental\": true,\n    \"plugins\": [{ \"name\": \"next\" }],\n    \"paths\": {\n      \"@/*\": [\"./*\"]\n    }\n  },\n  \"include\": [\"next-env.d.ts\", \"**/*.ts\", \"**/*.tsx\", \".next/types/**/*.ts\"],\n  \"exclude\": [\"node_modules\"]\n}\n```\n\n### `tailwind.config.ts`\n\n```ts\nimport type { Config } from \"tailwindcss\";\n\nconst config: Config = {\n  content: [\n    \"./app/**/*.{js,ts,jsx,tsx,mdx}\",\n    \"./components/**/*.{js,ts,jsx,tsx,mdx}\",\n  ],\n  theme: {\n    extend: {\n      colors: {\n        foreground: \"var(--foreground)\",\n        background: \"var(--background)\",\n        border: \"var(--border)\",\n        muted: \"var(--muted)\",\n        accent: \"var(--accent)\",\n      },\n    },\n  },\n  plugins: [],\n};\n\nexport default config;\n```\n\n### `app/globals.css`\n\n```css\n@tailwind base;\n@tailwind components;\n@tailwind utilities;\n\n:root {\n  --foreground: #ededed;\n  --background: #0a0a0a;\n  --border: #262626;\n  --muted: #666666;\n  --accent: #0070f3;\n}\n\nbody {\n  color: var(--foreground);\n  background: var(--background);\n  font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif;\n}\n\n@layer components {\n  .card {\n    @apply rounded-lg border border-border bg-[#111] p-6;\n  }\n}\n```\n\n### `lib/db.ts`\n\n```ts\n// Simulated database - replace with real DB in production\n\nexport interface Stat {\n  label: string;\n  value: string;\n  change: number;\n  trend: \"up\" | \"down\";\n}\n\nexport interface Activity {\n  id: string;\n  user: string;\n  action: string;\n  target: string;\n  timestamp: string;\n}\n\nexport interface ChartDataPoint {\n  name: string;\n  value: number;\n}\n\nexport async function getStats(): Promise<Stat[]> {\n  // Simulate network delay\n  await new Promise((r) => setTimeout(r, 100));\n  return [\n    { label: \"Total Revenue\", value: \"$45,231\", change: 12.5, trend: \"up\" },\n    { label: \"Active Users\", value: \"2,350\", change: 8.2, trend: \"up\" },\n    { label: \"Deployments\", value: \"1,247\", change: -3.1, trend: \"down\" },\n    { label: \"Bandwidth\", value: \"128 GB\", change: 24.7, trend: \"up\" },\n  ];\n}\n\nexport async function getActivity(): Promise<Activity[]> {\n  await new Promise((r) => setTimeout(r, 150));\n  return [\n    { id: \"1\", user: \"Alice\", action: \"deployed\", target: \"main \u2192 production\", timestamp: \"2 min ago\" },\n    { id: \"2\", user: \"Bob\", action: \"merged\", target: \"PR #482\", timestamp: \"15 min ago\" },\n    { id: \"3\", user: \"Carol\", action: \"created\", target: \"branch feature/auth\", timestamp: \"1 hr ago\" },\n    { id: \"4\", user: \"Dave\", action: \"updated\", target: \"env variables\", timestamp: \"2 hr ago\" },\n    { id: \"5\", user: \"Eve\", action: \"rolled back\", target: \"deployment dpl_8xK2\", timestamp: \"3 hr ago\" },\n  ];\n}\n\nexport async function getChartData(): Promise<ChartDataPoint[]> {\n  await new Promise((r) => setTimeout(r, 120));\n  return [\n    { name: \"Mon\", value: 120 },\n    { name: \"Tue\", value: 190 },\n    { name: \"Wed\", value: 150 },\n    { name: \"Thu\", value: 280 },\n    { name: \"Fri\", value: 220 },\n    { name: \"Sat\", value: 310 },\n    { name: \"Sun\", value: 270 },\n  ];\n}\n```\n\n### `lib/utils.ts`\n\n```ts\nimport { clsx, type ClassValue } from \"clsx\";\n\nexport function cn(...inputs: ClassValue[]) {\n  return clsx(inputs);\n}\n\nexport function formatNumber(num: number): string {\n  if (num >= 1_000_000) return `${(num / 1_000_000).toFixed(1)}M`;\n  if (num >= 1_000) return `${(num / 1_000).toFixed(1)}K`;\n  return num.toString();\n}\n```\n\n### `app/api/dashboard/route.ts`\n\n```ts\n// CRITICAL: Waterfall elimination pattern\n// Instead of sequential awaits, we use Promise.all to fetch all data in parallel\nimport { NextResponse } from \"next/server\";\nimport { getStats, getActivity, getChartData } from \"@/lib/db\";\n\nexport async function GET() {\n  // \u2705 PARALLEL: All three queries run concurrently \u2014 no waterfall\n  const [stats, activity, chartData] = await Promise.all([\n    getStats(),\n    getActivity(),\n    getChartData(),\n  ]);\n\n  return NextResponse.json({ stats, activity, chartData });\n}\n```\n\n### `app/components/StatsCard.tsx`\n\n```tsx\n\"use client\";\n\nimport { cn } from \"@/lib/utils\";\n\ninterface StatsCardProps {\n  label: string;\n  value: string;\n  change: number;\n  trend: \"up\" | \"down\";\n}\n\nexport function StatsCard({ label, value, change, trend }: StatsCardProps) {\n  return (\n    <div className=\"card\">\n      <p className=\"text-sm text-[var(--muted)]\">{label}</p>\n      <p className=\"mt-2 text-2xl font-semibold tracking-tight\">{value}</p>\n      <p\n        className={cn(\n          \"mt-2 text-sm\",\n          trend === \"up\" ? \"text-green-500\" : \"text-red-500\"\n        )}\n      >\n        {trend === \"up\" ? \"\u2191\" : \"\u2193\"} {Math.abs(change)}%\n        <span className=\"text-[var(--muted)]\"> vs last week</span>\n      </p>\n    </div>\n  );\n}\n```\n\n### `app/components/ActivityFeed.tsx`\n\n```tsx\n\"use client\";\n\nimport type { Activity } from \"@/lib/db\";\n\ninterface ActivityFeedProps {\n  activities: Activity[];\n}\n\nexport function ActivityFeed({ activities }: ActivityFeedProps) {\n  return (\n    <div className=\"card\">\n      <h2 className=\"mb-4 text-lg font-semibold\">Recent Activity</h2>\n      <ul className=\"space-y-4\">\n        {activities.map((item) => (\n          <li key={item.id} className=\"flex items-start gap-3\">\n            <div className=\"flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--accent)] text-xs font-bold text-white\">\n              {item.user[0]}\n            </div>\n            <div className=\"min-w-0 flex-1\">\n              <p className=\"text-sm\">\n                <span className=\"font-medium\">{item.user}</span>{\" \"}\n                <span className=\"text-[var(--muted)]\">{item.action}</span>{\" \"}\n                <span className=\"font-medium\">{item.target}</span>\n              </p>\n              <p className=\"text-xs text-[var(--muted)]\">{item.timestamp}</p>\n            </div>\n          </li>\n        ))}\n      </ul>\n    </div>\n  );\n}\n```\n\n### `app/components/Chart.tsx`\n\n```tsx\n\"use client\";\n\nimport type { ChartDataPoint } from \"@/lib/db\";\n\ninterface ChartProps {\n  data: ChartDataPoint[];\n}\n\nexport function Chart({ data }: ChartProps) {\n  const maxValue = Math.max(...data.map((d) => d.value));\n\n  return (\n    <div className=\"card\">\n      <h2 className=\"mb-4 text-lg font-semibold\">Deployments This Week</h2>\n      <div className=\"flex items-end gap-2\" style={{ height: 200 }}>\n        {data.map((point) => {\n          const height = (point.value / maxValue) * 100;\n          return (\n            <div key={point.name} className=\"flex flex-1 flex-col items-center gap-2\">\n              <div\n                className=\"w-full rounded-t bg-[var(--accent)] transition-all hover:opacity-80\"\n                style={{ height: `${height}%` }}\n                title={`${point.name}: ${point.value}`}\n              />\n              <span className=\"text-xs text-[var(--muted)]\">{point.name}</span>\n            </div>\n          );\n        })}\n      </div>\n    </div>\n  );\n}\n```\n\n### `app/components/Dashboard.tsx`\n\n```tsx\n\"use client\";\n\nimport { StatsCard } from \"./StatsCard\";\nimport { ActivityFeed } from \"./ActivityFeed\";\nimport { Chart } from \"./Chart\";\nimport type { Stat, Activity, ChartDataPoint } from \"@/lib/db\";\n\ninterface DashboardProps {\n  stats: Stat[];\n  activity: Activity[];\n  chartData: ChartDataPoint[];\n}\n\nexport function Dashboard({ stats, activity, chartData }: DashboardProps) {\n  return (\n    <div className=\"mx-auto max-w-6xl space-y-6 p-6\">\n      <header>\n        <h1 className=\"text-3xl font-bold tracking-tight\">Dashboard</h1>\n        <p className=\"mt-1 text-[var(--muted)]\">\n          Overview of your project metrics and activity.\n        </p>\n      </header>\n\n      {/* Stats Grid */}\n      <section className=\"grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4\">\n        {stats.map((stat) => (\n          <StatsCard key={stat.label} {...stat} />\n        ))}\n      </section>\n\n      {/* Chart + Activity */}\n      <section className=\"grid grid-cols-1 gap-6 lg:grid-cols-2\">\n        <Chart data={chartData} />\n        <ActivityFeed activities={activity} />\n      </section>\n    </div>\n  );\n}\n```\n\n### `app/layout.tsx`\n\n```tsx\nimport type { Metadata } from \"next\";\nimport \"./globals.css\";\n\nexport const metadata: Metadata = {\n  title: \"Dashboard | Vercel Guidelines Demo\",\n  description: \"A dashboard built following Vercel web interface guidelines\",\n};\n\nexport default function RootLayout({\n  children,\n}: {\n  children: React.ReactNode;\n}) {\n  return (\n    <html lang=\"en\">\n      <body className=\"min-h-screen antialiased\">{children}</body>\n    </html>\n  );\n}\n```\n\n### `app/page.tsx`\n\n```tsx\n// CRITICAL: Server Component \u2014 data fetched on the server, no client-side waterfall\n// All three data calls are parallelized via Promise.all in the API route,\n// OR we can fetch them directly here in parallel.\nimport { Dashboard } from \"./components/Dashboard\";\nimport { getStats, getActivity, getChartData } from \"@/lib/db\";\n\nexport const dynamic = \"force-dynamic\";\n\nexport default async function Page() {\n  // \u2705 PARALLEL data fetching \u2014 eliminates the waterfall\n  // All three queries start simultaneously instead of waiting for each other\n  const [stats, activity, chartData] = await Promise.all([\n    getStats(),\n    getActivity(),\n    getChartData(),\n  ]);\n\n  return (\n    <main>\n      <Dashboard stats={stats} activity={activity} chartData={chartData} />\n    </main>\n  );\n}\n```\n\n## Key Patterns Applied (React Best Practices)\n\n| # | Pattern | Implementation |\n|---|---------|---------------|\n| 1 | **Waterfall Elimination** | `Promise.all()` in `page.tsx` and `api/dashboard/route.ts` \u2014 all data fetched in parallel |\n| 2 | **Server Components by Default** | `page.tsx` is a Server Component; data fetched on server, zero client JS for data |\n| 3 | **\"use client\" Boundary** | Only interactive components (`StatsCard`, `ActivityFeed`, `Chart`, `Dashboard`) are client components |\n| 4 | **Props over Fetching** | Client components receive data via props \u2014 no redundant client-side fetches |\n| 5 | **Composition** | Small, focused components composed in `Dashboard` |\n| 6 | **Type Safety** | Full TypeScript with explicit interfaces for all data shapes |\n| 7 | **CSS Variables** | Design tokens via CSS custom properties for theming |\n| 8 | **Responsive Grid** | `grid-cols-1 sm:grid-cols-2 lg:grid-cols-4` progressive layout |\n| 9 | **Semantic HTML** | `<main>`, `<header>`, `<section>`, `<ul>/<li>` |\n| 10 | **Metadata** | Proper `<title>` and `<description>` in layout |\n\n## How to Run\n\n```bash\nnpm install\nnpm run dev\n```\n\nThen open `http://localhost:3000`.\n\nThis implementation follows Vercel's web-interface-guidelines by using server-first data fetching, eliminating request waterfalls with `Promise.all`, keeping the client bundle minimal with the `\"use client\"` boundary pattern, and maintaining a clean component architecture with proper TypeScript types throughout.", "solver_finish_reason": "stop"}
{"task": "fix-visual-stability", "condition": "random_wrong", "repeat": 0, "skill_ids": ["benchflow-ai--civ6lib"], "retrieval_correct": false, "judged_pass": false, "judged_score": 0, "judge_reason": "Agent solution is unrelated to the task, providing a Civ6 game mechanic implementation instead of a web interface setup script.", "solver_tokens": 8612, "judge_tokens": 5377, "solution_text": "# Civ6 District Mechanics - Web Interface & Agent Skill Guide\n\nBelow is a complete implementation adapting Vercel's web-interface-guidelines and agent-skills patterns to Civilization 6 district mechanics. This includes placement validation, adjacency bonus calculations, and structured skill definitions.\n\n---\n\n## 1. Core Types & Constants\n\n```typescript\n// types.ts\nexport type TerrainType = 'plains' | 'grassland' | 'desert' | 'tundra' | 'snow' | 'hill' | 'mountain' | 'coast' | 'ocean';\nexport type FeatureType = 'forest' | 'jungle' | 'marsh' | 'oasis' | 'floodplain' | 'reef' | 'woods' | 'rainforest' | null;\nexport type ResourceType = 'wheat' | 'stone' | 'cattle' | 'sheep' | 'deer' | 'fish' | 'bananas' | 'iron' | 'horses' | 'niter' | 'coal' | 'oil' | 'aluminum' | 'uranium' | 'gems' | 'gold_ore' | 'silver' | 'copper' | 'ivory' | 'silk' | 'spices' | 'dyes' | 'incense' | 'cotton' | 'truffles' | 'citrus' | 'crabs' | 'pearls' | 'salt' | 'wine' | 'tea' | 'coffee' | 'cocoa' | null;\nexport type DistrictType = 'campus' | 'holy_site' | 'theater_square' | 'commercial_hub' | 'harbor' | 'encampment' | 'industrial_zone' | 'entertainment_complex' | 'water_park' | 'government_plaza' | 'neighborhood' | 'aerodrome' | 'spaceport' | 'diplomatic_quarter' | 'aqueduct' | 'canal' | 'dam';\n\nexport interface Tile {\n  id: string;\n  x: number;\n  y: number;\n  terrain: TerrainType;\n  feature: FeatureType;\n  resource: ResourceType;\n  isRiver: boolean;\n  isCoastal: boolean;\n  isLake: boolean;\n  elevation: number;\n  continent: number;\n  ownedBy: string | null; // player id\n  hasWonder: boolean;\n  hasDistrict: DistrictType | null;\n  isCityCenter: boolean;\n}\n\nexport interface City {\n  id: string;\n  name: string;\n  x: number;\n  y: number;\n  ownerId: string;\n  tiles: Tile[]; // all tiles within city workable range\n}\n\nexport interface GameState {\n  tiles: Map<string, Tile>; // key: \"x,y\"\n  cities: City[];\n  players: string[];\n}\n\nexport interface AdjacencyBonus {\n  source: string;\n  value: number;\n}\n\nexport interface PlacementResult {\n  valid: boolean;\n  errors: string[];\n  warnings: string[];\n  adjacencyBonuses: AdjacencyBonus[];\n  totalAdjacency: number;\n}\n```\n\n---\n\n## 2. Adjacency Bonus Calculator\n\n```typescript\n// adjacency.ts\nimport { Tile, DistrictType, AdjacencyBonus, GameState } from './types';\n\nconst HEX_DIRECTIONS = [\n  { dx: 1, dy: 0 },\n  { dx: 1, dy: -1 },\n  { dx: 0, dy: -1 },\n  { dx: -1, dy: 0 },\n  { dx: -1, dy: 1 },\n  { dx: 0, dy: 1 },\n];\n\nfunction getTileKey(x: number, y: number): string {\n  return `${x},${y}`;\n}\n\nfunction getNeighbors(x: number, y: number): { x: number; y: number }[] {\n  return HEX_DIRECTIONS.map(d => ({ x: x + d.dx, y: y + d.dy }));\n}\n\nfunction getTilesInRange(x: number, y: number, range: number, state: GameState): Tile[] {\n  const results: Tile[] = [];\n  const visited = new Set<string>();\n  const queue: { x: number; y: number; dist: number }[] = [{ x, y, dist: 0 }];\n  visited.add(getTileKey(x, y));\n\n  while (queue.length > 0) {\n    const current = queue.shift()!;\n    if (current.dist > 0) {\n      const tile = state.tiles.get(getTileKey(current.x, current.y));\n      if (tile) results.push(tile);\n    }\n    if (current.dist < range) {\n      for (const n of getNeighbors(current.x, current.y)) {\n        const key = getTileKey(n.x, n.y);\n        if (!visited.has(key)) {\n          visited.add(key);\n          queue.push({ x: n.x, y: n.y, dist: current.dist + 1 });\n        }\n      }\n    }\n  }\n  return results;\n}\n\nfunction countAdjacent(\n  x: number, y: number,\n  state: GameState,\n  predicate: (tile: Tile) => boolean\n): number {\n  return getNeighbors(x, y).filter(n => {\n    const tile = state.tiles.get(getTileKey(n.x, n.y));\n    return tile && predicate(tile);\n  }).length;\n}\n\nfunction countInRange(\n  x: number, y: number, range: number,\n  state: GameState,\n  predicate: (tile: Tile) => boolean\n): number {\n  return getTilesInRange(x, y, range, state).filter(predicate).length;\n}\n\n// --- District-specific adjacency calculators ---\n\nfunction campusAdjacency(x: number, y: number, state: GameState): AdjacencyBonus[] {\n  const bonuses: AdjacencyBonus[] = [];\n  \n  // +1 per adjacent mountain\n  const mountains = countAdjacent(x, y, state, t => t.terrain === 'mountain');\n  if (mountains > 0) bonuses.push({ source: 'mountains', value: mountains });\n\n  // +1 per adjacent geothermal fissure (natural wonder) - simplified as +1 per adjacent reef/feature\n  // +1 per adjacent reef\n  const reefs = countAdjacent(x, y, state, t => t.feature === 'reef');\n  if (reefs > 0) bonuses.push({ source: 'reefs', value: reefs });\n\n  // +1 per adjacent rainforest\n  const rainforests = countAdjacent(x, y, state, t => t.feature === 'rainforest' || t.feature === 'jungle');\n  if (rainforests > 0) bonuses.push({ source: 'rainforests', value: rainforests });\n\n  // +2 per adjacent district (standard rule)\n  const districts = countAdjacent(x, y, state, t => t.hasDistrict !== null && t.hasDistrict !== 'campus');\n  if (districts > 0) bonuses.push({ source: 'districts', value: districts * 2 });\n\n  // +2 per adjacent Great Barrier Reef (world wonder) - simplified\n  // +1 per adjacent wonder (some)\n  const wonders = countAdjacent(x, y, state, t => t.hasWonder);\n  if (wonders > 0) bonuses.push({ source: 'wonders', value: wonders });\n\n  return bonuses;\n}\n\nfunction holySiteAdjacency(x: number, y: number, state: GameState): AdjacencyBonus[] {\n  const bonuses: AdjacencyBonus[] = [];\n\n  // +1 per adjacent n