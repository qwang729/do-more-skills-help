var)\n    net.gen.min_q_mvar = [-300.0, -300.0, -300.0]\n    net.gen.max_q_mvar = [300.0, 300.0, 300.0]\n    \n    # Line thermal limits (max loading percentage)\n    net.line.max_loading_percent = 100.0\n    \n    # ---------------------------------------------------------\n    # 3. Define Generator Cost Functions (Economic Dispatch)\n    # ---------------------------------------------------------\n    # Quadratic cost function: Cost = c2 * P^2 + c1 * P + c0\n    net.poly_cost = pd.DataFrame() # Clear any default costs\n    \n    # Gen 1 (Bus 1): Higher quadratic penalty, moderate linear\n    pp.create_poly_cost(net, 0, 'gen', cp2_eur_per_mw2=0.10, cp1_eur_per_mw=20.0, cp0_eur=0.0)\n    # Gen 2 (Bus 2): Lower quadratic penalty, higher linear\n    pp.create_poly_cost(net, 1, 'gen', cp2_eur_per_mw2=0.08, cp1_eur_per_mw=25.0, cp0_eur=0.0)\n    # Gen 3 (Bus 3): Highest quadratic penalty, lowest linear\n    pp.create_poly_cost(net, 2, 'gen', cp2_eur_per_mw2=0.12, cp1_eur_per_mw=15.0, cp0_eur=0.0)\n    \n    # ---------------------------------------------------------\n    # 4. Solve AC Optimal Power Flow\n    # ---------------------------------------------------------\n    # pandapower's runopp solves the non-linear AC-OPF using pypower/ipopt\n    pp.runopp(net, verbose=False)\n    \n    # ---------------------------------------------------------\n    # 5. Extract Results and Calculate Operating Margins\n    # ---------------------------------------------------------\n    print(\"=\"*50)\n    print(\" AC OPTIMAL POWER FLOW RESULTS\")\n    print(\"=\"*50)\n    \n    if not net.OPF_converged:\n        print(\"\\n[ERROR] OPF did not converge. Check constraints/initialization.\")\n        return\n\n    print(f\"\\nTotal Minimum Operating Cost: {net.res_cost:.2f} EUR/h\\n\")\n    \n    # Generator Setpoints & Margins\n    print(\"--- Generator Setpoints & Operating Margins ---\")\n    net.res_gen['p_margin_mw'] = net.gen.max_p_mw - net.res_gen.p_mw\n    net.res_gen['q_margin_mvar'] = net.gen.max_q_mvar - net.res_gen.q_mvar\n    print(net.res_gen[['p_mw', 'p_margin_mw', 'q_mvar', 'q_margin_mvar']].round(2))\n    \n    # Bus Voltages\n    print(\"\\n--- Bus Voltage Profiles ---\")\n    print(net.res_bus[['vm_pu', 'va_degree']].round(4))\n    \n    # Line Loading\n    print(\"\\n--- Line Loading & Margins ---\")\n    net.res_line['loading_margin_percent'] = 100.0 - net.res_line.loading_percent\n    print(net.res_line[['loading_percent', 'loading_margin_percent']].round(2))\n    \n    print(\"\\n[SUCCESS] AC-OPF converged successfully.\")\n\nif __name__ == \"__main__\":\n    solve_ac_opf()\n```\n\n### How this addresses the optimization requirements:\n1. **Economic Dispatch & Cost Optimization**: The `poly_cost` definitions map the quadratic fuel-cost curves to the generators. The solver shifts the active power dispatch to minimize the total system cost while respecting the non-linear network physics.\n2. **AC Network Constraints**: Unlike DC-OPF, this solves the full non-linear AC power flow equations, meaning reactive power (`q_mvar`), voltage magnitudes (`vm_pu`), and voltage angles (`va_degree`) are explicitly optimized and constrained.\n3. **Operating Margins**: The script explicitly calculates the remaining headroom (margin) for both generators (MW/Mvar) and transmission lines (%) to show how close the system is operating to its physical limits.", "solver_finish_reason": "stop"}
{"task": "energy-ac-optimal-power-flow", "condition": "random_wrong", "repeat": 0, "skill_ids": ["benchflow-ai--Voice Activity Detection (VAD)"], "retrieval_correct": false, "judged_pass": false, "judged_score": 0, "judge_reason": "Agent's solution uses Pyomo and a hardcoded 3-bus system, deviating from the oracle's CasADi-based, general formulation on the provided input data", "solver_tokens": 5452, "judge_tokens": 2740, "solution_text": "To solve the AC Optimal Power Flow (AC-OPF) problem, we formulate it as a non-linear programming (NLP) problem. The objective is to minimize the total generation cost while satisfying the non-linear AC power flow equations, generator capacity limits, and voltage limits. \n\nBelow is a complete, runnable Python solution using **Pyomo** (for mathematical modeling) and **Ipopt** (as the non-linear solver) for a standard 3-bus test system.\n\n### Prerequisites\nInstall the required Python packages and the Ipopt solver:\n```bash\npip install pyomo numpy\n# Install the Ipopt solver (using IDAES which provides pre-compiled binaries)\npip install idaes-pse --extend\nidaes get-extensions\n```\n\n### Complete AC-OPF Python Implementation\n\n```python\nimport pyomo.environ as pyo\nimport numpy as np\n\n# ==========================================\n# 1. SYSTEM DATA DEFINITION (3-Bus System)\n# ==========================================\nbuses = [1, 2, 3]\ngenerators = {1: [1], 2: [2]}  # Bus ID -> List of Generator IDs\nloads = {3: [1]}               # Bus ID -> List of Load IDs\n\n# Generator Cost Coefficients: Cost = c2*P^2 + c1*P + c0\ngen_cost = {\n    1: {'c2': 0.01, 'c1': 20.0, 'c0': 0.0},\n    2: {'c2': 0.02, 'c1': 30.0, 'c0': 0.0}\n}\n\n# Generator Active/Reactive Limits (p.u.)\ngen_limits = {\n    1: {'pmin': 0.5, 'pmax': 2.0, 'qmin': -1.0, 'qmax': 1.0},\n    2: {'pmin': 0.3, 'pmax': 1.5, 'qmin': -0.8, 'qmax': 0.8}\n}\n\n# Load Parameters (p.u.)\nload_params = {1: {'pd': 1.5, 'qd': 0.5}}\n\n# Transmission Line Parameters: (From, To, r, x, b/2)\nlines = [\n    (1, 2, 0.02, 0.06, 0.03),\n    (1, 3, 0.01, 0.03, 0.02),\n    (2, 3, 0.03, 0.08, 0.04)\n]\n\n# ==========================================\n# 2. BUILD ADMITTANCE MATRIX (Ybus)\n# ==========================================\nYbus = np.zeros((3, 3), dtype=complex)\nfor i, j, r, x, b in lines:\n    y = 1.0 / (r + 1j * x)\n    Ybus[i-1, j-1] -= y\n    Ybus[j-1, i-1] -= y\n    Ybus[i-1, i-1] += y + 1j * b\n    Ybus[j-1, j-1] += y + 1j * b\n\nG = np.real(Ybus)\nB = np.imag(Ybus)\n\n# ==========================================\n# 3. PYOMO OPTIMIZATION MODEL\n# ==========================================\nmodel = pyo.ConcreteModel()\n\n# Sets\nmodel.BUSES = pyo.Set(initialize=buses)\nmodel.GENS = pyo.Set(initialize=[1, 2])\n\n# Variables\nmodel.V = pyo.Var(model.BUSES, bounds=(0.9, 1.1))       # Voltage magnitude (p.u.)\nmodel.theta = pyo.Var(model.BUSES, bounds=(-np.pi, np.pi)) # Voltage angle (rad)\nmodel.Pg = pyo.Var(model.GENS, bounds=lambda m, g: (gen_limits[g]['pmin'], gen_limits[g]['pmax']))\nmodel.Qg = pyo.Var(model.GENS, bounds=lambda m, g: (gen_limits[g]['qmin'], gen_limits[g]['qmax']))\n\n# Fix slack bus angle reference\nmodel.theta[1].fix(0.0)\n\n# Objective: Minimize Total Generation Cost\ndef cost_rule(m, g):\n    return gen_cost[g]['c2'] * m.Pg[g]**2 + gen_cost[g]['c1'] * m.Pg[g] + gen_cost[g]['c0']\n\nmodel.obj = pyo.Objective(expr=sum(cost_rule(model, g) for g in model.GENS), sense=pyo.minimize)\n\n# Constraints: Active Power Balance (Nodal)\ndef p_balance_rule(m, i):\n    p_inj = sum(m.Pg[g] for g in generators.get(i, [])) - sum(load_params[l]['pd'] for l in loads.get(i, []))\n    \n    p_flow = 0\n    for j in m.BUSES:\n        p_flow += m.V[i] * m.V[j] * (G[i-1, j-1] * pyo.cos(m.theta[i] - m.theta[j]) + \n                                     B[i-1, j-1] * pyo.sin(m.theta[i] - m.theta[j]))\n    return p_inj == p_flow\n\nmodel.p_balance = pyo.Constraint(model.BUSES, rule=p_balance_rule)\n\n# Constraints: Reactive Power Balance (Nodal)\ndef q_balance_rule(m, i):\n    q_inj = sum(m.Qg[g] for g in generators.get(i, [])) - sum(load_params[l]['qd'] for l in loads.get(i, []))\n    \n    q_flow = 0\n    for j in m.BUSES:\n        q_flow += m.V[i] * m.V[j] * (G[i-1, j-1] * pyo.sin(m.theta[i] - m.theta[j]) - \n                                     B[i-1, j-1] * pyo.cos(m.theta[i] - m.theta[j]))\n    return q_inj == q_flow\n\nmodel.q_balance = pyo.Constraint(model.BUSES, rule=q_balance_rule)\n\n# ==========================================\n# 4. SOLVE AND PRINT RESULTS\n# ==========================================\nsolver = pyo.SolverFactory('ipopt')\n# Suppress solver output for cleaner console logs (set tee=True to see Ipopt iterations)\nresults = solver.solve(model, tee=False)\n\nif results.solver.termination_condition == pyo.TerminationCondition.optimal:\n    print(\"=== AC-OPF SOLVED SUCCESSFULLY ===\\n\")\n    \n    print(\"--- Bus Voltages & Angles ---\")\n    for i in model.BUSES:\n        v_mag = pyo.value(model.V[i])\n        v_ang = np.degrees(pyo.value(model.theta[i]))\n        print(f\"Bus {i}: |V| = {v_mag:.4f} p.u., \\u03b4 = {v_ang:.4f}\\u00b0\")\n        \n    print(\"\\n--- Generator Dispatch ---\")\n    for g in model.GENS:\n        pg = pyo.value(model.Pg[g])\n        qg = pyo.value(model.Qg[g])\n        cost = pyo.value(cost_rule(model, g))\n        print(f\"Gen {g}: Pg = {pg:.4f} p.u., Qg = {qg:.4f} p.u., Cost = ${cost:.2f}\")\n        \n    print(f\"\\nTotal System Cost: ${pyo.value(model.obj):.2f}\")\nelse:\n    print(f\"Solver failed to find optimal solution. Status: {results.solver.termination_condition}\")\n```\n\n### Mathematical Formulation Summary\n1. **Objective Function:** $\\min \\sum_{g \\in G} (c_{2,g} P_{g}^2 + c_{1,g} P_{g} + c_{0,g})$\n2. **Equality Constraints (Power Flow Equations):**\n   * $P_{G_i} - P_{D_i} = V_i \\sum_{j=1}^{N} V_j [G_{ij} \\cos(\\theta_i - \\theta_j) + B_{ij} \\sin(\\theta_i - \\theta_j)]$\n   * $Q_{G_i} - Q_{D_i} = V_i \\sum_{j=1}^{N} V_j [G_{i