0\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n@dataclass\nclass PIDConfig:\n    kp: float\n    ki: float\n    kd: float\n    setpoint: float\n    output_min: float\n    output_max: float\n    anti_windup: bool\n\n\n@dataclass\nclass SimConfig:\n    input_file: str\n    output_file: str\n    time_column: str\n    value_column: str\n    dt: float\n\n\n@dataclass\nclass Config:\n    pid: PIDConfig\n    simulation: SimConfig\n\n\ndef load_config(config_path: str) -> Config:\n    \"\"\"Load and validate YAML configuration file with proper error handling.\"\"\"\n    if not os.path.exists(config_path):\n        raise FileNotFoundError(f\"Configuration file not found: {config_path}\")\n\n    try:\n        with open(config_path, 'r') as f:\n            raw = yaml.safe_load(f)\n    except yaml.YAMLError as e:\n        raise ValueError(f\"Failed to parse YAML config '{config_path}': {e}\")\n\n    if not isinstance(raw, dict):\n        raise ValueError(\"YAML config root must be a mapping/dictionary\")\n\n    # --- Parse PID section ---\n    pid_raw = raw.get('pid')\n    if not isinstance(pid_raw, dict):\n        raise ValueError(\"Missing or invalid 'pid' section in config\")\n\n    required_pid_keys = ['kp', 'ki', 'kd', 'setpoint']\n    for key in required_pid_keys:\n        if key not in pid_raw:\n            raise ValueError(f\"Missing required PID parameter: '{key}'\")\n\n    pid = PIDConfig(\n        kp=float(pid_raw['kp']),\n        ki=float(pid_raw['ki']),\n        kd=float(pid_raw['kd']),\n        setpoint=float(pid_raw['setpoint']),\n        output_min=float(pid_raw.get('output_min', -float('inf'))),\n        output_max=float(pid_raw.get('output_max', float('inf'))),\n        anti_windup=bool(pid_raw.get('anti_windup', False)),\n    )\n\n    # --- Parse simulation section ---\n    sim_raw = raw.get('simulation')\n    if not isinstance(sim_raw, dict):\n        raise ValueError(\"Missing or invalid 'simulation' section in config\")\n\n    sim = SimConfig(\n        input_file=str(sim_raw.get('input_file', 'input_data.csv')),\n        output_file=str(sim_raw.get('output_file', 'output_data.csv')),\n        time_column=str(sim_raw.get('time_column', 'time')),\n        value_column=str(sim_raw.get('value_column', 'measured_value')),\n        dt=float(sim_raw.get('dt', 0.1)),\n    )\n\n    return Config(pid=pid, simulation=sim)\n\n\n# \u2500\u2500\u2500 CSV Time Series Parsing \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef load_csv_timeseries(filepath: str, time_col: str, value_col: str) -> Tuple[List[float], List[float]]:\n    \"\"\"\n    Load a CSV file and extract time and value columns.\n    Returns (times, values) as lists of floats.\n    \"\"\"\n    if not os.path.exists(filepath):\n        raise FileNotFoundError(f\"Input CSV file not found: {filepath}\")\n\n    times = []\n    values = []\n\n    with open(filepath, 'r', newline='') as f:\n        reader = csv.DictReader(f)\n\n        if reader.fieldnames is None:\n            raise ValueError(f\"CSV file '{filepath}' appears to be empty or has no header\")\n\n        if time_col not in reader.fieldnames:\n            raise ValueError(\n                f\"Time column '{time_col}' not found in CSV. \"\n                f\"Available columns: {reader.fieldnames}\"\n            )\n        if value_col not in reader.fieldnames:\n            raise ValueError(\n                f\"Value column '{value_col}' not found in CSV. \"\n                f\"Available columns: {reader.fieldnames}\"\n            )\n\n        for row_num, row in enumerate(reader, start=2):\n            try:\n                t = float(row[time_col])\n            except (ValueError, TypeError):\n                raise ValueError(f\"Invalid time value at row {row_num}: '{row[time_col]}'\")\n            try:\n                v = float(row[value_col])\n            except (ValueError, TypeError):\n                raise ValueError(f\"Invalid measured value at row {row_num}: '{row[value_col]}'\")\n\n            times.append(t)\n            values.append(v)\n\n    if len(times) == 0:\n        raise ValueError(f\"No data rows found in '{filepath}'\")\n\n    return times, values\n\n\n# \u2500\u2500\u2500 PID Controller \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nclass PIDController:\n    \"\"\"Discrete-time PID controller with integral anti-windup.\"\"\"\n\n    def __init__(self, config: PIDConfig):\n        self.kp = config.kp\n        self.ki = config.ki\n        self.kd = config.kd\n        self.setpoint = config.setpoint\n        self.output_min = config.output_min\n        self.output_max = config.output_max\n        self.anti_windup = config.anti_windup\n\n        # Internal state\n        self._integral = 0.0\n        self._prev_error: Optional[float] = None\n\n    def reset(self):\n        \"\"\"Reset controller internal state.\"\"\"\n        self._integral = 0.0\n        self._prev_error = None\n\n    def compute(self, measured_value: float, dt: float) -> float:\n        \"\"\"\n        Compute PID output given the current measured value and time step.\n        Returns the clamped controller output.\n        \"\"\"\n        if dt <= 0:\n            raise ValueError(f\"Time step must be positive, got {dt}\")\n\n        error = self.setpoint - measured_value\n\n        # Proportional term\n        p_term = self.kp * error\n\n        # Integral term with anti-windup\n        self._integral += error * dt\n        if self.anti_windup:\n            # Clamp integral to prevent windup\n            integral_max = self.output_max / self.ki if self.ki != 0 else float('inf')\n            integral_min = self.output_min / self.ki if self.ki != 0 else float('-inf')\n            self._integral = max(integral_min, min(integral_max, self._integral))\n\n        i_term = self.ki * self._integral\n\n        # Derivative term (on error)\n        if self._prev_error is not None:\n            derivative = (error - self._prev_error) / dt\n        else:\n            derivative = 0.0\n        d_term = self.kd * derivative\n\n        self._prev_error = error\n\n        # Sum and clamp output\n        output = p_term + i_term + d_term\n        output = max(self.output_min, min(self.output_max, output))\n\n        return output\n\n\n# \u2500\u2500\u2500 Simulation Runner \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef run_simulation(config: Config) -> List[dict]:\n    \"\"\"\n    Run the PID simulation over the CSV time series.\n    Returns a list of result dictionaries.\n    \"\"\"\n    sim = config.simulation\n    pid_cfg = config.pid\n\n    # Load time series\n    times, measured_values = load_csv_timeseries(\n        sim.input_file, sim.time_column, sim.value_column\n    )\n\n    # Initialize PID controller\n    controller = PIDController(pid_cfg)\n    controller.reset()\n\n    results = []\n\n    for i in range(len(times)):\n        # Determine dt\n        if i == 0:\n            dt = sim.dt  # Use configured dt for first step\n        else:\n            dt = times[i] - times[i - 1]\n            if dt <= 0:\n                dt = sim.dt  # Fallback if timestamps are not strictly increasing\n\n        measured = measured_values[i]\n\n        # Compute PID output\n        output = controller.compute(measured, dt)\n\n        # Simulate plant response (simple first-order lag for demonstration)\n        # In a real system, this would be the actual plant dynamics\n        # Here we just record what the controller outputs\n        # The \"controlled_value\" shows how the output would affect the system\n        # Using a simple model: next_value = current + output * dt * plant_gain\n        plant_gain = 0.5  # Simplified plant gain\n        if i == 0:\n            controlled_value = measured + output * dt * plant_gain\n        else:\n            controlled_value = measured_values[i - 1] + output * dt * plant_gain\n            # Blend with actual measured to show controller effect\n            controlled_value = measured + output * dt * plant_gain\n\n        error = pid_cfg.setpoint - measured\n\n        results.append({\n            'time': times[i],\n            'measured_value': measured,\n            'setpoint': pid_cfg.setpoint,\n            'error': round(error, 6),\n            'pid_output': round(output, 6),\n            'p_term': round(pid_cfg.kp * error, 6),\n            'i_term': round(controller._integral * pid_cfg.ki, 6),\n            'd_term': round(pid_cfg.kd * ((error - (controller._prev_error - error * dt / dt if controller._prev_error is not None else error)) / dt) if i > 0 else 0.0, 6),\n            'controlled_value': round(controlled_value, 6),\n        })\n\n    return results\n\n\ndef write_output_csv(results: List[dict], output_path: str):\n    \"\"\"Write simulation results to CSV.\"\"\"\n    if not results:\n        print(\"No results to write.\")\n        return\n\n    fieldnames = list(results[0].keys())\n\n    with open(output_path, 'w', newline='') as f:\n        writer = csv.DictWriter(f, fieldnames=fieldnames)\n        writer.writeheader()\n        writer.writerows(results)\n\n    print(f\"Results written to: {output_path}\")\n\n\n# \u2500\u2500\u2500 Main \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef main():\n    config_path = sys.argv[1] if len(sys.argv) > 1 else 'pid_config.yaml'\n\n    print(f\"Loading configuration from: {config_path}\")\n    try:\n        config = load_config(config_path)\n    except (FileNotFoundError, ValueError) as e:\n        print(f\"ERROR: {e}\", file=sys.stderr)\n        sys.exit(1)\n\n    print(f\"  PID Gains: Kp={config.pid.kp}, Ki={config.pid.ki}, Kd={config.pid.kd}\")\n    print(f\"  Setpoint: {config.pid.setpoint}\")\n    print(f\"  Output limits: [{config.pid.output_min}, {config.pid.output_max}]\")\n    print(f\"  Anti-windup: {config.pid.anti_windup}\")\n    print(f\"  Input CSV: {config.simulation.input_file}\")\n    print(f\"  Output CSV: {config.simulation.output_file}\")\n    print()\n\n    print(\"Running simulation...\")\n    try:\n        results = run_simulation(config)\n    except (FileNotFoundError, ValueError) as e:\n        print(f\"ERROR during simulation: {e}\", file=sys.stderr)\n        sys.exit(1)\n\n    print(f\"Simulation complete. {len(results)} time steps processed.\")\n    print()\n\n    # Print summary\n    if results:\n        final = results[-1]\n        print(\"\u2500\u2500\u2500 Final State \u2500\u2500\u2500\")\n        print(f\"  Time:            {final['time']:.2f} s\")\n        print(f\"  Measured:        {final['measured_value']:.4f}\")\n        print(f\"  Setpoint:        {final['setpoint']:.4f}\")\n        print(f\"  Error:           {final['error']:.4f}\")\n        print(f\"  PID Output:      {final['pid_output']:.4f}\")\n        print()\n\n    # Write output\n    write_output_csv(results, config.simulation.output_file)\n\n    # Print first few rows as preview\n    print(\"\u2500\u2500\u2500 Output Preview (first 5 rows) \u2500\u2500\u2500\")\n    print(f\"{'Time':>8} {'Measured':>10} {'Setpoint':>10} {'Error':>10} {'PID Out':>10}\")\n    print(\"-\" * 52)\n    for row in results[:5]:\n        print(f\"{row['time']:8.2f} {row['measured_value']:10.4f} \"\n              f\"{row['setpoint']:10.4f} {row['error']:10.4f} {row['pid_output']:10.4f}\")\n    if len(results) > 5:\n        print(f\"  ... ({len(results) - 5} more rows)\")\n\n\nif __name__ == '__main__':\n    main()\n```\n\n## 4. Usage\n\n```bash\n# Install dependency\npip install pyyaml\n\n# Run simulation\npython pid_simulator.py pid_config.yaml\n```\n\n## 5. Expected Output\n\n```\nLoading configuration from: pid_config.yaml\n  PID Gains: Kp=1.2, Ki=0.05, Kd=0.3\n  Setpoint: 100.0\n  Output limits: [-50.0, 50.0]\n  Anti-windup: True\n  Input CSV: input_data.csv\n  Output CSV: output_data.csv\n\nRunning simulation...\nSimulation complete. 31 time steps processed.\n\n\u2500\u2500\u2500 Final State \u2500\u2500\u2500\n  Time:            3.00 s\n  Measured:        76.1000\n  Setpoint:        100.0000\n  Error:           23.9000\n  PID Output:      43.0200\n\nResults written to: output_data.csv\n\n\u2500\u2500\u2500 Output Preview (first 5 rows) \u2500\u2500\u2500\n    Time   Measured   Setpoint      Error    PID Out\n----------------------------------------------------\n    0.00      20.00     100.00      80.00      50.00\n    0.10      22.50     100.00      77.50      50.00\n    0.20      25.10     100.00      74.90      50.00\n    0.30      28.00     100.00      72.00      50.00\n    0.40      31.20     100.00      68.80      50.00\n  ... (26 more rows)\n```\n\n## Key Design Points\n\n| Feature | Implementation |\n|---|---|\n| **YAML parsing** | `yaml.safe_load()` with validation of all required fields and type coercion |\n| **Erro