{"task": "flood-risk-analysis", "condition": "no_skill", "repeat": 0, "skill_ids": [], "retrieval_correct": null, "judged_pass": false, "judged_score": 0, "judge_reason": "Agent's solution does not match the task: it performs flood frequency analysis using Log-Pearson III instead of comparing daily streamflow to NWS flood thresholds and counting exceedance days as required.", "solver_tokens": 6108, "judge_tokens": 5438, "solution_text": "# USGS Streamflow Data Flood Threshold Analysis\n\nBelow is a complete Python solution that fetches USGS streamflow data, performs flood frequency analysis using the Log-Pearson Type III distribution (the US standard per Bulletin 17C), and calculates flood thresholds for various return periods.\n\n## Prerequisites\n\n```bash\npip install dataretrieval numpy scipy pandas matplotlib\n```\n\n## Complete Solution\n\n```python\n\"\"\"\nUSGS Streamflow Flood Threshold Analysis\n-----------------------------------------\nFetches daily streamflow data from USGS, extracts annual peaks,\nfits a Log-Pearson Type III distribution (Bulletin 17C), and\nestimates flood thresholds for standard return periods.\n\"\"\"\n\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nfrom scipy import stats\nfrom scipy.special import gamma as gamma_func\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# ============================================================\n# 1. FETCH USGS STREAMFLOW DATA\n# ============================================================\n\ndef fetch_usgs_data(site_number, start_date=\"1990-01-01\", end_date=\"2024-12-31\"):\n    \"\"\"\n    Fetch daily streamflow data from USGS Water Services API.\n    Falls back to generating synthetic data if the API is unreachable.\n    \"\"\"\n    try:\n        import dataretrieval.nwis as nwis\n        print(f\"Fetching daily streamflow data for USGS site {site_number}...\")\n        df, metadata = nwis.get_record(\n            sites=site_number,\n            service='dv',\n            start=start_date,\n            end=end_date,\n            parameterCd='00060'  # Discharge in ft\u00b3/s\n        )\n        df = df.reset_index()\n        df = df.rename(columns={\n            'datetime': 'date',\n            f'00060': 'discharge_cfs',\n            f'00060_cd': 'quality_code'\n        })\n        df['date'] = pd.to_datetime(df['date'])\n        df = df[['date', 'discharge_cfs']].dropna()\n        df['discharge_cfs'] = pd.to_numeric(df['discharge_cfs'], errors='coerce')\n        df = df.dropna()\n        print(f\"  Retrieved {len(df)} daily records from {df['date'].min().date()} to {df['date'].max().date()}\")\n        return df, metadata\n    except Exception as e:\n        print(f\"  API fetch failed ({e}). Generating realistic synthetic data...\")\n        return generate_synthetic_streamflow(start_date, end_date), None\n\n\ndef generate_synthetic_streamflow(start_date=\"1990-01-01\", end_date=\"2024-12-31\"):\n    \"\"\"Generate realistic synthetic daily streamflow data for demonstration.\"\"\"\n    np.random.seed(42)\n    dates = pd.date_range(start=start_date, end=end_date, freq='D')\n    n = len(dates)\n    day_of_year = dates.dayofyear.values\n\n    # Base flow with seasonal pattern (spring snowmelt peak)\n    base_flow = 150 + 200 * np.exp(-0.5 * ((day_of_year - 120) / 40) ** 2)\n    # Add random daily variability (log-normal)\n    noise = np.random.lognormal(0, 0.4, n)\n    discharge = base_flow * noise\n\n    # Inject some flood events\n    for _ in range(15):\n        flood_day = np.random.randint(60, 180)\n        flood_idx = np.where(day_of_year == flood_day)[0]\n        if len(flood_idx) > 0:\n            idx = flood_idx[0]\n            magnitude = np.random.exponential(800)\n            for offset in range(-2, 5):\n                if 0 <= idx + offset < n:\n                    decay = np.exp(-0.5 * abs(offset))\n                    discharge[idx + offset] += magnitude * decay\n\n    df = pd.DataFrame({'date': dates, 'discharge_cfs': np.maximum(discharge, 10)})\n    return df\n\n\n# ============================================================\n# 2. EXTRACT ANNUAL PEAK FLOWS\n# ============================================================\n\ndef extract_annual_peaks(df):\n    \"\"\"Extract the maximum daily discharge for each water year (Oct-Sep).\"\"\"\n    df = df.copy()\n    # Water year: Oct 1 - Sep 30\n    df['water_year'] = df['date'].apply(\n        lambda d: d.year + 1 if d.month >= 10 else d.year\n    )\n    annual_peaks = df.groupby('water_year')['discharge_cfs'].max().reset_index()\n    annual_peaks.columns = ['water_year', 'peak_cfs']\n    annual_peaks = annual_peaks.sort_values('water_year').reset_index(drop=True)\n    print(f\"\\nExtracted {len(annual_peaks)} annual peak flows\")\n    print(f\"  Water years: {annual_peaks['water_year'].min()} - {annual_peaks['water_year'].max()}\")\n    print(f\"  Peak range: {annual_peaks['peak_cfs'].min():.0f} - {annual_peaks['peak_cfs'].max():.0f} cfs\")\n    print(f\"  Mean peak:  {annual_peaks['peak_cfs'].mean():.0f} cfs\")\n    return annual_peaks\n\n\n# ============================================================\n# 3. LOG-PEARSON TYPE III FREQUENCY ANALYSIS (Bulletin 17C)\n# ============================================================\n\ndef log_pearson_type_iii_fit(peaks):\n    \"\"\"\n    Fit Log-Pearson Type III distribution to annual peak flows.\n    Returns distribution parameters and a function to compute quantiles.\n    \"\"\"\n    log_peaks = np.log10(peaks.values)\n    n = len(log_peaks)\n\n    # Sample statistics\n    mean_log = np.mean(log_peaks)\n    std_log = np.std(log_peaks, ddof=1)\n    skew_log = (n / ((n - 1) * (n - 2))) * np.sum(((log_peaks - mean_log) / std_log) ** 3)\n\n    print(f\"\\n--- Log-Pearson Type III Parameters ---\")\n    print(f\"  Mean of log10(Q):  {mean_log:.4f}\")\n    print(f\"  Std of log10(Q):   {std_log:.4f}\")\n    print(f\"  Skewness:          {skew_log:.4f}\")\n\n    # Fit using scipy's pearson3 distribution\n    # pearson3 parameterized by shape (skew), loc, scale\n    shape = skew_log\n    loc = mean_log\n    scale = std_log\n\n    return shape, loc, scale, mean_log, std_log, skew_log\n\n\ndef compute_flood_quantiles(shape, loc, scale, return_periods):\n    \"\"\"\n    Compute flood magnitudes for given return periods using the fitted\n    Log-Pearson Type III distribution.\n    \"\"\"\n    quantiles = {}\n    for T in return_periods:\n        # Exceedance probability\n        p_exceed = 1.0 / T\n        # Non-exceedance probability\n        p_non_exceed = 1.0 - p_exceed\n        # Quantile in log space\n        log_q = stats.pearson3.ppf(p_non_exceed, shape, loc=loc, scale=scale)\n        # Convert back to cfs\n        q_cfs = 10 ** log_q\n        quantiles[T] = q_cfs\n\n    return quantiles\n\n\ndef compute_flood_quantiles_bulletin17c(peaks, return_periods):\n    \"\"\"\n    Alternative: Use the standard Bulletin 17C frequency factors (K_T)\n    with the skew coefficient to compute flood magnitudes directly.\n    \"\"\"\n    log_peaks = np.log10(peaks.values)\n    n = len(log_peaks)\n    mean_log = np.mean(log_peaks)\n    std_log = np.std(log_peaks, ddof=1)\n    skew = (n / ((n - 1) * (n - 2))) * np.sum(((log_peaks - mean_log) / std_log) ** 3)\n\n    quantiles = {}\n    for T in return_periods:\n        p = 1.0 - 1.0 / T\n        # Standard normal variate\n        z = stats.norm.ppf(p)\n\n        # Frequency factor K_T using Wilson-Hilferty approximation (Bulletin 17C)\n        # K = (2/g) * [(1 + g*z/6 - g\u00b2/36)^3 - 1]  where g = skewness\n        g = skew\n        if abs(g) < 1e-6:\n            K = z\n        else:\n            K = (2.0 / g) * ((1.0 + g * z / 6.0 - g**2 / 36.0)**3 - 1.0)\n\n        log_q = mean_log + K * std_log\n        q_cfs = 10 ** log_q\n        quantiles[T] = q_cfs\n\n    return quantiles\n\n\n# ============================================================\n# 4. CONFIDENCE INTERVALS (Bootstrap)\n# ============================================================\n\ndef bootstrap_confidence_intervals(peaks, return_periods, n_bootstrap=1000, alpha=0.05):\n    \"\"\"\n    Estimate confidence intervals for flood quantiles using bootstrap resampling.\n    \"\"\"\n    n = len(peaks)\n    bootstrap_quantiles = {T: [] for T in return_periods}\n\n    for _ in range(n_bootstrap):\n        sample = np.random.choice(peaks.values, size=n, replace=True)\n        log_sample = np.log10(sample)\n        mean_log = np.mean(log_sample)\n        std_log = np.std(log_sample, ddof=1)\n        skew = (n / ((n - 1) * (n - 2))) * np.sum(((log_sample - mean_log) / std_log) ** 3)\n\n        for T in return_periods:\n            p = 1.0 - 1.0 / T\n            z = stats.norm.ppf(p)\n            g = skew\n            if abs(g) < 1e-6:\n                K = z\n            else:\n                K = (2.0 / g) * ((1.0 + g * z / 6.0 - g**2 / 36.0)**3 - 1.0)\n            log_q = mean_log + K * std_log\n            bootstrap_quantiles[T].append(10 ** log_q)\n\n    ci = {}\n    for T in return_periods:\n        vals = np.array(bootstrap_quantiles[T])\n        ci[T] = {\n            'lower': np.percentile(vals, 100 * alpha / 2),\n            'upper': np.percentile(vals, 100 * (1 - alpha / 2)),\n            'median': np.median(vals)\n        }\n    return ci\n\n\n# ============================================================\n# 5. GOODNESS OF FIT\n# ============================================================\n\ndef goodness_of_fit(peaks, shape, loc, scale):\n    \"\"\"Perform Kolmogorov-Smirnov test on log-transformed peaks.\"\"\"\n    log_peaks = np.log10(peaks.values)\n    ks_stat, p_value = stats.kstest(log_peaks, 'pearson3', args=(shape, loc, scale))\n    print(f\"\\n--- Goodness of Fit (K-S Test on log10 data) ---\")\n    print(f\"  K-S statistic: {ks_stat:.4f}\")\n    print(f\"  p-value:       {p_value:.4f}\")\n    if p_value > 0.05:\n        print(f\"  \u2192 Cannot reject LP-III fit at \u03b1=0.05 (good fit)\")\n    else:\n        print(f\"  \u2192 LP-III fit rejected at \u03b1=0.05 (consider alternative distributions)\")\n    return ks_stat, p_value\n\n\n# ============================================================\n# 6. VISUALIZATION\n# ============================================================\n\ndef plot_results(annual_peaks, quantiles, ci, return_periods, site_number):\n    \"\"\"Create comprehensive flood frequency analysis plots.\"\"\"\n    fig, axes = plt.subplots(2, 2, figsize=(16, 12))\n    fig.suptitle(f'USGS Flood Frequency Analysis \u2014 Site {site_number}',\n                 fontsize=16, fontweight='bold', y=0.98)\n\n    # --- Plot 1: Annual peaks time series with flood thresholds ---\n    ax1 = axes[0, 0]\n    ax1.bar(annual_peaks['water_year'], annual_peaks['peak_cfs'],\n            color='steelblue', alpha=0.7, edgecolor='navy', linewidth=0.5)\n    colors = plt.cm.RdYlGn_r(np.linspace(0.2, 0.9, len(return_periods)))\n    for i, T in enumerate(return_periods):\n        ax1.axhline(y=quantiles[T], color=colors[i], linestyle='--',\n                     linewidth=1.5, label=f'{T}-yr ({quantiles[T]:,.0f} cfs)')\n    ax1.set_xlabel('Water Year', fontsize=11)\n    ax1.set_ylabel('Peak Discharge (cfs)', fontsize=11)\n    ax1.set_title('Annual Peak Streamflow with Flood Thresholds', fontsize=12)\n    ax1.legend(fontsize=8, loc='upper left')\n    ax1.grid(True, alpha=0.3)\n\n    # --- Plot 2: Flood frequency curve (log scale) ---\n    ax2 = axes[0, 1]\n    T_plot = np.linspace(1.1, 500, 200)\n    log_peaks = np.log10(annual_peaks['peak_cfs'].values)\n    mean_log = np.mean(log_peaks)\n    std_log = np.std(log_peaks, ddof=1)\n    skew = (len(log_peaks) / ((len(log_peaks) - 1) * (len(log_peaks) - 2))) * \\\n           np.sum(((log_peaks - mean_log) / std_log) ** 3)\n\n    freq_curve = []\n    for T in T_plot:\n        p = 1.0 - 1.0 / T\n        z = stats.norm.ppf(p)\n        g = skew\n        if abs(g) < 1e-6:\n            K = z\n        else:\n            K = (2.0