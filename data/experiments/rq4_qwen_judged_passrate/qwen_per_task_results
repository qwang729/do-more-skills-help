_distance(p=3):\n    \"\"\"Factory for custom Minkowski distance with arbitrary p.\"\"\"\n    def minkowski(x, y):\n        return np.sum(np.abs(x - y) ** p) ** (1/p)\n    return minkowski\n\n# ============================================================\n# 3. DBSCAN Evaluation Function for Parallel Processing\n# ============================================================\ndef evaluate_dbscan_params(eps, min_samples, X, metric='euclidean'):\n    \"\"\"\n    Evaluate DBSCAN with given parameters.\n    Returns multiple clustering quality metrics.\n    \"\"\"\n    try:\n        dbscan = DBSCAN(eps=eps, min_samples=min_samples, metric=metric, n_jobs=-1)\n        labels = dbscan.fit_predict(X)\n        \n        n_clusters = len(set(labels)) - (1 if -1 in labels else 0)\n        n_noise = list(labels).count(-1)\n        noise_ratio = n_noise / len(labels)\n        \n        # Only compute silhouette if we have valid clusters\n        if n_clusters >= 2 and n_noise < len(labels) * 0.9:\n            # Silhouette score (higher is better, range [-1, 1])\n            sil_score = silhouette_score(X, labels)\n            \n            # Calinski-Harabasz index (higher is better)\n            ch_score = calinski_harabasz_score(X, labels)\n            \n            # Davies-Bouldin index (lower is better)\n            db_score = davies_bouldin_score(X, labels)\n        else:\n            sil_score = -1\n            ch_score = 0\n            db_score = float('inf')\n        \n        return {\n            'eps': eps,\n            'min_samples': min_samples,\n            'n_clusters': n_clusters,\n            'n_noise': n_noise,\n            'noise_ratio': noise_ratio,\n            'silhouette': sil_score,\n            'calinski_harabasz': ch_score,\n            'davies_bouldin': db_score\n        }\n    except Exception as e:\n        return {\n            'eps': eps,\n            'min_samples': min_samples,\n            'n_clusters': 0,\n            'n_noise': len(X),\n            'noise_ratio': 1.0,\n            'silhouette': -1,\n            'calinski_harabasz': 0,\n            'davies_bouldin': float('inf')\n        }\n\n# ============================================================\n# 4. Parallel Grid Search\n# ============================================================\n# Define parameter grid\neps_values = np.linspace(0.1, 1.0, 20)\nmin_samples_values = range(3, 15)\n\n# Create all parameter combinations\nparam_combinations = list(product(eps_values, min_samples_values))\nprint(f\"Total parameter combinations: {len(param_combinations)}\")\n\n# Run parallel evaluation\nresults = Parallel(n_jobs=-1, verbose=5)(\n    delayed(evaluate_dbscan_params)(eps, ms, X, 'euclidean')\n    for eps, ms in param_combinations\n)\n\n# Convert to DataFrame\ndf_results = pd.DataFrame(results)\ndf_results = df_results[df_results['n_clusters'] >= 2]  # Filter valid clusterings\nprint(f\"\\nValid clustering results: {len(df_results)}\")\n\n# ============================================================\n# 5. Pareto Frontier Optimization\n# ============================================================\ndef compute_pareto_frontier(df, objectives):\n    \"\"\"\n    Compute Pareto-optimal points for multi-objective optimization.\n    \n    objectives: list of tuples (column_name, direction)\n                direction: 'max' for maximize, 'min' for minimize\n    \"\"\"\n    pareto_optimal = []\n    \n    for idx, row in df.iterrows():\n        is_dominated = False\n        \n        for other_idx, other_row in df.iterrows():\n            if idx == other_idx:\n                continue\n            \n            # Check if other_row dominates row\n            dominates = True\n            for obj_name, direction in objectives:\n                if direction == 'max':\n                    if other_row[obj_name] < row[obj_name]:\n                        dominates = False\n                        break\n                else:  # min\n                    if other_row[obj