{"task": "dynamic-object-aware-egomotion", "condition": "retrieved_top1_full", "repeat": 0, "skill_ids": ["benchflow-ai--egomotion-estimation"], "retrieval_correct": true, "judged_pass": false, "judged_score": 1, "judge_reason": "Agent's solution does not produce required outputs 'pred_instructions.json' and 'pred_dyn_masks.npz' for evaluation.", "solver_tokens": 8156, "judge_tokens": 5359, "solution_text": "# Camera Motion Estimation from Optical Flow with Sparse Mask\n\nBelow is a complete, self-contained Python implementation that:\n\n1. Reads video frames\n2. Detects sparse features (Shi-Tomasi corners)\n3. Tracks them with Lucas-Kanade sparse optical flow\n4. Applies a user-defined sparse mask to select regions of interest\n5. Estimates per-frame camera motion via **affine** and **homography** models with RANSAC\n6. Supports **multi-label** motion (different motion models for different spatial regions)\n7. Uses **numpy** for all core math\n\n---\n\n## `egomotion_estimator.py`\n\n```python\n\"\"\"\nEgomotion (camera motion) estimation from video using sparse optical flow,\naffine/homography fitting with RANSAC, and optional multi-label segmentation.\n\nDependencies: numpy, opencv-python (cv2)\n\"\"\"\n\nimport numpy as np\nimport cv2\nimport sys\nfrom dataclasses import dataclass, field\nfrom typing import List, Tuple, Optional, Dict\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Data structures\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n@dataclass\nclass FrameMotion:\n    \"\"\"Camera motion estimate for a single frame transition.\"\"\"\n    frame_idx: int\n    affine_matrix: np.ndarray          # 2x3 affine\n    homography_matrix: np.ndarray      # 3x3 homography\n    inlier_ratio: float\n    num_inliers: int\n    num_total: int\n    translation: np.ndarray            # (tx, ty)\n    rotation_angle: float              # degrees\n    scale: float\n    labels: Optional[np.ndarray] = None          # per-point label\n    label_motions: Optional[Dict[int, np.ndarray]] = None  # label -> 2x3 affine\n\n\n@dataclass\nclass EgomotionResult:\n    \"\"\"Full sequence result.\"\"\"\n    motions: List[FrameMotion] = field(default_factory=list)\n    trajectory: Optional[np.ndarray] = None  # (N, 3) cumulative (x, y, theta)\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Core math helpers (pure numpy)\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef build_affine_system(pts_src: np.ndarray, pts_dst: np.ndarray) -> Tuple[np.ndarray, np.ndarray]:\n    \"\"\"\n    Build the linear system  A @ x = b  for affine transform:\n        [x']   [a b tx] [x]\n        [y'] = [c d ty] [y]\n                       [1]\n    pts_src, pts_dst: (N, 2) float64\n    Returns A (2N, 6), b (2N,)\n    \"\"\"\n    N = pts_src.shape[0]\n    A = np.zeros((2 * N, 6), dtype=np.float64)\n    b = np.zeros(2 * N, dtype=np.float64)\n\n    A[0::2, 0] = pts_src[:, 0]\n    A[0::2, 1] = pts_src[:, 1]\n    A[0::2, 2] = 1.0\n    A[1::2, 3] = pts_src[:, 0]\n    A[1::2, 4] = pts_src[:, 1]\n    A[1::2, 5] = 1.0\n\n    b[0::2] = pts_dst[:, 0]\n    b[1::2] = pts_dst[:, 1]\n    return A, b\n\n\ndef solve_affine(pts_src: np.ndarray, pts_dst: np.ndarray) -> np.ndarray:\n    \"\"\"Solve for 2x3 affine matrix via least-squares. Returns (2, 3).\"\"\"\n    A, b = build_affine_system(pts_src, pts_dst)\n    x, _, _, _ = np.linalg.lstsq(A, b, rcond=None)\n    return x.reshape(2, 3)\n\n\ndef solve_homography(pts_src: np.ndarray, pts_dst: np.ndarray) -> np.ndarray:\n    \"\"\"Solve for 3x3 homography via DLT. Returns (3, 3).\"\"\"\n    N = pts_src.shape[0]\n    A = np.zeros((2 * N, 9), dtype=np.float64)\n    sx, sy = pts_src[:, 0], pts_src[:, 1]\n    dx, dy = pts_dst[:, 0], pts_dst[:, 1]\n\n    A[0::2, 0] = sx;  A[0::2, 1] = sy;  A[0::2, 2] = 1\n    A[0::2, 6] = -dx * sx;  A[0::2, 7] = -dx * sy;  A[0::2, 8] = -dx\n\n    A[1::2, 3] = sx;  A[1::2, 4] = sy;  A[1::2, 5] = 1\n    A[1::2, 6] = -dy * sx;  A[1::2, 7] = -dy * sy;  A[1::2, 8] = -dy\n\n    _, _, Vt = np.linalg.svd(A)\n    H = Vt[-1].reshape(3, 3)\n    H /= H[2, 2]\n    return H\n\n\ndef affine_residuals(pts_src: np.ndarray, pts_dst: np.ndarray, M: np.ndarray) -> np.ndarray:\n    \"\"\"Per-point Euclidean residual under affine M (2x3). Returns (N,).\"\"\"\n    pts_h = np.hstack([pts_src, np.ones((pts_src.shape[0], 1))])  # (N,3)\n    pred = (M @ pts_h.T).T  # (N,2)\n    return np.linalg.norm(pred - pts_dst, axis=1)\n\n\ndef homography_residuals(pts_src: np.ndarray, pts_dst: np.ndarray, H: np.ndarray) -> np.ndarray:\n    \"\"\"Per-point Euclidean residual under homography H (3x3). Returns (N,).\"\"\"\n    pts_h = np.hstack([pts_src, np.ones((pts_src.shape[0], 1))])  # (N,3)\n    pred_h = (H @ pts_h.T).T  # (N,3)\n    pred = pred_h[:, :2] / pred_h[:, 2:3]\n    return np.linalg.norm(pred - pts_dst, axis=1)\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# RANSAC\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef ransac_affine(pts_src: np.ndarray, pts_dst: np.ndarray,\n                  threshold: float = 3.0, max_iters: int = 1000,\n                  min_samples: int = 3) -> Tuple[np.ndarray, np.ndarray]:\n    \"\"\"\n    RANSAC for affine model.\n    Returns (best_M (2,3), inlier_mask (N,) bool).\n    \"\"\"\n    N = pts_src.shape[0]\n    best_inliers = np.zeros(N, dtype=bool)\n    best_M = np.eye(2, 3, dtype=np.float64)\n    best_count = 0\n\n    for _ in range(max_iters):\n        idx = np.random.choice(N, min_samples, replace=False)\n        M = solve_affine(pts_src[idx], pts_dst[idx])\n        residuals = affine_residuals(pts_src, pts_dst, M)\n        inliers = residuals < threshold\n        count = inliers.sum()\n        if count > best_count:\n            best_count = count\n            best_inliers = inliers\n            best_M = M\n\n    # Refit on all inliers\n    if best_count >= min_samples:\n        best_M = solve_affine(pts_src[best_inliers], pts_dst[best_inliers])\n    return best_M, best_inliers\n\n\ndef ransac_homography(pts_src: np.ndarray, pts_dst: np.ndarray,\n                      threshold: float = 3.0, max_iters: int = 1000,\n                      min_samples: int = 4) -> Tuple[np.ndarray, np.ndarray]:\n    \"\"\"RANSAC for homography. Returns (best_H (3,3), inlier_mask (N,) bool).\"\"\"\n    N = pts_src.shape[0]\n    best_inliers = np.zeros(N, dtype=bool)\n    best_H = np.eye(3, dtype=np.float64)\n    best_count = 0\n\n    for _ in range(max_iters):\n        idx = np.random.choice(N, min_samples, replace=False)\n        H = solve_homography(pts_src[idx], pts_dst[idx])\n        residuals = homography_residuals(pts_src, pts_dst, H)\n        inliers = residuals < threshold\n        count = inliers.sum()\n        if count > best_count:\n            best_count = count\n            best_inliers = inliers\n            best_H = H\n\n    if best_count >= min_samples:\n        best_H = solve_homography(pts_src[best_inliers], pts_dst[best_inliers])\n    return best_H, best_inliers\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Multi-label motion segmentation\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef segment_motion_labels(pts_src: np.ndarray, pts_dst: np.ndarray,\n                          residuals: np.ndarray, inlier_mask: np.ndarray,\n                          spatial_grid: Tuple[int, int] = (3, 3),\n                          threshold: float = 5.0) -> Tuple[np.ndarray, Dict[int, np.ndarray]]:\n    \"\"\"\n    Assign integer labels to tracked points based on spatial grid cells,\n    then fit a separate affine model per label.  Points that are outliers\n    in their cell get label -1.\n\n    Returns (labels (N,) int, label_motions dict {label_id: 2x3 affine}).\n    \"\"\"\n    H, W = spatial_grid\n    # Normalise coordinates to [0,1]\n    xs = pts_src[:, 0]\n    ys = pts_src[:, 1]\n    xn = (xs - xs.min()) / (xs.max() - xs.min() + 1e-8)\n    yn = (ys - ys.min()) / (ys.max() - ys.min() + 1e-8)\n\n    col = np.clip((xn * W).astype(int), 0, W - 1)\n    row = np.clip((yn * H).astype(int), 0, H - 1)\n    labels = row * W + col  # 0 .. H*W-1\n\n    label_motions: Dict[int, np.ndarray] = {}\n    for lbl in np.unique(labels):\n        mask = (labels == lbl) & inlier_mask\n        if mask.sum() < 3:\n            labels[mask] = -1\n            continue\n        M = solve_affine(pts_src[mask], pts_dst[mask])\n        res = affine_residuals(pts_src[mask], pts_dst[mask], M)\n        good = res < threshold\n        final_mask = np.zeros_like(mask)\n        final_mask[mask] = good\n        labels[~good & mask] = -1\n        if good.sum() >= 3:\n            M = solve_affine(pts_src[final_mask], pts_dst[final_mask])\n        label_motions[int(lbl)] = M\n\n    return labels, label_motions\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Decompose affine \u2192 translation, rotation, scale\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef decompose_affine(M: np.ndarray) -> Tuple[np.ndarray, float, float]:\n    \"\"\"\n    Decompose 2x3 affine  M = [a b tx; c d ty]  into\n    translation (tx, ty), rotation (deg), uniform scale.\n    \"\"\"\n    tx, ty = M[0, 2], M[1, 2]\n    A = M[:, :2]\n    # polar decomposition  A = R * S\n    U, _, Vt = np.linalg.svd(A)\n    R = U @ Vt\n    if np.linalg.det(R) < 0:\n        U[:, -1] *= -1\n        R = U @ Vt\n    angle = np.degrees(np.arctan2(R[1, 0], R[0, 0]))\n    scale = np.sqrt(np.abs(np.linalg.det(A)))\n    return np.array([tx, ty]), angle, scale\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Sparse mask utilities\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef create_sparse_mask(frame_shape: Tuple[int, int],\n                       grid_spacing: int = 40,\n                       regions: Optional[List[Tuple[int, int, int, int]]] = None) -> np.ndarray:\n    \"\"\"\n    Create a binary sparse mask (H, W) uint8.\n    - grid_spacing: place a 5x5 patch every `grid_spacing` pixels.\n    - regions: optional list of (x, y, w, h) rectangles to additionally enable.\n    \"\"\"\n    H, W = frame_shape[:2]\n    mask = np.zeros((H, W), dtype=np.uint8)\n    for y in range(0, H, grid_spacing):\n        for x in range(0, W, grid_spacing):\n            mask[y:y+5, x:x+5] = 255\n    if regions:\n        for (rx, ry, rw, rh) in regions:\n            mask[ry:ry+rh, rx:rx+rw] = 255\n    return mask\n\n\ndef apply_sparse_mask(keypoints: np.ndarray, mask: np.ndarray) -> np.ndarray:\n    \"\"\"Keep only keypoints that fall on non-zero mask pixels. Returns filtered (M, 1, 2).\"\"\"\n    if keypoints.ndim == 3:\n        pts = keypoints.reshape(-1, 2)\n    else:\n        pts = keypoints\n    xs = np.clip(pts[:, 0].astype(int), 0, mask.shape[1] - 1)\n    ys = np.clip(pts[:, 1].astype(int), 0, mask.shape[0] - 1)\n    keep = mask[ys, xs] > 0\n    if keypoints.ndim == 3:\n        return keypoints[keep]\n    return pts[keep]\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Main estimator class\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nclass EgomotionEstimator:\n    \"\"\"\n    Estimate camera egomotion from a video file.\n\n    Parameters\n    ----------\n    video_path : str\n        Path to input video.\n    sparse_mask : np.ndarray or None\n        Binary mask (H, W). If None, a grid mask is auto-generated.\n    max_features : int\n        Max corners to track per frame.\n    ransac_thresh : float\n        Inlier threshold in pixels for RANSAC.\n    multi_label : bool\n        If True, segment flow into spatial-grid labels and fit per-label affine.\n    \"\"\"\n\n    def __init__(self,\n                 video_path: str,\n                 sparse_mask: Optional[np.ndarray] = None,\n                 max_features: int = 500,\n                 ransac_thresh: float = 3.0,\n                 multi_label: bool = True,\n                 lk_win_size: Tuple[int, int] = (21, 21),\n                 lk_max_level: int = 3):\n        self.video_path = video_path\n        self.max_features = max_features\n        self.ransac_thresh = ransac_thresh\n        self.multi_label = multi_label\n        self.lk_params = dict(winSize=lk_win_size,\n                              maxLevel=lk_max_level,\n                              criteria=(cv2.TERM_CRITERIA_EPS | cv2.TERM_CRITERIA_COUNT, 30, 0.01))\n        self.sparse_mask = sparse_mask\n        self.result = EgomotionResult()\n\n    # \u2500\u2500 feature detection \u2500\u2500\n\n    def _detect_features(self, gray: np.ndarray) -> np.ndarray:\n        \"\"\"Detect Shi-Tomasi corners, then apply sparse mask.\"\"\"\n        pts = cv2.goodFeaturesToTrack(gray,\n                                      maxCorners=self.max_features,\n                                      qualityLevel=0.01,\n                                      minDistance=10,\n                                      mask=self.sparse_mask)\n        if pts is None:\n            return np.empty((0, 1, 2), dtype=np.float32)\n        return pts\n\n    # \u2500\u2500 optical flow step \u2500\u2500\n\n    def _track(self, prev_gray: np.ndarray, curr_gray: np.ndarray,\n               prev_pts: np.ndarray) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:\n        \"\"\"\n        Track prev_pts from prev_gray \u2192 curr_gray.\n        Returns (good_prev_pts, good_curr_pts, status_bool).\n        Uses forward-backward error to reject bad tracks.\n        \"\"\"\n        if prev_pts.shape[0] == 0:\n            return np.empty((0, 2)), np.empty((0, 2)), np.empty(0, dtype=bool)\n\n        curr_pts, st, err = cv2.calcOpticalFlowPyrLK(prev_gray, curr_gray, prev_pts, None, **self.lk_params)\n        # backward check\n        prev_pts_back, st_back, err_back = cv2.calcOpticalFlowPyrLK(curr_gray, prev_gray, curr_pts, None, **self.lk_params)\n\n        st = st.squeeze().astype(bool)\n        fb_err = np.linalg.norm(prev_pts.reshape(-1, 2) - prev_pts_back.reshape(-1, 2), axis=1)\n        good = st & (fb_err < 1.0) & (err.squeeze() < 50.0)\n\n        return prev_pts.reshape(-1, 2)[good], curr_pts.reshape(-1, 2)[good], good\n\n    # \u2500\u2500 motion estimation for one pair \u2500\u2500\n\n    def _estimate_motion(self, pts_src: np.ndarray, pts_dst: np.ndarray,\n                         frame_idx: int) -> FrameMotion:\n        N = pts_src.shape[0]\n        fm = FrameMotion(\n            frame_idx=frame_idx,\n            affine_matrix=np.eye(2, 3),\n            homography_matrix=np.eye(3),\n            inlier_ratio=0.0,\n            num_inliers=0,\n            num_total=N,\n            translation=np.zeros(2),\n            rotation_angle=0.0,\n            scale=1.0,\n        )\n        if N < 6:\n            return fm\n\n        # Affine RANSAC\n        M_aff, inliers_aff = ransac_affine(pts_src, pts_dst,\n                                           threshold=self.ransac_thresh)\n        # Homography RANSAC\n       