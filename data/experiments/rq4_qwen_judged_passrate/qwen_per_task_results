_create_variables(self):\n        \"\"\"Create decision variables for each task\"\"\"\n        horizon = sum(t.duration for job in self.jobs for t in job.tasks)\n        \n        for job in self.jobs:\n            for task in job.tasks:\n                suffix = f\"_j{task.job_id}_t{task.task_id}\"\n                \n                start_var = self.model.NewIntVar(0, horizon, f\"start{suffix}\")\n                end_var = self.model.NewIntVar(0, horizon, f\"end{suffix}\")\n                \n                interval_var = self.model.NewIntervalVar(\n                    start_var, task.duration, end_var, f\"interval{suffix}\"\n                )\n                \n                key = (task.job_id, task.task_id)\n                self.task_starts[key] = start_var\n                self.task_ends[key] = end_var\n                self.task_intervals[key] = interval_var\n                \n                # Group tasks by machine\n                if task.machine not in self.machine_to_tasks:\n                    self.machine_to_tasks[task.machine] = []\n                self.machine_to_tasks[task.machine].append(interval_var)\n    \n    def _add_precedence_constraints(self):\n        \"\"\"Add precedence constraints: tasks in a job must execute in order\"\"\"\n        for job in self.jobs:\n            for i in range(len(job.tasks) - 1):\n                current_task = job.tasks[i]\n                next_task = job.tasks[i + 1]\n                \n                current_key = (current_task.job_id, current_task.task_id)\n                next_key = (next_task.job_id, next_task.task_id)\n                \n                # Current task must end before next task starts\n                self.model.Add(\n                    self.task_ends[current_key] <= self.task_starts[next_key]\n                )\n    \n    def _add_machine_constraints(self):\n        \"\"\"Add no-overlap constraints: each machine processes one task at a time\"\"\"\n        for machine_id, intervals in self.machine_to_tasks.items():\n            self.model.AddNoOverlap(intervals)\n    \n    def _add_objective(self):\n        \"\"\"Minimize makespan (maximum completion time across all jobs)\"\"\"\n        all_ends = []\n        for job in self.jobs:\n            last_task = job.tasks[-1]\n            all_ends.append(self.task_ends[(last_task.job_id, last_task.task_id)])\n        \n        self.makespan = self.model.NewIntVar(0, sum(t.duration for job in self.jobs for t in job.tasks), \"makespan\")\n        self.model.AddMaxEquality(self.makespan, all_ends)\n        self.model.Minimize(self.makespan)\n    \n    def solve(self, time_limit_seconds: int = 60, num_workers: int = 4) -> bool:\n        \"\"\"\n        Solve the job shop scheduling problem.\n        \n        Args:\n            time_limit_seconds: Maximum solving time\n            num_workers: Number of parallel workers\n            \n        Returns:\n            True if a solution was found, False otherwise\n        \"\"\"\n        self._create_variables()\n        self._add_precedence_constraints()\n        self._add_machine_constraints()\n        self._add_objective()\n        \n        solver = cp_model.CpSolver()\n        solver.parameters.max_time_in_seconds = time_limit_seconds\n        solver.parameters.num_search_workers = num_workers\n        \n        # Add solution callback for progress\n        callback = SolutionCallback()\n        \n        status = solver.Solve(self.model, callback)\n        \n        if status in (cp_model.OPTIMAL, cp_model.FEASIBLE):\n            self._extract_solution(solver)\n            return True\n        return False\n    \n    def _extract_solution(self, solver: cp_model.CpSolver):\n        \"\"\"Extract solution from solver\"\"\"\n        self.solution = {\n            \"makespan\": solver.Value(self.makespan),\n            \"tasks\": [],\n            \"machine_schedules\": {m: [] for m in range(self.num_machines)}\n        }\n        \n        for job in self.jobs:\n            for task in job.tasks:\n                key = (task.job_id, task.task_id)\n                start = solver.Value(self.task_starts[key])\n                end = solver.Value(self.task_ends[key])\n                \n                task_info = {\n                    \"job_id\": task.job_id,\n                    \"task_id\": task.task_id,\n                    \"machine\": task.machine,\n                    \"start\": start,\n                    \"end\": end,\n                    \"duration\": task.duration\n                }\n                self.solution[\"tasks\"].append(task_info)\n                self.solution[\"machine_schedules\"][task.machine].append(task_info)\n        \n        # Sort machine schedules by start time\n        for machine in self.solution[\"machine_schedules\"]:\n            self.solution[\"machine_schedules\"][machine].sort(key=lambda x: x[\"start\"])\n    \n    def print_solution(self):\n        \"\"\"Print the solution in a readable format\"\"\"\n        if not self.solution:\n            print(\"No solution found!\")\n            return\n        \n        print(f\"\\n{'='*60}\")\n        print(f\"OPTIMAL SCHEDULE - Makespan: {self.solution['makespan']}\")\n        print(f\"{'='*60}\\n\")\n        \n        # Print by machine\n        print(\"Schedule by Machine:\")\n        print(\"-\" * 60)\n        for machine_id in range(self.num_machines):\n            print(f\"\\nMachine {machine_id}:\")\n            tasks = self.solution[\"machine_schedules\"][machine_id]\n            for task in tasks:\n                print(f\"  Job {task['job_id']}, Task {task['task_id']}: \"\n                      f\"Start={task['start']}, End={task['end']}, Duration={task['duration']}\")\n        \n        # Print by job\n        print(\"\\n\" + \"-\" * 60)\n        print(\"Schedule by Job:\")\n        print(\"-\" * 60)\n        job_tasks = {}\n        for task in self.solution[\"tasks\"]:\n            if task[\"job_id\"] not in job_tasks:\n                job_tasks[task[\"job_id\"]] = []\n            job_tasks[task[\"job_id\"]].append(task)\n        \n        for job_id in sorted(job_tasks.keys()):\n            print(f\"\\nJob {job_id}:\")\n            for task in job_tasks[job_id]:\n                print(f\"  Task {task['task_id']} on Machine {task['machine']}: \"\n                      f\"Start={task['start']}, End={task['end']}\")\n    \n    def get_gantt_data(self) -> List[Dict]:\n        \"\"\"Get data formatted for Gantt chart visualization\"\"\"\n        if not self.solution:\n            return []\n        \n        return self.solution[\"tasks\"]\n    \n    def export_solution(self, filename: str):\n        \"\"\"Export solution to JSON file\"\"\"\n        if self.solution:\n            with open(filename, 'w') as f:\n                json.dump(self.solution, f, indent=2)\n            print(f\"Solution exported to {filename}\")\n\n\nclass SolutionCallback(cp_model.CpSolverSolutionCallback):\n    \"\"\"Callback to track solving progress\"\"\"\n    \n    def __init__(self):\n        cp_model.CpSolverSolutionCallback.__init__(self)\n        self._solution_count = 0\n    \n    def on_solution_callback(self):\n        self._solution_count += 1\n        if self._solution_count % 10 == 0:\n            print(f\"  Found {self._solution_count} solutions, \"\n                  f\"current makespan: {self.ObjectiveValue()}\")\n\n\ndef create_example_problem() -> Tuple[List[Job], int]:\n    \"\"\"\n    Create a classic job shop scheduling example.\n    \n    Example: 3 jobs, 3 machines\n    Job 0: [(M0, 3), (M1, 2), (M2, 2)]\n    Job 1: [(M0, 2), (M2, 1), (M1, 4)]\n    Job 2: [(M1, 4), (M2, 3)]\n    \"\"\"\n    jobs = []\n    \n    # Job 0: 3 tasks\n    job0_tasks = [\n        Task(0, 0, 0, 3),  # Machine 0, duration 3\n        Task(0, 1, 1, 2),  # Machine 1, duration 2\n        Task(0, 2, 2, 2),  # Machine 2, duration 2\n    ]\n    jobs.append(Job(0, job0_tasks))\n    \n    # Job 1: 3 tasks\n    job1_tasks = [\n        Task(1, 0, 0, 2),  # Machine 0, duration 2\n        Task(1, 1, 2, 1),  # Machine 2, duration 1\n        Task(1, 2, 1, 4),  # Machine 1, duration 4\n    ]\n    jobs.append(Job(1, job1_tasks))\n    \n    # Job 2: 2 tasks\n    job2_tasks = [\n        Task(2, 0, 1, 4),  # Machine 1, duration 4\n        Task(2, 1, 2, 3),  # Machine 2, duration 3\n    ]\n    jobs.append(Job(2, job2_tasks))\n    \n    return jobs, 3\n\n\ndef create_larger_problem() -> Tuple[List[Job], int]:\n    \"\"\"Create a larger benchmark problem (6 jobs, 6 machines)\"\"\"\n    # Classic ft06 benchmark\n    machines = [\n        [2, 0, 1, 3, 5, 4],\n        [1, 2, 4, 5, 0, 3],\n        [2, 3, 5, 0, 1, 4],\n        [1, 0, 2, 4, 5, 3],\n        [2, 1, 3, 5, 4, 0],\n        [1, 3, 5, 0, 4, 2]\n    ]\n    durations = [\n        [1, 3, 6, 7, 3, 6],\n        [8, 5, 10, 10, 10, 4],\n        [5, 4, 8, 9, 1, 7],\n        [5, 5, 5, 3, 8, 1],\n        [9, 3, 5, 4, 3, 1],\n        [3, 3, 9, 10, 4, 1]\n    ]\n    \n    jobs = []\n    for job_id in range(6):\n        tasks = []\n        for task_id in range(6):\n            tasks.append(Task(job_id, task_id, machines[job_id][task_id], durations[job_id][task_id]))\n        jobs.append(Job(job_id, tasks))\n    \n    return jobs, 6\n\n\ndef visualize_gantt_ascii(solution: Dict, num_machines: int, time_scale: int = 2):\n    \"\"\"Create a simple ASCII Gantt chart\"\"\"\n    if not solution:\n        return\n    \n    makespan = solution[\"makespan\"]\n    width = min(80, makespan // time_scale + 10)\n    \n    print(\"\\nASCII Gantt Chart:\")\n    print(\"=\" * width)\n    \n    for machine in range(num_machines):\n        line = [f\"M{machine}|\"]\n        timeline = [\" \"] * (makespan + 1)\n        \n        for task in solution[\"machine_schedules\"][machine]:\n            job_id = task[\"job_id\"]\n            for t in range(task[\"start\"], task[\"end\"]):\n                if t < len(timeline):\n                    timeline[t] = str(job_id)\n        \n        # Compr