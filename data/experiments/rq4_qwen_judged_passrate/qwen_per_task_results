(self.filepath, 'r') as zf:\n            namelist = zf.namelist()\n\n            # Parse map configuration XML\n            config_files = [n for n in namelist if 'config' in n.lower() and n.endswith('.xml')]\n            if config_files:\n                with zf.open(config_files[0]) as f:\n                    self._parse_config_xml(f.read())\n\n            # Parse plot/map data\n            plot_files = [n for n in namelist if 'plot' in n.lower() or 'map' in n.lower()]\n            for pf in plot_files:\n                if pf.endswith('.xml'):\n                    with zf.open(pf) as f:\n                        self._parse_plot_xml(f.read())\n                elif pf.endswith('.dat') or pf.endswith('.bin'):\n                    with zf.open(pf) as f:\n                        self._parse_plot_binary(f.read())\n\n            # If no specific files found, try all XML files\n            if not self.plots:\n                for name in namelist:\n                    if name.endswith('.xml'):\n                        with zf.open(name) as f:\n                            content = f.read()\n                            self._try_parse_generic_xml(content)\n\n    def _parse_config_xml(self, data: bytes):\n        \"\"\"Parse map configuration from XML.\"\"\"\n        root = ET.fromstring(data)\n        self.map_config['root_tag'] = root.tag\n\n        for elem in root.iter():\n            tag = elem.tag.lower()\n            if 'width' in tag or 'gridwidth' in tag:\n                self.map_width = int(elem.text) if elem.text else 0\n            elif 'height' in tag or 'gridheight' in tag:\n                self.map_height = int(elem.text) if elem.text else 0\n            elif 'wrap' in tag:\n                self.map_config['wrap'] = elem.text\n\n        # Defaults if not found\n        if self.map_width == 0:\n            self.map_width = 80\n        if self.map_height == 0:\n            self.map_height = 52\n\n    def _parse_plot_xml(self, data: bytes):\n        \"\"\"Parse plot data from XML format.\"\"\"\n        root = ET.fromstring(data)\n\n        for plot_elem in root.iter():\n            if 'plot' in plot_elem.tag.lower():\n                q = r = 0\n                terrain = 'plains'\n                feature = 'none'\n                resource = 'none'\n                elevation = 0\n\n                for child in plot_elem:\n                    tag = child.tag.lower()\n                    text = child.text if child.text else ''\n                    if 'x' in tag or 'q' in tag or 'col' in tag:\n                        q = int(text) if text else 0\n                    elif 'y' in tag or 'r' in tag or 'row' in tag:\n                        r = int(text) if text else 0\n                    elif 'terrain' in tag:\n                        terrain = text\n                    elif 'feature' in tag:\n                        feature = text\n                    elif 'resource' in tag:\n                        resource = text\n                    elif 'elevation' in tag or 'height' in tag:\n                        elevation = int(text) if text else 0\n\n                self.plots[(q, r)] = PlotData(q, r, terrain, feature, resource, elevation)\n\n    def _parse_plot_binary(self, data: bytes):\n        \"\"\"Parse binary plot data. Civ6 uses a structured binary format.\"\"\"\n        # Each plot record is typically a fixed-size struct\n        # Format assumption: q(i16), r(i16), terrain(u8), feature(u8), resource(u8), elevation(u8)\n        record_size = 8\n        num_records = len(data) // record_size\n\n        for i in range(num_records):\n            offset = i * record_size\n            if offset + record_size > len(data):\n                break\n            q, r, terrain_id, feature_id, resource_id, elevation = struct.unpack_from(\n                '<hhBBBB', data, offset\n            )\n            terrain = self._terrain_id_to_name(terrain_id)\n            feature = self._feature_id_to_name(feature_id)\n            resource = self._resource_id_to_name(resource_id)\n            self.plots[(q, r)] = PlotData(q, r, terrain, feature, resource, elevation)\n\n    def _try_parse_generic_xml(self, data: bytes):\n        \"\"\"Attempt to parse any XML file for plot/grid data.\"\"\"\n        try:\n            root = ET.fromstring(data)\n            # Look for grid dimensions\n            for elem in root.iter():\n                tag = elem.tag.lower()\n                if 'width' in tag and elem.text:\n                    self.map_width = max(self.map_width, int(elem.text))\n                if 'height' in tag and elem.text:\n                    self.map_height = max(self.map_height, int(elem.text))\n        except ET.ParseError:\n            pass\n\n    @staticmethod\n    def _terrain_id_to_name(tid: int) -> str:\n        terrains = {0: 'water', 1: 'coast', 2: 'plains', 3: 'grassland',\n                    4: 'desert', 5: 'tundra', 6: 'snow', 7: 'mountain', 8: 'ocean'}\n        return terrains.get(tid, f'terrain_{tid}')\n\n    @staticmethod\n    def _feature_id_to_name(fid: int) -> str:\n        features = {0: 'none', 1: 'forest', 2: 'jungle', 3: 'marsh',\n                    4: 'floodplain', 5: 'oasis', 6: 'reef', 7: 'fallout'}\n        return features.get(fid, f'feature_{fid}')\n\n    @staticmethod\n    def _resource_id_to_name(rid: int) -> str:\n        resources = {0: 'none', 1: 'iron', 2: 'horses', 3: 'coal', 4: 'oil',\n                     5: 'aluminum', 6: 'uranium', 7: 'wheat', 8: 'rice',\n                     9: 'cattle', 10: 'sheep', 11: 'stone', 12: 'gold', 13: 'silver'}\n        return resources.get(rid, f'resource_{rid}')\n\n\nclass PlotData:\n    \"\"\"Represents a single hex plot on the map.\"\"\"\n\n    def __init__(self, q: int, r: int, terrain: str, feature: str,\n                 resource: str, elevation: int):\n        self.q = q\n        self.r = r\n        self.terrain = terrain\n        self.feature = feature\n        self.resource = resource\n        self.elevation = elevation\n        self.adjacency_scores = {}  # district_type -> score\n\n    def __repr__(self):\n        return f\"Plot({self.q},{self.r}: {self.terrain}/{self.feature}/{self.resource})\"\n\n    def is_land(self) -> bool:\n        return self.terrain not in ('water', 'coast', 'ocean')\n\n    def is_water(self) -> bool:\n        return self.terrain in ('water', 'coast', 'ocean')\n\n    def is_coastal(self) -> bool:\n        return self.terrain in ('coast', 'ocean')\n\n\n# ============================================================\n# SECTION 2: Hex Grid with Adjacency Graph\n# ============================================================\n\nclass HexGrid:\n    \"\"\"\n    Hexagonal grid using axial coordinates (q, r).\n    Civ6 uses offset coordinates; we convert to axial for adjacency math.\n\n    Offset (odd-r) to Axial conversion:\n        q_axial = q_offset - (r_offset - (r_offset & 1)) / 2\n        r_axial = r_offset\n\n    Adjacency in axial coordinates uses 6 direction vectors:\n        [(+1,0), (+1,-1), (0,-1), (-1,0), (-1,+1), (0,+1)]\n    \"\"\"\n\n    # Axial direction vectors for 6 neighbors\n    DIRECTIONS = [\n        (+1, 0), (+1, -1), (0, -1),\n        (-1, 0), (-1, +1), (0, +1)\n    ]\n\n    def __init__(self, width: int, height: int, wrap_x: bool = True, wrap_y: bool = False):\n        self.width = width\n        self.height = height\n        self.wrap_x = wrap_x\n        self.wrap_y = wrap_y\n        self.plots: Dict[Tuple[int, int], PlotData] = {}\n        self.adjacency: Dict[Tuple[int, int], List[Tuple[int, int]]] = {}\n        self._build_grid()\n\n    def _build_grid(self):\n        \"\"\"Initialize all hex positions in the grid.\"\"\"\n        for r in range(self.height):\n            for q in range(self.width):\n                self.plots[(q, r)] = None  # Placeholder\n                self.adjacency[(q, r)] = []\n\n    def load_from_parser(self, parser: Civ6MapParser):\n        \"\"\"Load plot data from a parsed Civ6Map file.\"\"\"\n        self.width = parser.map_width\n        self.height = parser.map_height\n        self._build_grid()\n\n        for coord, plot in parser.plots.items():\n            if coord in self.plots:\n                self.plots[coord] = plot\n\n        self._compute_adjacency()\n\n    def set_plot(self, q: int, r: int, plot: PlotData):\n        \"\"\"Manually set a plot at given coordinates.\"\"\"\n        self.plots[(q, r)] = plot\n\n    def _compute_adjacency(self):\n        \"\"\"Compute adjacency for all hexes using axial coordinate directions.\"\"\"\n        for (q, r) in self.plots:\n            neighbors = []\n            for dq, dr in self.DIRECTIONS:\n                nq, nr = q + dq, r + dr\n\n                # Handle wrapping (Civ6 maps typically wrap horizontally)\n                if self.wrap_x:\n                    nq = nq % self.width\n                if self.wrap_y:\n                    nr = nr % self.height\n\n                # Bounds check\n                if 0 <= nq < self.width and 0 <= nr < self.height:\n                    if (nq, nr) in self.plots:\n                        neighbors.append((nq, nr))\n\n            self.adjacency[(q, r)] = neighbors\n\n    def get_neighbors(self, q: int, r: int) -> List[Tuple[int, int]]:\n        \"\"\"Get the 6 adjacent hex coordinates.\"\"\"\n        return self.adjacency.get((q, r), [])\n\n    def get_neighbors_within(self, q: int, r: int, radius: int) -> Set[Tuple[int, int]]:\n        \"\"\"Get all hexes within a given radius (BFS).\"\"\"\n        visited = set()\n        queue = deque([(q, r, 0)])\n        visited.add((q, r))\n\n        while queue:\n            cq, cr, dist = queue.popleft()\n            if dist < radius:\n                for nq, nr in self.get_neighbors(cq, cr):\n                    if (nq, nr) not in visited:\n                        visited.add((nq, nr))\n                        queue.append((nq, nr, dist + 1))\n\n        visited.discard((q, r))\n        return visited\n\n    def get_ring(self, q: int, r: int, radius: int) -> List[Tuple[int, int]]:\n        \"\"\"Get hexes at exactly a given radius (the ring).\"\"\"\n        if radius == 0:\n            return [(q, r)]\n\n        results = []\n        # Start from hex in direction [4] scaled by radius\n        dq, dr = self.DIRECTIONS[4]\n        cq, cr = q + dq * radius, r + dr * radius\n\n        for i in range(6):\n            direction = self.DIRECTIONS[i]\n            for _ in range(radius):\n                if (cq, cr) in self.plots:\n                    results.append((cq, cr))\n                cq += direction[0]\n                cr += direction[1]\n\n        return results\n\n    def hex_distance(self, q1: int, r1: int, q2: int, r2: int) -> int:\n        \"\"\"Compute hex distance between two axial coordinates.\"\"\"\n        # Convert to cube coordinates for distance calculation\n        # cube: x=q, z=r, y=-x-z\n        x1, z1 = q1, r1\n        y1 = -x1 - z1\n        x2, z2 = q2, r2\n        y2 = -x2 - z2\n\n        return (abs(x1 - x2) + abs(y1 - y2) + abs(z1 - z2)) // 2\n\n    def find_path(self, start: Tuple[int, int], end: Tuple[int, int],\n                  passable_fn=None) -> Optional[List[Tuple[int, int]]]:\n        \"\"\"A* pathfinding on the hex grid.\"\"\"\n        if passable_fn is None:\n            passable_fn = lambda coord: self.plots.get(coord) is not None\n\n        open_set = {start}\n        came_from = {}\n        g_score = {start: 0}\n        f_score = {start: self.hex_distance(*start, *end)}\n\n        while open_set:\n            # Get node with lowest f_score\n            current = min(open_set, key=lambda x: f_score.get(x, float('inf')))\n\n            if current == end:\n                path = []\n                while current in came_from:\n                    path.append(current)\n                    current = came_from[current]\n                path.append(start)\n                path.reverse()\n                return path\n\n            open_set.remove(current)\n\n            for neighbor in self.get_neighbors(*current):\n                if not passable_fn(neighbor):\n                    continue\n\n                tentative_g = g_score[current] + 1\n                if tentative_g < g_score.get(neighbor, float('inf')):\n                    came_from[neighbor] = current\n                    g_score[neighbor] = tentative_g\n                    f_score[neighbor] = tentative_g + self.hex_distance(*neighbor, *end)\n                    open_set.add(neighbor)\n\n        return None  # No path found\n\n    def connected_components(self, passable_fn=None) -> List[Set[Tuple[int, int]]]:\n        \"\"\"Find all connected components of passable hexes.\"\"\"\n        if passable_fn is None:\n            passable_fn = lambda coord: self.plots.get(coord) is not None\n\n        visited = set()\n        components = []\n\n        for coord in self.plots:\n            if coord in visited or not passable_fn(coord):\n                continue\n\n            # BFS to find component\n            component = set()\n            queue = deque([coord])\n            while queue:\n                current = queue.popleft()\n                if current in visited:\n                    continue\n                visited.add(current)\n                component.add(current)\n\n                for neighbor in self.get_neighbors(*current):\n                    if neighbor not in visited and passable_fn(neighbor):\n                        queue.append(neighbor)\n\n            components.append(component)\n\n        return components\n\n    def to_geojson(self) -> dict:\n        \"\"\"Export hex grid as GeoJSON for visualization.\"\"\"\n        features = []\n        for (q, r), plot in self.plots.items():\n            if plot is None:\n                continue\n            # Convert axial to pixel center (pointy-top hex)\n            size = 1.0\n            x = size * (np.sqrt(3) * q + np.sqrt(3) / 2 * r)\n            y = size * (3.0 / 2 * r)\n\n            # Generate hex vertices\n            vertices = []\n            for i in range(6):\n                angle = np.pi / 180 * (60 * i - 30)\n                vx = x + size * np.cos(angle)\n                vy = y + size * np.sin(angle)\n                vertices.append([vx, vy])\n            vertices.append(vertices[0])  # Close the polygon\n\n            feature = {\n                \"type\": \"Feature\",\n                \"geometry\": {\n                    \"type\": \"Polygon\",\n                    \"coordinates\": [vertices]\n                },\n                \"properties\": {\n                    \"q\": q, \"r\": r,\n                    \"terrain\": plot.terrain,\n                    \"feature\": plot.feature,\n                    \"resource\": plot.resource,\n                    \"elevation\": plot.elevation\n                }\n            }\n            features.append(feature)\n\n        return {\"type\": \"FeatureCollection\", \"features\": features}\n\n\n# ==========================================", "solver_finish_reason": "length"}
{"task": "civ6-adjacency-optimizer", "condition": "random_wrong", "repeat": 0, "skill_ids": ["benchflow-ai--gemini-video-understanding"], "retrieval_correct": false, "judged_pass": false, "judged_score": 0, "judge_reason": "Agent did not provide a solution in the required JSON format with placements and adjacency bonuses.", "solver_tokens": 3150, "judge_tokens": 3422, "solution_text": "# Civ6Map Hex Grid Parsing & Combinatorial Optimization\n\n## Solution Overview\n\nCiv6Map files are ZIP archives containing XML data. Here's a complete solution for parsing hex grids, calculating adjacency, and performing combinatorial optimization:\n\n```python\nimport zipfile\nimport xml.etree.ElementTree as ET\nimport numpy as np\nfrom typing import List, Tuple, Dict, Set\nfrom dataclasses import dataclass\nimport heapq\n\n@dataclass\nclass HexTile:\n    q: int  # axial coordinate\n    r: int  # axial coordinate\n    terrain: str\n    resource: str = None\n    feature: str = None\n    elevation: float = 0.0\n    \n    @property\n    def s(self):\n        \"\"\"Cube coordinate s = -q - r\"\"\"\n        return -self.q - self.r\n    \n    def __hash__(self):\n        return hash((self.q, self.r))\n    \n    def __eq__(self, other):\n        return self.q == other.q and self.r == other.r\n\nclass Civ6MapParser:\n    \"\"\"Parser for Civilization 6 map files\"\"\"\n    \n    def __init__(self, map_file: str):\n        self.map_file = map_file\n        self.tiles: Dict[Tuple[int, int], HexTile] = {}\n        self.map_width = 0\n        self.map_height = 0\n        \n    def parse(self):\n        \"\"\"Parse the Civ6Map file (ZIP archive with XML)\"\"\"\n        with zipfile.ZipFile(self.map_file, 'r') as zip_ref:\n            # Find the map data XML file\n            xml_files = [f for f in zip_ref.namelist() if f.endswith('.xml')]\n            \n            for xml_file in xml_files:\n                if 'MapSetupData' in xml_file or 'World' in xml_file:\n                    with zip_ref.open(xml_file) as f:\n                        self._parse_xml(f)\n                        break\n    \n    def _parse_xml(self, xml_data):\n        \"\"\"Parse XML map data\"\"\"\n        tree = ET.parse(xml_data)\n        root = tree.getroot()\n        \n        # Extract map dimensions\n        grid_elem = root.find('.//Grid')\n        if grid_elem is not None:\n            self.map_width = int(grid_elem.get('Width', 0))\n            self.map_height = int(grid_elem.get('Height', 0))\n        \n        # Parse tiles\n        for plot in root.findall('.//Plot'):\n            q = int(plot.get('X', 0))\n            r = int(plot.get('Y', 0))\n            \n            terrain = plot.get('Terrain', 'PLAINS')\n            resource = plot.get('Resource')\n            feature = plot.get('Feature')\n            elevation = float(plot.get('Elevation', 0.0))\n            \n            tile = HexTile(q, r, terrain, resource, feature, elevation)\n            self.tiles[(q, r)] = tile\n    \n    def get_tile(self, q: int, r: int) -> HexTile:\n        \"\"\"Get tile at axial coordinates\"\"\"\n        return self.tiles.get((q, r))\n\nclass HexGridAdjacency:\n    \"\"\"Hex grid adjacency calculator using axial coordinates\"\"\"\n    \n    # Six directions in axial coordinates\n    DIRECTIONS = [\n        (+1, 0), (+1, -1), (0, -1),\n        (-1, 0), (-1, +1), (0, +1)\n    ]\n    \n    @staticmethod\n    def get_neighbors(q: int, r: int) -> List[Tuple[int, int]]:\n        \"\"\"Get all 6 neighboring hex coordinates\"\"\"\n        return [(q + dq, r + dr) for dq, dr in HexGridAdjacency.DIRECTIONS]\n    \n    @staticmethod\n    def get_neighbors_in_range(q: int, r: int, radius: int) -> List[Tuple[int, int]]:\n        \"\"\"Get all hexes within radius (BFS)\"\"\"\n        results = []\n        for dq in range(-radius, radius + 1):\n            for dr in range(max(-radius, -dq - radius), \n                           min(radius, -dq + radius) + 1):\n                if dq == 0 and dr == 0:\n                    continue\n                results.append((q + dq, r + dr))\n        return results\n    \n    @staticmethod\n    def hex_distance(q1: int, r1: int, q2: int, r2: int) -> int:\n        \"\"\"Calculate distance between two hexes using cube coordinates\"\"\"\n        return (abs(q1 - q2) + abs(q1 + r1 - q2 - r2) + abs(r1 - r2)) // 2\n    \n    @staticmethod\n    def build_adjacency_map(tiles: Dict[Tuple[int, int], HexTile]) -> Dict[Tuple[int, int], Set[Tuple[int, int]]]:\n        \"\"\"Build complete adjacency map for all tiles\"\"\"\n        adjacency = {}\n        for (q, r) in tiles.keys():\n            neighbors = HexGridAdjacency.get_neighbors(q, r)\n            adjacency[(q, r)] = {(nq, nr) for nq, nr in neighbors if (nq, nr) in tiles}\n        return adjacency\n\nclass HexGridOptimizer:\n    \"\"\"Combinatorial optimization on hex grids\"\"\"\n    \n    def __init__(self, parser: Civ6MapParser):\n        self.parser = parser\n        self.adjacency = HexGridAdjacency.build_adjacency_map(parser.tiles)\n    \n    def calculate_tile_score(self, tile: HexTile) -> float:\n        \"\"\"Score a tile based on resources and terrain\"\"\"\n        score = 0.0\n        \n        # Base terrain value\n        terrain_scores = {\n            'PLAINS': 2.0, 'GRASS': 2.5, 'DESERT': 0.5,\n            'TUNDRA': 1.0, 'SNOW': 0.2\n        }\n        score += terrain_scores.get(tile.terrain, 1.0)\n        \n        # Resource bonus\n        if tile.resource:\n            score += 3.0\n        \n        # Feature bonus (forests, etc.)\n        if tile.feature:\n            score += 1.0\n        \n        # Elevation bonus\n        score += tile.elevation * 0.5\n        \n        return score\n    \n    def find_optimal_city_locations(self, num_cities: int, min_distance: int = 4) -> List[Tuple[int, int]]:\n        \"\"\"\n        Find optimal city placement using greedy algorithm with distance constraints\n        This is a variant of the k-center problem on hex grids\n        \"\"\"\n        # Score all tiles\n        scored_tiles = []\n        for (q, r), tile in self.parser.tiles.items():\n            score = self.calculate_tile_score(tile)\n            \n            # Bonus for adjacency to diverse tiles\n            neighbors = self.adjacency.get((q, r), set())\n            terrain_types = {self.parser.tiles[n].terrain for n in neighbors if n in self.parser.tiles}\n            score += len(terrain_types) * 0.5\n            \n            scored_tiles.append((score, q, r))\n        \n        # Sort by score descending\n        scored_tiles.sort(reverse=True)\n        \n        # Greedy selection with distance constraint\n        selected = []\n        for score, q, r in scored_tiles:\n            if len(selected) >= num_cities:\n                break\n            \n            # Check minimum distance to all selected cities\n            valid = True\n            for sq, sr in selected:\n                if HexGridAdjacency.hex_distance(q, r, sq, sr) < min_distance:\n                    valid = False\n                    break\n            \n            if valid:\n                selected.append((q, r))\n        \n        return selected\n    \n    def optimize_district_placement(self, city_q: int, city_r: int, districts: List[str]) -> Dict[str, Tuple[int, int]]:\n        \"\"\"\n        Optimize district placement around a city using adjacency bonuses\n        Uses dynamic programming on the hex neighborhood\n        \"\"\"\n        # Get all tiles within 3 hex radius (city range)\n        candidates = HexGridAdjacency.get_neighbors_in_range(city_q, city_r, 3)\n        candidates = [(q, r) for q, r in candidates if (q, r) in self.parser.tiles]\n        \n        # Calculate adjacency bonuses for each district type\n        district_bonuses = {\n            'CAMPUS': ['MOUNTAIN', 'REEF', 'JUNGLE'],\n            'HOLY_SITE': ['NATURAL_WONDER', 'WOODS', 'MOUNTAIN'],\n            'COMMERCIAL_HUB': ['RIVER', 'HARBOR', 'MARKETPLACE'],\n            'HARBOR': ['COAST', 'RESOURCE'],\n            'INDUSTRIAL_ZONE': ['MINE', 'QUARRY', 'LUMBER_MILL'],\n        }\n        \n        # Score each candidate location for each district\n        location_scores = {}\n        for q, r in candidates:\n            if (q, r) == (city_q, city_r):\n                continue  # Can't place district on city center\n            \n            tile = self.parser.tiles[(q, r)]\n            neighbors = self.adjacency.get((q, r), set())\n            \n            location_scores[(q, r)] = {}\n            for district in districts:\n                score = 0.0\n                bonuses = district_bonuses.get(district, [])\n                \n                # Check tile itself\n                if tile.terrain in bonuses or tile.feature in bonuses:\n                    score += 2.0\n                if tile.resource:\n                    score += 1.5\n                \n                # Check neighbors\n                for nq, nr in neighbors:\n                    if nq in self.parser.tiles:\n                        neighbor = self.parser.tiles[(nq, nr)]\n                        if neighbor.terrain in bonuses or neighbor.feature in bonuses:\n                            score += 1.0\n                        if neighbor.resource:\n                            score += 0.5\n                \n                location_scores[(q, r)][district] = score\n        \n        # Greedy assignment: assign districts to maximize total score\n        assignments = {}\n        used_locations = set()\n        \n        for district in districts:\n            best_score = -1\n            best_location = None\n            \n            for (q, r), scores in location_scores.items():\n                if (q, r) not in used_locations:\n                    if scores[district] > best_score:\n                        best_score = scores[district]\n                        best_location = (q, r)\n            \n            if best_location:\n                assignments[district] = best_location\n                used_locations.add(best_location)\n        \n        return assignments\n\n# Example usage\nif __name__ == \"__main__\":\n    # Parse map file\n    parser = Civ6MapParser(\"example_map.civ6map\")\n    parser.parse()\n    \n    # Create optimizer\n    optimizer = HexGridOptimizer(parser)\n    \n    # Find optimal city locations\n    cities = optimizer.find_optimal_city_locations(num_cities=5, min_distance=4)\n    print(f\"Optimal city locations: {cities}\")\n    \n    # Optimize district placement for first city\n    if cities:\n        city_q, city_r = cities[0]\n        districts = ['CAMPUS', 'HOLY_SITE', 'COMMERCIAL_HUB', 'INDUSTRIAL_ZONE']\n        assignments = optimizer.optimize_district_placement(city_q, city_r, districts)\n        print(f\"District assignments for city at ({city_q}, {city_r}):\")\n        for district, (q, r) in assignments.items():\n            print(f\"  {district}: ({q}, {r})\")\n```\n\n## Key Components\n\n1. **HexGridAdjacency**: Implements axial coordinate system with 6-directional adjacency and range queries\n2. **Civ6MapParser**: Extracts tile data from Civ6Map ZIP/XML structure\n3. **HexGridOptimizer**: Solves combinatorial problems:\n   - City placement (k-center variant with distance constraints)\n   - District placement (assignment problem with adjacency bonuses)\n\nThe solution uses greedy algorithms for tractable optimization on large maps. For exact solutions, you could replace the greedy approach with integer linear programming using PuLP or Gurobi.", "solver_finish_reason": "stop"}
