      break\n            self.frames.append(frame)\n            self.frame_indices.append(idx)\n            idx += self.sample_interval\n            \n        cap.release()\n        logger.info(f\"Sampled {len(self.frames)} frames at interval {self.sample_interval}\")\n\n    def estimate_egomotion(self):\n        \"\"\"\n        [Skill: egomotion-estimation]\n        Estimate camera motion with optical flow + affine/homography.\n        \"\"\"\n        if len(self.frames) < 2:\n            raise ValueError(\"Need at least 2 frames to estimate egomotion\")\n            \n        prev_gray = cv2.cvtColor(self.frames[0], cv2.COLOR_BGR2GRAY)\n        \n        for i in range(1, len(self.frames)):\n            curr_gray = cv2.cvtColor(self.frames[i], cv2.COLOR_BGR2GRAY)\n            \n            # Compute dense optical flow\n            flow = cv2.calcOpticalFlowFarneback(prev_gray, curr_gray, None, \n                                                0.5, 3, 15, 3, 5, 1.2, 0)\n            \n            h, w = flow.shape[:2]\n            y, x = np.mgrid[0:h, 0:w]\n            \n            # Subsample points for robust estimation\n            step = 8\n            x_s = x[::step, ::step].flatten()\n            y_s = y[::step, ::step].flatten()\n            fx_s = flow[::step, ::step, 0].flatten()\n            fy_s = flow[::step, ::step, 1].flatten()\n            \n            pts_src = np.column_stack((x_s, y_s)).astype(np.float32)\n            pts_dst = pts_src + np.column_stack((fx_s, fy_s)).astype(np.float32)\n            \n            # Filter out invalid/zero flows\n            valid = (fx_s != 0) | (fy_s != 0)\n            pts_src = pts_src[valid]\n            pts_dst = pts_dst[valid]\n            \n            # Estimate affine transform using RANSAC\n            if len(pts_src) >= 3:\n                M, inliers = cv2.estimateAffine2D(pts_src, pts_dst, method=cv2.RANSAC)\n                if M is None:\n                    M = np.eye(2, 3, dtype=np.float32)\n            else:\n                M = np.eye(2, 3, dtype=np.float32)\n                \n            self.egomotions.append(M)\n            prev_gray = curr_gray\n            \n        logger.info(f\"Estimated egomotion for {len(self.egomotions)} frame transitions\")\n\n    def generate_dynamic_masks(self):\n        \"\"\"\n        [Skill: dyn-object-masks]\n        Generate dynamic-object binary masks after global motion compensation, \n        output CSR sparse format (and raw numpy arrays).\n        \"\"\"\n        prev_gray = cv2.cvtColor(self.frames[0], cv2.COLOR_BGR2GRAY)\n        \n        for i in range(1, len(self.frames)):\n            curr_gray = cv2.cvtColor(self.frames[i], cv2.COLOR_BGR2GRAY)\n            M = self.egomotions[i-1]\n            \n            flow = cv2.calcOpticalFlowFarneback(prev_gray, curr_gray, None, \n                                                0.5, 3, 15, 3, 5, 1.2, 0)\n            \n            h, w = flow.shape[:2]\n            y, x = np.mgrid[0:h, 0:w]\n            \n            # Compute global flow from affine matrix M\n            global_dx = M[0, 0] * x + M[0, 1] * y + M[0, 2]\n            global_dy = M[1, 0] * x + M[1, 1] * y + M[1, 2]\n            \n            # Residual flow (dynamic objects)\n            res_dx = flow[:, :, 0] - global_dx\n            res_dy = flow[:, :, 1] - global_dy\n            res_mag = np.sqrt(res_dx**2 + res_dy**2)\n            \n            # Binary mask\n            mask = (res_mag > self.residual_threshold).astype(np.uint8)\n            \n            # Convert to CSR sparse matrix\n            mask_csr = csr_matrix(mask)\n            self.dynamic_masks_csr.append(mask_csr)\n            \n            # Store pure numpy CSR components\n            self.mask_numpy_components.append({\n                'data': mask_csr.data,\n                'indices': mask_csr.indices,\n                'indptr': mask_csr.indptr,\n                'shape': mask_csr.shape\n            })\n            \n            prev_gray = curr_gray\n            \n        logger.info(f\"Generated {len(self.dynamic_masks_csr)} dynamic masks in CSR format\")\n\n    def validate_outputs(self):\n        \"\"\"\n        [Skill: output-validation]\n        Local self-check of instructions and mask outputs (format/range/consistency) \n        without using GT.\n        \"\"\"\n        # Check frame indexing alignment\n        assert len(self.frame_indices) == len(self.frames), \"Frame indices and frames count mismatch\"\n        \n        # Check egomotion count\n        assert len(self.egomotions) == len(self.frames) - 1, \"Egomotion count mismatch\"\n        \n        # Check mask count and format\n        assert len(self.dynamic_masks_csr) == len(self.frames) - 1, \"Mask count mismatch\"\n        \n        for i, mask_csr in enumerate(self.dynamic_masks_csr):\n            assert isinstance(mask_csr, csr_matrix), f\"Mask {i} is not CSR\"\n            assert mask_csr.shape == self.frames[0].shape[:2], f\"Mask {i} shape mismatch\"\n            \n            # Check values are strictly 0 or 1\n            if mask_csr.nnz > 0:\n                unique_vals = np.unique(mask_csr.data)\n                assert np.all((unique_vals == 0) | (unique_vals == 1)), f\"Mask {i} contains invalid values\"\n                \n        logger.info(\"Output validation passed successfully\")\n\n    def run(self):\n        \"\"\"Execute the full pipeline.\"\"\"\n        self.sample_frames()\n        self.estimate_egomotion()\n        self.generate_dynamic_masks()\n        self.validate_outputs()\n        return self.frame_indices, self.egomotions, self.dynamic_masks_csr, self.mask_numpy_components\n\n\n# ==========================================\n# Example Usage\n# ==========================================\nif __name__ == \"__main__\":\n    # Initialize analyzer (replace 'input_video.mp4' with your actual video path)\n    analyzer = VideoMotionAnalyzer(\n        video_path=\"input_video.mp4\", \n        sample_interval=5,   