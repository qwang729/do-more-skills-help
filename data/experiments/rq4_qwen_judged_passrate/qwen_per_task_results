/ \u2705 BEST PRACTICE: Use next/font for automatic font optimization.\n// This eliminates layout shifts caused by font loading (FOUT/FOIT)\n// because next/font self-hosts fonts and uses font-display: optional\n// with size-adjust to prevent CLS.\nconst inter = Inter({\n  subsets: [\"latin\"],\n  variable: \"--font-inter\",\n  display: \"swap\",\n});\n\nconst jetbrainsMono = JetBrains_Mono({\n  subsets: [\"latin\"],\n  variable: \"--font-jetbrains-mono\",\n  display: \"swap\",\n});\n\nexport const metadata: Metadata = {\n  title: \"React Best Practices Demo\",\n  description: \"Demonstrating Vercel web interface guidelines\",\n};\n\nexport default function RootLayout({\n  children,\n}: {\n  children: React.ReactNode;\n}) {\n  return (\n    <html lang=\"en\" className={`${inter.variable} ${jetbrainsMono.variable}`}>\n      {/*\n        \u2705 BEST PRACTICE: suppressHydrationWarning on <html> and <body>\n        prevents hydration mismatches when using client-side injected\n        scripts (e.g., theme detection, analytics) that modify these elements.\n      */}\n      <body suppressHydrationWarning className=\"font-sans\">\n        {children}\n      </body>\n    </html>\n  );\n}\n```\n\n## 3. `app/globals.css`\n\n```css\n:root {\n  --font-sans: var(--font-inter), system-ui, -apple-system, sans-serif;\n  --font-mono: var(--font-jetbrains-mono), ui-monospace, monospace;\n\n  /* Color tokens */\n  --bg: #ffffff;\n  --fg: #0a0a0a;\n  --muted: #6b7280;\n  --border: #e5e7eb;\n  --card-bg: #f9fafb;\n  --accent: #2563eb;\n}\n\n@media (prefers-color-scheme: dark) {\n  :root {\n    --bg: #0a0a0a;\n    --fg: #fafafa;\n    --muted: #9ca3af;\n    --border: #374151;\n    --card-bg: #111827;\n    --accent: #60a5fa;\n  }\n}\n\n* {\n  box-sizing: border-box;\n  margin: 0;\n  padding: 0;\n}\n\nhtml {\n  /* \u2705 BEST PRACTICE: Prevent layout shift from scrollbar appearing/disappearing */\n  overflow-y: scroll;\n}\n\nbody {\n  font-family: var(--font-sans);\n  background-color: var(--bg);\n  color: var(--fg);\n  line-height: 1.6;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\ncode, pre {\n  font-family: var(--font-mono);\n}\n\n/* \u2705 BEST PRACTICE: Reserve space for images to prevent CLS */\nimg {\n  max-width: 100%;\n  height: auto;\n  display: block;\n}\n\n/* \u2705 BEST PRACTICE: Skeleton animation for loading states */\n@keyframes shimmer {\n  0% {\n    background-position: -200% 0;\n  }\n  100% {\n    background-position: 200% 0;\n  }\n}\n\n.skeleton {\n  background: linear-gradient(\n    90deg,\n    var(--card-bg) 25%,\n    var(--border) 50%,\n    var(--card-bg) 75%\n  );\n  background-size: 200% 100%;\n  animation: shimmer 1.5s ease-in-out infinite;\n  border-radius: 4px;\n}\n```\n\n## 4. `app/components/ClientOnly.tsx` \u2014 Preventing Hydration Mismatches\n\n```tsx\n\"use client\";\n\nimport { useState, useEffect, type ReactNode } from \"react\";\n\ninterface ClientOnlyProps {\n  children: ReactNode;\n  fallback?: ReactNode;\n}\n\n/**\n * \u2705 BEST PRACTICE: Wrap client-only content that depends on browser APIs\n * (window, localStorage, matchMedia) to prevent hydration mismatches.\n *\n * During SSR, the fallback is rendered. After hydration on the client,\n * the actual children are rendered. This prevents the classic\n * \"Text content does not match server-rendered HTML\" error.\n */\nexport function ClientOnly({ children, fallback = null }: ClientOnlyProps) {\n  const [hasMounted, setHasMounted] = useState(false);\n\n  useEffect(() => {\n    setHasMounted(true);\n  }, []);\n\n  if (!hasMounted) {\n    return <>{fallback}</>;\n  }\n\n  return <>{children}</>;\n}\n```\n\n## 5. `app/components/Skeleton.tsx` \u2014 Preventing Layout Shifts During Loading\n\n```tsx\nimport type { CSSProperties } from \"react\";\n\ninterface SkeletonProps {\n  width?: string | number;\n  height?: string | number;\n  borderRadius?: string | number;\n  className?: string;\n  style?: CSSProperties;\n}\n\n/**\n * \u2705 BEST PRACTICE: Use skeleton loaders with explicit dimensions\n * to reserve space and prevent Cumulative Layout Shift (CLS).\n *\n * The skeleton should match the final content's dimensions exactly.\n */\nexport function Skeleton({\n  width = \"100%\",\n  height = \"20px\",\n  borderRadius = \"4px\",\n  className = \"\",\n  style,\n}: SkeletonProps) {\n  return (\n    <div\n      className={`skeleton ${className}`}\n      style={{\n        width,\n        height,\n        borderRadius,\n        ...style,\n      }}\n      aria-hidden=\"true\"\n      role=\"presentation\"\n    />\n  );\n}\n\n/**\n * Card skeleton that matches the ImageCard component dimensions exactly.\n */\nexport function CardSkeleton() {\n  return (\n    <div\n      style={{\n        border: \"1px solid var(--border)\",\n        borderRadius: \"12px\",\n        overflow: \"hidden\",\n        background: \"var(--card-bg)\",\n      }}\n    >\n      {/* \u2705 Reserve exact image space: 16:9 aspect ratio */}\n      <Skeleton height=\"200px\" borderRadius=\"0\" />\n      <div style={{ padding: \"16px\", display: \"flex\", flexDirection: \"column\", gap: \"8px\" }}>\n        <Skeleton width=\"70%\" height=\"20px\" />\n        <Skeleton width=\"100%\" height=\"14px\" />\n        <Skeleton width=\"90%\" height=\"14px\" />\n        <div style={{ display: \"flex\", gap: \"8px\", marginTop: \"8px\" }}>\n          <Skeleton width=\"60px\" height=\"24px\" borderRadius=\"12px\" />\n          <Skeleton width=\"80px\" height=\"24px\" borderRadius=\"12px\" />\n        </div>\n      </div>\n    </div>\n  );\n}\n```\n\n## 6. `app/components/ImageCard.tsx` \u2014 Preventing CLS with Images\n\n```tsx\n\"use client\";\n\nimport Image from \"next/image\";\nimport { useState } from \"react\";\nimport { Skeleton } from \"./Skeleton\";\n\ninterface ImageCardProps {\n  src: string;\n  alt: string;\n  title: string;\n  description: string;\n  tags: string[];\n}\n\n/**\n * \u2705 BEST PRACTICE: Always provide explicit width/height for images\n * to prevent layout shifts. Use Next.js Image component with\n * the `fill` prop + aspect-ratio container for responsive images.\n *\n * \u2705 BEST PRACTICE: Show a skeleton placeholder while the image loads\n * to prevent visual flickering and CLS.\n */\nexport function ImageCard({ src, alt, title, description, tags }: ImageCardProps) {\n  const [imageLoaded, setImageLoaded] = useState(false);\n\n  return (\n    <article\n      style={{\n        border: \"1px solid var(--border)\",\n        borderRadius: \"12px\",\n        overflow: \"hidden\",\n        background: \"var(--card-bg)\",\n        transition: \"box-shadow 0.2s ease\",\n      }}\n    >\n      {/*\n        \u2705 BEST PRACTICE: Use a fixed-aspect-ratio container for the image.\n        This reserves the exact space needed, preventing CLS when the\n        image loads. The skeleton is shown underneath until the image is ready.\n      */}\n      <div\n        style={{\n          position: \"relative\",\n          width: \"100%\",\n          aspectRatio: \"16 / 9\",\n          overflow: \"hidden\",\n          background: \"var(--border)\",\n        }}\n      >\n        {!imageLoaded && (\n          <div\n            style={{\n              position: \"absolute\",\n              inset: 0,\n              display: \"flex\",\n              alignItems: \"center\",\n              justifyContent: \"center\",\n            }}\n          >\n            <Skeleton width=\"100%\" height=\"100%\" borderRadius=\"0\" />\n          </div>\n        )}\n        <Image\n          src={src}\n          alt={alt}\n          fill\n          sizes=\"(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw\"\n          style={{\n            objectFit: \"cover\",\n            opacity: imageLoaded ? 1 : 0,\n            transition: \"opacity 0.3s ease\",\n          }}\n          onLoad={() => setImageLoaded(true)}\n          priority={false}\n        />\n      </div>\n\n      <div style={{ padding: \"16px\" }}>\n        <h3\n          style={{\n            fontSize: \"1.125rem\",\n            fontWeight: 600,\n            marginBottom: \"8px\",\n            /* \u2705 BEST PRACTICE: Set explicit line-height to prevent\n               font-loading layout shifts on the heading */\n            lineHeight: 1.4,\n          }}\n        >\n          {title}\n        </h3>\n        <p\n          style={{\n            color: \"var(--muted)\",\n            fontSize: \"0.875rem\",\n            lineHeight: 1.6,\n            marginBottom: \"12px\",\n          }}\n        >\n          {description}\n        </p>\n        <div style={{ display: \"flex\", gap: \"8px\", flexWrap: \"wrap\" }}>\n          {tags.map((tag) => (\n            <span\n              key={tag}\n              style={{\n                padding: \"2px 10px\",\n                borderRadius: \"12px\",\n                fontSize: \"0.75rem\",\n                fontWeight: 500,\n                background: \"var(--border)\",\n                color: \"var(--fg)\",\n              }}\n            >\n              {tag}\n            </span>\n          ))}\n        </div>\n      </div>\n    </article>\n  );\n}\n```\n\n## 7. `app/components/ThemeToggle.tsx` \u2014 Safe Client-Side Theme Detection\n\n```tsx\n\"use client\";\n\nimport { useState, useEffect, useCallback } from \"react\";\nimport { ClientOnly } from \"./ClientOnly\";\n\n/**\n * \u2705 BEST PRACTICE: Theme toggle that reads from localStorage\n * only on the client to avoid hydration mismatches.\n *\n * Uses ClientOnly wrapper + useEffect to ensure localStorage\n * is only accessed after hydration is complete.\n */\nexport function ThemeToggle() {\n  const [isDark, setIsDark] = useState(false);\n\n  useEffect(() => {\n    // \u2705 Read system preference or stored preference AFTER mount\n    const stored = localStorage.getItem(\"theme\");\n    if (stored) {\n      setIsDark(stored === \"dark\");\n    } else {\n      setIsDark(window.matchMedia(\"(prefers-color-scheme: dark)\").matches);\n    }\n  }, []);\n\n  const toggleTheme = useCallback(() => {\n    setIsDark((prev) => {\n      const next = !prev;\n      localStorage.setItem(\"theme\", next ? \"dark\" : \"light\");\n      document.documentElement.classList.toggle(\"dark\", next);\n      return next;\n    });\n  }, []);\n\n  return (\n    <ClientOnly fallback={<div style={{ width: \"40px\", height: \"40px\" }} />}>\n      <button\n        onClick={toggleTheme}\n        aria-label={isDark ? \"Switch to light mode\" : \"Switch to dark mode\"}\n        style={{\n          width: \"40px\",\n          height: \"40px\",\n          borderRadius: \"8px\",\n          border: \"1px solid var(--border)\",\n          background: \"var(--card-bg)\",\n          color: \"var(--fg)\",\n          cursor: \"pointer\",\n          display: \"flex\",\n          alignItems: \"center\",\n          justifyContent: \"center\",\n          fontSize: \"1.25rem\",\n          /* \u2705 BEST PRACTICE: Fixed dimensions prevent layout shift\n             when the button content changes */\n        }}\n      >\n        {isDark ? \"\u2600\ufe0f\" : \"\ud83c\udf19\"}\n      </button>\n    </ClientOnly>\n  );\n}\n```\n\n## 8. `app/page.tsx` \u2014 Main Page with All Best Practices\n\n```tsx\nimport { Suspense } from \"react\";\nimport { ThemeToggle } from \"./components/ThemeToggle\";\nimport { ImageCard } from \"./components/ImageCard\";\nimport { CardSkeleton } from \"./components/Skeleton\";\nimport { DynamicContent } from \"./components/DynamicContent\";\n\n/**\n * \u2705 BEST PRACTICE: Use Suspense boundaries with skeleton fallbacks\n * to prevent layout shifts during data fetching. The skeleton\n * reserves the exact space the content will occupy.\n */\nexport default function Home() {\n  return (\n    <main\n      style={{\n        maxWidth: \"1200px\",\n        margin: \"0 auto\",\n        padding: \"24px\",\n        minHeight: \"100vh\",\n      }}\n    >\n      {/* Header with fixed height to prevent CLS */}\n      <header\n        style={{\n          display: \"flex\",\n          justifyContent: \"space-between\",\n          alignItems: \"center\",\n          height: \"64px\",\n          marginBottom: \"32px\",\n          /* \u2705 BEST PRACTICE: Explicit height prevents layout shift */\n        }}\n      >\n        <h1\n          style={{\n            fontSize: \"1.5rem\",\n            fontWeight: 700,\n            /* \u2705 BEST PRACTICE: Explicit line-height for consistent rendering */\n            lineHeight: 1.2,\n          }}\n        >\n          Web Interface Guidelines\n        </h1>\n        <ThemeToggle />\n      </header>\n\n      {/*\n        \u2705 BEST PRACTICE: Wrap async/streaming content in Suspense\n        with a skeleton fallback that matches the expected layout.\n        This prevents CLS when content loads.\n      */}\n      <Suspense fallback={<CardGridSkeleton />}>\n        <CardGrid />\n      </Suspense>\n\n      {/*\n        \u2705 BEST PRACTICE: Dynamic content that depends on client APIs\n        is wrapped in its own component that handles hydration safely.\n      */}\n      <section style={{ marginTop: \"48px\" }}>\n        <h2 style={{ fontSize: \"1.25rem\", fontWeight: 600, marginBottom: \"16px\" }}>\n          Client-Side Information\n        </h2>\n        <DynamicContent />\n      </section>\n    </main>\n  );\n}\n\n/** Server component that fetches data */\nasync function CardGrid() {\n  // Simulate data fetching\n  const cards = [\n    {\n      src: \"https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=600&h=338&fit=crop\",\n      alt: \"Code on a screen\",\n      title: \"Preventing Layout Shifts\",\n      description:\n        \"Always reserve space for dynamic content using explicit dimensions, aspect-ratio containers, or skeleton loaders.\",\n      tags: [\"CLS\", \"Layout\", \"UX\"],\n    },\n    {\n      src: \"https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=600&h=338&fit=crop\",\n      alt: \"Lap