GMA table_info({table})\")\n            columns = [\n                {'name': row['name'], 'type': row['type'], 'notnull': row['notnull']}\n                for row in cursor.fetchall()\n            ]\n            cursor = self.conn.execute(f\"SELECT COUNT(*) as cnt FROM {table}\")\n            count = cursor.fetchone()['cnt']\n            schema[table] = {'columns': columns, 'row_count': count}\n        return schema\n\n    def _extract_map_data(self) -> Dict:\n        \"\"\"Extract all map data as structured JSON-compatible dict.\"\"\"\n        data = {'schema': self.schema, 'tables': {}}\n\n        for table_name in self.schema:\n            cursor = self.conn.execute(f\"SELECT * FROM {table_name}\")\n            rows = [dict(row) for row in cursor.fetchall()]\n            data['tables'][table_name] = rows\n\n        return data\n\n    def get_map_dimensions(self) -> Tuple[int, int]:\n        \"\"\"Get map width and height.\"\"\"\n        # Try common table/column names for Civ6 maps\n        for table_name in ['Maps', 'Map', 'GameMap', 'World']:\n            if table_name in self.schema['tables']:\n                rows = self.map_data['tables'][table_name]\n                if rows:\n                    row = rows[0]\n                    w = row.get('Width', row.get('width', row.get('GridWidth', 0)))\n                    h = row.get('Height', row.get('height', row.get('GridHeight', 0)))\n                    if w and h:\n                        return (w, h)\n\n        # Fallback: infer from plot data\n        plots = self._get_plots()\n        if plots:\n            max_x = max(p['x'] for p in plots)\n            max_y = max(p['y'] for p in plots)\n            return (max_x + 1, max_y + 1)\n        return (0, 0)\n\n    def _get_plots(self) -> List[Dict]:\n        \"\"\"Get plot/tile data from the database.\"\"\"\n        for table_name in ['Plots', 'Plot', 'Tiles', 'Tile', 'MapPlots']:\n            if table_name in self.schema['tables']:\n                return self.map_data['tables'][table_name]\n        return []\n\n    def to_json(self, output_path: str):\n        \"\"\"Export parsed data as JSON.\"\"\"\n        with open(output_path, 'w') as f:\n            json.dump(self.map_data, f, indent=2, default=str)\n\n    def close(self):\n        self.conn.close()\n\n\n# ============================================================\n# PART 2: Hex Grid Spatial Utilities (Skill Guide #2)\n# ============================================================\n\n@dataclass\nclass HexTile:\n    \"\"\"Represents a single hex tile on the grid.\"\"\"\n    x: int\n    y: int\n    terrain: str = \"LAND\"\n    feature: str = \"\"\n    resource: str = \"\"\n    continent: int = 0\n    elevation: float = 0.0\n    is_water: bool = False\n    is_coast: bool = False\n    is_river: bool = False\n    natural_wonder: bool = False\n    has_mountain: bool = False\n    has_woods: bool = False\n    has_rainforest: bool = False\n    has_geothermal: bool = False\n    has_mine: bool = False\n    has_quarry: bool = False\n    has_reef: bool = False\n    has_sea_resource: bool = False\n    district_placed: str = \"\"\n    wonder_placed: str = \"\"\n    is_city_center: bool = False\n\n    @property\n    def key(self) -> Tuple[int, int]:\n        return (self.x, self.y)\n\n\nclass HexGrid:\n    \"\"\"\n    Hex grid using offset coordinates (odd-r offset).\n    Civ6 uses a diamond-shaped hex grid stored in rectangular coordinates.\n    Even rows are shifted right by half a hex width.\n    \"\"\"\n\n    # Neighbor offsets for odd-r offset hex grid\n    # Even row neighbors\n    EVEN_ROW_DIRS = [\n        (+1, 0), (-1, 0),   # East, West\n        (0, -1), (+1, -1),  # NE, NW (row above)\n        (0, +1), (+1, +1),  # SE, SW (row below)\n    ]\n    # Odd row neighbors\n    ODD_ROW_DIRS = [\n        (+1, 0), (-1, 0),   # East, West\n        (-1, -1), (0, -1),  # NE, NW (row above)\n        (-1, +1), (0, +1),  # SE, SW (row below)\n    ]\n\n    def __init__(self, width: int, height: int):\n        self.width = width\n        self.height = height\n        self.tiles: Dict[Tuple[int, int], HexTile] = {}\n        self.adjacency_cache: Dict[Tuple[int, int], List[Tuple[int, int]]] = {}\n\n    def add_tile(self, tile: HexTile):\n        self.tiles[tile.key] = tile\n\n    def get_tile(self, x: int, y: int) -> Optional[HexTile]:\n        return self.tiles.get((x, y))\n\n    def get_neighbors(self, x: int, y: int) -> List[Tuple[int, int]]:\n        \"\"\"Get 6 neighboring hex coordinates.\"\"\"\n        cache_key = (x, y)\n        if cache_key in self.adjacency_cache:\n            return self.adjacency_cache[cache_key]\n\n        if y % 2 == 0:\n            dirs = self.EVEN_ROW_DIRS\n        else:\n            dirs = self.ODD_ROW_DIRS\n\n        neighbors = []\n        for dx, dy in dirs:\n            nx, ny = x + dx, y + dy\n            if (nx, ny) in self.tiles:\n                neighbors.append((nx, ny))\n\n        self.adjacency_cache[cache_key] = neighbors\n        return neighbors\n\n    def get_neighbor_tiles(self, x: int, y: int) -> List[HexTile]:\n        \"\"\"Get neighboring HexTile objects.\"\"\"\n        return [self.tiles[k] for k in self.get_neighbors(x, y) if k in self.tiles]\n\n    def hex_distance(self, x1: int, y1: int, x2: int, y2: int) -> int:\n        \"\"\"Calculate hex distance between two tiles using cube coordinates.\"\"\"\n        # Convert offset to cube coordinates\n        def to_cube(x, y):\n            q = x - (y - (y & 1)) // 2\n            r = y\n            s = -q - r\n            return (q, r, s)\n\n        c1 = to_cube(x1, y1)\n        c2 = to_cube(x2, y2)\n        return max(abs(c1[0] - c2[0]), abs(c1[1] - c2[1]), abs(c1[2] - c2[2]))\n\n    def tiles_in_range(self, cx: int, cy: int, radius: int) -> List[HexTile]:\n        \"\"\"Get all tiles within hex distance radius.\"\"\"\n        result = []\n        for key, tile in self.tiles.items():\n            if self.hex_distance(cx, cy, key[0], key[1]) <= ra