FingerprintAsBitVect(mol, radius, nBits=n_bits)\n    return fp\n\n# ==============================================================================\n# 3. Custom Tanimoto Distance Metric\n# ==============================================================================\ndef tanimoto_distance(x, y):\n    \"\"\"\n    Custom distance metric for sklearn/scipy: Distance = 1 - Tanimoto Similarity.\n    x and y are expected to be RDKit ExplicitBitVect fingerprints.\n    \"\"\"\n    similarity = DataStructs.TanimotoSimilarity(x, y)\n    return 1.0 - similarity\n\ndef compute_tanimoto_distance_matrix(fps):\n    \"\"\"\n    Efficiently compute a pairwise Tanimoto distance matrix using RDKit's \n    BulkTanimotoSimilarity. This is required for precomputed distance clustering.\n    \"\"\"\n    n = len(fps)\n    dist_matrix = np.zeros((n, n))\n    for i in range(n):\n        # BulkTanimotoSimilarity is highly optimized for computing one FP against many\n        sims = DataStructs.BulkTanimotoSimilarity(fps[i], fps)\n        for j in range(n):\n            dist_matrix[i, j] = 1.0 - sims[j]\n    return dist_matrix\n\n# ==============================================================================\n# 4. Tanimoto Similarity Search\n# ==============================================================================\ndef perform_similarity_search(query_smiles, target_smiles_list, threshold=0.5):\n    \"\"\"\n    Perform a Tanimoto similarity search of a query molecule against a list of targets.\n    \"\"\"\n    query_fp = smiles_to_fingerprint(query_smiles)\n    if query_fp is None:\n        raise ValueError(f\"Invalid query SMILES: {query_smiles}\")\n        \n    valid_targets = []\n    for s in target_smiles_list:\n        fp = smiles_to_fingerprint(s)\n        if fp is not None:\n            valid_targets.append((s, fp))\n            \n    target_fps = [v[1] for v in valid_targets]\n    \n    # Compute similarities in bulk\n    similarities = DataStructs.BulkTanimotoSimilarity(query_fp,