end(loc=\"upper left\")\naxes[2].grid(True, alpha=0.3)\n\nplt.tight_layout()\nplt.savefig(\"hp_filter_chart.png\", dpi=150, bbox_inches=\"tight\")\nplt.show()\n\nprint(\"\\nChart saved to: hp_filter_chart.png\")\n\n# ============================================================\n# STEP 6: Identify business cycle turning points\n# ============================================================\ncycle = results[\"GDP_Cycle\"]\npeaks = cycle[(cycle.shift(1) < cycle) & (cycle.shift(-1) < cycle)]\ntroughs = cycle[(cycle.shift(1) > cycle) & (cycle.shift(-1) > cycle)]\n\nprint(\"\\n--- Business Cycle Turning Points ---\")\nprint(f\"\\nPeaks (top 5):\")\nprint(peaks.nlargest(5))\nprint(f\"\\nTroughs (bottom 5):\")\nprint(troughs.nsmallest(5))\n```\n\n## Key Points\n\n| Parameter | Quarterly | Annual | Monthly |\n|-----------|-----------|--------|---------|\n| **\u03bb (lambda)** | 1600 | 100 | 14400 |\n\n### How to adapt for your own Excel file:\n\n```python\n# Replace Step 1 with:\ndf = pd.read_excel(\"your_file.xlsx\", index_col=\"Date\", parse_dates=True)\nseries = df[\"YourColumnName\"]  # e.g., \"Real_GDP\", \"Industrial_Production\"\n\n# Apply filter\ncycle, trend = hpfilter(series, lamb=1600)  # adjust lambda for frequency\n```\n\n### Dependencies:\n```bash\npip install pandas numpy openpyxl statsmodels matplotlib\n```\n\nThe script reads economic time series data, decomposes it into **trend** and **cyclical** components via the HP filter, exports everything to a formatted Excel workbook (with results + summary statistics), and generates a 3-panel visualization showing the decomposition, cycle phases (expansion/contraction), and growth rates.", "solver_finish_reason": "stop"}
{"task": "econ-detrending-correlation", "condition": "gold_skill", "repeat": 0, "skill_ids": ["benchflow-ai--timeseries-detrending"], "retrieval_correct": true, "judged_pass": false, "judged_score": 0, "judge_reason": "Agent's solution uses synthetic data and does not load the required real datasets (ERP-2025-table10.xls, ERP-2025-table12.xls, CPI.xlsx) as specified.", "solver_tokens": 3758, "judge_tokens": 4076, "solution_text": "# Hodrick-Prescott Filter for Macroeconomic Time Series\n\n## Complete Solution\n\n### Prerequisites\n\n```bash\npip install pandas openpyxl statsmodels matplotlib numpy\n```\n\n### Full Python Script\n\n```python\nimport pandas as pd\nimport numpy as np\nimport matplotlib.pyplot as plt\nfrom statsmodels.tsa.filters.hp_filter import hpfilter\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# ============================================================\n# 1. LOAD DATA FROM EXCEL\n# ============================================================\n# Replace 'macro_data.xlsx' with your actual file path.\n# Expected format: columns like 'Date', 'GDP', 'Consumption', 'Investment', etc.\n# If you don't have a file, we generate synthetic data below.\n\ndef load_data(filepath='macro_data.xlsx'):\n    \"\"\"Load economic time series from Excel.\"\"\"\n    try:\n        df = pd.read_excel(filepath, parse_dates=['Date'], index_col='Date')\n        return df\n    except FileNotFoundError:\n        print(\"Excel file not found. Generating synthetic macroeconomic data...\")\n        return generate_synthetic_data()\n\ndef generate_synthetic_data():\n    \"\"\"Generate synthetic quarterly macroeconomic data (1990Q1 - 2023Q4).\"\"\"\n    np.random.seed(42)\n    n = 136  # 34 years * 4 quarters\n    dates = pd.date_range(start='1990-01-01', periods=n, freq='QS')\n\n    # Simulate log-GDP with trend + cycle\n    trend_gdp = np.linspace(np.log(10000), np.log(20000), n)\n    cycle_gdp = 0.02 * np.sin(np.linspace(0, 8 * np.pi, n)) + np.random.normal(0, 0.005, n)\n    log_gdp = trend_gdp + cycle_gdp\n\n    # Consumption: correlated with GDP cycle\n    log_consumption = np.linspace(np.log(7000), np.log(14000), n) + 0.8 * cycle_gdp + np.random.normal(0, 0.003, n)\n\n    # Investment: more volatile, correlated with GDP cycle\n    log_investment = np.linspace(np.log(2000), np.log(5000), n) + 1.5 * cycle_gdp + np.random.normal(0, 0.01, n)\n\n    # Interest rate (level series, not logged)\n    interest_rate = 4.0 + 0.5 * np.sin(np.linspace(0, 6 * np.pi, n)) + np.random.normal(0, 0.2, n)\n\n    df = pd.DataFrame({\n        'GDP': np.exp(log_gdp),\n        'Consumption': np.exp(log_consumption),\n        'Investment': np.exp(log_investment),\n        'InterestRate': interest_rate\n    }, index=dates)\n    df.index.name = 'Date'\n    return df\n\n\n# ============================================================\n# 2. APPLY HODRICK-PRESCOTT FILTER\n# ============================================================\ndef apply_hp_filter(series, lamb=1600):\n    \"\"\"\n    Apply HP filter to a time series.\n    \n    Parameters:\n        series: pandas Series of the economic variable\n        lamb: smoothing parameter (lambda)\n              - 1600 for quarterly data (standard)\n              - 6.25 for annual data\n              - 129600 for monthly data\n              - 104976000 for weekly data (Ravn-Uhlage convention)\n    \n    Returns:\n        cycle: cyclical component (deviation from trend)\n        trend: trend component\n    \"\"\"\n    cycle, trend = hpfilter(series, lamb=lamb)\n    return cycle, trend\n\n\ndef detrend_series(df, variables, lamb=1600, log_transform=True):\n    \"\"\"\n    Detrend multiple economic series using the HP filter.\n    \n    Parameters:\n        df: DataFrame with economic time series\n        variables: list of column names to detrend\n        lamb: HP filter smoothing parameter\n        log_transform: if True, take log before filtering (for growth/volume series)\n    \n    Returns:\n        cycles_df: DataFrame of cyclical components\n        trends_df: DataFrame of trend components\n    \"\"\"\n    cycles = {}\n    trends = {}\n    \n    for var in variables:\n        raw = df[var].dropna()\n        \n        # Log-transform for volume/growth series (GDP, Consumption, Investment)\n        if log_transform and var != 'InterestRate':\n            series = np.log(raw)\n        else:\n            series = raw\n        \n        cycle, trend = apply_hp_filter(series, lamb=lamb)\n        cycles[var] = cycle\n        trends[var] = trend\n    \n    cycles_df = pd.DataFrame(cycles, index=df.index)\n    trends_df = pd.DataFrame(trends, index=df.index)\n    \n    return cycles_df, trends_df\n\n\n# ============================================================\n# 3. BUSINESS CYCLE CORRELATION ANALYSIS\n# ============================================================\ndef compute_cycle_correlations(cycles_df):\n    \"\"\"Compute correlation matrix of cyclical components.\"\"\"\n    corr_matrix = cycles_df.corr()\n    return corr_matrix\n\n\ndef compute_cycle_statistics(cycles_df):\n    \"\"\"Compute standard deviations and relative volatility of cycles.\"\"\"\n    stats = pd.DataFrame()\n    stats['Std Dev'] = cycles_df.std()\n    \n    # Relative volatility (relative to GDP cycle)\n    if 'GDP' in cycles_df.columns:\n        gdp_std = cycles_df['GDP'].std()\n        stats['Relative Volatility (vs GDP)'] = cycles_df.std() / gdp_std\n    \n    # Compute co-movement with GDP (contemporaneous correlation)\n    if 'GDP' in cycles_df.columns:\n        stats['Correlation with GDP'] = cycles_df.corrwith(cycles_df['GDP'])\n    \n    return stats\n\n\n# ============================================================\n# 4. VISUALIZATION\n# ============================================================\ndef plot_hp_decomposition(df, cycles_df, trends_df, variable='GDP'):\n    \"\"\"Plot original series, trend, and cycle for a given variable.\"\"\"\n    fig, axes = plt.subplots(3, 1, figsize=(12, 10), sharex=True)\n    \n    # Original series\n    axes[0].plot(df.index, df[variable], 'b-', linewidth=1.2, label='Original')\n    axes[0].plot(df.index, trends_df[variable], 'r--', linewidth=1.5, label='HP Trend')\n    axes[0].set_title(f'Hodrick-Prescott Decomposition: {variable}', fontsize=14)\n    axes[0].set_ylabel('Level')\n    axes[0].legend(loc='upper left')\n    axes[0].grid(True, alpha=0.3)\n    \n    # Cyclical component\n    axes[1].plot(df.index, cycles_df[variable] * 100, 'g-', linewidth=1.0)\n    axes[1].axhline(y=0, color='k', linestyle='-', linewidth=0.5)\n    axes[1].fill_between(df.index, cycles_df[variable] * 100, 0, \n                         where=(cycles_df[variable] > 0), alpha=0.3, color='green', label='Expansion')\n    axes[1].fill_between(df.index, cycles_df[variable] * 100, 0, \n                         where=(cycles_df[variable] < 0), alpha=0.3, color='red', label='Recession')\n    axes[1].set_ylabel('Cycle (% deviation)')\n    axes[1].set_title(f'Cyclical Component: {variable}', fontsize=12)\n    axes[1].legend(loc='upper left')\n    axes[1].grid(True, alpha=0.3)\n    \n    # Growth rate comparison\n    growth_rate = df[variable].pct_change() * 100\n    axes[2].plot(df.index, growth_rate, 'b-', linewidth=0.8, alpha=0.6, label='Actual Growth Rate')\n    axes[2].axhline(y=0, color='k', linestyle='-', linewidth=0.5)\n    axes[2].set_ylabel('Growth Rate (%)')\n    axes[2].set_title(f'Quarterly Growth Rate: {variable}', fontsize=12)\n    axes[2].legend(loc='upper left')\n    axes[2].grid(True, alpha=0.3)\n    \n    plt.tight_layout()\n    plt.savefig(f'hp_decomposition_{variable}.png', dpi=150, bbox_inches='tight')\n    plt.show()\n\n\ndef plot_cycle_comparison(cycles_df, variables=None):\n    \"\"\"Plot cyclical components of multiple variables on the same chart.\"\"\"\n    if variables is None:\n        variables = [col for col in cycles_df.columns if col != 'InterestRate']\n    \n    fig, ax = plt.subplots(figsize=(14, 6))\n    colors = {'GDP': 'blue', 'Consumption': 'green', 'Investment': 'red'}\n    \n    for var in variables:\n        ax.plot(cycles_df.index, cycles_df[var] * 100, \n                label=var, color=colors.get(var, 'gray'), linewidth=1.0, alpha=0.8)\n    \n    ax.axhline(y=0, color='k', linestyle='-', linewidth=0.5)\n    ax.set_title('Business Cycle Components (HP-filtered, % deviation from trend)', fontsize=14)\n    ax.set_ylabel('% Deviation from Trend')\n    ax.legend(loc='upper right')\n    ax.grid(True, alpha=0.3)\n    plt.tight_layout()\n    plt.savefig('cycle_comparison.png', dpi=150, bbox_inches='tight')\n    plt.show()\n\n\n# ============================================================\n# 5. EXPORT RESULTS TO EXCEL\n# ============================================================\ndef export_results(cycles_df, trends_df, corr_matrix, stats, output_file='hp_results.xlsx'):\n    \"\"\"Export all results to a multi-sheet Excel file.\"\"\"\n    with pd.ExcelWriter(output_file, engine='openpyxl') as writer:\n        cycles_df.to_excel(writer, sheet_name='Cyclical Components')\n        trends_df.to_excel(writer, sheet_name='Trend Components')\n        corr_matrix.to_excel(writer, sheet_name='Correlation Matrix')\n        stats.to_excel(writer, sheet_name='Cycle Statistics')\n    print(f\"\\nResults exported to: {output_file}\")\n\n\n# ============================================================\n# MAIN EXECUTION\n# ============================================================\ndef main():\n    # --- Step 1: Load data ---\n    df = load_data('macro_data.xlsx')  # Change path to your Excel file\n    print(f\"Data loaded: {df.shape[0]} observations, {df.shape[1]} variables\")\n    print(f\"Date range: {df.index.min()} to {df.index.max()}\")\n    print(f\"\\nFirst 5 rows:\\n{df.head()}\\n\")\n    \n    # --- Step 2: Define variables to detrend ---\n    # Volume/growth series (will be log-transformed before HP filter)\n    volume_vars = ['GDP', 'Consumption', 'Investment']\n    # Level series (no log transform)\n    level_vars = ['InterestRate']\n    \n    all_vars = volume_vars + level_vars\n    all_vars = [v for v in all_vars if v in df.columns]\n    \n    # --- Step 3: Apply HP filter ---\n    # Lambda = 1600 for quarterly data (standard Ravn-Uhlage value)\n    LAMBDA = 1600\n    \n    # Detrend volume series with log transform\n    cycles_vol, trends_vol = detrend_series(df, volume_vars, lamb=LAMBDA, log_transform=True)\n    \n    # Detrend level series without log transform\n    cycles_lev, trends_lev = detrend_series(df, level_vars, lamb=LAMBDA, log_transform=False)\n    \n    # Combine\n    cycles_df = pd.concat([cycles_vol, cycles_lev], axis=1)\n    trends_df = pd.concat([trends_vol, trends_lev], axis=1)\n    \n    print(f\"HP Filter applied (lambda={LAMBDA}) to: {all_vars}\")\n    \n    # --- Step 4: Correlation analysis ---\n    corr_matrix = compute_cycle_correlations(cycles_df)\n    print(f\"\\n--- Correlation Matrix of Cyclical Components ---\")\n    print(corr_matrix.round(3))\n    \n    # --- Step 5: Cycle statistics ---\n    stats = compute_cycle_statistics(cycles_df)\n    print(f\"\\n--- Business Cycle Statistics ---\")\n    print(stats.round(4))\n    \n    # --- Step 6: Visualization ---\n    for var in volume_vars:\n        if var in df.columns:\n            plot_hp_decomposition(df, cycles_df, trends_df, variable=var)\n    \n    plot_cycle_comparison(cycles_df)\n    \n    # --- Step 7: Export to Excel ---\n    export_results(cycles_df, trends_df, corr_matrix, stats)\n    \n    print(\"\\n--- Summary ---\")\n    print(f\"\u2022 HP filter lambda: {LAMBDA} (quarterly data)\")\n    print(f\"\u2022 Variables detrended: {all_vars}\")\n    print(f\"\u2022 Log-transform applied to: {volume_vars}\")\n    print(f\"\u2022 Output files: hp_decomposition_*.png, cycle_comparison.png, hp_results.xlsx\")\n\n\nif __name__ == '__main__':\n    main()\n```\n\n## Key Concepts & Parameters\n\n| Parameter | Quarterly | Annual | Monthly | Weekly |\n|-----------|-----------|--------|---------|--------|\n| **\u03bb (lambda)** | 1600 | 6.25 | 129,600 | 104,976,000 |\n\n## How It Works\n\n1. **Log-transform** volume series (GDP, Consumption, Investment) \u2192 converts multiplicative trends to additive\n2. **HP Filter** decomposes `log(Y_t) = \u03c4_t + c_t` where:\n   - `\u03c4_t` = trend component (minimizes variation in growth rate of trend)\n   - `c_t` = cyclical component (deviation from trend)\n3. **Correlation analysis** of `c_t` across variables reveals business cycle co-movement\n4. **Relative volatility** = `\u03c3(c_X) / \u03c3(c_GDP)` shows which variables are more/less volatile than GDP\n\n## Expected Output\n\n- **3 decomposition plots** per variable (original + trend, cycle with shaded expansions/recessions, growth rate)\n- **1 comparison plot** overlaying all cyclical components\n- **Excel file** (`hp_results.xlsx`) with 4 sheets: Cyclical Components, Trend Components, Correlation Matrix, Cycle Statistics\n\n## Adapting to Your Data\n\nTo use your own Excel file, ensure it has:\n- A `Date` column (parsed as datetime index)\n- Columns for your economic variables (e.g., `GDP`, `CPI`, `Unemployment`)\n- Adjust `volume_vars` and `level_vars` lists to match your column names\n- Adjust `LAMBDA` if your data frequency is not quarterly", "solver_finish_reason": "stop"}
