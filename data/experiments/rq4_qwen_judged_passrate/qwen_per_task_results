n        # Resize for faster detection\n        frame_resized = cv2.resize(frame, (640, 480))\n        scale_x = frame.shape[1] / 640\n        scale_y = frame.shape[0] / 480\n        \n        # Detect people\n        boxes, weights = self.hog.detectMultiScale(\n            frame_resized,\n            winStride=(8, 8),\n            padding=(8, 8),\n            scale=1.05\n        )\n        \n        # Scale boxes back to original size\n        detections = []\n        for (x, y, w, h) in boxes:\n            x = int(x * scale_x)\n            y = int(y * scale_y)\n            w = int(w * scale_x)\n            h = int(h * scale_y)\n            detections.append((x, y, w, h))\n        \n        return detections\n    \n    def update_tracks(self, detections):\n        \"\"\"Update tracks with new detections using Hungarian-like assignment\"\"\"\n        matched_tracks = set()\n        matched_detections = set()\n        \n        # Match detections to existing tracks based on IoU\n        if self.tracks:\n            for det_idx, det in enumerate(detections):\n                best_iou = 0\n                best_track_id = -1\n                \n                for track_id, track_info in self.tracks.items():\n                    if track_id in matched_tracks:\n                        continue\n                    \n                    iou = self.calculate_iou(det, track_info['bbox'])\n                    if iou > best_iou and iou > self.iou_threshold:\n                        best_iou = iou\n                        best_track_id = track_id\n                \n                if best_track_id >= 0:\n                    # Update existing track\n                    self.tracks[best_track_id]['bbox'] = det\n                    self.tracks[best_track_id]['age'] = 0\n                    self.tracks[best_track_id]['hits'] += 1\n                    matched_tracks.add(best_track_id)\n                    matched_detections.add(det_idx)\n        \n        # Create new tracks for unm