ield(default_factory=dict)\n    start_node: Optional[str] = None\n\n\ndef parse_dialogue(text: str) -> DialogueTree:\n    \"\"\"Parse dialogue tree from structured text format.\"\"\"\n    tree = DialogueTree()\n    current_node = None\n\n    for line in text.strip().splitlines():\n        line = line.strip()\n        if not line:\n            continue\n\n        if line.startswith(\"NODE:\"):\n            node_id = line[len(\"NODE:\"):].strip()\n            current_node = DialogueNode(id=node_id, text=\"\", choices=[])\n            tree.nodes[node_id] = current_node\n            if tree.start_node is None:\n                tree.start_node = node_id\n\n        elif line.startswith(\"TEXT:\") and current_node is not None:\n            current_node.text = line[len(\"TEXT:\"):].strip()\n\n        elif line.startswith(\"CHOICE:\") and current_node is not None:\n            choice_str = line[len(\"CHOICE:\"):].strip()\n            if \"->\" in choice_str:\n                label, target = choice_str.split(\"->\", 1)\n                label = label.strip()\n                target = target.strip()\n            else:\n                label = \"\"\n                target = choice_str.strip()\n            current_node.choices.append(Choice(label=label, target=target))\n\n    return tree\n\n\ndef generate_dot(tree: DialogueTree) -> str:\n    \"\"\"Generate Graphviz DOT representation of the dialogue tree.\"\"\"\n    lines = []\n    lines.append(\"digraph DialogueTree {\")\n    lines.append(\"    rankdir=TB;\")\n    lines.append(\"    node [shape=box, style=rounded, fontname=\\\"Helvetica\\\"];\")\n    lines.append(\"    edge [fontname=\\\"Helvetica\\\", fontsize=10];\")\n    lines.append(\"\")\n\n    # Node definitions\n    for node_id, node in tree.nodes.items():\n        # Truncate long text for display\n        display_text = node.text.replace('\"', '\\\\\"')\n        if len(display_text) > 60:\n            display_text = display_text[:57] + \"...\"\n        label = f\"{node_id}\\\\n{display_text}\"\n        style = \"filled\" if node_id == tree.start_node else \"rounded\"\n        color = \"lightblue\" if node_id == tree.start_node else \"white\"\n        lines.append(\n            f'    \"{node_id}\" [label=\"{label}\", style=\"{style}\", fillcolor=\"{color}\"];'\n        )\n\n    lines.append(\"\")\n\n    # Edges\n    for node_id, node in tree.nodes.items():\n        for choice in node.choices:\n            edge_label = choice.label if choice.label else \"\"\n            lines.append(\n                f'    \"{node_id}\" -> \"{choice.target}\" [label=\"{edge_label}\"];'\n            )\n\n    lines.append(\"}\")\n    return \"\\n\".join(lines)\n\n\ndef generate_json(tree: DialogueTree) -> str:\n    \"\"\"Generate JSON graph representation of the dialogue tree.\"\"\"\n    graph = {\n        \"graph\": {\n            \"start_node\": tree.start_node,\n            \"node_count\": len(tree.nodes),\n        },\n        \"nodes\": [],\n        \"edges\": [],\n    }\n\n    for node_id, node in tree.nodes.items():\n        graph[\"nodes\"].append({\n            \"id\": node.id,\n            \"text\": node.text,\n            \"is_start\": node_id == tree.start_node,\n            \"choice_count\": len(node.choices),\n        })\n        for choice in node.choices:\n            graph[\"edges\"].append({\n                \"source\": node_id,\n                \"target\": choice.target,\n                \"label\": choice.label,\n            })\n\n    return json.dumps(graph, indent=2, ensure_ascii=False)\n\n\ndef main():\n    # Read input file\n    input_file = sys.argv[1] if len(sys.argv) > 1 else \"dialogue.txt\"\n\n    with open(input_file, \"r\", encoding=\"utf-8\") as f:\n        text = f.read()\n\n    # Parse\n    tree = parse_dialogue(text)\n    print(f\"Parsed {len(tree.nodes)} nodes, start node: '{tree.start_node}'\")\n\n    # Generate DOT\n    dot_output = generate_dot(tree)\n    dot_file = input_file.rsplit(\".\", 1)[0] + \".dot\"\n    with open(dot_file, \"w\", encoding=\"utf-8\") as f:\n        f.write(dot_output)\n    print(f\"DOT file written to: {dot_file}\")\n\n    # Generate JSON\n    json_output = generate_json(tree)\n    json_file = input_file.rsplit(\".\", 1)[0] + \".json\"\n    with open(json_file, \"w\", encoding=\"utf-8\") as f:\n        f.write(json_output)\n    print(f\"JSON file written to: {json_file}\")\n\n    # Print outputs\n    print(\"\\n--- DOT Output ---\")\n    print(dot_output)\n    print(\"\\n--- JSON Output ---\")\n    print(json_output)\n\n\nif __name__ == \"__main__\":\n    main()\n```\n\n## 3. Usage\n\n```bash\n# Run the parser\npython3 dialogue_parser.py dialogue.txt\n\n# Render the DOT file to PNG (requires Graphviz installed)\ndot -Tpng dialogue.dot -o dialogue.png\n\n# Render to SVG\ndot -Tsvg dialogue.dot -o dialogue.svg\n```\n\n## 4. Expected JSON Output\n\n```json\n{\n  \"graph\": {\n    \"start_node\": \"start\",\n    \"node_count\": 7\n  },\n  \"nodes\": [\n    {\n      \"id\": \"start\",\n      \"text\": \"Welcome, traveler! What brings you here?\",\n      \"is_start\": true,\n      \"choice_count\": 2\n    },\n    {\n      \"id\": \"adventure\",\n      \"text\": \"Great! Head north to find the dragon's lair.\",\n      \"is_start\": false,\n      \"choice_count\": 2\n    },\n    {\n      \"id\": \"dragon\",\n      \"text\": \"You face the mighty dragon!\",\n      \"is_start\": false,\n      \"choice_count\": 2\n    },\n    {\n      \"id\": \"village\",\n      \"text\": \"You arrive at a peaceful village.\",\n      \"is_start\": false,\n      \"choice_count\": 2\n    },\n    {\n      \"id\": \"fight\",\n      \"text\": \"You defeat the dragon and claim its treasure!\",\n      \"is_start\": false,\n      \"choice_count\": 1\n    },\n    {\n      \"id\": \"goodbye\",\n      \"text\": \"Safe travels!\",\n      \"is_start\": false,\n      \"choice_count\": 1\n    },\n    {\n      \"id\": \"end\",\n      \"text\": \"The End.\",\n      \"is_start\": false,\n      \"choice_count\": 0\n    }\n  ],\n  \"edges\": [\n    { \"source\": \"start\", \"target\": \"adventure\", \"label\": \"I'm looking for adventure\" },\n    { \"source\": \"start\", \"target\": \"goodbye\", \"label\": \"Just passing through\" },\n    { \"source\": \"adventure\", \"target\": \"dragon\", \"label\": \"Go north\" },\n    { \"source\": \"adventure\", \"target\": \"village\", \"label\": \"Go south\" },\n    { \"source\": \"dragon\", \"target\": \"fight\", \"label\": \"Fight\" },\n    { \"source\": \"dragon\", \"target\": \"village\", \"label\": \"Flee\" },\n    { \"source\": \"village\", \"target\": \"end\", \"label\": \"Rest\" },\n    { \"source\": \"village\", \"target\": \"end\", \"label\": \"Continue\" },\n    { \"source\": \"fight\", \"target\": \"end\", \"label\": \"\" },\n    { \"source\": \"goodbye\", \"target\": \"end\", \"label\": \"\" }\n  ]\n}\n```\n\n## 5. Expected DOT Output\n\n```dot\ndigraph DialogueTree {\n    rankdir=TB;\n    node [shape=box, style=rounded, fontname=\"Helvetica\"];\n    edge [fontname=\"Helvetica\", fontsize=10];\n\n    \"start\" [label=\"start\\nWelcome, traveler! What brings you here?\", style=\"filled\", fillcolor=\"lightblue\"];\n    \"adventure\" [label=\"adventure\\nGreat! Head north to find the dragon's lair.\", style=\"rounded\", fillcolor=\"white\"];\n    \"dragon\" [label=\"dragon\\nYou face the mighty dragon!\", style=\"rounded\", fillcolor=\"white\"];\n    \"village\" [label=\"village\\nYou arrive at a peaceful village.\", style=\"rounded\", fillcolor=\"white\"];\n    \"fight\" [label=\"fight\\nYou defeat the dragon and claim its treasure!\", style=\"rounded\", fillcolor=\"white\"];\n    \"goodbye\" [label=\"goodbye\\nSafe travels!\", style=\"rounded\", fillcolor=\"white\"];\n    \"end\" [label=\"end\\nThe End.\", style=\"rounded\", fillcolor=\"white\"];\n\n    \"start\" -> \"adventure\" [label=\"I'm looking for adventure\"];\n    \"start\" -> \"goodbye\" [label=\"Just passing through\"];\n    \"adventure\" -> \"dragon\" [label=\"Go north\"];\n    \"adventure\" -> \"village\" [label=\"Go south\"];\n    \"dragon\" -> \"fight\" [label=\"Fight\"];\n    \"dragon\" -> \"village\" [label=\"Flee\"];\n    \"village\" -> \"end\" [label=\"Rest\"];\n    \"village\" -> \"end\" [label=\"Continue\"];\n    \"fight\" -> \"end\" [label=\"\"];\n    \"goodbye\" -> \"end\" [label=\"\"];\n}\n```\n\n## Summary\n\n| Component | Description |\n|-----------|-------------|\n| **Text Parser** | Reads `NODE:`, `TEXT:`, `CHOICE:` lines into a structured `DialogueTree` |\n| **DOT Generator** | Produces a Graphviz `.dot` file with styled nodes and labeled edges |\n| **JSON Generator** | Exports a graph with `nodes[]` and `edges[]` arrays for programmatic use |\n| **Dependencies** | Python 3.7+ standard library only (no pip installs needed) |", "solver_finish_reason": "stop"}
{"task": "dynamic-object-aware-egomotion", "condition": "no_skill", "repeat": 0, "skill_ids": [], "retrieval_correct": null, "judged_pass": false, "judged_score": 2, "judge_reason": "Agent's solution implements sparse optical flow and motion estimation but does not produce the required output files matching the verifier criteria.", "solver_tokens": 6933, "judge_tokens": 5300, "solution_text": "```python\n\"\"\"\nCamera Motion Estimation from Video using Sparse Optical Flow with Mask\n========================================================================\nUses Lucas-Kanade sparse optical flow and estimates camera motion\n(translation + rotation) via homography/affine decomposition.\n\"\"\"\n\nimport cv2\nimport numpy as np\nimport sys\n\n\ndef load_video(video_path):\n    \"\"\"Load video and return frames as list of numpy arrays.\"\"\"\n    cap = cv2.VideoCapture(video_path)\n    if not cap.isOpened():\n        raise ValueError(f\"Cannot open video: {video_path}\")\n    frames = []\n    while True:\n        ret, frame = cap.read()\n        if not ret:\n            break\n        frames.append(frame)\n    cap.release()\n    return frames\n\n\ndef create_sparse_mask(frame_shape, grid_spacing=40, border=30):\n    \"\"\"\n    Create a sparse binary mask with grid points for feature tracking.\n    \n    Args:\n        frame_shape: (H, W) or (H, W, C) shape of frame\n        grid_spacing: spacing between grid points\n        border: border margin to avoid\n    \n    Returns:\n        mask: uint8 binary mask (H, W)\n        grid_points: (N, 1, 2) float32 array of initial points\n    \"\"\"\n    H, W = frame_shape[:2]\n    mask = np.zeros((H, W), dtype=np.uint8)\n    \n    xs = np.arange(border, W - border, grid_spacing)\n    ys = np.arange(border, H - border, grid_spacing)\n    \n    xx, yy = np.meshgrid(xs, ys)\n    points = np.stack([xx.ravel(), yy.ravel()], axis=1).astype(np.float32)\n    points = points.reshape(-1, 1, 2)\n    \n    # Draw small circles on mask at grid points\n    for pt in points:\n        x, y = int(pt[0, 0]), int(pt[0, 1])\n        cv2.circle(mask, (x, y), 5, 255, -1)\n    \n    return mask, points\n\n\ndef detect_good_features(frame, mask, max_corners=500):\n    \"\"\"Detect good features to track using Shi-Tomasi corner detection.\"\"\"\n    gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n    gray = cv2.equalizeHist(gray)\n    \n    corners = cv2.goodFeaturesToTrack(\n        gray,\n        mask=mask,\n        maxCorners=max_corners,\n        qualityLevel=0.01,\n        minDistance=10,\n        blockSize=7\n    )\n    \n    if corners is None:\n        return np.zeros((0, 1, 2), dtype=np.float32)\n    return corners\n\n\ndef compute_sparse_optical_flow(prev_gray, curr_gray, prev_pts, mask=None):\n    \"\"\"\n    Compute sparse optical flow using Lucas-Kanade method.\n    \n    Returns:\n        good_old: matched points in previous frame\n        good_new: matched points in current frame\n        flow_vectors: displacement vectors (dx, dy)\n    \"\"\"\n    if prev_pts is None or len(prev_pts) == 0:\n        return None, None, None\n    \n    # Parameters for Lucas-Kanade optical flow\n    lk_params = dict(\n        winSize=(21, 21),\n        maxLevel=3,\n        criteria=(cv2.TERM_CRITERIA_EPS | cv2.TERM_CRITERIA_COUNT, 30, 0.01)\n    )\n    \n    # Calculate optical flow\n    next_pts, status, error = cv2.calcOpticalFlowPyrLK(\n        prev_gray, curr_gray, prev_pts, None, **lk_params\n    )\n    \n    # Select good points\n    status = status.ravel()\n    good_old = prev_pts[status == 1]\n    good_new = next_pts[status == 1]\n    \n    # Apply mask filter if provided\n    if mask is not None and len(good_old) > 0:\n        H, W = mask.shape[:2]\n        in_mask = np.zeros(len(good_old), dtype=bool)\n        for i, pt in enumerate(good_new):\n            x, y = int(pt[0, 0]), int(pt[0, 1])\n            if 0 <= x < W and 0 <= y < H:\n                if mask[y, x] > 0:\n                    in_mask[i] = True\n        good_old = good_old[in_mask]\n        good_new = good_new[in_mask]\n    \n    # Compute flow vectors\n    if len(good_old) > 0:\n        flow_vectors = good_new.reshape(-1, 2) - good_old.reshape(-1, 2)\n    else:\n        flow_vectors = np.zeros((0, 2), dtype=np.float32)\n    \n    return good_old, good_new, flow_vectors\n\n\ndef estimate_camera_motion(flow_vectors, points):\n    \"\"\"\n    Estimate camera motion parameters from sparse optical flow.\n    \n    Decomposes flow into:\n    - Translation (tx, ty) - mean flow\n    - Rotation (theta) - rotational component\n    - Scale (s) - zoom component\n    \n    Uses least-squares fitting of affine model:\n        [dx]   [a11 a12 tx] [x]\n        [dy] = [a21 a22 ty] [y]\n                              [1]\n    \n    Returns dict with motion parameters.\n    \"\"\"\n    if len(flow_vectors) < 3:\n        return {\n            'tx': 0.0, 'ty': 0.0,\n            'rotation': 0.0,\n            'scale': 1.0,\n            'valid': False\n        }\n    \n    pts = points.reshape(-1, 2).astype(np.float64)\n    flows = flow_vectors.reshape(-1, 2).astype(np.float64)\n    \n    N = len(pts)\n    \n    # Build system for affine model: dx = a11*x + a12*y + tx\n    #                                  dy = a21*x + a22*y + ty\n    # Matrix A: [x, y, 1] for each point\n    A = np.column_stack([pts, np.ones(N)])\n    \n    # Solve for dx and dy separately\n    # A @ [a11, a12, tx]^T = flows[:, 0]\n    # A @ [a21, a22, ty]^T = flows[:, 1]\n    \n    try:\n        # Use least squares\n        result_x, _, _, _ = np.linalg.lstsq(A, flows[:, 0], rcond=None)\n        result_y, _, _, _ = np.linalg.lstsq(A, flows[:, 1], rcond=None)\n    except np.linalg.LinAlgError:\n        return {\n            'tx': 0.0, 'ty': 0.0,\n            'rotation': 0.0,\n            'scale': 1.0,\n            'valid': False\n        }\n    \n    a11, a12, tx = result_x\n    a21, a22, ty = result_y\n    \n    # Decompose affine into rotation + scale + translation\n    # Affine matrix (linear part):\n    # M = [[a11, a12],\n    #      [a21, a22]]\n    M = np.array([[a11, a12],\n                  [a21, a22]])\n    \n    # Extract rotation angle and scale using SVD\n    U, S, Vt = np.linalg.svd(M)\n    \n    # Rotation angle from the rotation component\n    R = U @ Vt\n    # Ensure proper rotation (det = +1)\n    if np.linalg.det(R) < 0:\n        Vt[-1, :] *= -1\n        R = U @ Vt\n    \n    theta = np.arctan2(R[1, 0], R[0, 0])\n    \n    # Scale from singular values\n    scale = np.mean(S)\n    \n    # Compute residual error\n    predicted = A @ np.column_stack([result_x, result_y])\n    residuals = flows - predicted\n    rmse = np.sqrt(np.mean(np.sum(residuals**2, axis=1)))\n    \n    # Inlier ratio (points with small residual)\n    inlier_threshold = 3.0  # pixels\n    inlier_count = np.sum(np.linalg.norm(residuals, axis=1) < inlier_threshold)\n    inlier_ratio = inlier_count / N if N > 0 else 0.0\n    \n    return {\n        'tx': float(tx),\n        'ty': float(ty),\n        'rotation': float(np.degrees(theta)),\n        'scale': float(1.0 + scale),\n        'affine_matrix': np.array([[a11, a12, tx],\n                                    [a21, a22, ty]]),\n        'rmse': float(rmse),\n        'inlier_ratio': float(inlier_ratio),\n        'num_points': N,\n        'valid': True\n    }\n\n\ndef robust_estimate_camera_motion(flow_vectors, points, ransac_threshold=3.0, max_iters=1000):\n    \"\"\"\n    RANSAC-based robust camera motion estimation.\n    Filters outliers before fitting affine model.\n    \"\"\"\n    if len(flow_vectors) < 6:\n        return estimate_camera_motion(flow_vectors, points)\n    \n    pts = points.reshape(-1, 2).astype(np.float64)\n    flows = flow_vectors.reshape(-1, 2).astype(np.float64)\n    N = len(pts)\n    \n    best_inliers = None\n    best_count = 0\n    \n    min_samples = 3  # minimum points for affine\n    \n    for _ in range(max_iters):\n        # Random sample\n        idx = np.random.choice(N, min_samples, replace=False)\n        sample_pts = pts[idx]\n        sample_flows = flows[idx]\n        \n        # Fit model\n        A_sample = np.column_stack([sample_pts, np.ones(min_samples)])\n        try:\n            rx, _, _, _ = np.linalg.lstsq(A_sample, sample_flows[:, 0], rcond=None)\n            ry, _, _, _ = np.linalg.lstsq(A_sample, sample_flows[:, 1], rcond=None)\n        except np.linalg.LinAlgError:\n            continue\n        \n        # Compute residuals for all points\n        A_all = np.column_stack([pts, np.ones(N)])\n        pred_x = A_all @ rx\n        pred_y = A_all @ ry\n        residuals = np.sqrt((flows[:, 0] - pred_x)**2 + (flows[:, 1] - pred_y)**2)\n        \n        inliers = residuals < ransac_threshold\n        count = np.sum(inliers)\n        \n        if count > best_count:\n            best_count = count\n            best_inliers = inliers\n    \n    if best_inliers is not None and best_count >= 3:\n        return estimate_camera_motion(flows[best_inliers], pts[best_inliers])\n    else:\n        return estimate_camera_motion(flows, pts)\n\n\ndef process_video(video_path, grid_spacing=40, use_ransac=True, max_corners=500):\n    \"\"\"\n    Main pipeline: process video and estimate camera motion per frame pair.\n    \n    Returns list of motion estimates per frame transition.\n    \"\"\"\n    frames = load_video(video_path)\n    if len(frames) < 2:\n        raise ValueError(\"Need at least 2 frames\")\n    \n    H, W = frames[0].shape[:2]\n    print(f\"Video: {len(frames)} frames, {W}x{H}\")\n    \n    # Create sparse mask\n    mask, grid_points = create_sparse_mask((H, W), grid_spacing=grid_spacing)\n    print(f\"Mask created with {len(grid_points)} grid points\")\n    \n    # Convert first frame to gray\n    prev_gray = cv2.cvtColor(frames[0], cv2.COLOR_BGR2GRAY)\n    prev_gray = cv2.equalizeHist(prev_gray)\n    \n    # Detect initial features\n    prev_pts = detect_good_features(frames[0], mask, max_corners=max_