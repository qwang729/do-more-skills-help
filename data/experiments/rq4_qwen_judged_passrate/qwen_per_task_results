 center;\n            min-height: 100vh;\n            padding: 20px;\n        }\n\n        h1 {\n            margin-bottom: 10px;\n            font-size: 1.8rem;\n            color: #e94560;\n        }\n\n        .controls {\n            margin-bottom: 15px;\n            display: flex;\n            gap: 15px;\n            align-items: center;\n            flex-wrap: wrap;\n            justify-content: center;\n        }\n\n        .controls label {\n            font-size: 0.9rem;\n            color: #aaa;\n        }\n\n        .controls select, .controls button {\n            padding: 6px 12px;\n            border: 1px solid #444;\n            border-radius: 4px;\n            background: #16213e;\n            color: #eee;\n            cursor: pointer;\n            font-size: 0.85rem;\n        }\n\n        .controls button:hover {\n            background: #e94560;\n            border-color: #e94560;\n        }\n\n        #chart-container {\n            background: #16213e;\n            border-radius: 12px;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);\n            overflow: hidden;\n        }\n\n        .tooltip {\n            position: absolute;\n            padding: 10px 14px;\n            background: rgba(22, 33, 62, 0.95);\n            border: 1px solid #e94560;\n            border-radius: 6px;\n            font-size: 0.85rem;\n            pointer-events: none;\n            opacity: 0;\n            transition: opacity 0.2s;\n            color: #eee;\n            max-width: 220px;\n        }\n\n        .tooltip .tt-name {\n            font-weight: bold;\n            color: #e94560;\n            margin-bottom: 4px;\n        }\n\n        .tooltip .tt-category {\n            color: #aaa;\n            font-size: 0.8rem;\n        }\n\n        .tooltip .tt-value {\n            margin-top: 4px;\n        }\n\n        .legend {\n            display: flex;\n            gap: 20px;\n            margin-top: 15px;\n            flex-wrap: wrap;\n            justify-content: center;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 6px;\n            font-size: 0.85rem;\n            color: #ccc;\n        }\n\n        .legend-color {\n            width: 14px;\n            height: 14px;\n            border-radius: 50%;\n        }\n    </style>\n</head>\n<body>\n    <h1>Force Layout Bubble Chart</h1>\n\n    <div class=\"controls\">\n        <label>\n            Group by:\n            <select id=\"group-select\">\n                <option value=\"category\">Category</option>\n                <option value=\"none\">None (spread)</option>\n            </select>\n        </label>\n        <label>\n            Size by:\n            <select id=\"size-select\">\n                <option value=\"value\">Value</option>\n                <option value=\"fixed\">Fixed Size</option>\n            </select>\n        </label>\n        <button id=\"btn-reheat\">Reheat Simulation</button>\n    </div>\n\n    <div id=\"chart-container\"></div>\n    <div class=\"legend\" id=\"legend\"></div>\n    <div class=\"tooltip\" id=\"tooltip\"></div>\n\n    <script>\n        // \u2500\u2500\u2500 Configuration \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        const WIDTH = 900;\n        const HEIGHT = 600;\n        const MARGIN = { top: 30, right: 30, bottom: 30, left: 30 };\n\n        const CATEGORY_COLORS = {\n            Technology: \"#e94560\",\n            Healthcare: \"#0f3460\",\n            Finance:    \"#533483\",\n            Energy:     \"#16c79a\"\n        };\n\n        // \u2500\u2500\u2500 Inline CSV (fallback if file not found) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        const INLINE_CSV = `name,category,value,description\nAlpha Corp,Technology,120,Leading tech company\nBeta Inc,Healthcare,85,Pharmaceutical giant\nGamma LLC,Finance,200,Investment banking\nDelta Co,Technology,95,Cloud computing\nEpsilon Ltd,Energy,150,Renewable energy\nZeta Group,Healthcare,70,Medical devices\nEta Systems,Technology,180,AI and ML\nTheta Works,Energy,110,Solar power\nIota Digital,Finance,60,Fintech startup\nKappa Bio,Healthcare,130,Biotech research\nLambda Net,Technology,75,Networking solutions\nMu Power,Energy,160,Wind energy\nNu Bank,Finance,90,Retail banking\nXi Health,Healthcare,105,Telemedicine\nOmicron AI,Technology,140,Deep learning`;\n\n        // \u2500\u2500\u2500 CSV Data Processing \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        function processData(rawData) {\n            // Parse numeric fields\n            const data = rawData.map(d => ({\n                name:        d.name.trim(),\n                category:    d.category.trim(),\n                value:       +d.value,\n                description: d.description.trim()\n            }));\n\n            // Compute radius scale\n            const valueExtent = d3.extent(data, d => d.value);\n            const radiusScale = d3.scaleSqrt()\n                .domain(valueExtent)\n                .range([18, 55]);\n\n            // Assign radius to each node\n            data.forEach(d => {\n                d.radius = radiusScale(d.value);\n            });\n\n            // Compute category centroids for grouping force\n            const categories = [...new Set(data.map(d => d.category))];\n            const categoryCenters = {};\n            const angleStep = (2 * Math.PI) / categories.length;\n            const clusterRadius = Math.min(WIDTH, HEIGHT) * 0.22;\n\n            categories.forEach((cat, i) => {\n                categoryCenters[cat] = {\n                    x: WIDTH / 2 + clusterRadius * Math.cos(angleStep * i - Math.PI / 2),\n                    y: HEIGHT / 2 + clusterRadius * Math.sin(angleStep * i - Math.PI / 2)\n                };\n            });\n\n            return { data, categories, categoryCenters };\n        }\n\n        // \u2500\u2500\u2500 Build Visualization \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        function buildChart(processed) {\n            const { data, categories, categoryCenters } = processed;\n\n            // Clear previous\n            d3.select(\"#chart-container\").selectAll(\"*\").remove();\n\n            // SVG\n            const svg = d3.select(\"#chart-container\")\n                .append(\"svg\")\n                .attr(\"width\", WIDTH)\n                .attr(\"height\", HEIGHT);\n\n            // Tooltip reference\n            const tooltip = d3.select(\"#tooltip\");\n\n            // \u2500\u2500 Scales \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            const colorScale = d3.scaleOrdinal()\n                .domain(categories)\n                .range(categories.map(c => CATEGORY_COLORS[c] || \"#888\"));\n\n            // \u2500\u2500 Force Simulation \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            let groupByCategory = true;\n\n            // Forces\n            const forceX = d3.forceX(d => {\n                return groupByCategory ? categoryCenters[d.category].x : WIDTH / 2;\n            }).strength(0.07);\n\n            const forceY = d3.forceY(d => {\n                return groupByCategory ? categoryCenters[d.category].y : HEIGHT / 2;\n            }).strength(0.07);\n\n            const simulation = d3.forceSimulation(data)\n                .force(\"x\", forceX)\n                .force(\"y\", forceY)\n                .force(\"collide\", d3.forceCollide(d => d.radius + 2).strength(0.8).iterations(3))\n                .force(\"charge\", d3.forceManyBody().strength(5))\n                .alphaDecay(0.02)\n                .on(\"tick\", ticked);\n\n            // \u2500\u2500 Draw Nodes \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            const nodeGroup = svg.append(\"g\").attr(\"class\", \"nodes\");\n\n            const nodes = nodeGroup.selectAll(\"g\")\n                .data(data)\n                .join(\"g\")\n                .attr(\"class\", \"node\")\n                .call(d3.drag()\n                    .on(\"start\", dragStarted)\n                    .on(\"drag\", dragged)\n                    .on(\"end\", dragEnded));\n\n            // Circle\n            nodes.append(\"circle\")\n                .attr(\"r\", d => d.radius)\n                .attr(\"fill\", d => colorScale(d.category))\n                .attr(\"stroke\", \"#fff\")\n                .attr(\"stroke-width\", 1.5)\n                .attr(\"opacity\", 0.85)\n                .on(\"mouseover\", function (event, d) {\n                    d3.select(this)\n                        .transition().duration(150)\n                        .attr(\"opacity\", 1)\n                        .attr(\"stroke-width\", 3);\n\n                    tooltip\n                        .style(\"opacity\", 1)\n                        .html(`\n                            <div class=\"tt-name\">${d.name}</div>\n                            <div class=\"tt-category\">${d.category}</div>\n                            <div class=\"tt-value\">Value: <strong>${d.value}</strong></div>\n                            <div style=\"margin-top:4px;font-size:0.8rem;color:#bbb\">${d.description}</div>\n                        `);\n                })\n                .on(\"mousemove\", function (event) {\n                    tooltip\n                        .style(\"left\", (event.pageX + 14) + \"px\")\n                        .style(\"top\", (event.pageY - 10) + \"px\");\n                })\n                .on(\"mouseout\", function () {\n                    d3.select(this)\n                        .transition().duration(150)\n                        .attr(\"opacity\", 0.85)\n                        .attr(\"stroke-width\", 1.5);\n                    tooltip.style(\"opacity\", 0);\n                });\n\n            // Labels\n            nodes.append(\"text\")\n                .attr(\"text-anchor\", \"middle\")\n                .attr(\"dy\", \"0.35em\")\n                .attr(\"font-size\", d => Math.max(9, d.radius / 3.5) + \"px\")\n                .attr(\"fill\", \"#fff\")\n                .attr(\"pointer-events\", \"none\")\n                .text(d => d.name.length > 12 ? d.name.slice(0, 11) + \"\u2026\" : d.name);\n\n            // \u2500\u2500 Tick \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            function ticked() {\n                nodes.attr(\"transform\", d => {\n                    // Keep within bounds\n                    d.x = Math.max(d.radius, Math.min(WIDTH - d.radius, d.x));\n                    d.y = Math.max(d.radius, Math.min(HEIGHT - d.radius, d.y));\n                    return `translate(${d.x},${d.y})`;\n                });\n            }\n\n            // \u2500\u2500 Drag Handlers \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            function dragStarted(event, d) {\n                if (!event.active) simulation.alphaTarget(0.3).restart();\n                d.fx = d.x;\n                d.fy = d.y;\n            }\n\n            function dragged(event, d) {\n                d.fx = event.x;\n                d.fy = event.y;\n            }\n\n            function dragEnded(event, d) {\n                if (!event.active) simulation.alphaTarget(0);\n                d.fx = null;\n                d.fy = null;\n            }\n\n            // \u2500\u2500 Controls \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            d3.select(\"#group-select\").on(\"change\", function () {\n                groupByCategory = this.value === \"category\";\n                simulation.alpha(0.8).restart();\n            });\n\n            d3.select(\"#size-select\").on(\"change\", function () {\n                const useFixed = this.value === \"fixed\";\n                const fixedRadius = 30;\n\n                data.forEach(d => {\n                    d.radius = useFixed ? fixedRadius : d.radius;\n                });\n\n                // Rebuild radius scale for fixed\n                if (useFixed) {\n                    data.forEach(d => d.radius = fixedRadius);\n                } else {\n                    const valueExtent = d3.extent(data, d => d.value);\n                    const radiusScale = d3.scaleSqrt().domain(valueExtent).range([18, 55]);\n                    data.forEach(d => d.radius = radiusScale(d.value));\n                }\n\n                nodes.select(\"circle\")\n                    .transition().duration(500)\n                    .attr(\"r\", d => d.radius);\n\n                nodes.select(\"text\")\n                    .transition().duration(500)\n                    .attr(\"font-size\", d => Math.max(9, d.radius / 3.5) + \"px\");\n\n                simulation.force(\"collide\", d3.forceCollide(d => d.radius + 2).strength(0.8).iterations(3));\n                simulation.alpha(0.8).restart();\n            });\n\n            d3.select(\"#btn-reheat\").on(\"click\", () => {\n                data.forEach(d => { d.fx = null; d.fy = null; });\n                simulation.alpha(1).restart();\n            });\n\n            // \u2500\u2500 Legend \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            const legendContainer = d3.select(\"#legend\");\n            legendContainer.selectAll(\"*\").remove();\n\n            categories.forEach(cat => {\n                const item = legendContainer.append(\"div\").attr(\"class\", \"legend-item\");\n                item.append(\"div\")\n                    .attr(\"class\", \"legend-color\")\n                    .style(\"background\", colorScale(cat));\n                item.append(\"span\").text(cat);\n            });\n        }\n\n        // \u2500\u2500\u2500 Load Data & Initialize \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        // Try loading external CSV; fall back to inline data\n        d3.csv(\"data.csv\").then(rawData => {\n            if (!rawData || rawData.length === 0) throw new Error(\"empty\");\n            const processed = processData(rawData);\n            buildChart(processed);\n        }).catch(() => {\n            // Fallback: parse inline CSV\n            const rawData = d3.csvParse(INLINE_CSV);\n            const processed = processData(rawData);\n            buildChart(processed);\n        });\n    </script>\n</body>\n</html>\n```\n\n## How It Works\n\n### CSV Data Processing Pipeline\n\n| Step | Description |\n|------|-------------|\n| **1. Load** | `d3.csv(\"data.csv\")` fetches and parses the CSV; falls back to inline data |\n| **2. Parse** | Converts `value` to numeric, trims strings |\n| **3. Scale** | `d3.scaleSqrt()` maps value domain \u2192 radius range `[18, 55]` |\n| **4. Cluster** | Computes category centroids arranged in a circle around center |\n| **5. Simulate** | D3 force simulation with `forceX`, `forceY`, `forceCollide`, `forceManyBody` |\n| **6. Render** | SVG `<g>` nodes with `<circle>` + `<text>`, updated each tick |\n\n### Key Features\n\n- **Force-directed layout** \u2014 bubbles repel each other (`forceCollide`) and attract to category centroids (`forceX`/`forceY`)\n- **Drag interaction** \u2014 grab and reposition any bubble\n- **Tooltips** \u2014 hover to see name, category, value, and description\n- **Controls** \u2014 toggle grouping by category vs. spread; switch between value-based and fixed sizing\n- **Reheat button** \u2014 restarts the simulation to re-settle the layout\n- **Responsive bounds** \u2014 nodes are clamped within the SVG viewport\n- **Color-coded legend** \u2014 auto-generated from unique categories\n\n### Running It\n\n```bash\n# Option 1", "solver_finish_reason": "stop"}
