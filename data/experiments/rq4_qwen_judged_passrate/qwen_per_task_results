th) as pdf:\n        for page in pdf.pages:\n            text = page.extract_text()\n            # Pattern for thermocouple readings: timestamp and temperature\n            pattern = r'(\\d{4}-\\d{2}-\\d{2}\\s+\\d{2}:\\d{2}:\\d{2})[,\\s]+([Tt]c\\d?)[,\\s]+([\\d.]+)'\n            matches = re.findall(pattern, text)\n            for match in matches:\n                data.append({\n                    'timestamp': match[0],\n                    'sensor_id': match[1],\n                    'temperature': float(match[2])\n                })\n    return pd.DataFrame(data)\n\n# ============================================================\n# PART 2: CSV Sensor Data Loading and Cleaning\n# ============================================================\n\ndef load_and_clean_sensor_data(csv_path):\n    \"\"\"Load and clean sensor data from CSV file.\"\"\"\n    df = pd.read_csv(csv_path)\n    \n    # Standardize column names\n    df.columns = df.columns.str.lower().str.replace(' ', '_')\n    \n    # Parse timestamp\n    if 'timestamp' in df.columns:\n        df['timestamp'] = pd.to_datetime(df['timestamp'], errors='coerce')\n        df = df.dropna(subset=['timestamp'])\n        df = df.sort_values('timestamp')\n    \n    # Clean temperature values\n    temp_cols = [col for col in df.columns if 'temp' in col or 'tc' in col]\n    for col in temp_cols:\n        df[col] = pd.to_numeric(df[col], errors='coerce')\n    \n    return df\n\n# ============================================================\n# PART 3: Thermocouple Time Series Analysis\n# ============================================================\n\nclass ThermocoupleAnalyzer:\n    def __init__(self, df, time_col='timestamp', temp_col='temperature'):\n        self.df = df.copy()\n        self.time_col = time_col\n        self.temp_col = temp_col\n        self.df = self.df.set_index(time_col)\n    \n    def basic_statistics(self):\n        \"\"\"Calculate basic statistics for thermocouple readings.\"\"\"\n        stats = {\n            'mean': self.df[self.temp_col].mean(),\n            'std': self.df[self.temp_col].std(),\n            'min': self.df[self.temp_col].min(),\n            'max': self.df[self.temp_col].max(),\n            'range': self.df[self.temp_col].max() - self.df[self.temp_col].min(),\n            'median': self.df[self.temp_col].median(),\n            'count': len(self.df)\n        }\n        return stats\n    \n    def detect_anomalies(self, threshold_std=2.5):\n        \"\"\"Detect temperature anomalies using z-score method.\"\"\"\n        mean = self.df[self.temp_col].mean()\n        std = self.df[self.temp_col].std()\n        self.df['z_score'] = (self.df[self.temp_col] - mean) / std\n        anomalies = self.df[abs(self.df['z_score']) > threshold_std]\n        return anomalies\n    \n    def calculate_rate_of_change(self):\n        \"\"\"Calculate temperature change rate (\u00b0C per second).\"\"\"\n        self.df['temp_diff'] = self.df[self.temp_col].diff()\n        self.df['time_diff'] = self.df.index.to_series().diff().dt.total_seconds()\n        self.df['rate_of_change'] = self.df['temp_diff'] / self.df['time_diff']\n        return self.df['rate_of_change']\n    \n    def resample_data(self, interval='1min'):\n        \"\"\"Resample time series to specified interval.\"\"\"\n        return self.df[self.temp_col].resample(interval).agg(['mean', 'min', 'max', 'std'])\n    \n    def rolling_statistics(self, window='5min'):\n        \"\"\"Calculate rolling statistics.\"\"\"\n        rolling = self.df[self.temp_col].rolling(window, min_periods=1)\n        return pd.DataFrame({\n            'rolling_mean': rolling.mean(),\n            'rolling_std': rolling.std(),\n            'rolling_min': rolling.min(),\n            'rolling_max': rolling.max()\n        })\n    \n    def detect_thermal_cycles(self, min_temp_diff=10.0):\n        \"\"\"Detect heating/cooling cycles.\"\"\"\n        temps = self.df[self.temp_col].values\n        cycles = []\n        direction = None\n        cycle_start = 0\n        \n        for i in range(1, len(temps)):\n            if temps[i] > temps[i-1]:\n                current_dir = 'heating'\n            elif temps[i] < temps[i-1]:\n                current_dir = 'cooling'\n            else:\n                continue\n            \n            if direction is None:\n                direction = current_dir\n                cycle_start = i - 1\n            elif current_dir != direction:\n                temp_diff = abs(temps[i-1] - temps[cycle_start])\n                if temp_diff >= min_temp_diff:\n                    cycles.append({\n                        'start_time': self.df.index[cycle_start],\n                        'end_time': self.df.index[i-1],\n                        'type': direction,\n                        'temp_change': temps[i-1] - temps[cycle_start]\n                    })\n                direction = current_dir\n                cycle_start = i - 1\n        \n        return pd.DataFrame(cycles)\n    \n    def generate_report(self, output_path='thermocouple_report.csv'):\n        \"\"\"Generate comprehensive analysis report.\"\"\"\n        stats = self.basic_statistics()\n        anomalies = self.detect_anomalies()\n        rate = self.calculate_rate_of_change()\n        cycles = self.detect_thermal_cycles()\n        \n        # Summary report\n        report = {\n            'metric': ['Mean Temp', 'Std Dev', 'Min Temp', 'Max Temp', \n                       'Temp Range', 'Anomaly Count', 'Max Heating Rate', 'Max Cooling Rate'],\n            'value': [stats['mean'], stats['std'], stats['min'], stats['max'],\n                      stats['range'], len(anomalies), \n                      rate.max() if not rate.empty else 0,\n                      rate.min() if not rate.empty else 0]\n        }\n        \n        report_df = pd.DataFrame(report)\n        report_df.to_csv(output_path, index=False)\n        \n        print(f\"\\n=== Thermocouple Analysis Report ===\")\n        print(f\"Total Readings: {stats['count']}\")\n        print(f\"Mean Temperature: {stats['mean']:.2f}\u00b0C\")\n        print(f\"Std Deviation: {stats['std']:.2f}\u00b0C\")\n        print(f\"Temperature Range: {stats['min']:.2f}\u00b0C to {stats['max']:.2f}\u00b0C\")\n        print(f\"Anomalies Detected: {len(anomalies)}\")\n        print(f\"Thermal Cycles: {len(cycles)}\")\n        \n        return report_df, anomalies, cycles\n\n# ============================================================\n# PART 4: Visualization\n# ============================================================\n\ndef plot_time_series(df, time_col='timestamp', temp_col='temperature', output_file='thermocouple_plot.png'):\n    \"\"\"Generate time series plot with anomalies highlighted.\"\"\"\n    fig, axes = plt.subplots(2, 1, figsize=(12, 8))\n    \n    # Main temperature plot\n    ax1 = axes[0]\n    ax1.plot(df[time_col], df[temp_col], 'b-', linewidth=0.8, label='Temperature')\n    ax1.set_xlabel('Time')\n    ax1.set_ylabel('Temperature (\u00b0C)')\n    ax1.set_title('Thermocouple Time Series')\n    ax1.grid(True, alpha=0.3)\n    ax1.legend()\n    \n    # Rate of change plot\n    ax2 = axes[1]\n    df_sorted = df.sort_values(time_col)\n    temp_diff = df_sorted[temp_col].diff()\n    time_diff = pd.to_datetime(df_sorted[time_col]).diff().dt.total_seconds()\n    rate = temp_diff / time_diff\n    ax2.plot(df_sorted[time_col], rate, 'r-', linewidth=0.8, label='Rate of Change')\n    ax2.set_xlabel('Time')\n    ax2.set_ylabel('Rate (\u00b0C/s)')\n    ax2.set_title('Temperature Rate of Change')\n    ax2.grid(True, alpha=0.3)\n    ax2.legend()\n    \n    plt.tight_layout()\n    plt.savefig(output_file, dpi=150)\n    plt.close()\n    print(f\"Plot saved to {output_file}\")\n\n# ============================================================\n# MAIN EXECUTION\n# ============================================================\n\nif __name__ == \"__main__\":\n    # Example usage - replace with actual file paths\n    PDF_FILE = \"sensor_readings.pdf\"\n    CSV_FILE = \"thermocouple_data.csv\"\n    \n    # Check if files exist\n    if Path(PDF_FILE).exists():\n        print(\"Extracting data from PDF...\")\n        df_extracted = extract_tables_from_pdf(PDF_FILE, \"extracted_sensor_data.csv\")\n    \n    if Path(CSV_FILE).exists():\n        print(\"\\nLoading and analyzing CSV data...\")\n        df = load_and_clean_sensor_data(CSV_FILE)\n        \n        # Perform analysis\n        analyzer = ThermocoupleAnalyzer(df)\n        report, anomalies, cycles = analyzer.generate_report()\n        \n        # Generate visualization\n        plot_time_series(df)\n        \n        # Save detailed results\n        if not anomalies.empty:\n            anomalies.to_csv('anomalies_detected.csv')\n            print(f\"Anomalies saved to anomalies_detected.csv\")\n        \n        if not cycles.empty:\n            cycles.to_csv('thermal_cycles.csv')\n            print(f\"Thermal cycles saved to thermal_cycles.csv\")\n    else:\n        print(f\"Create a CSV file with columns: timestamp, temperature\")\n        print(\"Example format:\")\n        print(\"timestamp,temperature\")\n        print(\"2024-01-01 08:00:00,25.3\")\n        print(\"2024-01-01 08:01:00,25.5\")\n```\n\n**Installation requirements:**\n```bash\npip install pandas numpy matplotlib pdfplumber\n```\n\n**Expected CSV input format:**\n```\ntimestamp,temperature\n2024-01-01 08:00:00,25.3\n2024-01-01 08:01:00,25.5\n2024-01-01 08:02:00,26.1\n```\n\n**Outputs generated:**\n1. `thermocouple_report.csv` - Summary statistics\n2. `anomalies_detected.csv` - Outlier readings\n3. `thermal_cycles.csv` - Heating/cooling cycles\n4. `thermocouple_plot.png` - Time series visualization", "solver_finish_reason": "stop"}
