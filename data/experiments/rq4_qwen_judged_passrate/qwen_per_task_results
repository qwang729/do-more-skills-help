ing.INFO, format=\"%(levelname)s: %(message)s\")\n+logger = logging.getLogger(__name__)\n+\n+\n+def preprocess_image(image: Image.Image) -> Image.Image:\n+    \"\"\"Apply preprocessing to improve OCR accuracy.\"\"\"\n+    # Convert to grayscale\n+    img = image.convert(\"L\")\n+\n+    # Enhance contrast\n+    enhancer = ImageEnhance.Contrast(img)\n+    img = enhancer.enhance(2.0)\n+\n+    # Sharpen\n+    img = img.filter(ImageFilter.SHARPEN)\n+\n+    # Threshold (binarize)\n+    img = img.point(lambda x: 0 if x < 140 else 255, \"1\")\n+\n+    return img\n+\n+\n+def preprocess_with_opencv(image_path: str) -> Image.Image:\n+    \"\"\"Advanced preprocessing using OpenCV for better OCR results.\"\"\"\n+    img = cv2.imread(image_path, cv2.IMREAD_GRAYSCALE)\n+    if img is None:\n+        raise ValueError(f\"Could not read image: {image_path}\")\n+\n+    # Apply Gaussian blur to reduce noise\n+    img = cv2.GaussianBlur(img, (3, 3), 0)\n+\n+    # Adaptive thresholding\n+    img = cv2.adaptiveThreshold(\n+        img, 255, cv2.ADAPTIVE_THRESH_GAUSSIAN_C, cv2.THRESH_BINARY, 11, 2\n+    )\n+\n+    # Dilate to strengthen text\n+    kernel = np.ones((2, 2), np.uint8)\n+    img = cv2.dilate(img, kernel, iterations=1)\n+\n+    return Image.fromarray(img)\n+\n+\n+def extract_text(image_path: str, lang: str = \"eng\", preprocess: bool = False) -> str:\n+    \"\"\"Extract text from an image file using Tesseract OCR.\"\"\"\n+    if not os.path.isfile(image_path):\n+        raise FileNotFoundError(f\"Image not found: {image_path}\")\n+\n+    logger.info(f\"Processing image: {image_path}\")\n+\n+    if preprocess:\n+        image = preprocess_with_opencv(image_path)\n+    else:\n+        image = Image.open(image_path)\n+\n+    text = pytesseract.image_to_string(image, lang=lang)\n+    logger.info(f\"OCR complete. Extracted {len(text)} characters.\")\n+    return text.strip()\n+\n+\n+def main():\n+    parser = argparse.ArgumentParser(description=\"Extract text from images via OCR\")\n+    parser.add_argument(\"image\", help=\"Path to the input image\")\n+    parser.add_argument(\"--lang\", default=\"eng\", help=\"Tesseract language (default: eng)\")\n+    parser.add_argument(\"--preprocess\", action=\"store_true\", help=\"Apply image preprocessing\")\n+    parser.add_argument(\"--output\", \"-o\", help=\"Write extracted text to file\")\n+    args = parser.parse_args()\n+\n+    try:\n+        text = extract_text(args.image, lang=args.lang, preprocess=args.preprocess)\n+    except Exception as e:\n+        logger.error(f\"OCR failed: {e}\")\n+        sys.exit(1)\n+\n+    if args.output:\n+        with open(args.output, \"w\", encoding=\"utf-8\") as f:\n+            f.write(text)\n+        logger.info(f\"Text written to: {args.output}\")\n+    else:\n+        print(text)\n+\n+\n+if __name__ == \"__main__\":\n+    main()\ndiff --git a/test_ocr.py b/test_ocr.py\nnew file mode 100644\nindex 0000000..i7j8k9l\n--- /dev/null\n+++ b/test_ocr.py\n@@ -0,0 +1,38 @@\n+#!/usr/bin/env python3\n+\"\"\"Tests for the OCR tool.\"\"\"\n+\n+import os\n+import sys\n+import unittest\n+from unittest.mock import patch, MagicMock\n+from PIL import Image\n+\n+sys.path.insert(0, os.path.dirname(__file__))\n+import ocr_tool\n+\n+\n+class TestOCRTool(unittest.TestCase):\n+\n+    def test_preprocess_image_returns_pil_image(self):\n+        img = Image.new(\"RGB\", (100, 50), color=\"white\")\n+        result = ocr_tool.preprocess_image(img)\n+        self.assertIsInstance(result, Image.Image)\n+\n+    @patch(\"ocr_tool.pytesseract\")\n+    @patch(\"ocr_tool.Image.open\")\n+    def test_extract_text_calls_tesseract(self, mock_open, mock_tesseract):\n+        mock_tesseract.image_to_string.return_value = \"Hello World\"\n+        mock_open.return_value = Image.new(\"RGB\", (10, 10))\n+\n+        with patch(\"ocr_tool.os.path.isfile\", return_value=True):\n+            text = ocr_tool.extract_text(\"fake.png\")\n+\n+        self.assertEqual(text, \"Hello World\")\n+        mock_