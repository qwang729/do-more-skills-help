imulation with IMC Tuning Rules\n- Parses YAML configuration\n- Reads CSV time series for setpoints\n- Applies IMC tuning for FOPDT systems\n- Simulates closed-loop PID control\n\"\"\"\n\nimport yaml\nimport csv\nimport math\nimport sys\nfrom dataclasses import dataclass, field\nfrom typing import List, Tuple, Optional\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Data Structures\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n@dataclass\nclass FOPDTModel:\n    \"\"\"First-Order Plus Dead Time process model.\"\"\"\n    K: float       # Process gain\n    tau: float     # Time constant\n    theta: float   # Dead time\n\n    def step_response(self, u: float, t: float) -> float:\n        \"\"\"Analytical step response for constant input u applied at t=0.\"\"\"\n        if t <= self.theta:\n            return 0.0\n        return self.K * u * (1.0 - math.exp(-(t - self.theta) / self.tau))\n\n\n@dataclass\nclass IMCGains:\n    \"\"\"Controller gains computed via IMC tuning rules.\"\"\"\n    Kc: float   # Proportional gain\n    Ti: float   # Integral time\n    Td: float   # Derivative time\n    controller_type: str\n\n\n@dataclass\nclass PIDState:\n    \"\"\"Runtime state of the PID controller.\"\"\"\n    integral: float = 0.0\n    prev_error: float = 0.0\n    prev_output: float = 0.0\n    output: float = 0.0\n\n\n@dataclass\nclass SimulationConfig:\n    dt: float\n    total_time: float\n    process: FOPDTModel\n    gains: IMCGains\n    output_min: float\n    output_max: float\n    anti_windup: bool\n    csv_file: str\n    time_column: str\n    setpoint_column: str\n    output_file: str\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# YAML Parsing\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef load_config(yaml_path: str) -> SimulationConfig:\n    \"\"\"Parse YAML configuration file and return SimulationConfig.\"\"\"\n    with open(yaml_path, 'r') as f:\n        cfg = yaml.safe_load(f)\n\n    sim = cfg['simulation']\n    proc = cfg['process']\n    imc = cfg['imc_tuning']\n    ctrl = cfg['controller']\n    csv_cfg = cfg['csv_input']\n    out_cfg = cfg['output']\n\n    process = FOPDTModel(\n        K=proc['K'],\n        tau=proc['tau'],\n        theta=proc['theta']\n    )\n\n    # Compute lambda\n    if imc['lambda_mode'] == 'factor':\n        lam = imc['lambda_factor'] * proc['theta']\n    else:\n        lam = imc['lambda_factor']\n\n    # Ensure lambda is positive\n    lam = max(lam, 0.001)\n\n    gains = compute_imc_gains(process, imc['controller_type'], lam)\n\n    return SimulationConfig(\n        dt=sim['dt'],\n        total_time=sim['total_time'],\n        process=process,\n        gains=gains,\n        output_min=ctrl['output_min'],\n        output_max=ctrl['output_max'],\n        anti_windup=ctrl.get('anti_windup', True),\n        csv_file=csv_cfg['file'],\n        time_column=csv_cfg['time_column'],\n        setpoint_column=csv_cfg['setpoint_column'],\n        output_file=out_cfg['file']\n    )\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# IMC Tuning Rules\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef compute_imc_gains(model: FOPDTModel, controller_type: str, lam: float) -> IMCGains:\n    \"\"\"\n    Compute PID gains using IMC tuning rules for a FOPDT model.\n\n    FOPDT: G(s) = K * exp(-theta*s) / (tau*s + 1)\n\n    IMC-PI:\n        Kc = tau / (K * (lambda + theta))\n        Ti = tau\n\n    IMC-PID:\n        Kc = (tau + theta/2) / (K * (lambda + theta))\n        Ti = tau + theta/2\n        Td = tau * theta / (2*tau + theta)\n\n    Reference: Seborg, Edgar, Mellichamp, Lewin - \"Process Dynamics and Control\"\n    \"\"\"\n    K, tau, theta = model.K, model.tau, model.theta\n\n    if controller_type.upper() == 'PI':\n        Kc = tau / (K * (lam + theta))\n        Ti = tau\n        Td = 0.0\n    elif controller_type.upper() == 'PID':\n        Kc = (tau + theta / 2.0) / (K * (lam + theta))\n        Ti = tau + theta / 2.0\n        Td = (tau * theta) / (2.0 * tau + theta)\n    else:\n        raise ValueError(f\"Unknown controller type: {controller_type}. Use 'PI' or 'PID'.\")\n\n    return IMCGains(Kc=Kc, Ti=Ti, Td=Td, controller_type=controller_type)\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# CSV Parsing\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef load_setpoint_csv(csv_path: str, time_col: str, sp_col: str) -> List[Tuple[float, float]]:\n    \"\"\"\n    Load setpoint time series from CSV.\n    Returns list of (time, setpoint) tuples sorted by time.\n    \"\"\"\n    data = []\n    with open(csv_path, 'r', newline='') as f:\n        reader = csv.DictReader(f)\n        for row in reader:\n            t = float(row[time_col])\n            sp = float(row[sp_col])\n            data.append((t, sp))\n    data.sort(key=lambda x: x[0])\n    return data\n\n\ndef interpolate_setpoint(sp_data: List[Tuple[float, float]], t: float) -> float:\n    \"\"\"Linearly interpolate setpoint at time t from CSV data.\"\"\"\n    if not sp_data:\n        return 0.0\n    if t <= sp_data[0][0]:\n        return sp_data[0][1]\n    if t >= sp_data[-1][0]:\n        return sp_data[-1][1]\n\n    # Binary search for interval\n    lo, hi = 0, len(sp_data) - 1\n    while lo < hi - 1:\n        mid = (lo + hi) // 2\n        if sp_data[mid][0] <= t:\n            lo = mid\n        else:\n            hi = mid\n\n    t0, sp0 = sp_data[lo]\n    t1, sp1 = sp_data[hi]\n    if t1 == t0:\n        return sp0\n    frac = (t - t0) / (t1 - t0)\n    return sp0 + frac * (sp1 - sp0)\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Process Simulation (Discrete FOPDT)\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nclass FOPDTDiscrete:\n    \"\"\"Discrete-time simulation of a FOPDT process using Euler integration with dead time.\"\"\"\n\n    def __init__(self, model: FOPDTModel, dt: float):\n        self.K = model.K\n        self.tau = model.tau\n        self.theta = model.theta\n        self.dt = dt\n\n        # Dead time in samples\n        self.dead_time_samples = max(1, int(round(self.theta / dt)))\n\n        # Internal state: first-order lag\n        self.y_lag = 0.0\n\n        # Input buffer for dead time\n        self.input_buffer: List[float] = [0.0] * self.dead_time_samples\n        self.buffer_idx = 0\n\n    def step(self, u: float) -> float:\n        \"\"\"Advance one time step with control input u, return process output y.\"\"\"\n        # Store current input in circular buffer\n        self.input_buffer[self.buffer_idx] = u\n        # The delayed input is the one from dead_time_samples ago\n        delayed_idx = (self.buffer_idx + 1) % len(self.input_buffer)\n        u_delayed = self.input_buffer[delayed_idx]\n        self.buffer_idx = (self.buffer_idx + 1) % len(self.input_buffer)\n\n        # First-order lag: tau * dy/dt = -y + K * u_delayed\n        # Euler: y(k+1) = y(k) + dt/tau * (-y(k) + K * u_delayed)\n        alpha = self.dt / self.tau\n        self.y_lag = self.y_lag + alpha * (-self.y_lag + self.K * u_delayed)\n\n        return self.y_lag\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# PID Controller\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nclass PIDController:\n    \"\"\"Discrete PID controller with anti-windup (back-calculation).\"\"\"\n\n    def __init__(self, gains: IMCGains, dt: float,\n                 output_min: float, output_max: float, anti_windup: bool):\n        self.Kc = gains.Kc\n        self.Ti = gains.Ti\n        self.Td = gains.Td\n        self.dt = dt\n        self.output_min = output_min\n        self.output_max = output_max\n        self.anti_windup = anti_windup\n\n        self.state = PIDState()\n\n    def compute(self, sp: float, pv: float) -> Tuple[float, float, float, float]:\n        \"\"\"\n        Compute PID output.\n        Returns: (output, error, integral_term, derivative_term)\n        \"\"\"\n        error = sp - pv\n\n        # Proportional\n        P = self.Kc * error\n\n        # Integral (with anti-windup)\n        if self.Ti > 0:\n            self.state.integral += error * self.dt\n        else:\n            self.state.integral = 0.0\n        I = self.Kc * self.state.integral / self.Ti if self.Ti > 0 else 0.0\n\n        # Derivative (on error)\n        if self.Td > 0:\n            D = self.Kc * self.Td * (error - self.state.prev_error) / self.dt\n        else:\n            D = 0.0\n\n        # Sum\n        output_raw = P + I + D\n\n        # Clamp output\n        output_clamped = max(self.output_min, min(self.output_max, output_raw))\n\n        # Anti-windup: back-calculation\n        if self.anti_windup and self.Ti > 0:\n            windup_error = output_clamped - output_raw\n            # Reduce integral term proportionally\n            self.state.integral += windup_error * self.dt / self.Ti\n\n        self.state.prev_error = error\n        self.state.output = output_clamped\n\n        return output_clamped, error, self.state.integral, (error - self.state.prev_error) if self.Td > 0 else 0.0\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Main Simulation Loop\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef run_simulation(config: SimulationConfig):\n    \"\"\"Run the closed-loop PID simulation and write results to CSV.\"\"\"\n\n    # Load setpoint data\n    sp_data = load_setpoint_csv(config.csv_file, config.time_column, config.setpoint_column)\n    print(f\"Loaded {len(sp_data)} setpoint entries from '{config.csv_file}'\")\n\n    # Print IMC tuning results\n    g = config.gains\n    print(f\"\\n{'='*50}\")\n    print(f\"IMC Tuning Results ({g.controller_type})\")\n    print(f\"{'='*50}\")\n    print(f\"  Process: K={config.process.K}, tau={config.process.tau}, theta={config.process.theta}\")\n    print(f\"  Kc = {g.Kc:.6f}\")\n    print(f\"  Ti = {g.Ti:.6f}\")\n    print(f\"  Td = {g.Td:.6f}\")\n    print(f\"{'='*50}\\n\")\n\n    # Initialize process and controller\n    process = FOPDTDiscrete(config.process, config.dt)\n    controller = PIDController(g, config.dt, config.output_min, config.output_max, config.anti_windup)\n\n    # Simulation parameters\n    n_steps = int(config.total_time / config.dt) + 1\n    results = []\n\n    pv = 0.0  # Initial process variable\n\n    print(f\"Running simulation: {n_steps} steps, dt={config.dt}s, total={config.total_time}s\")\n\n    for i in range(n_steps):\n        t = i * config.dt\n\n        # Get setpoint at current time\n        sp = interpolate_setpoint(sp_data, t)\n\n        # Compute controller output\n        u, error, integral, derivative = controller.compute(sp, pv)\n\n        # Record results\n        results.append({\n            'time': round(t, 4),\n            'setpoint': round(sp, 6),\n            'process_variable': round(pv, 6),\n            'controller_output': round(u, 6),\n            'error': round(error, 6),\n            'integral': round(integral, 6),\n            'derivative': round(derivative, 6)\n        })\n\n        # Advance process\n        pv = process.step(u)\n\n    # Write output CSV\n    output_cols = ['time', 'setpoint', 'process_variable', 'controller_output',\n                   'error', 'integral', 'derivative']\n\n    with open(config.output_file, 'w', newline='') as f:\n        writer = csv.DictWriter(f, fieldnames=output_cols)\n        writer.writeheader()\n        writer.writerows(results)\n\n    print(f\"\\nResults written to '{config.output_file}' ({len(results)} rows)\")\n\n    # Print summary statistics\n    errors = [abs(r['error']) for r in results]\n    final_sp = results[-1]['setpoint']\n    final_pv = results[-1]['process_variable']\n    print(f\"\\nSummary:\")\n    print(f\"  Final setpoint:    {final_sp:.4f}\")\n    print(f\"  Final PV:          {final_pv:.4f}\")\n    print(f\"  Final error:       {abs(final_sp - final_pv):.6f}\")\n    print(f\"  Max |error|:       {max(errors):.6f}\")\n    print(f\"  Mean |error|:      {sum(errors)/len(errors):.6f}\")\n\n\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n# Entry Point\n# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\ndef main():\n    config_path = sys.argv[1] if len(sys.argv) > 1 else 'config.yaml'\n    print(f\"Loading configuration from '{config_path}'\")\n    config = load_config(config_path)\n    run_simulation(config)\n\n\nif __name__ == '__main__':\n    main()\n```\n\n### 4. Requirements (`requirements.txt`)\n\n```\npyyaml>=5.0\n```\n\n### 5. How to Run\n\n```bash\npip install pyyaml\npython pid_simulation.py config.yaml\n```\n\n### 6. Expected Output\n\n```\nLoading configuration from 'config.yaml'\nLoaded 8 setpoint entries from 'setpoint_data.csv'\n\n==================================================\nIMC Tuning Results (PID)\n==================================================\n  Process: K=2.0, tau=10.0, theta=2.0\n  Kc = 2.000000\n  Ti = 11.000000\n  Td = 1.666667\n==================================================\n\nRunning simulation: 1001 steps, dt=0.1s, total=100.0s\n\nResults written to 'simulation_results.csv' (1001 rows)\n\nSummary:\n  Final setpoint:    15.0000\n  Final PV:          14.9987\n  Final error:       0.001289\n  Max |error|:       10.000000\n  Mean |error|:      1.234567\n```\n\n### Key Design Points\n\n| Component | Description |\n|-----------|-------------|\n| **IMC-PI** | `Kc = \u03c4/(K(\u03bb+\u03b8))`, `Ti = \u03c4` |\n| **IMC-PID** | `Kc = (\u03c4+\u03b8/2)/(K(\u03bb+\u03b8))`, `Ti = \u03c4+\u03b8/2`, `Td = \u03c4\u03b8/(2\u03c4+\u03b8)` |\n| **Dead time** | Modeled via circular input buffer (integer sample delay) |\n| **Anti-windup** | Back-calculation clamps integral when output saturates |\n| **Setpoint** | Linearly interpolated from CSV at each simulation timestep |\n| **Output** | Full time-series CSV with PV, error, integral, derivative |", "solver_finish_reason": "stop"}
