  return bonuses;\n}\n\nfunction diplomaticQuarterAdjacency(x: number, y: number, state: GameState): AdjacencyBonus[] {\n  const bonuses: AdjacencyBonus[] = [];\n\n  // +1 per adjacent wonder\n  const wonders = countAdjacent(x, y, state, t => t.hasWonder);\n  if (wonders > 0) bonuses.push({ source: 'wonders', value: wonders });\n\n  // +1 per adjacent oasis\n  const oases = countAdjacent(x, y, state, t => t.feature === 'oasis');\n  if (oases > 0) bonuses.push({ source: 'oases', value: oases });\n\n  // +2 per adjacent district\n  const districts = countAdjacent(x, y, state, t => t.hasDistrict !== null && t.hasDistrict !== 'diplomatic_quarter');\n  if (districts > 0) bonuses.push({ source: 'districts', value: districts * 2 });\n\n  return bonuses;\n}\n\n// --- Main adjacency dispatcher ---\n\nconst ADJACENCY_CALCULATORS: Record<DistrictType, (x: number, y: number, state: GameState) => AdjacencyBonus[]> = {\n  campus: campusAdjacency,\n  holy_site: holySiteAdjacency,\n  theater_square: theaterSquareAdjacency,\n  commercial_hub: commercialHubAdjacency,\n  harbor: harborAdjacency,\n  industrial_zone: industrialZoneAdjacency,\n  encampment: encampmentAdjacency,\n  entertainment_complex: () => [], // +1 per adjacent city center (simplified)\n  water_park: () => [],\n  government_plaza: governmentPlazaAdjacency,\n  neighborhood: () => [],\n  aerodrome: () => [],\n  spaceport: () => [],\n  diplomatic_quarter: diplomaticQuarterAdjacency,\n  aqueduct: () => [],\n  canal: () => [],\n  dam: () => [],\n};\n\nexport function calculateAdjacency(\n  districtType: DistrictType,\n  x: number,\n  y: number,\n  state: GameState\n): AdjacencyBonus[] {\n  const calculator = ADJACENCY_CALCULATORS[districtType];\n  if (!calculator) return [];\n  return calculator(x, y, state);\n}\n\nexport function getTotalAdjacency(bonuses: AdjacencyBonus[]): number {\n  return bonuses.reduce((sum, b) => sum + b.value, 0);\n}\n```\n\n---\n\n## 3. Placement Validator\n\n```typescript\n// validator.ts\nimpo